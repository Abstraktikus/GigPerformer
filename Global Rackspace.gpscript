On WidgetValueChanged(val : Double) from BTN_Inject_Solo_Strict
    var i : Integer
    For i = 0; i < 16; i = i + 1 Do
        if OutputScope[i] then
            if val > 0.5 then Mem_SoloStrict[i] = 1 else Mem_SoloStrict[i] = 0 end
            if val > 0.5 then Mem_SoloSmart[i] = 0 end 
        end
    End
    if val > 0.5 then SetWidgetValue(BTN_Inject_Solo_Strict, 0.0) end 
    UpdateSoloMuteState()
End

On WidgetValueChanged(val : Double) from BTN_Inject_Solo_Smart
    var i : Integer
    For i = 0; i < 16; i = i + 1 Do
        if OutputScope[i] then
            if val > 0.5 then Mem_SoloSmart[i] = 1 else Mem_SoloSmart[i] = 0 end
            if val > 0.5 then Mem_SoloStrict[i] = 0 end 
        end
    End
    if val > 0.5 then SetWidgetValue(BTN_Inject_Solo_Smart, 0.0) end 
    UpdateSoloMuteState()
End


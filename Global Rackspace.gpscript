   // v2: cross-map reverse index — four parallel arrays, all indexed 0..N
   // by binding number. Rebuilt by BuildLFOUsageIndex() at bootstrap and
   // after every mutation path that rewrites ControllerMaps.txt.
   LFO_Usage_LfoIdx    : Integer Array   // which LFO_Names[] entry
   LFO_Usage_MapIdx    : Integer Array   // which CtrlMapList[] entry
   LFO_Usage_MacroIdx  : Integer Array   // which macro slot (0..49)
   LFO_Usage_RawLine   : String Array    // cached raw `Macro<N> = <value>` line

   // v2: display pipeline — LBL_LFO_BoundMacro is a scrollable list backed
   // by this array and paginated via SLD_LFOBoundMacro. Matches the
   // LooperConfig_Lines / CtrlInfo_Lines pattern.
   LFOBind_Lines : String Array

   // v2: draft state — populated when the inspector is in DRAFT_STANDARD or
   // DRAFT_FALLBACK. Lives only while a no-LFO scope is focused.
   LFO_Draft_Active : Boolean = false
   LFO_Draft_Name   : String  = ""
   LFO_Draft_Type   : Integer = 0   // Triangle
   LFO_Draft_Rate   : Integer = 5   // 1/4
   LFO_Draft_Cycles : Integer = -1  // Infinite

   // v2: draft preview — one global slot for BTN_LFO_Run in DRAFT state.
   // TickLFOs() services this via a dedicated branch. Never persisted.
   LFO_Draft_Running   : Boolean = false
   LFO_Draft_Slot      : Integer = -1
   LFO_Draft_StartTime : Double  = 0.0
   LFO_Draft_PreValue  : Double  = 0.0

   // v2: origin flag for Timeline replay writes. Set to true around
   // every SetParameter(ExternalArranger,...) call inside FireTimelineEvent.
   // Two readers:
   //   1. LFO auto-start gate: bound LFOs only start when a Timeline
   //      replay hits their slot (hardware fader jitter must NOT start
   //      an LFO — BTN_LFO_Run and Timeline replay are the only entries)
   //   2. Timeline recording guard: prevents replay->record feedback
   //      loops when the Record button happens to be active during
   //      playback.
   Timeline_IsReplaying : Boolean = false

   // v2: per-slot echo-deduplication sentinel for script-initiated
   // ExternalArranger writes. The original LFO_IsDriving boolean flag
   // was conceptually broken because SetParameter(ExternalArranger,...)
   // dispatches On ParameterValueChanged asynchronously — by the time
   // the callback fires, any flag we set right before the SetParameter
   // call has already been cleared. Value-based deduplication works
   // because GP echoes back the exact float we wrote.
   //
   // Protocol:
   //   - Before every script-initiated SetParameter(ExternalArranger, slot, val):
   //        ScriptWrite_Expected[slot] = val
   //   - In On ParameterValueChanged from ExternalArranger, compare
   //     newVal to ScriptWrite_Expected[paramIdx] with 0.005 tolerance
   //     (wide enough for 1/127 MIDI quantization if a motorfader
   //     round-trips the value). Match == echo == skip all side-effects
   //     (HUD push, trace, SysAction dispatch, Timeline recording,
   //     LFO retrigger). Link routing stays unconditional so VST
   //     parameters still move.
   //   - The sentinel is NOT consumed on match — it stays until the
   //     next script write to the same slot refreshes it. This catches
   //     duplicate callbacks (internal + hardware round-trip) for a
   //     single write. The narrow false-suppression window (hardware
   //     happening to land exactly on the last-written value) is
   //     acceptable.
   //
   // Size MAX_MACROS so it covers the full parameter range the handler
   // inspects (the HUD path uses 0..15, the LFO/SysAction path uses
   // 0..MAX_MACROS-1). -1.0 is the "no pending echo" sentinel.
   //
   // DOUBLE SENTINEL — ScriptWrite_ExpectedPrev holds the value from
   // the write BEFORE the current one. Required because multiple script
   // writes to the same slot can happen between two message-loop
   // dispatches (e.g. TickLFOs emits a sample, then StopLFO snaps back
   // in the same call). Without the previous sentinel, the first async
   // callback arrives after the sentinel was already overwritten by
   // the second write, fails the match, and treats the script write
   // as a hardware event — cascading into a death loop on finite-cycle
   // LFO termination.
   //
   // Protocol change: every write site rotates before updating:
   //   ScriptWrite_ExpectedPrev[slot] = ScriptWrite_Expected[slot]
   //   ScriptWrite_Expected[slot]     = val
   // Handler matches against EITHER current OR previous.
   ScriptWrite_Expected     : Double Array
   ScriptWrite_ExpectedPrev : Double Array

   // v2: flash surface for LBL_LFO_BoundMacro — 1-second transient feedback
   // from BTN_LFO_Save when clicked in LOCKED state, prompting the user
   // to select a User Macro first via Scope Prev/Next.
   LFOFlashMsg   : String = ""
   LFOFlashTimer : Double = 0.0

   // v2: deferred LFO inspector refresh flag. Set by CycleEditScope /
   // CycleScopeSection (SECTION 17, early in file) and consumed by
   // On TimerTick (late in file) which calls RefreshLFOInspector. This
   // avoids a forward-declaration crash — RefreshLFOInspector lives far
   // below the scope cyclers in file order, so a direct call would fail
   // to compile. Coalesces rapid successive scope changes into a single
   // refresh per tick.
   LFOInspectorNeedsRefresh : Boolean = false


Function UpdateInjectionLooperTransportUI()
   var i, focusCh, currentState : Integer
   var isValid : Boolean = false
   focusCh = GetActiveLooperScope()
   
   if focusCh > -1 then 
       isValid = true 
   end
   
   SetWidgetHideOnPresentation(BTN_Loop_Rec, not isValid)
   SetWidgetHideOnPresentation(BTN_Loop_Play, not isValid)

   if isValid then
      currentState = Mem_Loop_State[focusCh]
      
      Select
         currentState == 0 or currentState == 4 Do 
            SetWidgetValue(BTN_Loop_Rec, 0.0); SetWidgetValue(BTN_Loop_Play, 0.0)
         currentState == 1 Do 
            SetWidgetValue(BTN_Loop_Rec, 1.0); SetWidgetValue(BTN_Loop_Play, 0.0)
         currentState == 2 Do 
            SetWidgetValue(BTN_Loop_Rec, 0.0); SetWidgetValue(BTN_Loop_Play, 1.0)
         currentState == 3 Do 
            SetWidgetValue(BTN_Loop_Rec, 1.0); SetWidgetValue(BTN_Loop_Play, 1.0)
         currentState == 5 Do 
            SetWidgetValue(BTN_Loop_Rec, 1.0); SetWidgetValue(BTN_Loop_Play, 0.0)
         currentState == 6 Do 
            SetWidgetValue(BTN_Loop_Rec, 0.0); SetWidgetValue(BTN_Loop_Play, 1.0)
         currentState == 7 Do 
            SetWidgetValue(BTN_Loop_Rec, 0.0); SetWidgetValue(BTN_Loop_Play, 1.0)
         currentState == 8 Do 
            SetWidgetValue(BTN_Loop_Rec, 1.0); SetWidgetValue(BTN_Loop_Play, 0.0)
      End
   end
End

// ---------------------------------------------------------
// INPUT FEEDBACK (TRISTATE LOGIC)
// ---------------------------------------------------------

Function SyncInputFeedback()
   var inIdx, outIdx : Integer
   var activeCount : Integer
   var scopeCount : Integer
   
   // Visualizes the state of the input buttons based on the output scope
   // 0.0 = None connected
   // 1.0 = All connected
   // 0.5 = Mixed (some connected, some not)
   
   // --- LOOP KILLER: Ignore UI echo from widgets for 150ms ---
   InputSyncTimer = TimeSinceStartup() + 150.0

   scopeCount = 0
   For outIdx = 0; outIdx < 16; outIdx = outIdx + 1 Do
      if OutputScope[outIdx] then scopeCount = scopeCount + 1 end
   End
   
   if scopeCount == 0 then
      For inIdx = 0; inIdx < 16; inIdx = inIdx + 1 Do
         SetWidgetValue(W_Btn_Input[inIdx], 0.0)
      End
   else
      For inIdx = 0; inIdx < 16; inIdx = inIdx + 1 Do
         activeCount = 0
         
         For outIdx = 0; outIdx < 16; outIdx = outIdx + 1 Do
            if OutputScope[outIdx] then
               if GetParameter(RECH, (inIdx * 16) + outIdx) > 0.5 then
                  activeCount = activeCount + 1
               end
            end
         End
         
         if activeCount == scopeCount then
             SetWidgetValue(W_Btn_Input[inIdx], 1.0)
         elsif activeCount == 0 then
             SetWidgetValue(W_Btn_Input[inIdx], 0.0)
         else
             SetWidgetValue(W_Btn_Input[inIdx], 0.5) 
         end
      End
   end
End

Function UpdateMidiConfigLabel()
   var i : Integer = 0
   var isDirty : Boolean = false
   
   // Compare current matrix with our snapshot (safe while-loop)
   While i < 256 and not isDirty Do
      if Abs(GetParameter(RECH, i) - Loaded_RECH_State[i]) > 0.5 then
         isDirty = true
      end
      i = i + 1
   End
   
   // Set label accordingly
   if isDirty then
      SetWidgetLabel(LBL_MidiConfig, "Custom (Unsaved)")
   else
      SetWidgetLabel(LBL_MidiConfig, BaseConfigName)
   end
End

// ---------------------------------------------------------
// MASTER LABELS UPDATE (fills empty displays with song names)
// ---------------------------------------------------------
Function UpdateMasterLabels(sName : String)
   var prefix, cleanName : String
   
   cleanName = ReplaceString(sName, ".ini", "", false)
   if cleanName == "" then prefix = "Global Rackspace" else prefix = "" + cleanName end
   
   BaseConfigName = prefix
   
   if CurrentCtrlMapName == "-" or CurrentCtrlMapName == "" then
       SetWidgetLabel(LBL_CtrlConfig, prefix)
   end
   
   UpdateMidiConfigLabel()
End

// ---------------------------------------------------------
// TRANSPORT SYNC CYCLE LOGIC
// ---------------------------------------------------------
Function UpdateSyncLabel()
   var baseName : String = SyncModeNames[CurrentSyncMode]
   if CurrentSyncMode == 4 then
       if IsPerformanceActive then 
           SetWidgetLabel(LBL_SyncMode, baseName + " (Active)")
       else
           SetWidgetLabel(LBL_SyncMode, baseName + " (Ready)")
       end
   else
       SetWidgetLabel(LBL_SyncMode, baseName)
   end
End

// CROSSFADER LOGIC 
Function UpdateCFConfigLabel()
    var vstPart, arrangerPart : String
    var activeCount : Integer
    var i : Integer
    
    // 1. GENERATE VST NAMES
    activeCount = 0
    For i = 0; i < 5; i = i + 1 Do
        if GetWidgetValue(W_CF_Audio[i]) > 0.5 then activeCount = activeCount + 1 end
    End
    
    if activeCount == 5 then vstPart = "VST_All"
    elsif activeCount == 0 then vstPart = "VST_None"
    else
        vstPart = "VST_"
        for i = 0; i < 5; i = i + 1 do
            if GetWidgetValue(W_CF_Audio[i]) > 0.5 then 
                vstPart = vstPart + ((i*2)+1) + "-" + ((i*2)+2) + ","
            end
        end
        if Length(vstPart) > 4 then vstPart = CopySubstring(vstPart, 0, Length(vstPart)-1) end
    end
    
    // 2. GENERATE ARRANGER NAMES
    activeCount = 0
    For i = 0; i < 16; i = i + 1 Do
        if GetWidgetValue(W_CF_Arranger[i]) > 0.5 then activeCount = activeCount + 1 end
    End
    
    if activeCount == 16 then arrangerPart = "Arranger_All"
    elsif activeCount == 0 then arrangerPart = "Arranger_None"
    else
        arrangerPart = "Arranger_"
        for i = 0; i < 16; i = i + 1 do
            if GetWidgetValue(W_CF_Arranger[i]) > 0.5 then 
                arrangerPart = arrangerPart + (i+1) + ","
            end
        end
        if Length(arrangerPart) > 6 then arrangerPart = CopySubstring(arrangerPart, 0, Length(arrangerPart)-1) end
    end
    
    // 3. UPDATE LABEL
    LBL_CrossFaderConfig.SetWidgetLabel(vstPart + " | " + arrangerPart)
End


// ============================================================================
// SECTION 17: CONTROLLER MAP ENGINE
// ============================================================================

// --- Unified Macro System: Array Initialization ---
// Helper: appends N elements to an Integer array using nested loops (GP limits ~256 appends per loop)
Function AppendIntN(arr : Integer Array, count : Integer, val : Integer) Returns Integer Array
   var outer, inner, remaining, batch : Integer
   remaining = count
   For outer = 0; outer < 100; outer = outer + 1 Do
      if remaining > 0 then
         if remaining > 200 then batch = 200 else batch = remaining end
         For inner = 0; inner < batch; inner = inner + 1 Do
            arr <-- val
         End
         remaining = remaining - batch
      end
   End
   result = arr
End

// Helper: appends N elements to a Double array
Function AppendDblN(arr : Double Array, count : Integer, val : Double) Returns Double Array
   var outer, inner, remaining, batch : Integer
   remaining = count
   For outer = 0; outer < 100; outer = outer + 1 Do
      if remaining > 0 then
         if remaining > 200 then batch = 200 else batch = remaining end
         For inner = 0; inner < batch; inner = inner + 1 Do
            arr <-- val
         End
         remaining = remaining - batch
      end
   End
   result = arr
End

// Helper: appends N elements to a String array
Function AppendStrN(arr : String Array, count : Integer, val : String) Returns String Array
   var outer, inner, remaining, batch : Integer
   remaining = count
   For outer = 0; outer < 100; outer = outer + 1 Do
      if remaining > 0 then
         if remaining > 200 then batch = 200 else batch = remaining end
         For inner = 0; inner < batch; inner = inner + 1 Do
            arr <-- val
         End
         remaining = remaining - batch
      end
   End
   result = arr
End

// Helper: appends N elements to a Boolean array
Function AppendBoolN(arr : Boolean Array, count : Integer, val : Boolean) Returns Boolean Array
   var outer, inner, remaining, batch : Integer
   remaining = count
   For outer = 0; outer < 100; outer = outer + 1 Do
      if remaining > 0 then
         if remaining > 200 then batch = 200 else batch = remaining end
         For inner = 0; inner < batch; inner = inner + 1 Do
            arr <-- val
         End
         remaining = remaining - batch
      end
   End
   result = arr
End

// Split into sub-functions to work around potential GP per-function append limits
Function InitMacroArrays_Sources()
   var o, i : Integer
   Mac_SourceCount = []; For o = 0; o < 2; o = o + 1 Do For i = 0; i < 129; i = i + 1 Do Mac_SourceCount <-- 0 End End
   Mac_SourceDev = []; For o = 0; o < 5; o = o + 1 Do For i = 0; i < 206; i = i + 1 Do Mac_SourceDev <-- -1 End End
   Mac_SourceType = []; For o = 0; o < 5; o = o + 1 Do For i = 0; i < 206; i = i + 1 Do Mac_SourceType <-- "" End End
   Mac_SourceCtrl = []; For o = 0; o < 5; o = o + 1 Do For i = 0; i < 206; i = i + 1 Do Mac_SourceCtrl <-- -1 End End
   Def_Mac_SourceCount = []; For o = 0; o < 2; o = o + 1 Do For i = 0; i < 129; i = i + 1 Do Def_Mac_SourceCount <-- 0 End End
   Def_Mac_SourceDev = []; For o = 0; o < 5; o = o + 1 Do For i = 0; i < 206; i = i + 1 Do Def_Mac_SourceDev <-- -1 End End
   Def_Mac_SourceType = []; For o = 0; o < 5; o = o + 1 Do For i = 0; i < 206; i = i + 1 Do Def_Mac_SourceType <-- "" End End
   Def_Mac_SourceCtrl = []; For o = 0; o < 5; o = o + 1 Do For i = 0; i < 206; i = i + 1 Do Def_Mac_SourceCtrl <-- -1 End End

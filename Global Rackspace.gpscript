   CTRL_DevIdx   : Integer Array
   CTRL_Type     : Integer Array
   CTRL_CC       : Integer Array
   CTRL_Channel  : Integer Array
   CTRL_RangeMin : Integer Array
   CTRL_RangeMax : Integer Array

// ---------------------------------------------------------
// STATE-DEPENDENT COLORS --> OUTPUT
// ---------------------------------------------------------
Function UpdateMetaColors()
   var i, colorCode, inCh : Integer
   var healed : Boolean = false 
   
   OutputSyncTimer = TimeSinceStartup() + 150.0
   
   For i = 0; i < 16; i = i + 1 Do
      // ... (Auto-Healer stays) ...
      colorCode = AnalyzeChannel(i)
      SetChannelState(i, colorCode)
   End
    
   RefreshDiagDisplay()  
   // ---> ExecuteSmartBypass() WAS REMOVED HERE! <---
   
   if healed then 
       UpdateInjectionLooperDisplay() 
   end
End



    If newValue > 0.5 Then CycleCtrlMap(-1); BTN_CtrlConfig_Prev.SetWidgetValue(0.0) End
End

On WidgetValueChanged(newValue : double) from BTN_CtrlConfig_Next
    If newValue > 0.5 Then CycleCtrlMap(1); BTN_CtrlConfig_Next.SetWidgetValue(0.0) End
End

On WidgetValueChanged(val : Double) from BTN_ScopeSection_Prev
    if val > 0.5 then CycleScopeSection(-1); SetWidgetValue(BTN_ScopeSection_Prev, 0.0) end
End

On WidgetValueChanged(val : Double) from BTN_ScopeSection_Next
    if val > 0.5 then CycleScopeSection(1); SetWidgetValue(BTN_ScopeSection_Next, 0.0) end
End

On WidgetValueChanged(v : Double) from BTN_Scope_Prev
    if v > 0.5 then CycleEditScope(-1); SetWidgetValue(BTN_Scope_Prev, 0.0) end
End

On WidgetValueChanged(v : Double) from BTN_Scope_Next
    if v > 0.5 then CycleEditScope(1); SetWidgetValue(BTN_Scope_Next, 0.0) end
End


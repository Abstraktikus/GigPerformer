           if t < 0 then t = 5 end
           LFO_Draft_Type = t
       elsif CurrentEditScope >= 0 and CurrentEditScope < 50 then
           lfoIdx = LFO_ByMacro[CurrentEditScope]
           if lfoIdx >= 0 then
               t = LFO_Types[lfoIdx] - 1
               if t < 0 then t = 5 end
               LFO_Types[lfoIdx] = t
           end
       end
       RefreshLFOInspector()
       SetWidgetValue(BTN_LFO_Type_Prev, 0.0)
   end
End


// ---------------------------------------------------------
// LOOPER: BUFFER SANITIZER (Hanging Note & Sustain Killer)
// ---------------------------------------------------------
Function CloseLooperBuffer(chIdx : Integer)
   var i, sz, note, b0, b1, b2 : Integer
   var m : MidiMessage
   var activeNotes : Boolean Array = []
   var sustainActive : Boolean = false
   var targetTime : Double = LoopLengthMS[chIdx] - 1.0 // 1 ms vor Ende
   
   if targetTime <= 0.0 then targetTime = 0.0 end
   For i = 0; i < 128; i = i + 1 Do activeNotes <-- false End

   Select 
      chIdx == 0 Do
         sz = Size(LoopMsg_Ch1)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch1[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch1 <-- targetTime; LoopMsg_Ch1 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch1 <-- targetTime; LoopMsg_Ch1 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 1 Do
         sz = Size(LoopMsg_Ch2)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch2[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch2 <-- targetTime; LoopMsg_Ch2 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch2 <-- targetTime; LoopMsg_Ch2 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 2 Do
         sz = Size(LoopMsg_Ch3)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch3[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch3 <-- targetTime; LoopMsg_Ch3 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch3 <-- targetTime; LoopMsg_Ch3 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 3 Do
         sz = Size(LoopMsg_Ch4)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch4[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch4 <-- targetTime; LoopMsg_Ch4 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch4 <-- targetTime; LoopMsg_Ch4 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 4 Do
         sz = Size(LoopMsg_Ch5)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch5[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch5 <-- targetTime; LoopMsg_Ch5 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch5 <-- targetTime; LoopMsg_Ch5 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 5 Do
         sz = Size(LoopMsg_Ch6)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch6[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch6 <-- targetTime; LoopMsg_Ch6 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch6 <-- targetTime; LoopMsg_Ch6 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 6 Do
         sz = Size(LoopMsg_Ch7)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch7[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch7 <-- targetTime; LoopMsg_Ch7 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch7 <-- targetTime; LoopMsg_Ch7 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 7 Do
         sz = Size(LoopMsg_Ch8)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch8[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch8 <-- targetTime; LoopMsg_Ch8 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch8 <-- targetTime; LoopMsg_Ch8 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 8 Do
         sz = Size(LoopMsg_Ch9)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch9[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch9 <-- targetTime; LoopMsg_Ch9 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch9 <-- targetTime; LoopMsg_Ch9 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 9 Do
         sz = Size(LoopMsg_Ch10)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch10[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch10 <-- targetTime; LoopMsg_Ch10 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch10 <-- targetTime; LoopMsg_Ch10 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 10 Do
         sz = Size(LoopMsg_Ch11)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch11[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch11 <-- targetTime; LoopMsg_Ch11 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch11 <-- targetTime; LoopMsg_Ch11 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 11 Do
         sz = Size(LoopMsg_Ch12)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch12[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch12 <-- targetTime; LoopMsg_Ch12 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch12 <-- targetTime; LoopMsg_Ch12 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 12 Do
         sz = Size(LoopMsg_Ch13)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch13[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch13 <-- targetTime; LoopMsg_Ch13 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch13 <-- targetTime; LoopMsg_Ch13 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 13 Do
         sz = Size(LoopMsg_Ch14)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch14[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch14 <-- targetTime; LoopMsg_Ch14 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch14 <-- targetTime; LoopMsg_Ch14 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 14 Do
         sz = Size(LoopMsg_Ch15)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch15[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch15 <-- targetTime; LoopMsg_Ch15 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch15 <-- targetTime; LoopMsg_Ch15 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 15 Do
         sz = Size(LoopMsg_Ch16)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch16[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch16 <-- targetTime; LoopMsg_Ch16 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch16 <-- targetTime; LoopMsg_Ch16 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end
   End
   if DebugMode then Trace("LOOPER: Buffer sanitized for Ch " + (chIdx+1)) end
End

// ---------------------------------------------------------
// LOOPER: CYCLERS & STATE MACHINE 
// ---------------------------------------------------------

Function ValidateLooperScopeConfig(testTarget : Integer, testOut : Integer) Returns Boolean
   var i, scopeCount : Integer = 0
   var isAllowed : Boolean = true
   
   // 1. How many channels are currently in scope?
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] and IsChannelActiveForLooper(i) then 
          scopeCount = scopeCount + 1 
      end
   End
   
   // 2. APPLY RULESET
   if scopeCount > 1 then
       // Auto-jump (Target != -1) is strictly forbidden in multi-channel scope!
       // (Prevents torn scopes and chaos during Punch-Out)
       if testTarget != -1 then isAllowed = false end
       
       // Loop Out = GLOBAL (1) is strictly forbidden in multi-channel scope!
       // (Would otherwise cause exponential MIDI loopback in the RECH matrix)
       if testOut == 1 then isAllowed = false end
   end
   
   result = isAllowed
End

Function CycleLoopLength(direction : Integer)
   var i, k, currentVal, newIdx : Integer
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] and IsChannelActiveForLooper(i) then
         currentVal = Mem_Loop_Length[i]
         newIdx = 0
         
         newIdx = -1
         k = 0
         While k < Size(AllowedLoopLengths) and newIdx == -1 Do
            if AllowedLoopLengths[k] == currentVal then newIdx = k end
            k = k + 1
         End
         if newIdx == -1 then newIdx = 0 end
         
         newIdx = newIdx + direction
         if newIdx < 0 then newIdx = Size(AllowedLoopLengths) - 1
         elsif newIdx >= Size(AllowedLoopLengths) then newIdx = 0 end
         
         Mem_Loop_Length[i] = AllowedLoopLengths[newIdx]
      end
   End
   UpdateInjectionLooperDisplay()
End

Function CycleLoopAction(direction : Integer)
   var i, newVal : Integer
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] and IsChannelActiveForLooper(i) then
         newVal = Mem_Loop_Action[i] + direction
         if newVal < 0 then newVal = 1
         elsif newVal > 1 then newVal = 0 end
         Mem_Loop_Action[i] = newVal
      end
   End
   UpdateInjectionLooperDisplay()
End

Function CycleLoopTarget(direction : Integer)
   var i, currentTarget, nextTarget, loopGuard : Integer
   var foundValid, scopeValid : Boolean
   var firstScopeIdx : Integer
   
   firstScopeIdx = GetActiveLooperScope()
   
   if firstScopeIdx > -1 then
      currentTarget = Mem_Loop_Target[firstScopeIdx]
      nextTarget = currentTarget
      foundValid = false
      loopGuard = 0
      
      While not foundValid and loopGuard < 18 Do
         loopGuard = loopGuard + 1
         nextTarget = nextTarget + direction
         
         if nextTarget < -1 then nextTarget = 15
         elsif nextTarget > 15 then nextTarget = -1 end
         
         if nextTarget == -1 then 
            foundValid = true 
         else
            if IsChannelActiveForLooper(nextTarget) then foundValid = true end
         end
      End
      
      if foundValid then 
         // GUARD: Is this target allowed in the current scope?
         scopeValid = ValidateLooperScopeConfig(nextTarget, Mem_Loop_OutMode[firstScopeIdx])
         
         if scopeValid then
             // Allowed! Apply to all channels in scope.
             For i = 0; i < 16; i = i + 1 Do
                 if OutputScope[i] and IsChannelActiveForLooper(i) then Mem_Loop_Target[i] = nextTarget end
             End
             UpdateInjectionLooperDisplay()
         else
             // Verboten! 
             ShowCtrlOverlay("NOT ALLOWED: TARGET CONFLICT", 1500.0)
             if DebugMode then Trace("LOOPER UI: Multi-scope blocked target change!") end
         end
      end
   end
End

Function CycleLoopOutMode(direction : Integer)
   var i, newVal : Integer
   var scopeValid : Boolean
   var firstScopeIdx : Integer
   
   firstScopeIdx = GetActiveLooperScope()
   
   if firstScopeIdx > -1 then
      newVal = Mem_Loop_OutMode[firstScopeIdx] + direction
      if newVal < 0 then newVal = 1
      elsif newVal > 1 then newVal = 0 end
      
      // GUARD CHECK
      scopeValid = ValidateLooperScopeConfig(Mem_Loop_Target[firstScopeIdx], newVal)
      
      if scopeValid then
          For i = 0; i < 16; i = i + 1 Do
             if OutputScope[i] and IsChannelActiveForLooper(i) then Mem_Loop_OutMode[i] = newVal end
          End
          UpdateInjectionLooperDisplay()
      else
          ShowCtrlOverlay("NOT ALLOWED: GLOBAL OUT CONFLICT", 1500.0)
          if DebugMode then Trace("LOOPER UI: Multi-Scope blocks LoopOut=GLOBAL!") end
      end
   end
End

Function CycleLoopStopMode(direction : Integer)
   var i, newVal : Integer
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] and IsChannelActiveForLooper(i) then
         newVal = Mem_Loop_StopMode[i] + direction
         if newVal < 0 then newVal = 2
         elsif newVal > 2 then newVal = 0 end
         Mem_Loop_StopMode[i] = newVal
      end
   End
   UpdateInjectionLooperDisplay()
End

// LOOPER: EVENT COUNT HELPER
Function GetLooperEventCount(ch : Integer) Returns Integer
    Select
        ch == 0  Do result = Size(LoopTime_Ch1)
        ch == 1  Do result = Size(LoopTime_Ch2)
        ch == 2  Do result = Size(LoopTime_Ch3)
        ch == 3  Do result = Size(LoopTime_Ch4)
        ch == 4  Do result = Size(LoopTime_Ch5)
        ch == 5  Do result = Size(LoopTime_Ch6)
        ch == 6  Do result = Size(LoopTime_Ch7)
        ch == 7  Do result = Size(LoopTime_Ch8)
        ch == 8  Do result = Size(LoopTime_Ch9)
        ch == 9  Do result = Size(LoopTime_Ch10)
        ch == 10 Do result = Size(LoopTime_Ch11)
        ch == 11 Do result = Size(LoopTime_Ch12)
        ch == 12 Do result = Size(LoopTime_Ch13)
        ch == 13 Do result = Size(LoopTime_Ch14)
        ch == 14 Do result = Size(LoopTime_Ch15)
        ch == 15 Do result = Size(LoopTime_Ch16)
    End
End

// ---------------------------------------------------------
// LOOPER: CAPTURE ENGINE
// ---------------------------------------------------------
Function RecordLoopEvent(chIdx : Integer, m : MidiMessage)
   var timeOff : Double = 0.0
   var currentState : Integer = Mem_Loop_State[chIdx]
   
   // Only record when the channel is in REC (1) or OVERDUB (3) state
   if currentState == 1 or currentState == 3 then
      
      // Calculate timestamp
      timeOff = TimeSinceStartup() - LoopStartTime[chIdx]
      
      // Insert into the parallel buffers
      Select
         chIdx == 0  Do LoopTime_Ch1 <-- timeOff;  LoopMsg_Ch1 <-- m
         chIdx == 1  Do LoopTime_Ch2 <-- timeOff;  LoopMsg_Ch2 <-- m
         chIdx == 2  Do LoopTime_Ch3 <-- timeOff;  LoopMsg_Ch3 <-- m
         chIdx == 3  Do LoopTime_Ch4 <-- timeOff;  LoopMsg_Ch4 <-- m
         chIdx == 4  Do LoopTime_Ch5 <-- timeOff;  LoopMsg_Ch5 <-- m
         chIdx == 5  Do LoopTime_Ch6 <-- timeOff;  LoopMsg_Ch6 <-- m
         chIdx == 6  Do LoopTime_Ch7 <-- timeOff;  LoopMsg_Ch7 <-- m
         chIdx == 7  Do LoopTime_Ch8 <-- timeOff;  LoopMsg_Ch8 <-- m
         chIdx == 8  Do LoopTime_Ch9 <-- timeOff;  LoopMsg_Ch9 <-- m
         chIdx == 9  Do LoopTime_Ch10 <-- timeOff; LoopMsg_Ch10 <-- m
         chIdx == 10 Do LoopTime_Ch11 <-- timeOff; LoopMsg_Ch11 <-- m
         chIdx == 11 Do LoopTime_Ch12 <-- timeOff; LoopMsg_Ch12 <-- m
         chIdx == 12 Do LoopTime_Ch13 <-- timeOff; LoopMsg_Ch13 <-- m
         chIdx == 13 Do LoopTime_Ch14 <-- timeOff; LoopMsg_Ch14 <-- m
         chIdx == 14 Do LoopTime_Ch15 <-- timeOff; LoopMsg_Ch15 <-- m
         chIdx == 15 Do LoopTime_Ch16 <-- timeOff; LoopMsg_Ch16 <-- m
      End
   end
End

// ---------------------------------------------------------
// LOOPER: PLAYBACK ENGINE (Called from TimerTick)
// ---------------------------------------------------------

Function InjectLooperEvent(ch : Integer, msg : MidiMessage)
    var forceLocal : Boolean = false
    
    // ---> PLAYBACK OVERRIDE <---
    // If the channel is in the active scope AND any solo mode is on,
    // force the output to LOCAL. This prevents the looper from
    // firing the entire RECH matrix while we want solo playback!
    if OutputScope[ch] and Mem_SoloStrict[ch] == 1 or Mem_SoloSmart[ch] == 1 then
        forceLocal = true
    end

    if Mem_Loop_OutMode[ch] == 1 and not forceLocal then
        SendNow(DeviceIn_0, msg) // GLOBAL MODE (fires into the RECH matrix)
    else
        SendNow(BLK_MidiIn[ch], msg) // CHANNEL MODE (fires directly into VST)
    end
End

Function ProcessLooperPlayback()
   var ch, sz, i : Integer
   var currentTimeInLoop, lastTime, eventTime : Double = 0.0
   var state : Integer
   var needsWrap : Boolean

   For ch = 0; ch < 16; ch = ch + 1 Do
      state = Mem_Loop_State[ch]

      if (state == 2 or state == 3) and LoopLengthMS[ch] > 0.0 then
         needsWrap = true

         While needsWrap Do
            currentTimeInLoop = TimeSinceStartup() - LoopStartTime[ch]
            lastTime = LoopPlayheadMS[ch] // Where were we at the last tick?
            sz = LoopNextEventIdx[ch]     // The sentinel (hides overdubs until next bar)

            // Check all old notes: does their time fall within our window?
            Select
               ch == 0 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch1[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch1[i]) end
                  End
               ch == 1 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch2[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch2[i]) end
                  End
               ch == 2 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch3[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch3[i]) end
                  End
               ch == 3 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch4[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch4[i]) end
                  End
               ch == 4 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch5[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch5[i]) end
                  End
               ch == 5 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch6[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch6[i]) end
                  End
               ch == 6 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch7[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch7[i]) end
                  End
               ch == 7 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch8[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch8[i]) end
                  End
               ch == 8 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch9[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch9[i]) end
                  End
               ch == 9 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch10[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch10[i]) end
                  End
               ch == 10 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch11[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch11[i]) end
                  End
               ch == 11 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch12[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch12[i]) end
                  End
               ch == 12 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch13[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch13[i]) end
                  End
               ch == 13 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch14[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch14[i]) end
                  End
               ch == 14 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch15[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch15[i]) end
                  End
               ch == 15 Do
                  For i = 0; i < sz; i = i + 1 Do
                     eventTime = LoopTime_Ch16[i]
                     if eventTime > lastTime and eventTime <= currentTimeInLoop then InjectLooperEvent(ch, LoopMsg_Ch16[i]) end
                  End
            End

            LoopPlayheadMS[ch] = currentTimeInLoop

            // REWIND (Wrap-Around)
            if currentTimeInLoop >= LoopLengthMS[ch] then
               if state == 7 and Mem_Loop_StopMode[ch] == 2 then
                   Mem_Loop_State[ch] = 4
                   Trigger_NotesOff(ch + 1)
                   BuildLooperConfigLines()
                   UpdateInjectionLooperTransportUI()
                   needsWrap = false
               else
                   LoopStartTime[ch] = LoopStartTime[ch] + LoopLengthMS[ch]
                   
                   // IMPORTANT: Reset window and release new overdubs for the next bar!
                   LoopPlayheadMS[ch] = -1.0 
                   LoopNextEventIdx[ch] = GetLooperEventCount(ch) 
                   
                   if state != 3 then Trigger_NotesOff(ch + 1) end
               end
            else
               needsWrap = false
            end
         End
      end
   End
End

// ---------------------------------------------------------
// LOOPER: THE ROUTING DISTRIBUTOR (Feed the Looper) - NOTES
// ---------------------------------------------------------
Function FeedLooper_Note(m : NoteMessage)
   var hwChan : Integer = GetChannel(m) - 1 
   var outCh, currentState, statusByte : Integer
   var mappedMsg : MidiMessage
   
   if hwChan >= 0 and hwChan <= 15 then
      For outCh = 0; outCh < 16; outCh = outCh + 1 Do
         
         // 1. Check: Is the physical keyboard routed to this rackspace channel?
         if GetParameter(RECH, (hwChan * 16) + outCh) > 0.5 then
            currentState = Mem_Loop_State[outCh]
            
            // 2. GUARD: Process the MIDI event for the looper ONLY
            // only when the looper is actually in record mode! (Ghost mode)
            if currentState == 1 or currentState == 3 then
               
               if IsNoteOn(m) then statusByte = 144 + outCh
               else statusByte = 128 + outCh end
               
               mappedMsg = MakeMidiMessage3(statusByte, GetNoteNumber(m), GetVelocity(m))
               RecordLoopEvent(outCh, mappedMsg)
               
               if DebugMode and IsNoteOn(m) then 
                  Trace("    -> [SUCCESS] Note recorded in RAM for RS-Ch " + (outCh+1))
               end
            end
            
         end
      End
   end
End

// ---------------------------------------------------------
// LOOPER: THE ROUTING DISTRIBUTOR (Feed the Looper) - CCs
// ---------------------------------------------------------
Function FeedLooper_CC(m : ControlChangeMessage)
   var hwChan : Integer = GetChannel(m) - 1 
   var outCh : Integer
   var mappedMsg : MidiMessage // Generic type for our array
   
   if hwChan >= 0 and hwChan <= 15 then
      For outCh = 0; outCh < 16; outCh = outCh + 1 Do
         if GetParameter(RECH, (hwChan * 16) + outCh) > 0.5 then
            
            // Status byte for CC is 176 (+ target channel)
            mappedMsg = MakeMidiMessage3(176 + outCh, GetCCNumber(m), GetCCValue(m))
            RecordLoopEvent(outCh, mappedMsg)
            
         end
      End
   end
End

// ---------------------------------------------------------
// LOOPER: NAME HELPERS
// ---------------------------------------------------------

Function GetLoopModeName(modeId : Integer) Returns String
   if modeId == 0 then result = "Immediate"
   elsif modeId == 1 then result = "End of Bar"
   elsif modeId == 2 then result = "End of Phrase"
   else result = "-" end
End


// ============================================================================
// SECTION 19: PROMPTER & TIMELINE ENGINE
// ============================================================================

Function TraceTimeDomains()
    var gpStr, songStr, loopStr : String
    var ch, activeLoopers : Integer
    
    // 1. Layer 1: GP Absolute (the engine)
    gpStr = "GP: " + Global_CurrentBar + "." + Global_CurrentBeat + "." + PadInt(Global_CurrentTick, 3)

    // 2. Layer 2: Virtual Song Time (the playhead)
    songStr = "SONG: " + CurrentBar + "." + CurrentBeat + " (Offset: " + GlobalBarOffset + " Bars)"
    
    // 3. Layer 3: Looper status (quick scan for active loopers)
    loopStr = "LOOPER: "
    activeLoopers = 0
    For ch = 0; ch < 16; ch = ch + 1 Do
        if Mem_Loop_State[ch] == 1 or Mem_Loop_State[ch] == 2 or Mem_Loop_State[ch] == 3 then
            // Uses existing function for the string
            loopStr = loopStr + "[Ch" + (ch+1) + " " + TrimString(GetLoopProgressString(ch)) + "] "
            activeLoopers = activeLoopers + 1
        end
    End
    
    if activeLoopers == 0 then loopStr = loopStr + "Idle" end
    
    // Output
    Trace("TIME SYNC | " + gpStr + " | " + songStr + " | " + loopStr)
End

// ---------------------------------------------------------
// LOOP MASTER EVENT ENCODING
// Timeline stores a looper trigger event as a single Integer val.
// Upper nibble = channel index (0..15), lower nibble = action code:
//   0 = Rec, 1 = Play, 2 = Overdub, 3 = Clear
// Encoding: val = chIdx * 16 + actionCode
// ---------------------------------------------------------
Function EncodeLoopMasterVal(chIdx : Integer, actionCode : Integer) Returns Integer
   result = (chIdx * 16) + actionCode
End

Function DecodeLoopMasterChIdx(val : Integer) Returns Integer
   result = val / 16
End

Function DecodeLoopMasterActionCode(val : Integer) Returns Integer
   result = val % 16
End

Function LoopMasterActionName(actionCode : Integer) Returns String
   if actionCode == 0 then result = "REC"
   elsif actionCode == 1 then result = "PLAY"
   elsif actionCode == 2 then result = "OVR"
   elsif actionCode == 3 then result = "CLR"
   else result = "?" end
End

// ---------------------------------------------------------
// SHOW PROJECTION GATE
// Show-events are computed only when the ms <-> bars conversion is
// reliable — i.e. after a song has been stored (RecordedBPM > 0 and
// SongDurationBars > 0). During live REC we deliberately suppress
// projections so the user never sees a future that tempo-drift could
// invalidate.
// ---------------------------------------------------------
Function ShowProjectionsAllowed() Returns Boolean
   result = (RecordedBPM > 0.0) and (SongDurationBars > 0)
End

// ---------------------------------------------------------
// COMPUTE SHOW CHAIN
// Given a master event's starting channel, walk Mem_Loop_Target and
// accumulate offsets in bars (converted to ms on the fly via
// RecordedBPM + GetTimeSigNumerator). Returns three parallel arrays:
// showChain_OffsetMS, showChain_ChIdx, showChain_ActionCode.
// These are module-level arrays rebuilt on every call — callers that
// need them persistently must copy them out before the next call.
//
// N_MAX_CHAIN_DEPTH = 32 caps runaway projection for cyclic chains.
// ---------------------------------------------------------
Function ComputeShowChain(startChIdx : Integer)
   var cursor, next, depth, beatsPerBar : Integer
   var accumMS, msPerBar : Double = 0.0

   showChain_OffsetMS = []
   showChain_ChIdx = []
   showChain_ActionCode = []

   if not ShowProjectionsAllowed() then
       if DebugMode then Trace("LOOPER-TL: ComputeShowChain skipped (projections not allowed)") end
   else
       beatsPerBar = GetTimeSigNumerator()
       if beatsPerBar <= 0 then beatsPerBar = 4 end
       msPerBar = (60000.0 / RecordedBPM) * IntToFloat(beatsPerBar)

       cursor = startChIdx
       accumMS = 0.0
       depth = 0

       While cursor >= 0 and cursor < 16 and depth < N_MAX_CHAIN_DEPTH Do
          // Add the length of the current channel to the accumulator
          if Mem_Loop_Length[cursor] > 0 then
              accumMS = accumMS + (msPerBar * IntToFloat(Mem_Loop_Length[cursor]))
          end

          next = Mem_Loop_Target[cursor]
          if next < 0 or next >= 16 then
              cursor = -1   // chain ends
          else
              showChain_OffsetMS <-- accumMS
              showChain_ChIdx <-- next
              showChain_ActionCode <-- Mem_Loop_Action[next]
              cursor = next
              depth = depth + 1
          end
       End

       if DebugMode then Trace("LOOPER-TL: ComputeShowChain from Ch" + (startChIdx+1) + " produced " + Size(showChain_OffsetMS) + " entries") end
   end
End

// ---------------------------------------------------------
// COMPUTE NEXT LOOP SHOW ACTION
// Walks Snap_TL_* (committed timeline) for the last LoopMaster event
// whose chain has not yet fully elapsed relative to the current
// playhead, runs ComputeShowChain, and selects the earliest future
// show entry. Result triple exposed via module-level scratch
// variables. countdownMS = -1 means "no active chain".
// ---------------------------------------------------------
Function ComputeNextLoopShowAction(playheadMS : Double)
   var i, k, masterChIdx, latestMasterIdx : Integer
   var masterTimeMS, eventAbsMS : Double = 0.0
   var foundNext : Boolean = false

   nextLoopShow_CountdownMS = -1.0
   nextLoopShow_ChIdx = -1
   nextLoopShow_ActionCode = -1

   if not ShowProjectionsAllowed() then
       // leave the -1 sentinels in place
   else
       // Find the latest LoopMaster event whose timestamp is <= playheadMS
       latestMasterIdx = -1
       For i = 0; i < Size(Snap_TL_TimeMS); i = i + 1 Do
          if Snap_TL_Type[i] == "LoopMaster" and Snap_TL_TimeMS[i] <= playheadMS then
              latestMasterIdx = i
          end
       End

       if latestMasterIdx >= 0 then
          masterChIdx = DecodeLoopMasterChIdx(Snap_TL_Val[latestMasterIdx])
          masterTimeMS = Snap_TL_TimeMS[latestMasterIdx]
          ComputeShowChain(masterChIdx)

          // Find the earliest show entry whose absolute time is > playheadMS
          k = 0
          While k < Size(showChain_OffsetMS) and not foundNext Do
             eventAbsMS = masterTimeMS + showChain_OffsetMS[k]
             if eventAbsMS > playheadMS then
                 nextLoopShow_CountdownMS = eventAbsMS - playheadMS
                 nextLoopShow_ChIdx = showChain_ChIdx[k]
                 nextLoopShow_ActionCode = showChain_ActionCode[k]
                 foundNext = true
             end
             k = k + 1
          End
       end
   end
End

// =========================================================
// RECORDING MONITOR
// =========================================================

Function BuildRecDisplayLines()
    var i, partIdx, tms, masterChIdx, k, showMS, ovlCh, ovlState : Integer
    var line, eType, valStr, showLine, barStr, ovlFunc : String

    RecDisplayLines = []

    // 1. SHOW COMMITTED TIMELINE (Snap_TL_* = last saved/committed state)
    if Size(Snap_TL_TimeMS) == 0 and Size(Arr_Rec_TimeMS) == 0 then
        RecDisplayLines <-- "(Timeline is empty)"
    else
        for i = 0; i < Size(Snap_TL_TimeMS); i = i + 1 do
            eType = Snap_TL_Type[i]
            tms = Round(Snap_TL_TimeMS[i])

            if eType == "RegMem" then valStr = "Registration " + Snap_TL_Val[i]
                elsif eType == "Macro" then valStr = "Fader/Btn " + (Snap_TL_Val[i] + 1)
                elsif eType == "Style" then valStr = "Style Action " + Snap_TL_Val[i]
                elsif eType == "Map" then
                    if Snap_TL_Val[i] >= 0 and Snap_TL_Val[i] < Size(CtrlMapList) then
                        valStr = "Map: " + CtrlMapList[Snap_TL_Val[i]]
                    else
                        valStr = "Map: Unknown"
                    end
                // -------------
                elsif eType == "Marker" then
                partIdx = Snap_TL_Val[i]
                if partIdx >= 0 and partIdx < Size(Arr_SectionNames) then valStr = "Set: " + Arr_SectionNames[partIdx]
                else valStr = "Set: Unknown Part" end
            elsif eType == "LoopMaster" then
                valStr = LoopMasterActionName(DecodeLoopMasterActionCode(Snap_TL_Val[i])) + " Ch" + (DecodeLoopMasterChIdx(Snap_TL_Val[i]) + 1)
            else valStr = "Value: " + Snap_TL_Val[i] end

            line = IntToString(tms) + "ms | " + valStr

            RecDisplayLines <-- line

            // If this is a LoopMaster event, expand its show chain
            if eType == "LoopMaster" then
                masterChIdx = DecodeLoopMasterChIdx(Snap_TL_Val[i])
                ComputeShowChain(masterChIdx)
                for k = 0; k < Size(showChain_OffsetMS); k = k + 1 do
                    showMS = Round(IntToFloat(tms) + showChain_OffsetMS[k])
                    barStr = "+" + IntToString(Round(showChain_OffsetMS[k] / ((60000.0 / RecordedBPM) * IntToFloat(GetTimeSigNumerator())))) + "b"
                    showLine = "    " + TrimString(LOOP_SHOW_ARROW) + " " + barStr + "  " + LoopMasterActionName(showChain_ActionCode[k]) + " Ch" + (showChain_ChIdx[k] + 1) + "  (" + IntToString(showMS) + "ms)"
                    RecDisplayLines <-- showLine
                end
            end
        end

        // 2. APPEND NEW RECORDINGS AT BOTTOM (live feedback during active recording)
        if Size(Arr_Rec_TimeMS) > 0 then
            RecDisplayLines <-- "--- NEW EVENTS ---"
            for i = 0; i < Size(Arr_Rec_TimeMS); i = i + 1 do
                eType = Arr_Rec_Type[i]
                tms = Round(Arr_Rec_TimeMS[i])

                if eType == "RegMem" then valStr = "Registration " + Arr_Rec_Val[i]
                elsif eType == "Macro" then valStr = "Fader/Btn " + (Arr_Rec_Val[i] + 1)
                elsif eType == "Style" then valStr = "Style Action " + Arr_Rec_Val[i]
                elsif eType == "Map" then
                    if Arr_Rec_Val[i] >= 0 and Arr_Rec_Val[i] < Size(CtrlMapList) then
                        valStr = "Map: " + CtrlMapList[Arr_Rec_Val[i]]
                    else
                        valStr = "Map: Unknown"
                    end
                // -------------
                elsif eType == "Marker" then
                    partIdx = Arr_Rec_Val[i]
                    if partIdx >= 0 and partIdx < Size(Arr_SectionNames) then valStr = "Set: " + Arr_SectionNames[partIdx]
                    else valStr = "Set: Unknown Part" end
                elsif eType == "LoopMaster" then
                    valStr = LoopMasterActionName(DecodeLoopMasterActionCode(Arr_Rec_Val[i])) + " Ch" + (DecodeLoopMasterChIdx(Arr_Rec_Val[i]) + 1)
                elsif IndexOfSubstring(eType, "OVL_", false) == 0 then
                    ovlFunc = CopySubstring(eType, 4, Length(eType) - 4)
                    ovlCh = Arr_Rec_Val[i] / 2
                    ovlState = Arr_Rec_Val[i] - (ovlCh * 2)
                    if ovlState == 1 then valStr = "Overlay ON: " + ovlFunc + " CH" + IntToString(ovlCh)
                    else valStr = "Overlay OFF: " + ovlFunc + " CH" + IntToString(ovlCh) end
                else valStr = "Value: " + Arr_Rec_Val[i] end

                line = IntToString(tms) + "ms | " + valStr + " [NEW]"

                RecDisplayLines <-- line

                // If this is a LoopMaster event, expand its show chain
                if eType == "LoopMaster" then
                    masterChIdx = DecodeLoopMasterChIdx(Arr_Rec_Val[i])
                    ComputeShowChain(masterChIdx)
                    for k = 0; k < Size(showChain_OffsetMS); k = k + 1 do
                        showMS = Round(IntToFloat(tms) + showChain_OffsetMS[k])
                        barStr = "+" + IntToString(Round(showChain_OffsetMS[k] / ((60000.0 / RecordedBPM) * IntToFloat(GetTimeSigNumerator())))) + "b"
                        showLine = "    " + TrimString(LOOP_SHOW_ARROW) + " " + barStr + "  " + LoopMasterActionName(showChain_ActionCode[k]) + " Ch" + (showChain_ChIdx[k] + 1) + "  (" + IntToString(showMS) + "ms)"
                        RecDisplayLines <-- showLine
                    end
                end
            end
        end
    end
End

Function RefreshRecDisplay(scrollVal : Double)
    var totalLines : Integer = Size(RecDisplayLines)
    var displayLines : Integer = 15 // Check how many lines fit in the label
    var maxStart : Integer = totalLines - displayLines
    var startIdx, i : Integer
    var finalText, stateHeader : String = ""

    // 1. OVERLAY CHECK (show error messages for X seconds)
    if Rec_OverlayTimer > 0.0 and TimeSinceStartup() < Rec_OverlayTimer then
        finalText = "=== [ SYSTEM MESSAGE ] ===" + NEW_LINE
        finalText = finalText + "---------------------------------" + NEW_LINE + NEW_LINE + NEW_LINE
        finalText = finalText + "  >>> " + Rec_OverlayMsg + " <<<"
        SetWidgetLabel(LBL_CurrentState, finalText)
    else
        // 2. NORMAL MODE (list view)
        if TimelineRecActive then
            stateHeader = "--- TIMELINE (MS-REC ACTIVE) ---"
        elsif RecordMode == 0 then
            stateHeader = "--- TIMELINE (PLAY MODE) ---"
        elsif RecordMode == 1 then
            if IsPerformanceActive or IsPlayheadEnabled() then stateHeader = "--- TIMELINE (OVERDUB REC) ---"
            else stateHeader = "--- TIMELINE (OVERDUB READY) ---" end
        elsif RecordMode == 2 then
            if IsPerformanceActive or IsPlayheadEnabled() then stateHeader = "--- TIMELINE (REPLACE REC) ---"
            else stateHeader = "--- TIMELINE (REPLACE READY) ---" end
        end
        
        finalText = stateHeader + NEW_LINE + NEW_LINE

        // SCROLLING LIST
        if maxStart < 0 then maxStart = 0 end
        startIdx = Round((1.0 - scrollVal) * IntToFloat(maxStart))

        For i = 0; i < displayLines; i = i + 1 Do
            if (startIdx + i) < totalLines then
                finalText = finalText + RecDisplayLines[startIdx + i] + NEW_LINE
            end
        End

        SetWidgetLabel(LBL_CurrentState, finalText)
    end
End


// ============================================================================
// SECTION 13: CORE UTILITIES
// ============================================================================

Function ShowRecOverlay(msg : String, durationMS : Double)
    Rec_OverlayMsg = msg
    Rec_OverlayTimer = TimeSinceStartup() + durationMS
    RefreshRecDisplay(GetWidgetValue(SLD_CurrentState))
End


// ============================================================================
// SECTION 19: PROMPTER & TIMELINE ENGINE
// ============================================================================

Function ScrollToCurrentTimelineEvent()
    var targetLine : Integer = -1
    var totalLines : Integer = Size(RecDisplayLines)
    var displayLines : Integer = 15
    var maxStart : Integer = totalLines - displayLines
    var scrollVal : Double = 0.0

    // Scroll to the last committed event (no bar-based position — just scroll to end)
    targetLine = Size(Snap_TL_TimeMS) - 1
    if targetLine < 0 then targetLine = 0 end

    // Fallback: If actively recording, scroll to new events section
    if Size(Arr_Rec_TimeMS) > 0 then
        targetLine = Size(Snap_TL_TimeMS) + 1 // +1 for the "--- NEW EVENTS ---" separator line
    end

    if maxStart <= 0 then 
        scrollVal = 1.0 
    else
        if targetLine > maxStart then targetLine = maxStart end
        scrollVal = 1.0 - (IntToFloat(targetLine) / IntToFloat(maxStart))
    end

    // Move slider and redraw UI
    SetWidgetValue(SLD_CurrentState, scrollVal)
    RefreshRecDisplay(scrollVal)
End

Function GetChordProFile(songName : String) Returns String
   var baseDir, sep, fullPath : String
   baseDir = UserChordProPath
   if IndexOfSubstring(baseDir, "\\", false) > -1 Then sep = "\\" Else sep = "/" End
   fullPath = baseDir + sep + songName + ".gpchord"
   result = fullPath
End

Function CalculateEffectiveTranspose()
   EffectiveTranspose = ManualTranspose + FileTranspose + GetGlobalTranspose()
   
   CurrentTranspose = EffectiveTranspose
   if CurrentTranspose > 48 Then CurrentTranspose = 48 End
   if CurrentTranspose < -48 Then CurrentTranspose = -48 End
End

Function TriggerStyleAction(styleId : Integer)
   // Safety: Max index for send triggers is 28 (Trig_Fade).
   // Anything above is out of bounds or our HW input (index 29).
   if styleId >= 0 and styleId <= 28 then
       if DebugMode then Trace("STYLE: Triggering ID " + styleId) end
       
       // Electronic key press (Note On)
       SetParameter(BLK_ArrangerSync, styleId, 1.0)
       
       // Wait 50ms for the scriptlet to respond
       Wait(50.0) 
       
       // Release the button (Note Off)
       SetParameter(BLK_ArrangerSync, styleId, 0.0)
   else
       if DebugMode then Trace("STYLE ERROR: Invalid ID (" + styleId + ") ignored! Max is 28.") end
   end
End

// ---------------------------------------------------------
// DISPLAY ENGINE & PROMPTER PUSH FOR CHORD VIEWER
// ---------------------------------------------------------

Function UpdatePrompter(moveSlider : Boolean)
   var num, i, currentIndex, a, barsToGo, currentBeats, curSecs, cMin, oscPayload, tSec, cSec, totalSecs, tMin, displayBeat : Integer
   var sliderPos, currentBPM : Double = 0.0
   var isWrite : Boolean
   var timeStr, barStr, finalCountStr, headerStr, footerStr, nextSection, cueText, curTimeStr : String
     
   isWrite = (RecordMode > 0) or TimelineRecActive
   
   If IsEmptyMode Then
       currentIndex = 0
   Else
       i = 0; currentIndex = 0
       If Size(Arr_BarTriggers) > 0 Then
           While i < Size(Arr_BarTriggers) Do If Arr_BarTriggers[i] <= CurrentBar Then currentIndex = i End; i = i + 1 End
       End
   End
   
   // --- BUILD STRINGS AND SEND TO DISPLAY ---
   If IsEmptyMode == true Then
       headerStr = ""; footerStr = ""
       If CurrentState == 9 Then
          OSC_SendStringSpecific("/UI/SetLyrics", "LOADING SCRIPT...", Local_IP, Local_PORT)
       Elsif CurrentState == 2 Then
          // Expected state: file exists but is empty (waiting for clipboard)
          OSC_SendStringSpecific("/UI/SetLyrics", "WAITING FOR CHORDS..." + NEW_LINE + "Paste from Clipboard to complete.", Local_IP, Local_PORT)
       Else
          // Fallback for unforeseen states
          OSC_SendStringSpecific("/UI/SetLyrics", "READY." + NEW_LINE + "(State " + CurrentState + ")", Local_IP, Local_PORT)
       End
       OSC_SendStringSpecific("/UI/SetChords", "", Local_IP, Local_PORT)
   Else
       if currentIndex < Size(Arr_SectionNames) Then headerStr = Arr_SectionNames[currentIndex] Else headerStr = "" End
       if headerStr == "End" Then headerStr = "END" End
       
       footerStr = ""
       if currentIndex + 1 < Size(Arr_SectionNames) Then
           nextSection = Arr_SectionNames[currentIndex + 1]
           if currentIndex + 1 < Size(Arr_BarTriggers) Then
               barsToGo = Arr_BarTriggers[currentIndex + 1] - CurrentBar
               if barsToGo < 0 Then barsToGo = 0 End
               footerStr = "Next: " + nextSection + " (" + IntToString(barsToGo) + ")" + NEW_LINE
           End
       End
       if currentIndex < Size(Arr_Cues) Then
           cueText = Arr_Cues[currentIndex]
           if Length(cueText) > 0 Then footerStr = footerStr + "Cue: " + cueText End
       End
       
       // Send the clean zebra-striped blocks to the monitor
       If currentIndex < Size(Arr_Text_Lyrics) Then OSC_SendStringSpecific("/UI/SetLyrics", Arr_Text_Lyrics[currentIndex], Local_IP, Local_PORT) End
       If currentIndex < Size(Arr_Text_Chords) Then OSC_SendStringSpecific("/UI/SetChords", Arr_Text_Chords[currentIndex], Local_IP, Local_PORT) End
   End
   
   OSC_SendStringSpecific("/UI/SetHeader", headerStr, Local_IP, Local_PORT)
   OSC_SendStringSpecific("/UI/SetFooter", footerStr, Local_IP, Local_PORT)
   
// 1. Query time and time signature
   num = GetTimeSigNumerator()
   if num <= 0 then num = 4 end 
   
   currentBPM = GetBPM()
   if currentBPM < 1.0 then currentBPM = 120.0 end

   // 2. Calculate total length
   totalSecs = Round((IntToFloat(SongDurationBars * num) * 60.0) / currentBPM)
   tMin = totalSecs / 60
   tSec = totalSecs % 60
   timeStr = IntToString(tMin) + ":" + PadInt(tSec, 2) 

   // 3. Calculate current position
   currentBeats = ((CurrentBar - 1) * num) + (CurrentBeat - 1)
   if currentBeats < 0 then currentBeats = 0 end 
   
   displayBeat = CurrentBeat
   
   // === COSMETIC CHEAT WITHOUT SIDE EFFECTS ===
   if CurrentBar >= SongDurationBars and not IsPerformanceActive then
       displayBeat = num        // Cosmetically shows the last beat (e.g. .4)
       curSecs = totalSecs      // Forces the left time to exactly match the right time
   else
       curSecs = Round((IntToFloat(currentBeats) * 60.0) / currentBPM)
   end
   
   cMin = curSecs / 60
   cSec = curSecs % 60
   curTimeStr = IntToString(cMin) + ":" + PadInt(cSec, 2)

   // 4. Format bar string (e.g. "071.4")
   barStr = PadInt(CurrentBar, 3) + "." + IntToString(displayBeat)

   // 5. Assemble display (DAW style)
   if isWrite Then 
       finalCountStr = "REC: " + barStr + " / " + IntToString(SongDurationBars) + " | " + curTimeStr + " / " + timeStr
   Else 
       finalCountStr = "Bar: " + barStr + " / " + IntToString(SongDurationBars) + " | " + curTimeStr + " / " + timeStr
   End

   // Send to monitor!
   OSC_SendStringSpecific("/UI/SetBarCount", finalCountStr, Local_IP, Local_PORT)
   // ========================================================
   
   if moveSlider and SongDurationBars > 1 Then
       sliderPos = 1.0 - (IntToFloat(CurrentBar) / IntToFloat(SongDurationBars))
       if sliderPos > 1.0 Then sliderPos = 1.0 End; if sliderPos < 0.0 Then sliderPos = 0.0 End
       
       OSC_SendDoubleSpecific("/UI/SetScrubber", sliderPos, Local_IP, Local_PORT)
       SetWidgetValue(SLD_CurrentState, sliderPos)
       
       // ---> FIX: Increase deaf timer to 1 second! <---
       ScrubberTaubTimer = TimeSinceStartup() + 1000.0 
       
       if SCRUB_MacroIdx >= 0 and SCRUB_MacroIdx <= 15 then
           ScriptWrite_ExpectedPrev[SCRUB_MacroIdx] = ScriptWrite_Expected[SCRUB_MacroIdx]
           ScriptWrite_Expected[SCRUB_MacroIdx] = sliderPos
           SetParameter(ExternalArranger, SCRUB_MacroIdx, sliderPos)
       end
   End
   
   // --- TIMELINE TRIGGER (MACROS & STYLES) ---
   if not isWrite and CurrentBar != LastFiredBar then
       // 1. FIRE MACROS DIRECTLY
       for a = 0; a < Size(Arr_Anim_Bar); a = a + 1 do
           if Arr_Anim_Bar[a] == CurrentBar then
               StartMacroAnimation(Arr_Anim_MacroIdx[a], Arr_Anim_Target[a], Arr_Anim_DurMS[a])
           end
       end
       
       // 2. FIRE STYLE TRIGGERS DIRECTLY
       for a = 0; a < Size(Arr_Style_Bar); a = a + 1 do
           if Arr_Style_Bar[a] == CurrentBar then
               TriggerStyleAction(Arr_Style_ID[a])
           end
       end
       LastFiredBar = CurrentBar
   end
End

Function HasRealLyrics(line : String) Returns Boolean
   var i, len : Integer; var c : String; var insideBracket : Boolean; var hasContent : Boolean
   len = Length(line); insideBracket = false; hasContent = false
   i = 0
   
   While i < len and not hasContent Do
      c = CopySubstring(line, i, 1)
      
      If c == "[" Then 
         insideBracket = true
      Elsif c == "]" Then 
         insideBracket = false
      Else 
         If insideBracket == false Then 
            If c != " " and c != "-" and c != "–" and c != "_" Then 
               hasContent = true // Terminates the loop on the next iteration
            End 
         End 
      End
      
      i = i + 1
   End
   
   result = hasContent
End

Function TransposeNote(note : String, amount : Integer) Returns String
   var idx, newIdx : Integer; var res : String
   idx = GetNoteIndex(note); res = note
   If idx > -1 Then 
      newIdx = idx + amount
      while newIdx < 0 Do newIdx = newIdx + 12 End
      while newIdx > 11 Do newIdx = newIdx - 12 End
      res = NoteNamesSharp[newIdx] 
   Else res = MyToUpper(note) End
   result = res
End

Function TransposeChordContent(content : String, amount : Integer) Returns String
   var root, suffix, bass, temp, tempRoot, tempBass : String; var slashPos, len : Integer
   root = ""; suffix = ""; bass = ""; temp = content; len = Length(content)
   slashPos = IndexOfSubstring(content, "/", false)
   If slashPos > -1 Then 
      tempBass = CopySubstring(content, slashPos + 1, len - slashPos - 1); temp = CopySubstring(content, 0, slashPos)
      bass = TransposeNote(tempBass, amount); bass = "/" + bass 
   End
   tempRoot = ""; if Length(temp) > 1 then tempRoot = CopySubstring(temp, 1, 1) End
   if Length(temp) > 1 and (tempRoot == "#" or tempRoot == "b") Then root = CopySubstring(temp, 0, 2); suffix = CopySubstring(temp, 2, Length(temp)-2)
   Else root = CopySubstring(temp, 0, 1); suffix = CopySubstring(temp, 1, Length(temp)-1) End
   root = TransposeNote(root, amount)
   result = root + suffix + bass
End

Function TransposeLine(line : String, amount : Integer) Returns String
   var res, temp, chordPart, transposedChord, textPart : String; var openPos, closePos, loopGuard : Integer
   res = ""; loopGuard = 0; temp = line
   While Length(temp) > 0 and loopGuard < 100 Do
      openPos = IndexOfSubstring(temp, "[", false)
      If openPos > -1 Then
         textPart = CopySubstring(temp, 0, openPos); res = res + textPart + "["
         temp = CopySubstring(temp, openPos + 1, Length(temp) - openPos - 1);
         closePos = IndexOfSubstring(temp, "]", false)
         If closePos > -1 Then 
             chordPart = CopySubstring(temp, 0, closePos)
             transposedChord = TransposeChordContent(chordPart, amount)
             res = res + transposedChord + "]"; temp = CopySubstring(temp, closePos + 1, Length(temp) - closePos - 1)
         Else res = res + temp; temp = "" End
      Else res = res + temp; temp = "" End
      loopGuard = loopGuard + 1
   End
   result = res
End

// ---------------------------------------------------------
// ZEBRA RENDER ENGINE (GLOBAL)
// ---------------------------------------------------------

Function BuildZebraBlocks()
   var i, k, j, lineLen : Integer
   var originalBlock, transposedLine, tempChordLine, tempLyricLine, currentChord, c : String
   var lines : String Array
   var hasLyrics, inChord : Boolean
   var finalBlockChords, finalBlockLyrics : String
   
   Arr_Text_Chords = []; Arr_Text_Lyrics = []
   
   if Size(Arr_PartText_Raw) > 0 Then
      i = 0
      While i < Size(Arr_PartText_Raw) Do
         originalBlock = Arr_PartText_Raw[i]
         lines = SplitString(originalBlock, NEW_LINE)
         
         // Initialize blocks for this part
         finalBlockChords = ""; 
         finalBlockLyrics = ""; 
         
         if Size(lines) > 0 Then 
            k = 0
            While k < Size(lines) Do 
               transposedLine = TransposeLine(lines[k], CurrentTranspose)
               hasLyrics = HasRealLyrics(transposedLine)
               
               tempChordLine = ""; tempLyricLine = ""; currentChord = ""; inChord = false
               lineLen = Length(transposedLine); j = 0 
               
               While j < lineLen Do
                  c = CopySubstring(transposedLine, j, 1)
                  If c == "[" Then
                     While Length(tempChordLine) < Length(tempLyricLine) Do tempChordLine = tempChordLine + " " End
                     inChord = true; currentChord = ""
                  Elsif c == "]" Then
                     inChord = false
                     tempChordLine = tempChordLine + currentChord
                     While Length(tempLyricLine) < Length(tempChordLine) Do tempLyricLine = tempLyricLine + " " End
                  Elsif inChord Then 
                     currentChord = currentChord + c
                  Else
                     tempLyricLine = tempLyricLine + c
                     If Length(tempChordLine) < Length(tempLyricLine) Then tempChordLine = tempChordLine + " " End
                  End
                  j = j + 1
               End
               
               // Length equalization (high-speed)
               if Length(tempChordLine) < Length(tempLyricLine) then
                   tempChordLine = tempChordLine + GetSpaces(Length(tempLyricLine) - Length(tempChordLine))
               elsif Length(tempLyricLine) < Length(tempChordLine) then
                   tempLyricLine = tempLyricLine + GetSpaces(Length(tempChordLine) - Length(tempLyricLine))
               end
               
               // Interleave assembly
               finalBlockChords = finalBlockChords + tempChordLine + NEW_LINE + " " + NEW_LINE
               
               // FIX: Force lyric lines to ALWAYS contain content (spaces),
               // so that old "LOADING..." text gets replaced.
               if hasLyrics Then 
                   finalBlockLyrics = finalBlockLyrics + " " + NEW_LINE + tempLyricLine + NEW_LINE 
               Else 
                   finalBlockLyrics = finalBlockLyrics + " " + NEW_LINE + " " + NEW_LINE 
               End
               
               k = k + 1
            End 
         End
         
         // If the entire block (e.g. Intro) has no lyrics,
         // ensure it is not completely empty.
         if finalBlockLyrics == "" Then finalBlockLyrics = " " End
         
         Arr_Text_Chords <-- finalBlockChords
         Arr_Text_Lyrics <-- finalBlockLyrics
         i = i + 1
      End
   End
End

Function RecordTimelineEvent(eventType : String, eventVal : Integer)
    var eventTimeMS : Double = 0.0

    // GUARD: Only record when Timeline REC is active
    if not TimelineRecActive then
        Trace("TIMELINE-REC: Ignored (not active)")
    else
        eventTimeMS = TimeSinceStartup() - RecordStartTimeMS

        // Write to working arrays
        Arr_Rec_TimeMS <-- eventTimeMS
        Arr_Rec_Type <-- eventType
        Arr_Rec_Val <-- eventVal

        Trace("TIMELINE-REC: " + eventType + " val=" + eventVal + " at " + Round(eventTimeMS) + "ms")

        BuildRecDisplayLines()
        RefreshRecDisplay(GetWidgetValue(SLD_CurrentState))
    end
End

Function RecalculateTextDisplay()
   var sign : String = ""
   
   CalculateEffectiveTranspose()
   
   if CurrentTranspose > 0 Then sign = "+" End
   LBL_OffsetValue.SetWidgetLabel(sign + CurrentTranspose) 
   
   if IsEmptyMode Then
       UpdatePrompter(false)
   Else
       Trace("PROMPTER: Starting Zebra Render Engine...")
       BuildZebraBlocks()
       Trace("PROMPTER: Zebra rendering complete. Sending to display...")
       UpdatePrompter(false)
   End
End

Function TriggerNextSongPart()
    // Only respond when recording is armed AND transport is running!
    if RecordMode > 0 and IsPerformanceActive then
        if NextRecPartIdx >= 0 and NextRecPartIdx < Size(Arr_SectionNames) then
            
            RecordTimelineEvent("Marker", NextRecPartIdx)
            Arr_BarTriggers[NextRecPartIdx] = CurrentBar
            
            if CurrentBar + 15 > SongDurationBars then SongDurationBars = CurrentBar + 15 end
            
            Trace("PROMPTER: Marker Set! [" + Arr_SectionNames[NextRecPartIdx] + "] -> Bar " + CurrentBar)
            OSC_SendStringSpecific("/UI/SetHeader", ">>> MARKER SET: " + Arr_SectionNames[NextRecPartIdx] + " <<<", Local_IP, Local_PORT)
            
            NextRecPartIdx = NextRecPartIdx + 1
            RecalculateTextDisplay()
            
        else
            Trace("PROMPTER: All parts marked!")
            OSC_SendStringSpecific("/UI/SetHeader", ">>> ALL PARTS MARKED <<<", Local_IP, Local_PORT)
        end
    else
        // Indicates the button was ignored (because playhead is stopped)
        Trace("PROMPTER: Marker button ignored (transport stopped or REC is off)")
    end
End

// ---------------------------------------------------------
// INTERNAL TRIGGERS & FILE ACTIONS (replaces the old OSC senders)
// ---------------------------------------------------------

Function TriggerSongTextLoad(songName : String)
   // Store the name and set the timer 200ms into the future
   PendingSongName = songName
   DelayedSongSwitchTimer = TimeSinceStartup() + 200.0 
   Trace("TRIGGER: Song Text Load scheduled for '" + songName + "'")
End

Function DecodeDeviceSysExName(sysExString : String) Returns String
   var parts : String Array = SplitString(sysExString, " ")
   var decoded : String = ""
   var i, val : Integer
   var isDone : Boolean = false // ---> NEW: Clean exit flag <---

   i = 10 // Start at index 10 as before
   While i < Size(parts) and not isDone Do
      val = (HexCharToInt(CopySubstring(parts[i],0,1)) * 16) + HexCharToInt(CopySubstring(parts[i],1,1))
      
      // 0 = Null-Terminator, 247 = F7 (End of SysEx)
      if val == 0 or val == 247 then 
          isDone = true 
      else 
          decoded = decoded + IntToChar(val) 
      end 
      
      i = i + 1 // Always increment
   End
   
   result = decoded
End

Function SanitizeAndSlugify(rawName : String) Returns String
    var processed, charToCheck, finalSlug : String
    var i, lastSlash, dotIndex, idx : Integer
    var alphaUpper : String = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    var alphaLower : String = "abcdefghijklmnopqrstuvwxyz"
    
    // 1. REMOVE PATH (everything before the last / or \)
    lastSlash = -1
    for i = 0; i < Length(rawName); i=i+1 do
       charToCheck = CopySubstring(rawName, i, 1)
       if charToCheck == "/" or charToCheck == "\\" then lastSlash = i end
    end
    if lastSlash > -1 then processed = CopySubstring(rawName, lastSlash+1, Length(rawName)-lastSlash-1)
    else processed = rawName end

    // 2. REMOVE .RGT EXTENSION (case insensitive)
    dotIndex = IndexOfSubstring(processed, ".rgt", false) 
    if dotIndex > -1 then 
        processed = CopySubstring(processed, 0, dotIndex) 
    end
    
    // 3. REMOVE ARRANGER ID (.T589, .S038, etc.)
    dotIndex = -1
    for i = 0; i < Length(processed); i=i+1 do
       if CopySubstring(processed, i, 1) == "." then dotIndex = i end
    end
    
    if dotIndex > 0 and (Length(processed) - dotIndex) <= 6 then
         processed = CopySubstring(processed, 0, dotIndex)
    end

    // 4. SLUGIFY (keep only letters)
    finalSlug = ""
    for i = 0; i < Length(processed); i=i+1 do
       charToCheck = CopySubstring(processed, i, 1)
       if IndexOfSubstring(alphaLower, charToCheck, true) > -1 then
          finalSlug = finalSlug + charToCheck
       else
          idx = IndexOfSubstring(alphaUpper, charToCheck, true)
          if idx > -1 then
             finalSlug = finalSlug + CopySubstring(alphaLower, idx, 1)
          end
       end
    end
    result = finalSlug
End

// ---------------------------------------------------------
// LFO ENUMERATORS
// Forward + reverse lookup between text names and integer indices
// for the three enum fields (Type, Rate, Cycles).
// ---------------------------------------------------------

Function LFOTypeIdx(name : String) Returns Integer
   var n : String = ""
   n = TrimString(name)
   if n == "Triangle" then result = 0
   elsif n == "TriangleUp" then result = 1
   elsif n == "TriangleDown" then result = 2
   elsif n == "Sinus" then result = 3
   elsif n == "Square" then result = 4
   elsif n == "Random" then result = 5
   else result = -1 end
End

Function LFOTypeName(idx : Integer) Returns String
   if idx == 0 then result = "Triangle"
   elsif idx == 1 then result = "TriangleUp"
   elsif idx == 2 then result = "TriangleDown"
   elsif idx == 3 then result = "Sinus"
   elsif idx == 4 then result = "Square"
   elsif idx == 5 then result = "Random"
   else result = "?" end
End

Function LFORateIdx(name : String) Returns Integer
   var n : String = ""
   n = TrimString(name)
   if n == "8/1" then result = 0
   elsif n == "4/1" then result = 1
   elsif n == "2/1" then result = 2
   elsif n == "1/1" then result = 3
   elsif n == "1/2" then result = 4
   elsif n == "1/4" then result = 5
   elsif n == "1/8" then result = 6
   elsif n == "1/16" then result = 7
   elsif n == "1/32" then result = 8
   else result = -1 end
End

Function LFORateName(idx : Integer) Returns String
   if idx == 0 then result = "8/1"
   elsif idx == 1 then result = "4/1"
   elsif idx == 2 then result = "2/1"
   elsif idx == 3 then result = "1/1"
   elsif idx == 4 then result = "1/2"
   elsif idx == 5 then result = "1/4"
   elsif idx == 6 then result = "1/8"
   elsif idx == 7 then result = "1/16"
   elsif idx == 8 then result = "1/32"
   else result = "?" end
End

Function LFORateBars(idx : Integer) Returns Double
   if idx == 0 then result = 8.0
   elsif idx == 1 then result = 4.0
   elsif idx == 2 then result = 2.0
   elsif idx == 3 then result = 1.0
   elsif idx == 4 then result = 0.5
   elsif idx == 5 then result = 0.25
   elsif idx == 6 then result = 0.125
   elsif idx == 7 then result = 0.0625
   elsif idx == 8 then result = 0.03125
   else result = 1.0 end
End

Function LFOCyclesParse(s : String) Returns Integer
   var n : String = ""
   n = TrimString(s)
   if n == "-" or n == "" then result = 0
   elsif n == "Infinite" then result = -1
   else result = StringToInt(n) end
End

Function LFOCyclesName(cycles : Integer) Returns String
   if cycles == 0 then result = "-"
   elsif cycles == -1 then result = "Infinite"
   else result = IntToString(cycles) end
End

// ---------------------------------------------------------
// LOAD LFO CONFIG
// Parses LFOConfig.txt into the LFO registry arrays. Silently
// skips malformed sections with a DebugMode trace.
// ---------------------------------------------------------
Function LoadLFOConfig()
   var content, sectionContent, remaining, line, key, val, name : String
   var lines : String Array
   var startPos, endPos, headerLen, i, eqPos : Integer
   var parsedType, parsedRate, parsedCycles : Integer

   LFO_Names = []
   LFO_Types = []
   LFO_Rates = []
   LFO_Cycles = []

   if not FileExists(LFOConfigFilePath) then
       if DebugMode then Trace("LFO: LFOConfig.txt not found at " + LFOConfigFilePath + " — registry empty") end
   else
       content = LoadStringFromTextFile(LFOConfigFilePath)

       startPos = IndexOfSubstring(content, "[LFO:", false)
       While startPos > -1 Do
          endPos = IndexOfSubstring(CopySubstring(content, startPos, Length(content) - startPos), "]", false)
          if endPos < 0 then
              startPos = -1
          else
              name = CopySubstring(content, startPos + 5, endPos - 5)
              headerLen = endPos + 1

              remaining = CopySubstring(content, startPos + headerLen, Length(content) - (startPos + headerLen))
              endPos = IndexOfSubstring(remaining, "[LFO:", false)
              if endPos > -1 then
                  sectionContent = CopySubstring(remaining, 0, endPos)
              else
                  sectionContent = remaining
              end

              parsedType = -1
              parsedRate = -1
              parsedCycles = 0

              lines = SplitString(sectionContent, NEW_LINE)
              For i = 0; i < Size(lines); i = i + 1 Do
                 line = TrimString(lines[i])
                 if Length(line) > 0 and IndexOfSubstring(line, ";", false) != 0 and IndexOfSubstring(line, "=", false) > -1 then
                     eqPos = IndexOfSubstring(line, "=", false)
                     key = TrimString(CopySubstring(line, 0, eqPos))
                     val = TrimString(CopySubstring(line, eqPos + 1, Length(line) - (eqPos + 1)))
                     if key == "Type" then parsedType = LFOTypeIdx(val)
                     elsif key == "Rate" then parsedRate = LFORateIdx(val)
                     elsif key == "Cycles" then parsedCycles = LFOCyclesParse(val)
                     else
                         if DebugMode then Trace("LFO: unknown key '" + key + "' in [LFO:" + name + "]") end
                     end
                 end
              End

              if parsedType < 0 or parsedRate < 0 then
                  if DebugMode then Trace("LFO: [LFO:" + name + "] rejected (malformed Type/Rate)") end
              else
                  LFO_Names <-- name
                  LFO_Types <-- parsedType
                  LFO_Rates <-- parsedRate
                  LFO_Cycles <-- parsedCycles
                  if DebugMode then Trace("LFO: registered '" + name + "' type=" + LFOTypeName(parsedType) + " rate=" + LFORateName(parsedRate) + " cycles=" + LFOCyclesName(parsedCycles)) end
              end

              // Advance: chop off the parsed prefix and re-scan
              content = CopySubstring(content, startPos + 1, Length(content) - (startPos + 1))
              startPos = IndexOfSubstring(content, "[LFO:", false)
          end
       End
   end

   if DebugMode then Trace("LFO: LoadLFOConfig complete, " + Size(LFO_Names) + " entries") end
End

// ---------------------------------------------------------
// BUILD LFO USAGE INDEX (v2)
// Scans ControllerMaps.txt for every `Macro<N> = LFO:<Name> | ...`
// line across every [Map:...] section and populates the four
// parallel LFO_Usage_* arrays with (lfoIdx, mapIdx, macroIdx,
// rawLine) tuples. Orphan prefixes (LFO name not in registry) are
// DebugMode-traced and skipped.
//
// Called from bootstrap PHASE 5 after LoadLFOConfig, and from every
// BTN_* callback that mutates ControllerMaps.txt.
// ---------------------------------------------------------
Function BuildLFOUsageIndex()
   var content, section, line, mapName, valuePart : String
   var rawLine, lfoName, firstEntry : String
   var sectionStart, sectionEnd, lineStart, lineEnd, eqPos, pipePos : Integer
   var macroSlot, lfoIdx, mapIdx, i, n, bindingCount : Integer
   var lines : String Array

   LFO_Usage_LfoIdx   = []
   LFO_Usage_MapIdx   = []
   LFO_Usage_MacroIdx = []
   LFO_Usage_RawLine  = []
   bindingCount = 0

   if not FileExists(ControllerMapFilePath) then
       if DebugMode then Trace("LFO v2: BuildLFOUsageIndex skipped, ControllerMaps.txt not found") end
   else
       content = LoadStringFromTextFile(ControllerMapFilePath)

       // Walk every [Map:...] header
       sectionStart = IndexOfSubstring(content, "[Map:", false)
       While sectionStart > -1 Do
          // Extract map name from "[Map:<name>]"
          lineEnd = IndexOfSubstring(CopySubstring(content, sectionStart, Length(content) - sectionStart), "]", false)
          if lineEnd < 0 then
              sectionStart = -1
          else
              mapName = CopySubstring(content, sectionStart + 5, lineEnd - 5)

              // Look up mapName in CtrlMapList
              mapIdx = -1
              For i = 0; i < Size(CtrlMapList); i = i + 1 Do
                 if CtrlMapList[i] == mapName then mapIdx = i end
              End

              // Find section body bounds: from end of header line to next [Map: or EOF
              sectionEnd = IndexOfSubstring(CopySubstring(content, sectionStart + lineEnd + 1, Length(content) - (sectionStart + lineEnd + 1)), "[Map:", false)
              if sectionEnd > -1 then
                  section = CopySubstring(content, sectionStart + lineEnd + 1, sectionEnd)
              else
                  section = CopySubstring(content, sectionStart + lineEnd + 1, Length(content) - (sectionStart + lineEnd + 1))
              end

              // Scan every non-comment Macro<N> = line for LFO: prefix
              lines = SplitString(section, NEW_LINE)
              For n = 0; n < Size(lines); n = n + 1 Do
                 line = TrimString(lines[n])
                 if Length(line) > 0 and IndexOfSubstring(line, ";", false) != 0 and IndexOfSubstring(line, "Macro", false) == 0 then
                     eqPos = IndexOfSubstring(line, "=", false)
                     if eqPos > 0 then
                         // Extract macro slot number
                         macroSlot = StringToInt(TrimString(ReplaceString(CopySubstring(line, 0, eqPos), "Macro", "", false))) - 1
                         valuePart = TrimString(CopySubstring(line, eqPos + 1, Length(line) - (eqPos + 1)))

                         // Check if first |-entry starts with LFO:
                         pipePos = IndexOfSubstring(valuePart, "|", false)
                         if pipePos >= 0 then
                             firstEntry = TrimString(CopySubstring(valuePart, 0, pipePos))
                         else
                             firstEntry = valuePart
                         end

                         if IndexOfSubstring(firstEntry, "LFO:", false) == 0 then
                             lfoName = TrimString(ReplaceString(firstEntry, "LFO:", "", false))

                             // Registry lookup
                             lfoIdx = -1
                             For i = 0; i < Size(LFO_Names); i = i + 1 Do
                                if LFO_Names[i] == lfoName then lfoIdx = i end
                             End

                             if lfoIdx < 0 then
                                 if DebugMode then Trace("LFO v2: orphan binding '" + lfoName + "' in [" + mapName + "] Macro" + (macroSlot + 1) + ", not in registry") end
                             elsif macroSlot < 0 or macroSlot >= 50 then
                                 if DebugMode then Trace("LFO v2: binding '" + lfoName + "' in [" + mapName + "] Macro" + (macroSlot + 1) + " outside user zone, skipped") end
                             elsif mapIdx < 0 then
                                 if DebugMode then Trace("LFO v2: binding '" + lfoName + "' in unknown map '" + mapName + "', skipped") end
                             else
                                 LFO_Usage_LfoIdx   <-- lfoIdx
                                 LFO_Usage_MapIdx   <-- mapIdx
                                 LFO_Usage_MacroIdx <-- macroSlot
                                 LFO_Usage_RawLine  <-- line
                                 bindingCount = bindingCount + 1
                             end
                         end
                     end
                 end
              End

              // Advance to next section by chopping the prefix we just consumed
              content = CopySubstring(content, sectionStart + 1, Length(content) - (sectionStart + 1))
              sectionStart = IndexOfSubstring(content, "[Map:", false)
          end
       End
   end

   if DebugMode then Trace("LFO v2: BuildLFOUsageIndex complete, " + bindingCount + " bindings across all maps") end
End

// ---------------------------------------------------------
// BUILD LFO BIND LINES (v2)
// Populates LFOBind_Lines with the head-line-only display of every
// binding for a given LFO, grouped by map. Called from
// RefreshLFOInspector() in EDIT state.
//
// For active-map bindings, the head line uses Link_* arrays (the
// same pattern as CtrlInfo_Lines at ~line 3154). For inactive-map
// bindings, the raw Macro<N> = ... line is re-parsed verbatim to
// extract the first target without touching plugin state.
// ---------------------------------------------------------
Function BuildLFOBindLines(lfoIdx : Integer)
   var i, j, mapIdx, macroSlot, firstTargetLink : Integer
   var currentMapIdx : Integer = -1
   var hwStr, headLine, rawLine, valuePart, firstEntry, realName, valStr : String
   var vMin, vMax : Integer
   var eqPos, pipePos, lfoPipePos : Integer
   var sortedBinding : Integer Array
   var b, b2, tmp : Integer

   LFOBind_Lines = []

   if lfoIdx < 0 or lfoIdx >= Size(LFO_Names) then
       // Defensive — caller should not pass invalid index
       if DebugMode then Trace("LFO v2: BuildLFOBindLines called with invalid lfoIdx=" + lfoIdx) end
   else
       LFOBind_Lines <-- "--- LFO BINDINGS: " + LFO_Names[lfoIdx] + " ---"

       // Collect bindings for this LFO, sorted by (mapIdx, macroSlot)
       sortedBinding = []
       For i = 0; i < Size(LFO_Usage_LfoIdx); i = i + 1 Do
          if LFO_Usage_LfoIdx[i] == lfoIdx then sortedBinding <-- i end
       End

       // Bubble-sort by (mapIdx, macroSlot) — binding counts are tiny
       For b = 0; b < Size(sortedBinding); b = b + 1 Do
          For b2 = b + 1; b2 < Size(sortedBinding); b2 = b2 + 1 Do
             if LFO_Usage_MapIdx[sortedBinding[b]] > LFO_Usage_MapIdx[sortedBinding[b2]] then
                 tmp = sortedBinding[b]; sortedBinding[b] = sortedBinding[b2]; sortedBinding[b2] = tmp
             elsif LFO_Usage_MapIdx[sortedBinding[b]] == LFO_Usage_MapIdx[sortedBinding[b2]] then
                 if LFO_Usage_MacroIdx[sortedBinding[b]] > LFO_Usage_MacroIdx[sortedBinding[b2]] then
                     tmp = sortedBinding[b]; sortedBinding[b] = sortedBinding[b2]; sortedBinding[b2] = tmp
                 end
             end
          End
       End

       // Emit grouped head lines
       For i = 0; i < Size(sortedBinding); i = i + 1 Do
          j = sortedBinding[i]
          mapIdx = LFO_Usage_MapIdx[j]
          macroSlot = LFO_Usage_MacroIdx[j]

          if mapIdx != currentMapIdx then
              LFOBind_Lines <-- "[Map: " + CtrlMapList[mapIdx] + "]"
              currentMapIdx = mapIdx
          end

          hwStr = GetAssignedHWString(macroSlot)

          // Active-map vs inactive-map
          if CtrlMapList[mapIdx] == CurrentCtrlMapName then
              // Active map: look up first Link_* for this macro slot
              firstTargetLink = -1
              For b = 0; b < Link_Count; b = b + 1 Do
                 if Link_Active[b] and Link_SourceIdx[b] == macroSlot and firstTargetLink == -1 then
                     firstTargetLink = b
                 end
              End

              if firstTargetLink >= 0 then
                  realName = Link_ExpectedName[firstTargetLink]
                  if realName == "" then realName = "Param " + Link_TargetParam[firstTargetLink] end
                  vMin = Round(Link_MinVal[firstTargetLink] * 100.0)
                  vMax = Round(Link_MaxVal[firstTargetLink] * 100.0)
                  if vMin != 0 or vMax != 100 then valStr = " {" + vMin + "%-" + vMax + "%}" else valStr = "" end
                  headLine = "  Macro " + (macroSlot + 1) + hwStr + ": " + Link_BlockName[firstTargetLink] + ":" + realName + valStr
              else
                  headLine = "  Macro " + (macroSlot + 1) + hwStr + ": (no target)"
              end
          else
              // Inactive map: re-parse raw line, extract first non-LFO |-entry
              rawLine = LFO_Usage_RawLine[j]
              eqPos = IndexOfSubstring(rawLine, "=", false)
              valuePart = ""
              if eqPos >= 0 then
                  valuePart = TrimString(CopySubstring(rawLine, eqPos + 1, Length(rawLine) - (eqPos + 1)))
              end

              // Strip leading LFO:<Name> | prefix
              lfoPipePos = IndexOfSubstring(valuePart, "|", false)
              if lfoPipePos >= 0 then
                  valuePart = TrimString(CopySubstring(valuePart, lfoPipePos + 1, Length(valuePart) - (lfoPipePos + 1)))
              else
                  valuePart = ""
              end

              // Take first |-entry after the LFO prefix
              pipePos = IndexOfSubstring(valuePart, "|", false)
              if pipePos >= 0 then
                  firstEntry = TrimString(CopySubstring(valuePart, 0, pipePos))
              else
                  firstEntry = valuePart
              end

              if firstEntry == "" then
                  headLine = "  Macro " + (macroSlot + 1) + hwStr + ": (no target)"
              else
                  headLine = "  Macro " + (macroSlot + 1) + hwStr + ": " + firstEntry
              end
          end

          LFOBind_Lines <-- headLine
       End

       if DebugMode then Trace("LFO v2: BuildLFOBindLines built " + Size(LFOBind_Lines) + " lines for '" + LFO_Names[lfoIdx] + "'") end
   end
End

// ---------------------------------------------------------
// REFRESH LFO BOUND MACRO DISPLAY (v2)
// Paginates LFOBind_Lines through SLD_LFOBoundMacro into
// LBL_LFO_BoundMacro. Mirrors RefreshLooperConfigDisplay at ~4043.
//
// Two-phase display:
//   Phase 1 (flash active):   show ONLY the flash message, no list.
//   Phase 2 (flash expired):  show the bindings list, no flash.
//
// Transition from phase 1 to phase 2 is driven by On TimerTick which
// polls LFOFlashTimer and calls this function once the timer expires.
// ---------------------------------------------------------
Function RefreshLFOBoundMacroDisplay()
   var scrollVal : Double = 0.0
   var totalLines, displayLines, maxStart, startIdx, i : Integer
   var finalText : String = ""

   displayLines = 10   // Adjust to the LBL_LFO_BoundMacro widget's line capacity

   // Phase 1: flash message exclusive
   if LFOFlashTimer > 0.0 and TimeSinceStartup() < LFOFlashTimer then
       finalText = NEW_LINE + NEW_LINE + "    *** " + LFOFlashMsg + " ***"
       SetWidgetLabel(LBL_LFO_BoundMacro, finalText)
   else
       // Timer expired — clear stale flash state (safe to run even when
       // already cleared; the On TimerTick poller may have cleared it).
       if LFOFlashTimer > 0.0 then
           LFOFlashTimer = 0.0
           LFOFlashMsg = ""
       end

       // Phase 2: bindings list
       scrollVal = GetWidgetValue(SLD_LFOBoundMacro)
       totalLines = Size(LFOBind_Lines)
       maxStart = totalLines - displayLines
       if maxStart < 0 then maxStart = 0 end
       startIdx = Round((1.0 - scrollVal) * IntToFloat(maxStart))

       For i = 0; i < displayLines; i = i + 1 Do
          if (startIdx + i) < totalLines then
              finalText = finalText + LFOBind_Lines[startIdx + i] + NEW_LINE
          end
       End

       SetWidgetLabel(LBL_LFO_BoundMacro, finalText)
   end
End

// ---------------------------------------------------------
// SAVE LFO CONFIG
// Writes the in-memory registry back to LFOConfig.txt. Called from
// BTN_LFO_Save and BTN_LFO_Delete.
// ---------------------------------------------------------
Function SaveLFOConfig()
   var content : String = ""
   var i : Integer
   var saved : Boolean = false
   content = "; LFO Configurations (auto-generated by BTN_LFO_Save)" + NEW_LINE + NEW_LINE
   For i = 0; i < Size(LFO_Names); i = i + 1 Do
       content = content + "[LFO:" + LFO_Names[i] + "]" + NEW_LINE
       content = content + "Type   = " + LFOTypeName(LFO_Types[i]) + NEW_LINE
       content = content + "Rate   = " + LFORateName(LFO_Rates[i]) + NEW_LINE
       content = content + "Cycles = " + LFOCyclesName(LFO_Cycles[i]) + NEW_LINE
       content = content + NEW_LINE
   End
   saved = SaveStringToTextFile(LFOConfigFilePath, content)
   if DebugMode then Trace("LFO: wrote " + Size(LFO_Names) + " entries to " + LFOConfigFilePath + " (saved=" + saved + ")") end
End

// ---------------------------------------------------------
// SAMPLE LFO WAVEFORM
// Pure function: given a type index 0..5 and a phase 0..1, return
// a sample in 0..1. Used by TickLFOs every tick.
// ---------------------------------------------------------
Function SampleLFOWaveform(typeIdx : Integer, phase : Double) Returns Double
   var p : Double = 0.0
   p = phase
   if p < 0.0 then p = 0.0 end
   if p > 1.0 then p = p - Floor(p) end

   if typeIdx == 0 then
       if p < 0.5 then result = p * 2.0
       else result = 2.0 - (p * 2.0) end
   elsif typeIdx == 1 then
       result = p
   elsif typeIdx == 2 then
       result = 1.0 - p
   elsif typeIdx == 3 then
       result = (Sin(p * 2.0 * 3.14159265) + 1.0) / 2.0
   elsif typeIdx == 4 then
       if p < 0.5 then result = 0.0 else result = 1.0 end
   elsif typeIdx == 5 then
       result = Random()
   else
       result = 0.0
   end
End

// ---------------------------------------------------------
// LFO RUNTIME — start, stop, per-tick advance
// ---------------------------------------------------------

Function StartLFO(slot : Integer)
   var lfoIdx : Integer
   if slot < 0 or slot >= MAX_MACROS then
       // ignore
   else
       lfoIdx = LFO_ByMacro[slot]
       if lfoIdx < 0 then
           // nothing bound
       else
           LFO_PreValue[slot] = GetParameter(ExternalArranger, slot)
           LFO_StartTime[slot] = TimeSinceStartup()
           LFO_CyclesLeftI[slot] = LFO_Cycles[lfoIdx]
           LFO_Active[slot] = true
           LFO_LastSample[slot] = LFO_PreValue[slot]
           LFO_Progress[slot] = 0.0
           if DebugMode then Trace("LFO: StartLFO slot " + slot + " (" + LFO_Names[lfoIdx] + ", preVal=" + LFO_PreValue[slot] + ")") end
       end
   end
End

Function StopLFO(slot : Integer)
   if slot < 0 or slot >= MAX_MACROS then
       // ignore
   elsif not LFO_Active[slot] then
       // nothing to do
   else
       LFO_Active[slot] = false
       ScriptWrite_ExpectedPrev[slot] = ScriptWrite_Expected[slot]
       ScriptWrite_Expected[slot] = LFO_PreValue[slot]
       SetParameter(ExternalArranger, slot, LFO_PreValue[slot])
       LFO_LastSample[slot] = LFO_PreValue[slot]
       LFO_Progress[slot] = 0.0
       // Reset meters so they don't freeze on the last-tick value
       SetWidgetValue(METER_LFO_H, 0.0)
       SetWidgetValue(METER_LFO_V, 0.0)
       // Release the Run button visually. The release-callback checks
       // LFO_Active (already false) and LFO_Draft_Running (false), so
       // it no-ops and does not re-enter StopLFO.
       SetWidgetValue(BTN_LFO_Run, 0.0)
       if DebugMode then
           Trace("METER: METER_LFO_H <- 0.0 (StopLFO slot=" + slot + ")")
           Trace("METER: METER_LFO_V <- 0.0 (StopLFO slot=" + slot + ")")
           Trace("LFO: StopLFO slot " + slot + " (snapped back to " + LFO_PreValue[slot] + ")")
       end
   end
End

// ---------------------------------------------------------
// HARD-STOP ALL LFOs — emergency kill switch for critical
// transitions (song change, map load, rackspace switch).
//
// Unlike StopLFO(slot) this does NOT do a snap-back write to
// ExternalArranger: the caller is about to reload song state
// anyway, so GetParameter/SetParameter of the old pre-value
// would either conflict with the new load or write stale data.
// We just kill the runtime flags so TickLFOs stops emitting
// samples on its next tick.
//
// Call this BEFORE LoadControllerMap, BEFORE SongText loads,
// BEFORE any mass rewrite of LFO_ByMacro[] bindings. If an
// LFO is running on a slot whose binding is about to change
// and we don't hard-stop, TickLFOs will keep writing samples
// with the new lfoIdx (or no lfoIdx at all) and potentially
// collide with the song-load sync writes.
// ---------------------------------------------------------
Function HardStopAllLFOs(reason : String)
   var slot : Integer
   var stoppedCount : Integer = 0

   For slot = 0; slot < MAX_MACROS; slot = slot + 1 Do
       if LFO_Active[slot] then
           LFO_Active[slot]     = false
           LFO_LastSample[slot] = 0.0
           LFO_Progress[slot]   = 0.0
           stoppedCount = stoppedCount + 1
       end
   End

   if LFO_Draft_Running then
       LFO_Draft_Running = false
       LFO_Draft_Slot    = -1
       stoppedCount = stoppedCount + 1
   end

   if stoppedCount > 0 then
       // Reset UI. BTN_LFO_Run callback checks LFO_Active/Draft flags
       // first — since we've already cleared them, the release handler
       // will no-op gracefully.
       SetWidgetValue(BTN_LFO_Run, 0.0)
       SetWidgetValue(METER_LFO_H, 0.0)
       SetWidgetValue(METER_LFO_V, 0.0)
       if DebugMode then
           Trace("METER: METER_LFO_H <- 0.0 (HardStop)")
           Trace("METER: METER_LFO_V <- 0.0 (HardStop)")
           Trace("LFO: HardStop killed " + stoppedCount + " active LFO(s) — reason: " + reason)
       end
   end
End

Function TickLFOs()
   var slot, lfoIdx, beatsPerBar, cyclesDone : Integer
   var elapsedMS, cycleLenMS, phase, sample, bpm, totalBars, elapsedBars, vMeter : Double = 0.0

   // EMERGENCY BRAKE — if the Trace() watchdog tripped the kill switch,
   // stop emitting LFO samples. Idempotent HardStopAllLFOs kills any
   // still-active instances on the first pass, subsequent passes are
   // cheap no-ops until the auto-recovery in On TimerTick clears the
   // flag.
   if EmergencyKillSwitch then
       HardStopAllLFOs("emergency kill switch")
   else

   bpm = GetBPM()
   if bpm < 1.0 then bpm = 120.0 end
   beatsPerBar = GetTimeSigNumerator()
   if beatsPerBar <= 0 then beatsPerBar = 4 end

   // v2: DRAFT PREVIEW — single global slot driven by BTN_LFO_Run in DRAFT
   if LFO_Draft_Running and LFO_Draft_Slot >= 0 and LFO_Draft_Slot < MAX_MACROS then
       elapsedMS = TimeSinceStartup() - LFO_Draft_StartTime
       cycleLenMS = (60000.0 / bpm) * IntToFloat(beatsPerBar) * LFORateBars(LFO_Draft_Rate)
       if cycleLenMS < 1.0 then cycleLenMS = 1.0 end
       phase = (elapsedMS / cycleLenMS) - Floor(elapsedMS / cycleLenMS)
       sample = SampleLFOWaveform(LFO_Draft_Type, phase)

       // V meter = progress toward finite end. For Infinite draft, stay
       // flat at 0 (no "end" to progress toward).
       if LFO_Draft_Cycles < 0 then
           vMeter = 0.0
       else
           totalBars = LFORateBars(LFO_Draft_Rate) * IntToFloat(LFO_Draft_Cycles)
           elapsedBars = (elapsedMS / cycleLenMS) * LFORateBars(LFO_Draft_Rate)
           if totalBars > 0.0 then vMeter = elapsedBars / totalBars
           else vMeter = 0.0 end
           if vMeter > 1.0 then vMeter = 1.0 end
       end

       ScriptWrite_ExpectedPrev[LFO_Draft_Slot] = ScriptWrite_Expected[LFO_Draft_Slot]
       ScriptWrite_Expected[LFO_Draft_Slot] = sample
       SetParameter(ExternalArranger, LFO_Draft_Slot, sample)
       SetWidgetValue(METER_LFO_H, sample)
       SetWidgetValue(METER_LFO_V, vMeter)
       if DebugMode then
           Trace("METER: METER_LFO_H <- " + sample + " (draft tick, slot=" + LFO_Draft_Slot + ")")
           Trace("METER: METER_LFO_V <- " + vMeter + " (draft tick, cycles=" + LFO_Draft_Cycles + ")")
       end
   end

   For slot = 0; slot < MAX_MACROS; slot = slot + 1 Do
       if LFO_Active[slot] then
           lfoIdx = LFO_ByMacro[slot]
           if lfoIdx < 0 then
               LFO_Active[slot] = false
           else
               elapsedMS = TimeSinceStartup() - LFO_StartTime[slot]
               cycleLenMS = (60000.0 / bpm) * IntToFloat(beatsPerBar) * LFORateBars(LFO_Rates[lfoIdx])
               if cycleLenMS < 1.0 then cycleLenMS = 1.0 end

               phase = (elapsedMS / cycleLenMS) - Floor(elapsedMS / cycleLenMS)
               sample = SampleLFOWaveform(LFO_Types[lfoIdx], phase)

               // Compute V-meter progress for THIS tick (was lagging
               // one tick behind before). For Infinite cycles there is
               // no "end" to progress toward — freeze at 0.
               if LFO_CyclesLeftI[slot] < 0 then
                   LFO_Progress[slot] = 0.0
               else
                   totalBars = LFORateBars(LFO_Rates[lfoIdx]) * IntToFloat(LFO_CyclesLeftI[slot])
                   elapsedBars = (elapsedMS / cycleLenMS) * LFORateBars(LFO_Rates[lfoIdx])
                   if totalBars > 0.0 then LFO_Progress[slot] = elapsedBars / totalBars
                   else LFO_Progress[slot] = 0.0 end
                   if LFO_Progress[slot] > 1.0 then LFO_Progress[slot] = 1.0 end
               end

               ScriptWrite_ExpectedPrev[slot] = ScriptWrite_Expected[slot]
               ScriptWrite_Expected[slot] = sample
               SetParameter(ExternalArranger, slot, sample)
               LFO_LastSample[slot] = sample
               SetWidgetValue(METER_LFO_H, sample)
               SetWidgetValue(METER_LFO_V, LFO_Progress[slot])
               if DebugMode then
                   Trace("METER: METER_LFO_H <- " + sample + " (tick, slot=" + slot + ")")
                   Trace("METER: METER_LFO_V <- " + LFO_Progress[slot] + " (tick, cyclesLeft=" + LFO_CyclesLeftI[slot] + ")")
               end

               // Cycle-done check for finite LFOs
               if LFO_CyclesLeftI[slot] >= 0 then
                   cyclesDone = Floor(elapsedMS / cycleLenMS)
                   if cyclesDone >= LFO_CyclesLeftI[slot] then
                       StopLFO(slot)
                   end
               end
           end
       end
   End
   end // end of "if EmergencyKillSwitch then ... else ..."
End

// ---------------------------------------------------------
// REFRESH LFO INSPECTOR (v2)
// Scope-driven state machine. The displayed LFO is a pure function
// of CurrentEditScope and the registry / LFO_ByMacro state.
//
// Five states:
//   LOCKED          — scope is -1 or >= 50 (not a user macro)
//   EDIT            — scope has a real LFO bound (LFO_ByMacro[slot] >= 0)
//   DRAFT_EXISTING  — scope has no LFO, but draft-name already in registry
//                     (auto-adopt that entry's Type/Rate/Cycles + show its
//                      existing bindings; a Save click adds this scope as
//                      an additional binding to the same LFO)
//   DRAFT_STANDARD  — scope has no LFO, draft-name is new, [LFO:Standard]
//                     exists (adopt the Standard template)
//   DRAFT_FALLBACK  — scope has no LFO, draft-name is new, no
//                     [LFO:Standard] (hardcoded Triangle / 1/4 / Infinite)
// ---------------------------------------------------------
Function RefreshLFOInspector()
   var scopeSlot, lfoIdx, standardIdx, existingIdx, i, boundSlot : Integer
   var songNameForDraft : String = ""

   scopeSlot = CurrentEditScope
   lfoIdx = -1

   // Meter reset on every inspector refresh. If an LFO is actively
   // running, the next TickLFOs pass (max 100ms) will overwrite the
   // meters with fresh sample/progress values. If nothing is running,
   // the meters stay flat at 0 — which is exactly what the user wants
   // ("when no LFO is running, meters should show 0").
   SetWidgetValue(METER_LFO_H, 0.0)
   SetWidgetValue(METER_LFO_V, 0.0)
   if DebugMode then
       Trace("METER: METER_LFO_H <- 0.0 (inspector refresh)")
       Trace("METER: METER_LFO_V <- 0.0 (inspector refresh)")
   end

   if scopeSlot < 0 or scopeSlot >= 50 then
       // LOCKED state
       SetWidgetLabel(LBL_LFO, "-")
       SetWidgetLabel(LBL_LFO_Type, "-")
       SetWidgetLabel(LBL_LFO_Rate, "-")
       SetWidgetLabel(LBL_LFO_Cycles, "-")
       LFOBind_Lines = []
       LFOBind_Lines <-- "Only User Macros allowed (scope 1-50)"
       LFO_Draft_Active = false
       if DebugMode then
           Trace("LFO v2: inspector LOCKED (scope=" + scopeSlot + ")")
       end
   else
       lfoIdx = LFO_ByMacro[scopeSlot]

       if lfoIdx >= 0 then
           // EDIT state
           LFO_Draft_Active = false
           SetWidgetLabel(LBL_LFO, LFO_Names[lfoIdx])
           SetWidgetLabel(LBL_LFO_Type, LFOTypeName(LFO_Types[lfoIdx]))
           SetWidgetLabel(LBL_LFO_Rate, LFORateName(LFO_Rates[lfoIdx]))
           SetWidgetLabel(LBL_LFO_Cycles, LFOCyclesName(LFO_Cycles[lfoIdx]))
           BuildLFOBindLines(lfoIdx)
           if DebugMode then Trace("LFO v2: inspector EDIT (slot=" + (scopeSlot+1) + " lfo='" + LFO_Names[lfoIdx] + "')") end
       else
           // DRAFT state — resolve draft name first, then decide which
           // sub-state applies (DRAFT_EXISTING vs DRAFT_STANDARD vs
           // DRAFT_FALLBACK).
           LFO_Draft_Active = true

           // Resolve draft name from GetCurrentSongName() — but only if
           // InSetlistMode() is true (the call crashes otherwise). Outside
           // setlist view, show a placeholder; BTN_LFO_Save is blocked by
           // an InSetlistMode guard at the top of its callback, so the
           // placeholder never leaks into a file.
           if InSetlistMode() then
               songNameForDraft = GetCurrentSongName()
           else
               songNameForDraft = "(Setlist View required to save)"
           end
           LFO_Draft_Name = songNameForDraft

           // 1. DRAFT_EXISTING — draft name already in registry (multi-bind path)
           existingIdx = -1
           For i = 0; i < Size(LFO_Names); i = i + 1 Do
              if LFO_Names[i] == LFO_Draft_Name then existingIdx = i end
           End

           if existingIdx >= 0 then
               LFO_Draft_Type   = LFO_Types[existingIdx]
               LFO_Draft_Rate   = LFO_Rates[existingIdx]
               LFO_Draft_Cycles = LFO_Cycles[existingIdx]
               BuildLFOBindLines(existingIdx)
               if DebugMode then Trace("LFO v2: inspector DRAFT_EXISTING (slot=" + (scopeSlot+1) + " name='" + LFO_Draft_Name + "', Save adds scope as another binding)") end
           else
               // 2. DRAFT_STANDARD — no existing entry, look for [LFO:Standard] template
               standardIdx = -1
               For i = 0; i < Size(LFO_Names); i = i + 1 Do
                  if LFO_Names[i] == "Standard" then standardIdx = i end
               End

               if standardIdx >= 0 then
                   LFO_Draft_Type   = LFO_Types[standardIdx]
                   LFO_Draft_Rate   = LFO_Rates[standardIdx]
                   LFO_Draft_Cycles = LFO_Cycles[standardIdx]
                   if DebugMode then Trace("LFO v2: inspector DRAFT_STANDARD (slot=" + (scopeSlot+1) + " name='" + LFO_Draft_Name + "')") end
               else
                   // 3. DRAFT_FALLBACK — no entry, no Standard template
                   LFO_Draft_Type   = 0    // Triangle
                   LFO_Draft_Rate   = 5    // 1/4
                   LFO_Draft_Cycles = -1   // Infinite
                   if DebugMode then Trace("LFO v2: inspector DRAFT_FALLBACK (slot=" + (scopeSlot+1) + " name='" + LFO_Draft_Name + "')") end
               end

               LFOBind_Lines = []
               LFOBind_Lines <-- "(draft - click Save to create this LFO and bind it to Macro " + (scopeSlot + 1) + ")"
           end

           SetWidgetLabel(LBL_LFO, LFO_Draft_Name)
           SetWidgetLabel(LBL_LFO_Type, LFOTypeName(LFO_Draft_Type))
           SetWidgetLabel(LBL_LFO_Rate, LFORateName(LFO_Draft_Rate))
           SetWidgetLabel(LBL_LFO_Cycles, LFOCyclesName(LFO_Draft_Cycles))
       end
   end

   RefreshLFOBoundMacroDisplay()
End

// ---------------------------------------------------------
// ARRANGER MAPPING FILE HANDLER
// ---------------------------------------------------------

Function LoadMappingFile()
   var sep, content : String
   var lines, parts : String Array
   var i : Integer
   var saved : Boolean 
   
   if IndexOfSubstring(UserSnapshotPath, "\\", false) > -1 Then sep = "\\" Else sep = "/" End
   MappingFilePath = UserSnapshotPath + sep + "GenosMapping.txt"
   
   Trace("ARRANGER FILE DEBUG: Full Path is -> " + MappingFilePath)
   
   Mapping_SysEx = []
   Mapping_GPSong = []
   
   if FileExists(MappingFilePath) then
       content = LoadStringFromTextFile(MappingFilePath)
       lines = SplitString(content, NEW_LINE)
       
       For i = 0; i < Size(lines); i=i+1 do
           if Length(TrimString(lines[i])) > 5 and IndexOfSubstring(lines[i], ";", false) > -1 then
               parts = SplitString(lines[i], ";")
               if Size(parts) >= 3 then
                   Mapping_SysEx <-- TrimString(parts[0])
                   Mapping_GPSong <-- TrimString(parts[2])
               end
           end
       end
       Trace("ARRANGER: Loaded " + Size(Mapping_SysEx) + " mappings.")
   else
       Trace("ARRANGER: File not found. Attempting to create new file...")
       saved = SaveStringToTextFile(MappingFilePath, "; Arranger Mapping File" + NEW_LINE + "; SysEx ; DecodedName ; GPSongName" + NEW_LINE)
       
       if saved then 
           Trace("ARRANGER: SUCCESS! New file created.")
       else
           Trace("ARRANGER: ERROR! Could not create file. Check if Folder 'Snapshots' exists!")
       end
   end
End

Function AppendToMappingFile(hexCode : String, rawName : String, gpSong : String)
   var line : String 
   var currentContent : String = ""
   var saveOK : Boolean 
   
   line = hexCode + " ; " + rawName + " ; " + gpSong + NEW_LINE
   
   if FileExists(MappingFilePath) then 
      currentContent = LoadStringFromTextFile(MappingFilePath) 
   end
   
   currentContent = currentContent + line
   
   saveOK = SaveStringToTextFile(MappingFilePath, currentContent)
   
   if saveOK then
       Trace("ARRANGER: Write Success to file.")
   else
       Trace("ARRANGER: WRITE FAILED! Could not save to: " + MappingFilePath)
   end
End

Function AddNewMapping(hex : String, gpSong : String, rawName : String)
   Mapping_SysEx <-- hex
   Mapping_GPSong <-- gpSong
   AppendToMappingFile(hex, rawName, gpSong)
   Trace("ARRANGER: Mapped New -> " + rawName + " = " + gpSong)
End

// ---------------------------------------------------------
// GET DYNAMIC STANDARD CONTROLLER MAP
// ---------------------------------------------------------
Function GetDynamicStandardMap() Returns String
    var i, activeCount, lastActiveIdx : Integer
    activeCount = 0
    lastActiveIdx = -1
    
    // Count active VSTs directly via plugin status
    For i = 0; i < MAX_VSTS; i = i + 1 Do
        // IsPluginBypassed == false means: Plugin is ON!
        if IsPluginBypassed(BLK_VST[i]) == false then
            activeCount = activeCount + 1
            lastActiveIdx = i
        end
    End
    
    // Decision logic
    if activeCount == 1 then
        // Only one VST is active -> Load Map: Standard_VSTx
        result = "Standard_VST" + IntToString(lastActiveIdx + 1)
    else
        // Multiple or none active -> Load Map: Standard
        result = "Standard"
    end
    
    Trace("Dynamic Map Check: Found " + activeCount + " active VSTs. Result: " + result)
End

// ---------------------------------------------------------
// VALIDATION LOGIC (FINGERPRINTING)
// ---------------------------------------------------------

Function ValidateMapping() Returns Boolean
   var i : Integer
   var realName : String
   var isValid : Boolean = true
   var mismatchDetails : String = ""
   var linkOk : Boolean

   For i = 0; i < Link_Count; i = i + 1 Do
      if Link_Active[i] then
         linkOk = true
         
         // Only check when it is NOT a CC and we expect a name
         if Link_IsCC[i] == false and Length(Link_ExpectedName[i]) > 0 then
             
             realName = ""
             if Link_Type[i] == 0 then realName = GetParameterName(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i])
             elsif Link_Type[i] == 1 then realName = GetParameterName(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i])
             elsif Link_Type[i] == 2 then realName = GetParameterName(AudioMixer, Link_TargetParam[i])
             end
             
             // Comparison (case insensitive)
             if realName != "" and TrimString(realName) != TrimString(Link_ExpectedName[i]) then
                 linkOk = false
                 isValid = false
                 mismatchDetails = mismatchDetails + "Link " + i + ": Mismatch! Exp='" + Link_ExpectedName[i] + "' Got='" + realName + "'" + NEW_LINE
             end
         end
         
         // Emergency stop on error
         if linkOk == false then
             Link_Active[i] = false
             Trace("SAFETY CUT: Link " + i + " disabled!")
         end
      end
   End
   
   if not isValid then
       Trace("VALIDATION FAILED:" + NEW_LINE + mismatchDetails)
   end
   
   result = isValid
End


// ============================================================================
// SECTION 17: CONTROLLER MAP ENGINE
// ============================================================================

// ---------------------------------------------------------
// SYSTEM ACTION HELPERS
// (moved above LoadControllerMap so the parser can resolve calls to
//  ResetSysActionBindings / SysActIdx from inside LoadControllerMap.)
// ---------------------------------------------------------
Function SysActIdx(name : String) Returns Integer
   var i, res : Integer
   res = -1
   For i = 0; i < Size(SysAction_Names); i = i + 1 Do
      if SysAction_Names[i] == name then res = i end
   End
   result = res
End

Function ResetSysActionBindings()
   var i : Integer
   For i = 0; i < MAX_MACROS; i = i + 1 Do SysAction_ByMacro[i] = -1 End
   For i = 0; i < 128; i = i + 1 Do SysAction_ByCC[i] = -1 End
End

Function IsSystemActionMacro(paramIdx : Integer) Returns Boolean
   var res : Boolean = false
   if paramIdx >= 0 and paramIdx < MAX_MACROS then
      res = SysAction_ByMacro[paramIdx] > -1
   end
   result = res
End

// --- Unified ControllerMap Loader ---

// Copies all Def_Mac_* arrays into Mac_* (active) arrays
Function CloneDefaultToActive()
   var m, s, l, b, fi : Integer
   For m = 1; m <= MAX_MACROS; m = m + 1 Do
      Mac_SourceCount[m] = Def_Mac_SourceCount[m]
      For s = 0; s < MAX_SOURCES_PER_MACRO; s = s + 1 Do
         Mac_SourceDev[MacSourceIdx(m, s)] = Def_Mac_SourceDev[MacSourceIdx(m, s)]
         Mac_SourceType[MacSourceIdx(m, s)] = Def_Mac_SourceType[MacSourceIdx(m, s)]
         Mac_SourceCtrl[MacSourceIdx(m, s)] = Def_Mac_SourceCtrl[MacSourceIdx(m, s)]
      End
      For l = 0; l < MAX_LAYERS; l = l + 1 Do
         Mac_Layer_BindCount[MacLayerIdx(m, l)] = Def_Mac_Layer_BindCount[MacLayerIdx(m, l)]
         For b = 0; b < MAX_BINDINGS_PER_LAYER; b = b + 1 Do
            fi = MacLayerBindIdx(m, l, b)
            Mac_Layer_TargetType[fi] = Def_Mac_Layer_TargetType[fi]
            Mac_Layer_Target[fi] = Def_Mac_Layer_Target[fi]
            Mac_Layer_RangeMin[fi] = Def_Mac_Layer_RangeMin[fi]
            Mac_Layer_RangeMax[fi] = Def_Mac_Layer_RangeMax[fi]
            Mac_Layer_Channel[fi] = Def_Mac_Layer_Channel[fi]
            Mac_Layer_VSTIdx[fi] = Def_Mac_Layer_VSTIdx[fi]
            Mac_Layer_ParamIdx[fi] = Def_Mac_Layer_ParamIdx[fi]
            Mac_Layer_ParamLabel[fi] = Def_Mac_Layer_ParamLabel[fi]
         End
      End
   End
   // Clone VST declarations
   For m = 0; m < MAX_VST_DECL; m = m + 1 Do
      MapVST_Name[m] = DefMapVST_Name[m]
   End
End

// Validates declared VSTs against loaded plugins
Function ValidateMapVSTs()
   var v : Integer; var loadedName : String
   For v = 1; v < MAX_VST_DECL; v = v + 1 Do
      if Length(MapVST_Name[v]) > 0 then
         if MapVST_Name[v] == "*" then
            MapVST_Valid[v] = 1  // wildcard = always valid
         else
            if v <= MAX_VSTS then
               loadedName = GetPluginInfo(BLK_VST[v], 0)
            else
               loadedName = ""
            end
            if Length(loadedName) == 0 then
               MapVST_Valid[v] = 3  // not loaded
            elsif loadedName == MapVST_Name[v] then
               MapVST_Valid[v] = 1  // valid match
            else
               MapVST_Valid[v] = 2  // mismatch
            end
         end
      else
         MapVST_Valid[v] = 0  // not declared
      end
   End
End

// Rebuilds CC and SysAction reverse lookups from active Mac_* arrays
Function RebuildReverseLookups()
   var m, b, fi, lookupIdx, bindCount, actionIdx, srcCount, devIdx, ctrlIdx, physCC, physCh : Integer
   var actionName, srcType : String

   // Clear reverse lookups
   For m = 0; m < 2048; m = m + 1 Do
      Mac_ReverseLookup_CC[m] = -1
   End
   For m = 0; m <= MAX_MACROS; m = m + 1 Do
      Mac_ReverseLookup_SysAct[m] = -1
   End

   // Build SysAction lookup from LAY0 bindings (isolation rule: must be sole binding)
   For m = 1; m <= MAX_MACROS; m = m + 1 Do
      bindCount = Mac_Layer_BindCount[MacLayerIdx(m, 0)]
      if bindCount == 1 then
         fi = MacLayerBindIdx(m, 0, 0)
         if Mac_Layer_TargetType[fi] == "SYSACT" then
            actionName = Mac_Layer_Target[fi]
            if IndexOfSubstring(actionName, "SYSACT_", false) == 0 then
               actionName = CopySubstring(actionName, 7, Length(actionName) - 7)
            end
            actionIdx = SysActIdx(actionName)
            if actionIdx >= 0 then
               Mac_ReverseLookup_SysAct[m] = actionIdx
            end
         end
      end
   End

   // Build source-to-macro CC lookup
   For m = 1; m <= MAX_MACROS; m = m + 1 Do
      srcCount = Mac_SourceCount[m]
      For b = 0; b < srcCount; b = b + 1 Do
         devIdx = Mac_SourceDev[MacSourceIdx(m, b)]
         srcType = Mac_SourceType[MacSourceIdx(m, b)]
         ctrlIdx = Mac_SourceCtrl[MacSourceIdx(m, b)]
         physCC = ResolveControlCC(devIdx, srcType, ctrlIdx)
         physCh = ResolveControlChannel(devIdx, srcType, ctrlIdx)
         if physCC >= 0 and physCh >= 0 then
            lookupIdx = physCh * 128 + physCC
            if lookupIdx >= 0 and lookupIdx < 2048 then
               Mac_ReverseLookup_CC[lookupIdx] = m
            end
         end
      End
   End
End

// Main entry: loads Default on first call, song delta on subsequent calls
Function LoadControllerMap(mapName : String)
   var content, line, trimmedLine, currentMap : String
   var lines : String Array
   var i, eqPos, closeBracket, vstDeclIdx, vstDeclIdx2 : Integer; var key, val : String
   var inDefaultMap, inTargetMap, isFirstLoad : Boolean
   var savedEditScope, dbIdx : Integer
   var ctrlMapFilePath : String

   savedEditScope = CurrentEditScope
   ctrlMapFilePath = UserSnapshotPath + "/ControllerMaps.txt"

   if mapName == "DEFAULT_INIT" then
      isFirstLoad = true
   else
      isFirstLoad = false
      CloneDefaultToActive()
   end

   if FileExists(ctrlMapFilePath) then
      content = LoadStringFromTextFile(ctrlMapFilePath)
      lines = SplitString(content, NEW_LINE)
      inDefaultMap = false
      inTargetMap = false
      currentMap = ""

      For i = 0; i < Size(lines); i = i + 1 Do
         trimmedLine = TrimString(lines[i])

         if Length(trimmedLine) > 0 and IndexOfSubstring(trimmedLine, ";", false) <> 0 then

            // Section header
            if IndexOfSubstring(trimmedLine, "[Map:Default]", false) == 0 then
               inDefaultMap = true
               inTargetMap = false
               currentMap = "Default"

            elsif IndexOfSubstring(trimmedLine, "[Map:", false) == 0 then
               closeBracket = IndexOfSubstring(trimmedLine, "]", false)
               currentMap = CopySubstring(trimmedLine, 5, closeBracket - 5)
               inDefaultMap = false
               if not isFirstLoad and currentMap == mapName then
                  inTargetMap = true
               else
                  inTargetMap = false
               end

            // Content lines
            elsif inDefaultMap and isFirstLoad then
               eqPos = IndexOfSubstring(trimmedLine, "=", false)
               if eqPos > 0 then
                  key = TrimString(CopySubstring(trimmedLine, 0, eqPos))
                  val = TrimString(CopySubstring(trimmedLine, eqPos + 1, Length(trimmedLine) - eqPos - 1))
                  // VST declarations
                  if IndexOfSubstring(key, "VST", false) == 0 and IndexOfSubstring(key, "Macro", false) <> 0 then
                     vstDeclIdx = StringToInt(CopySubstring(key, 3, Length(key) - 3))
                     if vstDeclIdx >= 1 and vstDeclIdx < MAX_VST_DECL then
                        DefMapVST_Name[vstDeclIdx] = val
                     end
                  // Macro lines
                  elsif IndexOfSubstring(key, "Macro", false) == 0 then
                     ParseMacroLine(trimmedLine, true)
                  end
               end

            elsif inTargetMap and not isFirstLoad then
               eqPos = IndexOfSubstring(trimmedLine, "=", false)
               if eqPos > 0 then
                  key = TrimString(CopySubstring(trimmedLine, 0, eqPos))
                  val = TrimString(CopySubstring(trimmedLine, eqPos + 1, Length(trimmedLine) - eqPos - 1))
                  // VST declarations (override default)
                  if IndexOfSubstring(key, "VST", false) == 0 and IndexOfSubstring(key, "Macro", false) <> 0 then
                     vstDeclIdx2 = StringToInt(CopySubstring(key, 3, Length(key) - 3))
                     if vstDeclIdx2 >= 1 and vstDeclIdx2 < MAX_VST_DECL then
                        MapVST_Name[vstDeclIdx2] = val
                     end
                  // Macro lines (per-layer merge)
                  elsif IndexOfSubstring(key, "Macro", false) == 0 then
                     ParseMacroLine(trimmedLine, false)
                  end
               end
            end
         end
      End
   else
      Trace("CTRLMAP: File not found: " + ctrlMapFilePath)
   end

   ValidateMapVSTs()
   RebuildReverseLookups()
   CurrentCtrlMapName = mapName

   // Reset debounce timers
   For dbIdx = 0; dbIdx < MAX_OVERLAY_BINDINGS; dbIdx = dbIdx + 1 Do
      Debounce_Active[dbIdx] = false
      Debounce_Timer[dbIdx] = 0.0
      Debounce_State[dbIdx] = 0
   End

   CurrentEditScope = savedEditScope

   Trace("CTRLMAP: Loaded [Map:" + mapName + "]")
End

// ---------------------------------------------------------
// SMART ADAPT: AUTO-MAP ON ISOLATION (UNIVERSAL)
// ---------------------------------------------------------
Function EvaluateSmartAdapt()
    var i, activeVSTs, targetVstIdx : Integer
    var targetMap : String = ""
    var pluginName : String = ""

    // 1. GUARD: Is the feature enabled?
    if GetWidgetValue(BTN_SmartAdapt) > 0.5 then
        
        // 2. HOW MANY VSTS ARE CURRENTLY ACTIVE? (Definitive count)
        activeVSTs = 0
        targetVstIdx = -1
        
        For i = 0; i < MAX_VSTS; i = i + 1 Do
            // IsPluginBypassed == false means the VST is ACTIVE (not bypassed)
            if not IsPluginBypassed(BLK_VST[i]) and GetPluginInfo(BLK_VST[i], 0) != "Element" then
                activeVSTs = activeVSTs + 1
                targetVstIdx = i
            end
        End

        // 3. ISOLATION ACTIVE: Exactly ONE VST is active! (regardless of mode)
        if activeVSTs == 1 then
            // Search by plugin name instead of slot number
            pluginName = GetPluginInfo(BLK_VST[targetVstIdx], 0)
            if Length(pluginName) > 0 then
               targetMap = pluginName
            else
               targetMap = "Standard_VST" + IntToString(targetVstIdx + 1)  // fallback
            end
            
            // Only switch if we are not already on this map
            if CurrentCtrlMapName != targetMap then
                
                // Save current map (but only if we are just entering solo!)
                if not IsAutoSoloMapActive then
                    PreSoloMapName = CurrentCtrlMapName
                    IsAutoSoloMapActive = true
                end
                
                Trace("SMART ADAPT: VST " + (targetVstIdx + 1) + " playing solo. Loading " + targetMap)
                LoadControllerMap(targetMap)
                
                // Slightly delay hardware sync (debounce 400ms)
                HardwareSyncTimer = TimeSinceStartup() + 400.0 
                
                OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> AUTO-MAP: " + targetMap + " <<<", Local_IP, Local_PORT)
                MacroFeedbackTimer = TimeSinceStartup() + 2000.0
            end
            
        // 4. ISOLATION INACTIVE (>1 VST active or all muted): Revert to previous map!
        else
            if IsAutoSoloMapActive then
                if PreSoloMapName != "" and PreSoloMapName != CurrentCtrlMapName then
                    Trace("SMART ADAPT: Isolation ended (" + activeVSTs + " VSTs active). Reverting to -> " + PreSoloMapName)
                    LoadControllerMap(PreSoloMapName)
                    
                    HardwareSyncTimer = TimeSinceStartup() + 400.0
                    OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> MAP RESTORED <<<", Local_IP, Local_PORT)
                    MacroFeedbackTimer = TimeSinceStartup() + 2000.0
                end
                IsAutoSoloMapActive = false
                PreSoloMapName = ""
            end
        end
        
    // 5. FEATURE DISABLED: Clean up any ghost state!
    else
        if IsAutoSoloMapActive then
            if PreSoloMapName != "" and PreSoloMapName != CurrentCtrlMapName then
                Trace("SMART ADAPT: Feature disabled. Reverting to -> " + PreSoloMapName)
                LoadControllerMap(PreSoloMapName)
                HardwareSyncTimer = TimeSinceStartup() + 400.0
            end
            IsAutoSoloMapActive = false
            PreSoloMapName = ""
        end
    end
End

Function CycleCtrlMap(direction : Integer)
    var newIdx : Integer
    
    // List empty? Scan!
    if Size(CtrlMapList) <= 1 then 
        Trace("Cycle: List empty/default. Refreshing...")
        RefreshCtrlMapList() 
    end
    
    if Size(CtrlMapList) > 0 then
        newIdx = CurrentCtrlMapIndex + direction
        
        // Wrap Around
        if newIdx < 0 then newIdx = Size(CtrlMapList) - 1
        elsif newIdx >= Size(CtrlMapList) then newIdx = 0
        end
        
        Trace("Cycle: Index " + CurrentCtrlMapIndex + " -> " + newIdx + " (" + CtrlMapList[newIdx] + ")")
        
        LoadControllerMap(CtrlMapList[newIdx])
        RecordTimelineEvent("Map", newIdx)        
        CurrentCtrlMapIndex = newIdx
    else
        Trace("Cycle: ERROR - List is still empty!")
        LBL_CtrlConfig.SetWidgetLabel("No Maps!")
    end
End

// ---------------------------------------------------------
// AUTO SWITCH MAP ON BYPASS
// ---------------------------------------------------------

// Checks whether we are in default mode
// and immediately adjusts the map to the new VST status.
Function AutoSwitchMapOnBypass()
    // Only auto-switch if the current map
    // is either "Standard" or already one of the dynamic VST maps.
    // Prevents a specifically loaded song map from being overwritten.
    if CurrentCtrlMapName == "Standard" or IndexOfSubstring(CurrentCtrlMapName, "Standard_VST", false) == 0 then
        LoadControllerMap(GetDynamicStandardMap())
    end
    
    // Always sync hardware afterwards
    SyncArrangerToCurrentMap()
End


// ============================================================================
// SECTION 19: PROMPTER & TIMELINE ENGINE
// ============================================================================

// =========================================================================
// THE ULTIMATE GUITAR WEAVER (Auto-Converter)
// =========================================================================

// Detects header lines
Function IsHeaderLine(line : String) Returns Boolean
    var tLine : String = TrimString(line)
    var isH : Boolean = false
    
    if IndexOfSubstring(tLine, "]", false) > 0 then
        if IndexOfSubstring(tLine, "[", false) == 0 then 
            isH = true
        else
            if IndexOfSubstring(tLine, "Chorus]", false) > -1 or IndexOfSubstring(tLine, "CHORUS]", false) > -1 or IndexOfSubstring(tLine, "chorus]", false) > -1 then isH = true
            elsif IndexOfSubstring(tLine, "Verse]", false) > -1 or IndexOfSubstring(tLine, "VERSE]", false) > -1 or IndexOfSubstring(tLine, "verse]", false) > -1 then isH = true
            elsif IndexOfSubstring(tLine, "Intro]", false) > -1 or IndexOfSubstring(tLine, "INTRO]", false) > -1 or IndexOfSubstring(tLine, "intro]", false) > -1 then isH = true
            elsif IndexOfSubstring(tLine, "Bridge]", false) > -1 or IndexOfSubstring(tLine, "BRIDGE]", false) > -1 or IndexOfSubstring(tLine, "bridge]", false) > -1 then isH = true
            elsif IndexOfSubstring(tLine, "Solo]", false) > -1 or IndexOfSubstring(tLine, "SOLO]", false) > -1 or IndexOfSubstring(tLine, "solo]", false) > -1 then isH = true
            elsif IndexOfSubstring(tLine, "Outro]", false) > -1 or IndexOfSubstring(tLine, "OUTRO]", false) > -1 or IndexOfSubstring(tLine, "outro]", false) > -1 then isH = true
            end
        end
    end
    result = isH
End

// Detects whether a line contains only chords
Function IsChordLine(line : String) Returns Boolean
    var words : String Array = SplitString(line, " ")
    var i, wordCount : Integer = 0
    var w, firstChar : String
    var isChord : Boolean = true
    
    // Detect whether at least one real chord appears in the line
    var hasRealChord : Boolean = false 
    
    if IndexOfSubstring(line, "Chorus", false) > -1 or IndexOfSubstring(line, "CHORUS", false) > -1 then isChord = false
    elsif IndexOfSubstring(line, "Verse", false) > -1 or IndexOfSubstring(line, "VERSE", false) > -1 then isChord = false
    elsif IndexOfSubstring(line, "Bridge", false) > -1 or IndexOfSubstring(line, "BRIDGE", false) > -1 then isChord = false
    elsif IndexOfSubstring(line, "Intro", false) > -1 or IndexOfSubstring(line, "INTRO", false) > -1 then isChord = false
    elsif IndexOfSubstring(line, "Outro", false) > -1 or IndexOfSubstring(line, "OUTRO", false) > -1 then isChord = false
    elsif IndexOfSubstring(line, "Solo", false) > -1 or IndexOfSubstring(line, "SOLO", false) > -1 then isChord = false
    else
        For i = 0; i < Size(words); i = i + 1 Do
            w = TrimString(words[i])
            if Length(w) > 0 then
                wordCount = wordCount + 1
                firstChar = CopySubstring(w, 0, 1)
                
                // 1. Is the word a real chord? (A-H, plus 'N' for N.C.)
                if IndexOfSubstring("ABCDEFGHNabcdefghn", firstChar, false) > -1 then
                    hasRealChord = true
                end
                
                // 2. Allowed start characters for ALL words in a chord line (chords + annotations)
                if IndexOfSubstring("ABCDEFGHNabcdefghnxX(0123456789*", firstChar, false) == -1 then
                    isChord = false
                end
                
                if Length(w) > 9 then
                    isChord = false
                end
            end
        End
        
        if wordCount == 0 then isChord = false end 
        
        // ---> THE TRAP TRIGGERS HERE:
        // Were there only 'x4' or 'X' in the line, but no A-G? -> Then it is just text!
        if not hasRealChord then isChord = false end
    end
    
    result = isChord
End

// Removes inline comments like (single notes: E G A B)
Function RemoveInlineComments(line : String) Returns String
    var openPos, closePos : Integer
    var res : String = line
    openPos = IndexOfSubstring(res, "(", false)
    While openPos > -1 Do
        closePos = IndexOfSubstring(res, ")", false)
        if closePos > openPos then
            res = CopySubstring(res, 0, openPos) + CopySubstring(res, closePos + 1, Length(res) - closePos - 1)
        else
            res = CopySubstring(res, 0, openPos)
        end
        openPos = IndexOfSubstring(res, "(", false)
    End
    result = res
End

// AUTO-TAGGER (automatically inserts missing [Parts] and [Intros])
Function AutoTagSections(lines : String Array) Returns String Array
    var i, partCounter : Integer = 1
    var res : String Array = []
    var hasAnyHeader : Boolean = false
    var inBlock : Boolean = false
    var firstBlockFound : Boolean = false
    var line : String

    // 1. Does the song have its own [headers]?
    For i = 0; i < Size(lines); i = i + 1 Do
        if IsHeaderLine(lines[i]) then hasAnyHeader = true end
    End

    // 2. Split text into blocks and inject headers
    For i = 0; i < Size(lines); i = i + 1 Do
        line = lines[i]
        
        if Length(TrimString(line)) > 0 then
            if not inBlock then
                // Ein neuer Block beginnt!
                inBlock = true
                
                // Only intervene if the block does not already have a header
                if not IsHeaderLine(line) then
                    if not hasAnyHeader then
                        // NO headers in the entire song? Tag everything!
                        if not firstBlockFound and IsChordLine(RemoveInlineComments(line)) then
                            res <-- "[Intro]"
                        else
                            res <-- "[Part " + partCounter + "]"
                            partCounter = partCounter + 1
                        end
                    else
                        // Song HAS headers, but one is missing at the top!
                        if not firstBlockFound and IsChordLine(RemoveInlineComments(line)) then
                            res <-- "[Intro]"
                        end
                    end
                end
                firstBlockFound = true
            end
            res <-- line
        else
            // Empty line -> end of block
            if inBlock then
                res <-- "" // Keep separator
                inBlock = false
            end
        end
    End
    
    result = res
End

// --- FILTER: Specifically detects tablature drawings ---
Function IsTabLine(line : String) Returns Boolean
    var tLine : String = TrimString(line)
    var isTab : Boolean = false
    if IndexOfSubstring(tLine, "|-", false) > -1 then isTab = true
    elsif IndexOfSubstring(tLine, "-|", false) > -1 then isTab = true
    elsif IndexOfSubstring(tLine, "e|", false) == 0 then isTab = true
    elsif IndexOfSubstring(tLine, "B|", false) == 0 then isTab = true
    elsif IndexOfSubstring(tLine, "G|", false) == 0 then isTab = true
    elsif IndexOfSubstring(tLine, "D|", false) == 0 then isTab = true
    elsif IndexOfSubstring(tLine, "A|", false) == 0 then isTab = true
    elsif IndexOfSubstring(tLine, "E|", false) == 0 then isTab = true
    end
    result = isTab
End

// --- FILTER: Detects guitar tabs, web junk, and legends ---
Function IsJunkLine(line : String) Returns Boolean
    var tLine : String = TrimString(line)
    var junk : Boolean = false
    
    // Tablature lines
    if IsTabLine(line) then junk = true
    
    // UG metadata & web junk
    elsif IndexOfSubstring(tLine, "Tuning:", false) > -1 then junk = true
    elsif IndexOfSubstring(tLine, "Key:", false) > -1 then junk = true
    elsif IndexOfSubstring(tLine, "Capo", false) == 0 then junk = true 
    elsif IndexOfSubstring(tLine, "http", false) > -1 then junk = true
    
    // Alternates & chord mapping at the end
    elsif IndexOfSubstring(tLine, "Alternates:", false) > -1 then junk = true
    elsif IndexOfSubstring(tLine, " = ", false) > -1 then junk = true
    
    // UG legend junk & arrows
    elsif IndexOfSubstring(tLine, "***", false) > -1 then junk = true
    elsif IndexOfSubstring(tLine, "| /", false) == 0 then junk = true
    elsif IndexOfSubstring(tLine, "| \\", false) == 0 then junk = true
    elsif IndexOfSubstring(tLine, "↓", false) > -1 then junk = true
    elsif IndexOfSubstring(tLine, "↑", false) > -1 then junk = true
    
    // ---> NEW SMART PARENTHESIS FILTER <---
    elsif IndexOfSubstring(tLine, "(", false) == 0 then 
        // Only delete the line if it contains typical instruction words,
        // OR if it is a very short multiplier like (x4).
        // (Ho!) and (Hey!) lyrics stay alive this way!
        if IndexOfSubstring(tLine, "note", true) > -1 then junk = true
        elsif IndexOfSubstring(tLine, "strum", true) > -1 then junk = true
        elsif IndexOfSubstring(tLine, "repeat", true) > -1 then junk = true
        elsif IndexOfSubstring(tLine, "fade", true) > -1 then junk = true
        elsif IndexOfSubstring(tLine, "play", true) > -1 then junk = true
        elsif IndexOfSubstring(tLine, "x", true) > -1 and Length(tLine) < 8 then junk = true
        end
    end
    
    result = junk
End

// Clean up chord name
Function CleanChordName(raw : String) Returns String
    var res : String = ""
    var i : Integer
    var c : String
    // ---> FIX: Added asterisk (*) <---
    var allowed : String = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789#/+-().*" 
    
    For i = 0; i < Length(raw); i = i + 1 Do
        c = CopySubstring(raw, i, 1)
        if IndexOfSubstring(allowed, c, false) > -1 then
            res = res + c
        end
    End
    result = res
End

// The zipper: weaves chords into the text (championship edition)
Function WeaveChords(chordLine : String, lyricLine : String) Returns String
    var woven : String = ""
    var cNames : String Array = []
    var cPos : Integer Array = []
    var pos, startIdx, i, lastPos : Integer
    var char, currentName, safeLyric : String
    
    // Extract chords
    pos = 0
    While pos < Length(chordLine) Do
        char = CopySubstring(chordLine, pos, 1)
        if char != " " and char != "	" then
            startIdx = pos
            While pos < Length(chordLine) and CopySubstring(chordLine, pos, 1) != " " Do
                pos = pos + 1
            End
            currentName = CleanChordName(CopySubstring(chordLine, startIdx, pos - startIdx))
            if Length(currentName) > 0 then
                cNames <-- currentName
                cPos <-- startIdx
            end
        else
            pos = pos + 1
        end
    End
    
    // Silently stamp instrumental lines with '§' ---
    if Size(cNames) > 0 and Length(TrimString(lyricLine)) == 0 then
        safeLyric = "§"
    else
        safeLyric = lyricLine
    end
    
    // B) Weave in
    lastPos = 0
    For i = 0; i < Size(cNames); i = i + 1 Do
        pos = cPos[i]
        if pos > lastPos then
            if pos <= Length(safeLyric) then
                woven = woven + CopySubstring(safeLyric, lastPos, pos - lastPos)
                lastPos = pos
            else
                if lastPos < Length(safeLyric) then
                    woven = woven + CopySubstring(safeLyric, lastPos, Length(safeLyric) - lastPos)
                    lastPos = Length(safeLyric)
                end
            end
        end
        if pos > lastPos then
            woven = woven + GetSpaces(pos - lastPos)
            lastPos = pos
        end
        woven = woven + "[" + cNames[i] + "]"
    End
    
    if lastPos < Length(safeLyric) then
        woven = woven + CopySubstring(safeLyric, lastPos, Length(safeLyric) - lastPos)
    end
    
    result = woven
End

// Virtual ruler (measures ACTUAL width after merging)
Function GetEffectiveLength(cLine : String, lLine : String) Returns Integer
    var woven : String = WeaveChords(cLine, lLine)
    // Subtract brackets since Gig Performer does not display them!
    woven = ReplaceString(woven, "[", "", false)
    woven = ReplaceString(woven, "]", "", false)
    result = Length(woven)
End

// Smart scanner (tests whether the cut fits on screen)
Function GetSmartWrapIndex(cLine : String, lLine : String, maxLen : Integer) Returns Integer
    var idx : Integer
    var loopMax : Integer
    var safeInLyric, safeInChord : Boolean
    var lChar, cChar, leftC, leftL : String
    var bestIdx : Integer = -1
    
    if Length(lLine) > Length(cLine) then loopMax = Length(lLine) else loopMax = Length(cLine) end
    idx = loopMax
    
    While idx > 0 and bestIdx == -1 Do
        safeInLyric = false
        safeInChord = false
        
        // 1. Is the cut physically safe in the text?
        if idx >= Length(lLine) then safeInLyric = true
        else
            lChar = CopySubstring(lLine, idx, 1)
            if lChar == " " or lChar == "	" or lChar == "-" then safeInLyric = true end
        end
        
        // 2. Is the cut physically safe at the chords?
        if idx >= Length(cLine) then safeInChord = true
        else
            cChar = CopySubstring(cLine, idx, 1)
            if cChar == " " or cChar == "	" then safeInChord = true 
            elsif idx > 0 and CopySubstring(cLine, idx - 1, 1) == " " then safeInChord = true end
        end
        
        // 3. If physically safe -> does the finished result fit on screen?
        if safeInLyric and safeInChord then
            leftC = CopySubstring(cLine, 0, idx)
            leftL = CopySubstring(lLine, 0, idx)
            
            // Virtual test weave!
            if GetEffectiveLength(leftC, leftL) <= maxLen then
                bestIdx = idx // Perfect cut found! Loop breaks.
            end
        end
        
        if bestIdx == -1 then idx = idx - 1 end // Continue searching backwards
    End
    
    // Emergency fallback (if a single word is already too long)
    if bestIdx == -1 then
        if loopMax > maxLen then bestIdx = maxLen
        else bestIdx = loopMax end
    end
    
    result = bestIdx
End

// SMART PAGE-FLIP: Intelligently splits overly long text blocks
Function FlushSection(secName : String, secLines : String Array) Returns String Array
    var res : String Array = []
    var pageStart, pageEnd, i, searchIdx, pageNum : Integer
    var validLen : Integer = Size(secLines)
    var readStart : Integer = 0
    var emptyFound, keepTrimming, textBelowOnPage : Boolean
    var maxL : Integer = 6 
    var currentMaxL : Integer
    var pLine : String
    var tempLines : String Array

    // 1. TRIM EMPTY LINES AT THE END
    keepTrimming = true
    While validLen > 0 and keepTrimming Do
        if Length(TrimString(secLines[validLen-1])) == 0 then
            validLen = validLen - 1
        else
            keepTrimming = false
        end
    End

    // 2. TRIM EMPTY LINES AT THE TOP (Top-Trimmer!)
    keepTrimming = true
    While readStart < validLen and keepTrimming Do
        if Length(TrimString(secLines[readStart])) == 0 then
            readStart = readStart + 1
        else
            keepTrimming = false
        end
    End

    if validLen > readStart then
        pageNum = 1
        pageStart = readStart
        
        While pageStart < validLen Do
            
            // Does the rest fit completely on one (or the last) page?
            if (validLen - pageStart) <= (maxL + 1) and pageStart == readStart then
                pageEnd = validLen
                if Length(secName) > 0 then res <-- secName end
            elsif (validLen - pageStart) <= (maxL + 1) then
                pageEnd = validLen
                if Length(secName) > 0 then res <-- secName + " (Pt " + pageNum + ")" end
            else
                // Page must be cut!
                currentMaxL = maxL
                pageEnd = pageStart + currentMaxL
                
                emptyFound = false
                searchIdx = pageEnd - 1
                While searchIdx >= pageStart + 2 and not emptyFound Do
                    if Length(TrimString(secLines[searchIdx])) == 0 then
                        pageEnd = searchIdx + 1 
                        emptyFound = true
                    end
                    searchIdx = searchIdx - 1
                End
                
                if Length(secName) > 0 then res <-- secName + " (Pt " + pageNum + ")" end
            end

            // --- PAGE ANALYZER (resolves page breaks from bottom to top) ---
            tempLines = []
            textBelowOnPage = false
            
            i = pageEnd - 1
            While i >= pageStart Do
                pLine = secLines[i]
                
                if IndexOfSubstring(pLine, "§", false) > -1 then
                    if textBelowOnPage then
                        pLine = ReplaceString(pLine, "§", "_", false) // Set anchor!
                    else
                        pLine = ReplaceString(pLine, "§", "", false)  // Remove without trace
                    end
                else
                    if Length(TrimString(pLine)) > 0 then
                        textBelowOnPage = true // Text found!
                    end
                end
                
                tempLines <-- pLine 
                i = i - 1
            End
            
            // Reverse tempLines and write final to the page
            i = Size(tempLines) - 1
            While i >= 0 Do
                res <-- tempLines[i]
                i = i - 1
            End
            // ------------------------------------------------------------

            pageStart = pageEnd
            pageNum = pageNum + 1
        End
    end

    result = res
End

// Master clipboard cleaner (GOD-MODE TRIMMER)
Function WashClipboardText(rawText : String) Returns String
    var cleanRaw : String = rawText
    var rawLines, lines, cleanLines : String Array
    var outLines : String Array = []
    var currentSecLines : String Array = []
    var currentSecName : String = ""
    var flushed : String Array
    var i, j : Integer = 0
    var line, nextLine, cleanedLine, finalStr, tLine : String
    var isHeader : Boolean
    var maxLineLen : Integer = 60
    var wrapIdx : Integer
    var cLine1, cLine2, lLine1, lLine2 : String
    
    // --- SAFETIES ---
    var isTabAhead : Boolean
    var inChordLegend : Boolean = false
    var startOfSongIdx : Integer = -1
    var firstHeaderIdx : Integer = -1
    var isIntroFirst : Boolean = false

    cleanRaw = ReplaceString(cleanRaw, "[", NEW_LINE + "[", false)
    cleanRaw = ReplaceString(cleanRaw, "]", "]" + NEW_LINE, false)
    rawLines = SplitString(cleanRaw, NEW_LINE)
    
    // =================================================================
    // 1. SHREDDER (junk filter & legend killer)
    // =================================================================
    lines = []
    for i = 0; i < Size(rawLines); i = i + 1 do
        tLine = TrimString(rawLines[i])

        if IndexOfSubstring(tLine, "Chords used:", true) > -1 then
            inChordLegend = true
        elsif IndexOfSubstring(tLine, "Chords:", true) == 0 then
            inChordLegend = true
        elsif inChordLegend and Length(tLine) == 0 then
            inChordLegend = false 
        end

        if not inChordLegend then
            if not IsJunkLine(rawLines[i]) then
                isTabAhead = false
                if i + 1 < Size(rawLines) then
                    if IsTabLine(rawLines[i+1]) then
                        isTabAhead = true
                    end
                end
                
                if IsChordLine(RemoveInlineComments(rawLines[i])) and isTabAhead then
                    // Chord over tab -> eliminate
                else
                    lines <-- rawLines[i]
                end
            end
        end
    end

    // =================================================================
    // 2. STRUCTURAL TOP-TRIMMER (WITH INTRO-KILLER!)
    // =================================================================
    cleanLines = []
    startOfSongIdx = -1
    firstHeaderIdx = -1
    isIntroFirst = false
    
    // A) Find the very FIRST header in the cleaned text
    for i = 0; i < Size(lines); i = i + 1 do
        if firstHeaderIdx == -1 and IsHeaderLine(lines[i]) then
            firstHeaderIdx = i
            // Check: Is this very first title an Intro?
            if IndexOfSubstring(lines[i], "[Intro", true) > -1 then
                isIntroFirst = true
            end
        end
    end
    
    // B) Determine start index
    if isIntroFirst then
        // SPECIAL RULE: [Intro] is the boss. EVERYTHING before it gets eliminated!
        startOfSongIdx = firstHeaderIdx
    else
        // FALLBACK: If there is no intro, start at the first header or first real chord
        for i = 0; i < Size(lines); i = i + 1 do
            if startOfSongIdx == -1 then
                tLine = TrimString(lines[i])
                if IsHeaderLine(tLine) then
                    startOfSongIdx = i
                elsif IsChordLine(RemoveInlineComments(tLine)) then
                    startOfSongIdx = i
                end
            end
        end
    end
    
    // C) Trim
    if startOfSongIdx > 0 then
        for i = startOfSongIdx; i < Size(lines); i = i + 1 do
            cleanLines <-- lines[i]
        end
        lines = cleanLines
    end
    // =================================================================
    
    // 3. Auto-Tagger
    lines = AutoTagSections(lines)
    
    // 4. The loom
    i = 0
    While i < Size(lines) Do
        line = lines[i]
        tLine = TrimString(line)
        isHeader = IsHeaderLine(line) 
        
        if isHeader then
            flushed = FlushSection(currentSecName, currentSecLines)
            for j = 0; j < Size(flushed); j = j + 1 do outLines <-- flushed[j] end
            
            cleanedLine = ReplaceString(tLine, "[", "", false)
            cleanedLine = ReplaceString(cleanedLine, "]", "", false)
            currentSecName = "# " + TrimString(cleanedLine)
            currentSecLines = [] 
            i = i + 1
            
        elsif IsChordLine(RemoveInlineComments(line)) then
            line = RemoveInlineComments(line)
            
            if i + 1 < Size(lines) then
                nextLine = lines[i+1]
                
                if not IsChordLine(RemoveInlineComments(nextLine)) and not IsHeaderLine(nextLine) and Length(TrimString(nextLine)) > 0 then
                    nextLine = TrimString(nextLine)
                    While GetEffectiveLength(line, nextLine) > maxLineLen Do
                        wrapIdx = GetSmartWrapIndex(line, nextLine, maxLineLen)
                        if Length(line) > wrapIdx then
                            cLine1 = CopySubstring(line, 0, wrapIdx)
                            cLine2 = CopySubstring(line, wrapIdx, Length(line) - wrapIdx)
                        else cLine1 = line; cLine2 = "" end
                        
                        if Length(nextLine) > wrapIdx then
                            lLine1 = CopySubstring(nextLine, 0, wrapIdx)
                            lLine2 = TrimString(CopySubstring(nextLine, wrapIdx, Length(nextLine) - wrapIdx))
                        else lLine1 = nextLine; lLine2 = "" end
                        
                        currentSecLines <-- WeaveChords(cLine1, lLine1)
                        line = cLine2; nextLine = lLine2
                    End
                    
                    if Length(TrimString(line)) > 0 or Length(TrimString(nextLine)) > 0 then
                        currentSecLines <-- WeaveChords(line, nextLine)
                    end
                    i = i + 2 
                else
                    currentSecLines <-- WeaveChords(line, "")
                    i = i + 1
                end
            else
                currentSecLines <-- WeaveChords(line, "")
                i = i + 1
            end
        else
            if Length(TrimString(line)) > 0 or Size(currentSecLines) > 0 then
                currentSecLines <-- line
            end
            i = i + 1
        end
    End
    
    flushed = FlushSection(currentSecName, currentSecLines)
    for j = 0; j < Size(flushed); j = j + 1 do outLines <-- flushed[j] end
    
    finalStr = ""
    for i = 0; i < Size(outLines); i = i + 1 do
        finalStr = finalStr + outLines[i] + NEW_LINE
    end
    result = finalStr
End

// ---------------------------------------------------------
// TIMELINE ACTION EXECUTORS 1
// ---------------------------------------------------------

Function ExecuteScrub(newValue : Double, fromOSC : Boolean)
   var calcVal : Double = 0.0
   var targetBar : Integer
   
   Trace("[SCRUB-IN] Value=" + newValue + " | From UI (fromOSC): " + fromOSC)
   
   // ---> ABSOLUTE SHIELD AGAINST OSC ECHOES <---
   if fromOSC and TimeSinceStartup() < ScrubberTaubTimer then
       Trace("[SCRUB-IN] Ignored: OSC echo blocked by deaf timer.")
   elsif IsPerformanceActive and fromOSC then
       Trace("[SCRUB-IN] Ignored: OSC echo blocked during playback.")
   else
       // Normal execution continues from here...
       if not IsLoadingSnapshot and not IsLoading then
           if not fromOSC then
               OSC_SendDoubleSpecific("/UI/SetScrubber", newValue, Local_IP, Local_PORT)
           end

           calcVal = 1.0 - newValue 
           targetBar = Round(calcVal * IntToFloat(SongDurationBars))
           
           if targetBar < 1 then targetBar = 1 end
           if targetBar > SongDurationBars then targetBar = SongDurationBars end
           
           if newValue > 0.95 Then
               if IsPerformanceActive == true and CurrentBar >= 5 Then
                   Trace("PROMPTER: >>> MANUAL EMERGENCY STOP TRIGGERED! (Bar " + CurrentBar + ") <<<")
                   IsPerformanceActive = false 
                   EnablePlayhead(false) 
                   
                   SetParameter(BLK_ArrangerSync, P_STYLE_START_STOP, 1.0)
                   StyleTriggerResetTimer = TimeSinceStartup() + 60.0
               end
           end

           If targetBar != CurrentBar Then 
              Trace("[SCRUB-MATH] Previous offset=" + GlobalBarOffset + " | targetBar=" + targetBar + " | SysBar=" + LastSystemBar)
              
              CurrentBar = targetBar
              CurrentBeat = 1 
              GlobalBarOffset = targetBar - LastSystemBar
              
              Trace("[SCRUB-MATH] NEW offset=" + GlobalBarOffset)
              
              UpdatePrompter(false) 
              
              if RecordMode > 0 and not IsPerformanceActive then
                  BuildRecDisplayLines()
                  RefreshRecDisplay(GetWidgetValue(SLD_CurrentState))
              end            
           end
       end 
   end
End

// ---------------------------------------------------------
// HELPER: ARRANGER ECHO SENDER
// ---------------------------------------------------------
Function FireArrangerTransportEcho()
    SetParameter(BLK_ArrangerSync, P_STYLE_START_STOP, 1.0)
    StyleTriggerResetTimer = TimeSinceStartup() + 60.0
End

// ---------------------------------------------------------
// DIRECT ARRANGER TRIGGER (native MIDI FA / FC)
// ---------------------------------------------------------
Function FireDirectArrangerTransport()
    // Fires Note 14 directly to the physical MIDI Out, without loopback risk!
    // (Channel 16 = 0x9F / 0x8F, since GP uses 0-based channels)
    
    // Note ON
    if arrangerDevIdx >= 0 and IsDeviceConnected(arrangerDevIdx) then
        SendNowToMidiOutDevice(GetDeviceMidiOut(arrangerDevIdx), MakeMidiMessage3(159, 14, 127))

        // Wait 50 milliseconds (simulates holding the key)
        Wait(50.0)

        // Note OFF
        SendNowToMidiOutDevice(GetDeviceMidiOut(arrangerDevIdx), MakeMidiMessage3(143, 14, 0))
    end
    
    Trace(">>> FireDIRECT-OUT: Start/Stop (Note 14) physically sent to arranger.")
End


// ============================================================================
// SECTION 20: VST REPLACER ENGINE
// ============================================================================

Function ParkFadersForVST(vstIdx : Integer)
    var i, s : Integer
    var count : Integer = 0
    
    Trace("PARK: Request for VST Index " + vstIdx)

    // FIX: Limit raised to MAX_VSTS!
    if vstIdx >= 0 and vstIdx < MAX_VSTS then
        For i = 0; i < Link_Count; i = i + 1 Do
            if Link_Active[i] and Link_Type[i] == 0 and Link_BlockIdx[i] == vstIdx then

                s = Link_SourceIdx[i]

                // Only park arranger faders (Index 0-15)
                if s >= 0 and s <= 15 then
                    Trace("PARK: Found Match! Link " + i + " is on Slider " + s + ". Current Val: " + GetParameter(ExternalArranger, s))
                    Mem_Fader_Buffer[s] = GetParameter(ExternalArranger, s)
                    ScriptWrite_ExpectedPrev[s] = ScriptWrite_Expected[s]
                    ScriptWrite_Expected[s] = 0.0
                    SetParameter(ExternalArranger, s, 0.0)
                    count = count + 1
                end
            end
        End
    end
    
    if count == 0 then Trace("PARK: No Links found for VST " + vstIdx + " in current Map!") end
End

// 2. RESTORE: Restore values (from plugin or memory)
Function RestoreFadersForVST(vstIdx : Integer)
    var i, s : Integer
    var currentVal, faderVal : Double = 0.0
    var range : Double = 0.0
    var count : Integer = 0
    
    Trace("RESTORE: Request for VST Index " + vstIdx)
    
    // FIX: Limit raised to MAX_VSTS!
    if vstIdx >= 0 and vstIdx < MAX_VSTS then
        For i = 0; i < Link_Count; i = i + 1 Do
            if Link_Active[i] and Link_Type[i] == 0 and Link_BlockIdx[i] == vstIdx then

                s = Link_SourceIdx[i]
                faderVal = 0.0

                // Only restore arranger faders (Index 0-15)
                if s >= 0 and s <= 15 then
                    if Link_IsCC[i] then
                        faderVal = Mem_Fader_Buffer[s]
                        Trace("RESTORE: Link " + i + " (CC) -> Buffer says: " + faderVal)
                    else
                        currentVal = GetParameter(BLK_VST[vstIdx], Link_TargetParam[i])
                        range = Link_MaxVal[i] - Link_MinVal[i]
                        if Abs(range) > 0.0001 then
                            faderVal = (currentVal - Link_MinVal[i]) / range
                        else
                            faderVal = 0.0 
                        end
                        Trace("RESTORE: Link " + i + " (Param) -> Plugin says: " + currentVal + " -> Fader: " + faderVal)
                    end
                    
                    if faderVal < 0.0 then faderVal = 0.0 elsif faderVal > 1.0 then faderVal = 1.0 end
                    ScriptWrite_ExpectedPrev[s] = ScriptWrite_Expected[s]
                    ScriptWrite_Expected[s] = faderVal
                    SetParameter(ExternalArranger, s, faderVal)
                    count = count + 1
                end
            end
        End
    end
    if count == 0 then Trace("RESTORE: No Links found to restore.") end
End

Function ScrollToCurrentVST()
   var targetLine : Integer = GetActiveMapSlot() * 4 // Wieder * 4!
   var totalLines : Integer = Size(VstInfo_Lines)
   var displayLines : Integer = 13 
   var maxStart : Integer = totalLines - displayLines
   var scrollVal : Double = 0.0

   if maxStart <= 0 then 
       scrollVal = 1.0 
   else
       if targetLine > maxStart then targetLine = maxStart end
       scrollVal = 1.0 - (IntToFloat(targetLine) / IntToFloat(maxStart))
   end

   SetWidgetValue(SLD_VSTConfiguration, scrollVal)
   RefreshVstInfoDisplay()
End

// ---------------------------------------------------------
// STATE & CONFIG APPLICATION (OPTIMIZED)
// ---------------------------------------------------------

Function SafeLoadPreset(pl : PluginBlock, pName : String)
   var presets : String Array; var i : Integer; var found : Boolean = false
   presets = GetGPPresetList(pl, 0)
   for i = 0; i < Size(presets); i = i + 1 do if presets[i] == pName then found = true end end
   if found then LoadGPPreset(pl, pName) else Trace("WARNING: Preset '" + pName + "' not found!") end
End

Function GetStoredPreset(blockName : String, oldNames : String Array, oldPresets : String Array) Returns String
   var i : Integer; var foundPreset : String = "Standard"
   For i = 0; i < Size(oldNames); i = i + 1 Do If oldNames[i] == blockName Then foundPreset = oldPresets[i] End End
   result = foundPreset
End

// ---------------------------------------------------------
// REVERSE LOOKUP FOR VST ROUTING
// Finds the first MIDI channel (1-16) routed to this VST
// ---------------------------------------------------------
Function GetChannelForVST(vstIdx : Integer) Returns Integer
   var i : Integer = 0
   var found : Boolean = false
   
   result = 1 // Fallback
   
   // ---> SAFE WHILE-LOOP <---
   While i < 16 and not found Do
      if RoutingMatrix[(vstIdx * 16) + i] == true then
         result = i + 1
         found = true
      end
      i = i + 1
   End
End


// ============================================================================
// SECTION 17: CONTROLLER MAP ENGINE
// ============================================================================

Function ExecuteLink(i : Integer, val : Double)
   var scaledVal : Double = Link_MinVal[i] + (val * (Link_MaxVal[i] - Link_MinVal[i]))
   var midiVal : Integer
   var m : MidiMessage

   if Link_IsCC[i] == true then
       midiVal = Round(scaledVal * 127.0)
       if midiVal < 0 then midiVal = 0 elsif midiVal > 127 then midiVal = 127 end
       
       if Link_Type[i] == 0 then 
           m = MakeControlChangeMessageEx(Link_TargetParam[i], midiVal, GetChannelForVST(Link_BlockIdx[i]))
           SendNow(BLK_VSTControl, m)
       elsif Link_Type[i] == 3 then
           m = MakeControlChangeMessageEx(Link_TargetParam[i], midiVal, Link_BlockIdx[i])
           SendNow(BLK_VSTControl, m)
       end
   else
       if Link_Type[i] == 0 then SetParameter(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i], scaledVal)
       elsif Link_Type[i] == 1 then SetParameter(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i], scaledVal)
       elsif Link_Type[i] == 2 then SetParameter(AudioMixer, Link_TargetParam[i], scaledVal)
       end
   end
End

// ---------------------------------------------------------------------
// APPLY EDITOR-TEST // Executes the test fader logic in the editor
// ---------------------------------------------------------------------

Function ApplyEditorTest(val : Double)
    var i, midiVal : Integer
    var scaledVal : Double = 0.0
    var m : MidiMessage 
    
    if CurrentEditScope == -1 then
        For i = 0; i < Link_Count; i = i + 1 Do
            if Link_Active[i] then ExecuteLink(i, val) end
        End
    else
        // ---> GUARD <---
        if CurrentEditScope >= 0 and CurrentEditScope <= 15 then
            ScriptWrite_ExpectedPrev[CurrentEditScope] = ScriptWrite_Expected[CurrentEditScope]
            ScriptWrite_Expected[CurrentEditScope] = val
            SetParameter(ExternalArranger, CurrentEditScope, val)
        end
        
        For i = 0; i < Link_Count; i = i + 1 Do
            if Link_Active[i] and Link_SourceIdx[i] == CurrentEditScope then ExecuteLink(i, val) end
        End
    end
End


// ============================================================================
// SECTION 20: VST REPLACER ENGINE
// ============================================================================

// ---------------------------------------------------------
// PRESET BROWSER LOGIC (Smart-Browse)
// ---------------------------------------------------------
Function CyclePluginPreset(pluginIndex : Integer, direction : Integer)
    var presets : String Array
    var currentName : String
    var idx, i, newIdx : Integer
    var isActive : Boolean
    
    // Wrap the entire logic in an IF to simulate early return
    if ReplaceTargetIdx == -1 and EmergencyKillSwitch == false then
        
        if pluginIndex >= 0 and pluginIndex < MAX_VSTS then
            presets = GetGPPresetList(BLK_VST[pluginIndex], 0)
            
            if Size(presets) > 0 then
                currentName = LoadedPresets[pluginIndex]
                idx = -1
                
                // ---> SAFE WHILE-LOOP <---
                i = 0
                While i < Size(presets) and idx == -1 Do
                    If presets[i] == currentName Then 
                        idx = i 
                    End
                    i = i + 1
                End
                
                if idx == -1 then idx = 0 end
                newIdx = idx + direction
                If newIdx < 0 Then newIdx = Size(presets) - 1 
                Elsif newIdx >= Size(presets) Then newIdx = 0 End

                isActive = not IsPluginBypassed(BLK_VST[pluginIndex])
                if isActive then
                    LoadGPPreset(BLK_VST[pluginIndex], presets[newIdx])
                    LoadedPresets[pluginIndex] = presets[newIdx] 
                end
            else
                Trace("PRESET: No list available for VST " + (pluginIndex+1))
            end
        end
        
    else
        Trace("PRESET: Action blocked - System is still stabilizing after Replace.")
    end
End


// ---------------------------------------------------------
// Updates the hardware faders on the arranger for a specific VST
// ---------------------------------------------------------
Function ResetHardwareFadersForVST(vstIdx : Integer)
   var i, s : Integer
   var currentVal, faderVal : Double = 0.0
   var range : Double = 0.0

   if vstIdx >= 0 and vstIdx < MAX_VSTS then
       For i = 0; i < Link_Count; i = i + 1 Do
           if Link_Active[i] and Link_Type[i] == 0 and Link_BlockIdx[i] == vstIdx and Link_IsCC[i] == false then
               
               s = Link_SourceIdx[i] // The hardware slider index
               
               currentVal = GetParameter(BLK_VST[vstIdx], Link_TargetParam[i])
               range = Link_MaxVal[i] - Link_MinVal[i]
               
               if range != 0.0 then faderVal = (currentVal - Link_MinVal[i]) / range else faderVal = currentVal end
               if faderVal < 0.0 then faderVal = 0.0 elsif faderVal > 1.0 then faderVal = 1.0 end
               
               if s >= 0 and s <= 15 then
                   ScriptWrite_ExpectedPrev[s] = ScriptWrite_Expected[s]
                   ScriptWrite_Expected[s] = faderVal
                   SetParameter(ExternalArranger, s, faderVal)
               end
           end
       End
   end
End

// ---------------------------------------------------------
// SENDET BANK SELECT & PROGRAM CHANGE AN DAS VST
// ---------------------------------------------------------
Function SendProgramChangeToVst(vstIdx : Integer, direction : Integer)
    var absVal, bankLSB, pcVal, ch : Integer
    var msgMSB, msgLSB : ControlChangeMessage
    var msgPC : ProgramChangeMessage
    
    // 1. Increment/decrement counter
    absVal = Current_PC_Absolute[vstIdx] + direction
    
    // Limits (clamp to 0-3000 range)
    if absVal < 0 then absVal = 0 
    elsif absVal > 3000 then absVal = 3000 end // Adjust the max limit to match your VST
    
    Current_PC_Absolute[vstIdx] = absVal
    
    // 2. Bank/PC calculation (conversion to Bank and PC)
    bankLSB = absVal / 128
    pcVal = absVal % 128
    
    // 3. Find target channel and fire!
    For ch = 0; ch < 16; ch = ch + 1 Do
        if RoutingMatrix[(vstIdx * 16) + ch] then
            
            // Build MIDI messages WITH explicit channel (ch + 1)!
            msgMSB = MakeControlChangeMessageEx(0, 0, ch + 1)       // MSB = 0
            msgLSB = MakeControlChangeMessageEx(32, bankLSB, ch + 1)// LSB = Bank
            msgPC = MakeProgramChangeMessageEx(pcVal, ch + 1)       // PC = Patch 0-127
            
            // Into the central funnel (without array brackets!)
            SendNow(BLK_VSTControl, msgMSB)
            SendNow(BLK_VSTControl, msgLSB)
            SendNow(BLK_VSTControl, msgPC)
            
            if DebugMode then
                Trace("PC-SENDER: VST " + (vstIdx+1) + " (Ch " + (ch+1) + ") -> Bank: " + bankLSB + " | PC: " + pcVal)
            end
        end
    End
End

// ---------------------------------------------------------
// VST PRESET BROWSE ENGINE (INTERNAL)
// ---------------------------------------------------------
Function TriggerVstPresetChange(direction : Integer) // -1 = Prev, 1 = Next
    var loadedName, cType : String
    var pDown, pUp, i : Integer
    var found : Boolean = false
    var feedbackMsg : String = ""
    var absVal, bankLSB, pcVal : Integer
    
    // 1. Which plugin is loaded in the current scope?
    if Active_VST_Scope >= 0 and Active_VST_Scope < MAX_VSTS then
        loadedName = GetPluginInfo(BLK_VST[Active_VST_Scope], 0)
        
        // 2. Lookup in the master DB
        // ---> SAFE WHILE-LOOP <---
        i = 0
        While i < Size(DB_VstNames) and not found Do
            if DB_VstNames[i] == loadedName then
                cType = DB_ControlType[i]
                pDown = DB_ParamDown[i]
                pUp = DB_ParamUp[i]
                found = true
            end
            i = i + 1
        End
        
        if found then
            if DebugMode then Trace("VST BROWSE: Scope=" + (Active_VST_Scope+1) + " | Plugin=" + loadedName + " | Type=" + cType) end
            
            // --- A: CONTROL VIA PLUGIN PARAMETERS (Arturia, Omnisphere) ---
            if cType == "PARAM" then
                if direction == 1 and pUp > 0 then
                    // 1. Zero out as a safety measure (in case Arturia swallowed the last Off command)
                    SetParameter(BLK_VST[Active_VST_Scope], pUp, 0.0) 
                    
                    // 2. Force inject
                    SetParameter(BLK_VST[Active_VST_Scope], pUp, 1.0)
                    
                    // 3. Hold significantly longer so heavy VSTs register it!
                    Wait(150.0) 
                    
                    // 4. Release again
                    SetParameter(BLK_VST[Active_VST_Scope], pUp, 0.0)
                    feedbackMsg = ">> " + loadedName + " : Next Patch <<"
                    
                elsif direction == -1 and pDown > 0 then
                    SetParameter(BLK_VST[Active_VST_Scope], pDown, 0.0)
                    SetParameter(BLK_VST[Active_VST_Scope], pDown, 1.0)
                    Wait(150.0)
                    SetParameter(BLK_VST[Active_VST_Scope], pDown, 0.0)
                    feedbackMsg = ">> " + loadedName + " : Prev Patch <<"
                end
                
            // --- B: CONTROL VIA GIG PERFORMER HOST LIST ---
            elsif cType == "HOST" then
                CyclePluginPreset(Active_VST_Scope, direction)
                
                // After Cycle(), the actual name is in our array
                feedbackMsg = ">> " + loadedName + " : " + LoadedPresets[Active_VST_Scope] + " <<"
                
            // --- C: CONTROL VIA PROGRAM CHANGE (Korg etc.) ---
            elsif cType == "PC" then
                SendProgramChangeToVst(Active_VST_Scope, direction)
                
                // Convert back to show the numbers in the display
                absVal = Current_PC_Absolute[Active_VST_Scope]
                bankLSB = absVal / 128
                pcVal = absVal % 128
                feedbackMsg = ">> " + loadedName + " : Bank " + bankLSB + " / PC " + PadInt(pcVal, 3) + " <<"
                
            else
                if DebugMode then Trace("VST BROWSE: Ignored. Type is NONE or unsupported.") end
            end
            
            // ========================================================
            // --- DIRECT HUD FEEDBACK FOR PRESETS ---
            // ========================================================
            if feedbackMsg != "" then
                OSC_SendStringSpecific("/UI/SetMacroFeedback", feedbackMsg, Local_IP, Local_PORT)
                MacroFeedbackTimer = TimeSinceStartup() + 2500.0 // Show slightly longer
                if DebugMode then Trace("HUD PUSH: " + feedbackMsg) end
            end
             
            // ---> FADER SYNC AFTER PRESET CHANGE <---
            HardwareSyncTimer = TimeSinceStartup() + 400.0
             
         else
             if DebugMode then Trace("VST BROWSE: Error - Plugin '" + loadedName + "' not found in DB!") end
         end
     end
End

// ---------------------------------------------------------
// SAFE VST REPLACER ENGINE & PRESET LOGIC
// ---------------------------------------------------------

// Fetches the perfect preset according to your 4 rules!
Function SmartLoadPresetAfterReplace(vstIdx : Integer)
    var presets : String Array = GetGPPresetList(BLK_VST[vstIdx], 0)
    var sName : String = ReplaceString(GetCurrentSongName(), ".ini", "", false)
    var i : Integer
    var foundSong : Boolean = false
    var foundStd : Boolean = false
    var presetToLoad : String = "-"
    
    // 1. Presets scannen
    For i = 0; i < Size(presets); i = i + 1 Do
        if presets[i] == sName then foundSong = true end
        if presets[i] == "Standard" then foundStd = true end
    End
    
    // 2. & 3. Hierarchie anwenden
    if foundSong then
        presetToLoad = sName
    elsif foundStd then
        presetToLoad = "Standard"
    end
    
    // 4. Load or leave at "-"
    if presetToLoad != "-" then
        LoadGPPreset(BLK_VST[vstIdx], presetToLoad)
    end
    
    LoadedPresets[vstIdx] = presetToLoad
    SetWidgetLabel(LBL_VSTPreset, presetToLoad)
    Trace("REPLACER: Auto-loaded Preset -> " + presetToLoad)
End

Function BuildFilteredVstList()
    var i : Integer
    var targetPub : String
    
    Filtered_VstNames = []; Filtered_VstPaths = []
    
    if Size(UniquePublishers) > 0 then
        targetPub = UniquePublishers[CurrentPubIndex]
        For i = 0; i < Size(DB_Publishers); i = i + 1 Do
            if DB_Publishers[i] == targetPub then
                Filtered_VstNames <-- DB_VstNames[i]
                Filtered_VstPaths <-- DB_VstPaths[i]
            end
        End
    end
End

// SYNC BROWSER: Jumps to the correct manufacturer immediately on slot change or replace!
Function SyncBrowserToLoadedPlugin(loadedName : String)
    var i, p : Integer
    var found, pubFound, favFound : Boolean
    
    found = false
    
    // Only execute if the database actually exists
    if Size(DB_VstNames) > 0 then
        
        // ---> OUTER SAFE WHILE-LOOP <---
        i = 0
        While i < Size(DB_VstNames) and not found Do
            if DB_VstNames[i] == loadedName then
                
                // 1. Set publisher index
                pubFound = false
                p = 0
                // ---> INNERE SICHERE WHILE-SCHLEIFE 1 <---
                While p < Size(UniquePublishers) and not pubFound Do
                    if UniquePublishers[p] == DB_Publishers[i] then
                        CurrentPubIndex = p
                        pubFound = true
                    end
                    p = p + 1
                End
                
                // 2. Liste neu filtern
                BuildFilteredVstList()
                
                // 3. Set plugin index in the filtered list
                favFound = false
                p = 0
                // ---> INNERE SICHERE WHILE-SCHLEIFE 2 <---
                While p < Size(Filtered_VstNames) and not favFound Do
                    if Filtered_VstNames[p] == loadedName then
                        CurrentFavIndex = p
                        favFound = true
                    end
                    p = p + 1
                End
                
                found = true
            end
            i = i + 1 // Don't forget the outer counter!
        End
        
        // 4. Fallback if the plugin was not found
        if not found then
            CurrentPubIndex = 0; BuildFilteredVstList(); CurrentFavIndex = 0
        end
        
    end // End of safety block
End

// =========================================================
// HIERARCHY SYNC: Forces the UI to match reality
// MAP -> Publisher -> VST -> Preset
// =========================================================
Function FocusBrowserOnCurrentSlot()
    var realSlotIdx : Integer
    var loadedName : String
    
    // 1. Array guard
    if Size(ReplaceableSlots) > 0 then
        
        // 2. Guard the map-slot index
        if CurrentMapSlotIndex < 0 or CurrentMapSlotIndex >= Size(ReplaceableSlots) then 
            CurrentMapSlotIndex = 0 
        end
        
        realSlotIdx = ReplaceableSlots[CurrentMapSlotIndex]
        
        // 3. Read reality (what is ACTUALLY loaded?)
        loadedName = GetPluginInfo(BLK_VST[realSlotIdx], 0)
        
        // 4. Datenbank-Zeiger ausrichten (Publisher & VST)
        SyncBrowserToLoadedPlugin(loadedName)
        
        // 5. Preset Backup
        if LoadedPresets[realSlotIdx] == "" then LoadedPresets[realSlotIdx] = "-" end
        
        // 6. UI States bereinigen
        IsBrowsingFavorites = false
        IsPresetLocked = false
        
        // 7. Redraw everything!
        RefreshSafeReplacerUI()
        ScrollToCurrentVST()
    end
End

// =========================================================
// RECOVERY ENGINE FOR UI AFTER REPLACE REBOOT
// =========================================================
Function RebuildBrowserStateAfterReboot()
   var activeSlot : Integer
   var loadedName : String
   
   if Size(ReplaceableSlots) > 0 then
       // 1. Safety: Is the slot index valid?
       if CurrentMapSlotIndex < 0 or CurrentMapSlotIndex >= Size(ReplaceableSlots) then 
           CurrentMapSlotIndex = 0 
       end
       
       // 2. Check reality: Which plugin is ACTUALLY in the current slot?
       activeSlot = ReplaceableSlots[CurrentMapSlotIndex]
       loadedName = GetPluginInfo(BLK_VST[activeSlot], 0)
       
       // 3. Sync browser variables (publisher, index) with reality
       SyncBrowserToLoadedPlugin(loadedName)
       
       // 4. Secure preset memory (fallback against null strings)
       if LoadedPresets[activeSlot] == "" then LoadedPresets[activeSlot] = "-" end
       
       // 5. Release lock & draw UI cleanly
       IsBrowsingFavorites = false
       IsPresetLocked = false
       RefreshSafeReplacerUI()
       ScrollToCurrentVST()
   end
End

// =========================================================
// 1. ADD JOB TO THE QUEUE
// =========================================================
Function AddJobToQueue(vstIdx : Integer, targetName : String, targetPath : String, isManualUpdate : Boolean, targetPreset : String)
   var newJob, manualStr : String
   
   if vstIdx < 2 then
       Trace("SECURITY: Blocked replace request for RESIDENT VST " + (vstIdx + 1))
   elsif targetPath != "" then
       if isManualUpdate then manualStr = "true" else manualStr = "false" end
       
       // Append targetPreset to the queue string
       newJob = IntToString(vstIdx) + "|" + targetName + "|" + manualStr + "|" + targetPath + "|" + targetPreset
       
       if GlobalReplaceQueue == "EMPTY" or GlobalReplaceQueue == "" then
           GlobalReplaceQueue = newJob
       else
           GlobalReplaceQueue = GlobalReplaceQueue + ";" + newJob
       end
       SetWidgetLabel(MEM_ReplaceState, GlobalReplaceQueue) 
       Trace("QUEUE: Added Job -> VST " + (vstIdx + 1) + " to " + targetName + " (Preset: " + targetPreset + ")")
   end
End

// =========================================================
// THE GP-ARRAY BYPASS (Hard-Fire Replace)
// =========================================================

Function ContinueActualReplace(success : Boolean, slotIdx : Integer, path : String, isManual : Boolean)
    if success then
        Trace("HARD-FIRE: GUI automation successful. Starting activation for slot " + (slotIdx + 1))
    else
        Trace("HARD-FIRE: TIMEOUT! GUI automation unresponsive. Attempting activation without confirmation...")
    end

    // Issue the activation command
    SetPluginBypassed(BLK_VST[slotIdx], false)
    
    // Activate the TimerTick watchdog
    IsWaitingForWakeUp = true
    WakeUpRetryCount = 0
    WakeUpCheckTimer = TimeSinceStartup() + 200.0 
End

Function FireActualReplace(slotIdx : Integer, path : String, isManual : Boolean)
   Trace("HARD-FIRE: Start sequence for slot " + (slotIdx + 1))
   EmergencyKillSwitch = true
   
   if InSetlistMode() then
       Trace("HARD-FIRE: Forcing Fullscreen via SystemActions...")
       
       // Parameter 81 is "Full Screen" in the System Actions
//       SetParameter(SystemActions, 81, 1.0) 
       
       // Short pause so the graphics can process the fullscreen switch
       Wait(800.0) 
       
       // Switch to Panels view (forces local focus for the following toggle)
       SwitchToPanelView()
       Wait(500.0)
       
       // Save data for Python
       PendingReplaceSlotIdx = slotIdx
       PendingReplacePath = path
       PendingReplaceIsManual = isManual
       
       OSC_IsWaitingForViewSwitch = true
       OSC_ViewSwitchTimeout = TimeSinceStartup() + 3000.0
       
       Trace(">>> OSC-OUT: Sende Laser-Klick Signal an Python <<<")
       OSC_SendDoubleSpecific("/GP/PressCtrlG", 1.0, "127.0.0.1", 8000)
   else
       ContinueActualReplace(true, slotIdx, path, isManual)
   end
End

Function TriggerNextQueueJob()
   var jobs, parts : String Array
   var nextIdx : Integer
   var targetName, cleanPath : String
   var isManual : Boolean // Variable for the flag
   
   if GlobalReplaceQueue != "EMPTY" and GlobalReplaceQueue != "" then
       jobs = SplitString(GlobalReplaceQueue, ";")
       parts = SplitString(jobs[0], "|")
       
       if Size(parts) == 4 then
           nextIdx = StringToInt(parts[0])
           targetName = parts[1]
           isManual = (parts[2] == "true") // <--- NEW: Read the flag from the ticket!
           cleanPath = SuperCleanPath(parts[3])
           
           Trace("QUEUE: Firing Replace directly on Slot " + (nextIdx+1) + " -> " + targetName)
           
           // INSPEKTOR VORBEREITEN (3 Sekunden absolute Ruhe)
           ReplaceTargetIdx = nextIdx
           ReplaceTargetName = targetName
           ReplaceTimeoutTimer = TimeSinceStartup() + 3000.0 
           
           // FIRE! (Now with all 3 arguments)
           FireActualReplace(nextIdx, cleanPath, isManual)
       else
           GlobalReplaceQueue = "EMPTY"
           SetWidgetLabel(MEM_ReplaceState, "EMPTY")
       end
   end
End

Function ExecuteVSTReplace(vstIdx : Integer, targetName : String, targetPath : String, isManualUpdate : Boolean)
   var cleanName : String = TrimString(targetName)
   
   if vstIdx < 2 then
       Trace("SECURITY: Blocked replace request for RESIDENT VST " + (vstIdx + 1))
   elsif targetPath != "" then
       Trace("REPLACER: Queued VST " + (vstIdx + 1) + " swap to '" + cleanName + "'")
       
       // NO LONGER call ReplacePlugin directly, push cleanly into the queue instead!
       AddJobToQueue(vstIdx, cleanName, targetPath, isManualUpdate, "-")
   end
End

// ---------------------------------------------------------
// HELPER: GET PATH FOR VST (for the .vst3 variant)
// ---------------------------------------------------------
Function GetPathForVst(vstName : String) Returns String
   var i : Integer = 0
   var found : Boolean = false
   
   result = ""
   
   // FIX: Search in the new master database (DB_VstNames)
   // ---> SAFE WHILE-LOOP <---
   While i < Size(DB_VstNames) and not found Do
      if DB_VstNames[i] == vstName then
         result = DB_VstPaths[i]
         found = true
      end
      i = i + 1 // Always increment
   End
End

// ---------------------------------------------------------
// VST DATABASE LOADER & FILTERING
// ---------------------------------------------------------
Function LoadVstDatabase()
   var content, line, pth, pub, plg, cType : String
   var lines, parts, leftParts : String Array
   var i, u, extPos, pDown, pUp : Integer
   var found : Boolean
   
   DB_Publishers = []; DB_VstNames = []; DB_VstPaths = []; UniquePublishers = []
   DB_ControlType = []; DB_ParamDown = []; DB_ParamUp = []
   
   if FileExists(VstDatabaseFilePath) then
       content = LoadStringFromTextFile(VstDatabaseFilePath)
       lines = SplitString(content, NEW_LINE)
       
       For i = 0; i < Size(lines); i = i + 1 Do
           line = TrimString(lines[i])
           if Length(line) > 0 and IndexOfSubstring(line, ";", false) != 0 and IndexOfSubstring(line, "[", false) != 0 then
               
               parts = SplitString(line, "=")
               if Size(parts) == 2 then
                   
                   leftParts = SplitString(TrimString(parts[0]), "|")
                   if Size(leftParts) >= 2 then
                       pub = TrimString(leftParts[0])
                       plg = TrimString(leftParts[1])
                       
                       DB_Publishers <-- pub
                       DB_VstNames <-- plg
                       
                       found = false
                       for u = 0; u < Size(UniquePublishers); u = u + 1 do
                           if UniquePublishers[u] == pub then found = true end
                       end
                       if not found then UniquePublishers <-- pub end
                       
                       cType = "NONE"; pDown = 0; pUp = 0
                       if Size(leftParts) >= 5 then
                           cType = TrimString(leftParts[2])
                           pDown = StringToInt(TrimString(leftParts[3]))
                           pUp = StringToInt(TrimString(leftParts[4]))
                       elsif Size(leftParts) >= 3 then 
                           cType = TrimString(leftParts[2])
                       end
                       
                       DB_ControlType <-- cType
                       DB_ParamDown <-- pDown
                       DB_ParamUp <-- pUp
                       
                       // 4. DIE RECHTE SEITE (PFAD) AUSLESEN & BEREINIGEN
                       pth = TrimString(parts[1])
                       pth = ReplaceString(pth, "\"", "", false)
                       
                       DB_VstPaths <-- pth
                   end
               end
           end
       End
       Trace("VST-DB: Loaded " + Size(DB_VstNames) + " Plugins.")
   else
       Trace("CRITICAL: VstDatabase.txt not found at " + VstDatabaseFilePath)
       DB_Publishers <-- "None"; DB_VstNames <-- "None"; DB_VstPaths <-- ""; UniquePublishers <-- "None"
       DB_ControlType <-- "NONE"; DB_ParamDown <-- 0; DB_ParamUp <-- 0
   end
End

// =========================================================
// ARRAY HEALER (Repairs the dead pointer after Replace)
// =========================================================
Function RefreshVstArray(idx : Integer)
   Select
      idx == 0 Do BLK_VST[0] = VST1_GRS
      idx == 1 Do BLK_VST[1] = VST2_GRS
      idx == 2 Do BLK_VST[2] = VST3_GRS
      idx == 3 Do BLK_VST[3] = VST4_GRS
      idx == 4 Do BLK_VST[4] = VST5_GRS
      idx == 5 Do BLK_VST[5] = VST6_GRS
      idx == 6 Do BLK_VST[6] = VST7_GRS
      idx == 7 Do BLK_VST[7] = VST8_GRS
      idx == 8 Do BLK_VST[8] = VST9_GRS
      idx == 9 Do BLK_VST[9] = VST10_GRS
   End
End


// ============================================================================
// SECTION 21: ORCHESTRATION
// ============================================================================

Function CycleGlobalSystemMode()
   var modeName : String

   StickySystemMode = -1  // Reset sticky on explicit mode change
   SystemModeActive = true

   GlobalSystemMode = GlobalSystemMode + 1
   if GlobalSystemMode > 4 then GlobalSystemMode = 0 end

   modeName = SysModeNames[GlobalSystemMode]

   Trace("SYS-MODE: Switched to " + modeName)
   OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> SYS-MODE: " + modeName + " <<<", Local_IP, Local_PORT)
   MacroFeedbackTimer = TimeSinceStartup() + 2000.0
   MacroFeedbackLockTimer = TimeSinceStartup() + 2000.0
End

Function SelectGlobalSystemMode(targetMode : Integer)
    var modeName : String

    if targetMode < 0 or targetMode > 4 then
        Trace("SYSMODE_SELECT: Invalid mode " + targetMode)
    else
        StickySystemMode = -1  // Reset sticky on explicit mode change
        GlobalSystemMode = targetMode
        SystemModeActive = true

        modeName = SysModeNames[GlobalSystemMode]
        Trace("SYS-MODE: Selected " + modeName)
        OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> SYS-MODE: " + modeName + " <<<", Local_IP, Local_PORT)
        MacroFeedbackTimer = TimeSinceStartup() + 2000.0
        MacroFeedbackLockTimer = TimeSinceStartup() + 2000.0
    end
End

Function StartTimelineRecording()
    // Start count-in
    TimelineCountInTimer = TimeSinceStartup() + GetCountInDurationMS()
    TimelineRecActive = false  // Not yet — wait for count-in to expire
    TimelineCurrentPartIdx = 1 // First manual marker = part 1 (Intro is implicit at t=0)
    PreviewPartIdx = 0

    // In Overdub mode, keep existing working arrays (append to them)
    // In Replace mode, clear them
    if TimelineRecState != 1 then
        Arr_Rec_TimeMS = []; Arr_Rec_Type = []; Arr_Rec_Val = []
    end

    Trace("TIMELINE: Count-in started, expires in " + Round(GetCountInDurationMS()) + "ms")
    OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> TIMELINE: Count-In... <<<", Local_IP, Local_PORT)
    MacroFeedbackTimer = TimeSinceStartup() + GetCountInDurationMS() + 500.0
End

Function CommitTimelineRecording()
    var i : Integer
    var lmCount, lmIdxTrace : Integer

    if TimelineRecState == 1 then
        // Overdub: Append new events to existing committed events
        for i = 0; i < Size(Arr_Rec_TimeMS); i = i + 1 do
            Snap_TL_TimeMS <-- Arr_Rec_TimeMS[i]
            Snap_TL_Type <-- Arr_Rec_Type[i]
            Snap_TL_Val <-- Arr_Rec_Val[i]
        end
    else
        // Replace: Overwrite committed with working
        Snap_TL_TimeMS = []; Snap_TL_Type = []; Snap_TL_Val = []
        for i = 0; i < Size(Arr_Rec_TimeMS); i = i + 1 do
            Snap_TL_TimeMS <-- Arr_Rec_TimeMS[i]
            Snap_TL_Type <-- Arr_Rec_Type[i]
            Snap_TL_Val <-- Arr_Rec_Val[i]
        end
    end

    if DebugMode then
        lmCount = 0
        for lmIdxTrace = 0; lmIdxTrace < Size(Snap_TL_Type); lmIdxTrace = lmIdxTrace + 1 do
            if Snap_TL_Type[lmIdxTrace] == "LoopMaster" then lmCount = lmCount + 1 end
        end
        Trace("LOOPER-TL: snapshot now contains " + lmCount + " LoopMaster events")
    end

    Snap_TL_Fired = []

    TimelineRecActive = false
    TimelineCountInTimer = 0.0
    Trace("TIMELINE: Recording committed. " + Size(Snap_TL_TimeMS) + " events.")
End

Function DiscardTimelineRecording()
    Arr_Rec_TimeMS = []; Arr_Rec_Type = []; Arr_Rec_Val = []
    TimelineRecActive = false
    TimelineCountInTimer = 0.0

    Trace("TIMELINE: Recording discarded.")
    OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> RECORDING DISCARDED <<<", Local_IP, Local_PORT)
    MacroFeedbackTimer = TimeSinceStartup() + 2000.0

    // Restart recording immediately so user can re-record
    TimelineRecState = 0  // Reset to Replace
    StartTimelineRecording()
End

Function ExecuteRecSongpart()
    var partName : String

    if not TimelineRecActive then
        Trace("TIMELINE: REC_SONGPART ignored (not recording)")

    // No parts loaded — single-marker recording (marks song end)
    elsif Size(Arr_SectionNames) == 0 then
        RecordEndTimeMS = TimeSinceStartup() - RecordStartTimeMS
        RecordTimelineEvent("Marker", 0)
        CommitTimelineRecording()
        TimelineSubMode = 0
        OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> SONG RECORDED <<<", Local_IP, Local_PORT)
        MacroFeedbackTimer = TimeSinceStartup() + 2000.0

    // Last part already recorded — this press = END OF SONG
    elsif TimelineCurrentPartIdx >= Size(Arr_SectionNames) then
        RecordEndTimeMS = TimeSinceStartup() - RecordStartTimeMS
        RecordTimelineEvent("Marker", TimelineCurrentPartIdx)
        CommitTimelineRecording()
        TimelineSubMode = 0
        OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> SONG RECORDED <<<", Local_IP, Local_PORT)
        MacroFeedbackTimer = TimeSinceStartup() + 2000.0
        Trace("TIMELINE: END OF SONG at " + Round(RecordEndTimeMS) + "ms")

    else
        // Normal part marker
        partName = Arr_SectionNames[TimelineCurrentPartIdx]
        RecordTimelineEvent("Marker", TimelineCurrentPartIdx)

        OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> PART: " + partName + " <<<", Local_IP, Local_PORT)
        MacroFeedbackTimer = TimeSinceStartup() + 2000.0

        TimelineCurrentPartIdx = TimelineCurrentPartIdx + 1
        Trace("TIMELINE: Recorded part " + partName + ", next idx=" + TimelineCurrentPartIdx)
    end
End

Function PartJumpPreview(dir : Integer)
    var partName : String

    if Size(Arr_SectionNames) == 0 then
        OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> NO PARTS LOADED <<<", Local_IP, Local_PORT)
        MacroFeedbackTimer = TimeSinceStartup() + 2000.0
    else
        PreviewPartIdx = PreviewPartIdx + dir
        if PreviewPartIdx < 0 then PreviewPartIdx = 0 end
        if PreviewPartIdx >= Size(Arr_SectionNames) then PreviewPartIdx = Size(Arr_SectionNames) - 1 end

        partName = Arr_SectionNames[PreviewPartIdx]

        OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> " + partName + " <<<", Local_IP, Local_PORT)
        MacroFeedbackTimer = TimeSinceStartup() + 2000.0

        Trace("TIMELINE: Preview part " + PreviewPartIdx + " = " + partName)
    end
End

// Replay overlay toggle from Timeline (defined here to satisfy forward declaration
// order — ActivateOverlay/DeactivateOverlay are defined later and call UpdateSoloMuteState
// which has further dependencies). Sets Mem_* directly; SoloMuteStateDirty flag defers
// the UpdateSoloMuteState call to the next TimerTick or parameter change.
Function ReplayOverlayToggle(funcName : String, channel : Integer, state : Integer)
   if funcName == "SMART_SOLO" then
      Mem_SoloSmart[channel] = state
      if state == 1 then Mem_SoloStrict[channel] = 0 end
      SoloMuteStateDirty = true
   elsif funcName == "STRICT_SOLO" then
      Mem_SoloStrict[channel] = state
      if state == 1 then Mem_SoloSmart[channel] = 0 end
      SoloMuteStateDirty = true
   elsif funcName == "USER_MUTE" then
      Mem_UserMute[channel] = state
      SoloMuteStateDirty = true
   elsif funcName == "ROOT" then
      Mem_NP_ChordMode[channel] = state
      SetParameter(BLK_NoteProcessor[channel], GetParamIdxByName(BLK_NoteProcessor[channel], "p_ChordMode"), IntToFloat(state))
   elsif funcName == "OCTAVER" then
      Mem_NP_Octaver[channel] = state
      SetParameter(BLK_NoteProcessor[channel], GetParamIdxByName(BLK_NoteProcessor[channel], "p_Octaver"), IntToFloat(state))
   elsif funcName == "HUMANIZE" then
      Mem_NP_HumanizeActive[channel] = state
      SetParameter(BLK_NoteProcessor[channel], GetParamIdxByName(BLK_NoteProcessor[channel], "p_HumanizeActive"), IntToFloat(state))
   elsif funcName == "SCALE" then
      Mem_NP_QuantizeActive[channel] = state
      SetParameter(BLK_NoteProcessor[channel], GetParamIdxByName(BLK_NoteProcessor[channel], "p_QuantizeActive"), IntToFloat(state))
   elsif funcName == "RANGE" then
      Mem_NP_VelRangeActive[channel] = state
      SetParameter(BLK_NoteProcessor[channel], GetParamIdxByName(BLK_NoteProcessor[channel], "p_VelRangeActive"), IntToFloat(state))
   elsif funcName == "AUTO_SUSTAIN" then
      Mem_NP_AutoSustain[channel] = state
      SetParameter(BLK_NoteProcessor[channel], GetParamIdxByName(BLK_NoteProcessor[channel], "p_AutoSustain"), IntToFloat(state))
   end
   if DebugMode then
      Trace("TIMELINE REPLAY: " + funcName + " CH" + IntToString(channel) + " -> " + IntToString(state))
   end
End

Function FireTimelineEvent(eventType : String, eventVal : Integer)
    var ovlFuncPlay : String
    var ovlChPlay, ovlStatePlay : Integer
    // Origin flag: marks every macro write in this function as "from
    // Timeline replay" so On ParameterValueChanged from ExternalArranger
    // can (a) auto-start a bound LFO and (b) skip Timeline recording.
    Timeline_IsReplaying = true

    if eventType == "Macro" then
        if eventVal >= 0 and eventVal < MAX_MACROS then
            ScriptWrite_ExpectedPrev[eventVal] = ScriptWrite_Expected[eventVal]
            ScriptWrite_Expected[eventVal] = 1.0
        end
        SetParameter(ExternalArranger, eventVal, 1.0)
    elsif eventType == "Map" then
        if eventVal >= 0 and eventVal < Size(CtrlMapList) then
            Trace("TIMELINE: Auto-Switching Map to -> " + CtrlMapList[eventVal])
            LoadControllerMap(CtrlMapList[eventVal])
            HardwareSyncTimer = TimeSinceStartup() + 400.0
            OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> TL-MAP: " + CtrlMapList[eventVal] + " <<<", Local_IP, Local_PORT)
            MacroFeedbackTimer = TimeSinceStartup() + 2000.0
        end
    elsif eventType == "Style" then
        TriggerStyleAction(eventVal)
    elsif eventType == "RegMem" then
        if eventVal >= 0 then
            Trace("TIMELINE: RegMem -> " + eventVal)
            if eventVal < MAX_MACROS then
                ScriptWrite_ExpectedPrev[eventVal] = ScriptWrite_Expected[eventVal]
                ScriptWrite_Expected[eventVal] = 1.0
            end
            SetParameter(ExternalArranger, eventVal, 1.0)
        end
    elsif eventType == "Marker" then
        if eventVal >= 0 and eventVal < Size(Arr_SectionNames) then
            PreviewPartIdx = eventVal
            OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> " + Arr_SectionNames[eventVal] + " <<<", Local_IP, Local_PORT)
            MacroFeedbackTimer = TimeSinceStartup() + 2000.0
            Trace("TIMELINE: Part -> " + Arr_SectionNames[eventVal])
        end
    elsif IndexOfSubstring(eventType, "OVL_", false) == 0 then
        // Overlay event playback: decode funcName, channel, state
        ovlFuncPlay = CopySubstring(eventType, 4, Length(eventType) - 4)
        ovlChPlay = eventVal / 2
        ovlStatePlay = eventVal - (ovlChPlay * 2)
        ReplayOverlayToggle(ovlFuncPlay, ovlChPlay, ovlStatePlay)
        Trace("TIMELINE: Overlay " + ovlFuncPlay + " CH" + IntToString(ovlChPlay) + " -> " + IntToString(ovlStatePlay))
    end

    Timeline_IsReplaying = false
End

Function StartTimelinePlayback()
    var i : Integer

    if Size(Snap_TL_TimeMS) == 0 then
        Trace("TIMELINE: No events to play back.")
    else
        PlaybackStartTimeMS = TimeSinceStartup()
        TimelinePlaybackActive = true
        PreviewPartIdx = 0

        // Reset fired flags
        Snap_TL_Fired = []
        for i = 0; i < Size(Snap_TL_TimeMS); i = i + 1 do
            Snap_TL_Fired <-- false
        end

        Trace("TIMELINE: Playback started at " + Round(PlaybackStartTimeMS) + "ms, " + Size(Snap_TL_TimeMS) + " events.")
    end
End

Function CalculateBarFromMS(timeMS : Double) Returns Integer
    var msPerBar : Double = 0.0
    var bpm : Double = RecordedBPM
    var timeSig : Integer = RecordedTimeSig

    if bpm < 1.0 then bpm = 120.0 end
    if timeSig <= 0 then timeSig = 4 end

    msPerBar = (60000.0 / bpm) * IntToFloat(timeSig)

    if msPerBar <= 0.0 then result = 1
    else result = Round(timeMS / msPerBar) + 1
    end
End

// ---------------------------------------------------------
// REALTIME SMART BYPASS — per-scope two-branch logic
//
// Per channel with active RECH input, decide independently:
//   Mem_ScopeBypassConfigured[ch] = true  -> Explicit Branch:
//      honor Mem_ManualVSTBypass[] for every routed VST of this scope
//   Mem_ScopeBypassConfigured[ch] = false -> Default Branch:
//      activate only the first routed VST of HumanRoutingMap[ch],
//      bypass the rest
//
// Contributions from all active scopes are merged with OR logic:
// a VST is ultimately active iff at least one scope contributes
// "active" for it. This matches the pre-existing behaviour where
// any-routed-scope-needs-it wakes a VST.
// ---------------------------------------------------------
Function ExecuteSmartBypass()
   var ch, i, p, activeInputs, vstIdx : Integer
   var routeParts : String Array
   var vstShouldBeActive : Boolean Array = [false, false, false, false, false, false, false, false, false, false]

   // 1. Per channel: gather routing contributions
   For ch = 0; ch < 16; ch = ch + 1 Do
       activeInputs = 0
       For i = 0; i < 16; i = i + 1 Do
          if GetParameter(RECH, (i * 16) + ch) > 0.5 then activeInputs = activeInputs + 1 end
       End

       if activeInputs > 0 then
           // Channel is in use -> NoteProcessor on
           if IsPluginBypassed(BLK_NoteProcessor[ch]) then
               SetPluginBypassed(BLK_NoteProcessor[ch], false)
               if DebugMode then Trace("BYPASS: NP ch" + (ch+1) + " woken (active inputs=" + activeInputs + ")") end
           end

           routeParts = SplitString(HumanRoutingMap[ch], ",")

           if Mem_ScopeBypassConfigured[ch] then
               // EXPLICIT BRANCH: honor Mem_ManualVSTBypass for each routed VST
               For p = 0; p < Size(routeParts); p = p + 1 Do
                   vstIdx = StringToInt(TrimString(routeParts[p])) - 1
                   if vstIdx >= 0 and vstIdx < MAX_VSTS then
                       if not Mem_ManualVSTBypass[vstIdx] then
                           vstShouldBeActive[vstIdx] = true
                       end
                   end
               End
           else
               // DEFAULT BRANCH: first routed VST active, rest stay at their current contribution
               if Size(routeParts) > 0 then
                   vstIdx = StringToInt(TrimString(routeParts[0])) - 1
                   if vstIdx >= 0 and vstIdx < MAX_VSTS then
                       vstShouldBeActive[vstIdx] = true
                   end
               end
           end
       else
           // Channel NOT in use -> NoteProcessor sleep
           if not IsPluginBypassed(BLK_NoteProcessor[ch]) then
               SetPluginBypassed(BLK_NoteProcessor[ch], true)
               if DebugMode then Trace("BYPASS: NP ch" + (ch+1) + " parked (no active inputs)") end
           end
       end
   End

   // 2. Apply merged decisions to the plugin bypass states
   For i = 0; i < MAX_VSTS; i = i + 1 Do
       if vstShouldBeActive[i] then
           if IsPluginBypassed(BLK_VST[i]) then
               SetPluginBypassed(BLK_VST[i], false)
               RestoreFadersForVST(i)
               if DebugMode then Trace("BYPASS: VST " + (i+1) + " woken (merged OR across scopes)") end
           end
       else
           if not IsPluginBypassed(BLK_VST[i]) then
               ParkFadersForVST(i)
               SetPluginBypassed(BLK_VST[i], true)
               if DebugMode then Trace("BYPASS: VST " + (i+1) + " parked (no scope needs it)") end
           end
       end
   End

   UpdateVstInfoDisplay()
   UpdateUsageLabelDisplay()
End


// ============================================================================
// SECTION 15: MIDI & CHANNEL ENGINE
// ============================================================================

// ---------------------------------------------------------
// VST MANUAL OVERRIDE BYPASS CALLBACKS
// ---------------------------------------------------------

Function HandleInjectBypassClick(btnIdx : Integer, val : Double)
    var i, count, firstScopeIdx, targetVstIdx : Integer

    // GPScript-compliant guard:
    if not IsUpdatingBypassUI then

        firstScopeIdx = GetFirstActiveScope()

        if firstScopeIdx > -1 then
            count = 0
            targetVstIdx = -1

            // Which VST belongs to this button?
            if Size(RoutingMatrix) == 160 then
                i = 0
                While i < MAX_VSTS and targetVstIdx == -1 Do
                    if RoutingMatrix[(i * 16) + firstScopeIdx] == true then
                        if count == btnIdx then
                            targetVstIdx = i
                        end
                        count = count + 1
                    end
                    i = i + 1
                End
            end

            // Write value to RAM and execute
            if targetVstIdx > -1 then

                // FLIP TO EXPLICIT BRANCH for this scope on the very first click
                if not Mem_ScopeBypassConfigured[firstScopeIdx] then
                    Mem_ScopeBypassConfigured[firstScopeIdx] = true
                    if DebugMode then Trace("BYPASS: scope ch" + (firstScopeIdx+1) + " switched to Explicit Branch (first click)") end
                end

                // NEW POLARITY: lit button (val > 0.5) = VST active = Mem_ManualVSTBypass = false
                if val > 0.5 then
                    Mem_ManualVSTBypass[targetVstIdx] = false  // Button LIT = VST active
                    if DebugMode then Trace("BYPASS: VST " + (targetVstIdx+1) + " set ACTIVE via button " + (btnIdx+1)) end
                else
                    Mem_ManualVSTBypass[targetVstIdx] = true   // Button DARK = VST bypassed
                    if DebugMode then Trace("BYPASS: VST " + (targetVstIdx+1) + " set BYPASSED via button " + (btnIdx+1)) end
                end

                // Force immediate re-evaluation
                ExecuteSmartBypass()

                // Re-validate VST bindings after bypass change
                ValidateMapVSTs()
                UpdateControllerInfoDisplay()
            end
        end

    end // End of guard block
End


// ============================================================================
// SECTION 21: ORCHESTRATION
// ============================================================================

// ----------------------------------------------------------------------
// --- THE INSPECTOR (Analysis Engine) ---
// ----------------------------------------------------------------------

Function AnalyzeChannel(chIdx : Integer) Returns Integer
   var activeInputs, p, vstIdx : Integer
   var colorCode, count : Integer 
   var routingText, bypassStr, chActiveStr : String
   
   // Status Flags
   var s_NP : String 
   var isFact_Total : Boolean = true 
   var isUser_Total : Boolean = true 
   var isCustom_Total : Boolean = false
   
   var tagString, suffixString : String 
   var chName : String = "Ch" + (chIdx + 1)
   
   // 1. ROUTING CHECK (Incoming connections)
   activeInputs = 0
   For p = 0; p < 16; p = p + 1 Do
      if GetParameter(RECH, (p * 16) + chIdx) > 0.5 then activeInputs = activeInputs + 1 end
   End
   
   // 2. DATA ANALYSE (Scriptlet checken)
   isUser_Total = CheckBlock(BLK_NoteProcessor[chIdx], DEF_NoteProcessor, chName + " NP(Std)")
   if isUser_Total then 
       s_NP = "Standard" 
   else 
       isFact_Total = CheckBlock(BLK_NoteProcessor[chIdx], FACT_NoteProcessor, chName + " NP(Fact)")
       if isFact_Total then s_NP = "Factory" else s_NP = "Custom" end 
   end
   
   if not isFact_Total and not isUser_Total then isCustom_Total = true end

   // 3. BUILD TAGS (for the 3rd line)
   suffixString = ""
   tagString = "["
   if activeInputs == 0 then tagString = tagString + "OFF" elsif activeInputs == 1 then tagString = tagString + "ON" else tagString = tagString + "MERGE" end
   tagString = tagString + " | "
   if isFact_Total then tagString = tagString + "FACT" elsif isUser_Total then tagString = tagString + "STD" else tagString = tagString + "CUST" end
   tagString = tagString + "]"
   
   // --- COLOR LOGIC ---
   if activeInputs > 1 then colorCode = 2 
   elsif activeInputs == 0 and isCustom_Total then colorCode = 4; suffixString = " (Unused Edits)" 
   elsif activeInputs == 0 then colorCode = 0
   elsif activeInputs == 1 and isCustom_Total then colorCode = 3 
   else colorCode = 1 end
   
   // --- BUILD NOTE PROCESSOR TAGS (Directly from the plugin!) ---
   if GetParameter(BLK_NoteProcessor[chIdx], 14) > 0.5 then // p_ChordMode
      suffixString = suffixString + " [Root"
      if GetParameter(BLK_NoteProcessor[chIdx], 16) > 0.5 then suffixString = suffixString + "(H)]" else suffixString = suffixString + "]" end // Engine
   end
   if GetParameter(BLK_NoteProcessor[chIdx], 20) > 0.5 then suffixString = suffixString + " [Sus]" end // AutoSustain
   if GetParameter(BLK_NoteProcessor[chIdx], 22) > 0.5 then suffixString = suffixString + " [MonoL]" end // Mono Lowest
   if GetParameter(BLK_NoteProcessor[chIdx], 23) > 0.5 then suffixString = suffixString + " [MonoH]" end // Mono Highest
   
   if Mem_UserMute[chIdx] == 1 then suffixString = suffixString + " [MUTED]" end 
   
   // 4. VST COLLECTOR (for the 2nd line)
   count = 0
   routingText = ""
   if Size(RoutingMatrix) == 160 then
       For vstIdx = 0; vstIdx < MAX_VSTS; vstIdx = vstIdx + 1 Do
           if RoutingMatrix[(vstIdx * 16) + chIdx] == true then
               if count < 3 then
                   // Priority 1: Manual Bypass, Priority 2: CPU Bypass
                   if Mem_ManualVSTBypass[vstIdx] then bypassStr = " [MANUAL]"
                   elsif IsPluginBypassed(BLK_VST[vstIdx]) then bypassStr = " [Bypassed]"
                   else bypassStr = " [Active]" end
                   
                   if count > 0 then routingText = routingText + " | " end
                   routingText = routingText + GetPluginInfo(BLK_VST[vstIdx], 0) + bypassStr
                   count = count + 1
               end
           end
       End
   end
   if count == 0 then routingText = "- None -" end

   // 5. CHANNEL STATUS (for the 1st line)
   if IsPluginBypassed(BLK_NoteProcessor[chIdx]) then chActiveStr = "[Bypassed]" else chActiveStr = "[Active]" end

   // 6. ASSEMBLE BLOCK (3 separate array entries for smooth scrolling)
   Diag_Lines[chIdx * 3] = "CH " + (chIdx+1) + ": " + chActiveStr + " | " + ChannelUsage[chIdx]
   Diag_Lines[(chIdx * 3) + 1] = " |- " + routingText
   Diag_Lines[(chIdx * 3) + 2] = " L- " + tagString + " NP:" + s_NP + suffixString
   
   result = colorCode
End



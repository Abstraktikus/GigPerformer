// 6. INJECTION (KEYBOARD, FILTER, NOTES & BYPASS)
// =========================================================

On WidgetValueChanged(w : Widget, index : Integer, val : Double) from 
   BTN_Inject_FadeIn_Up, BTN_Inject_FadeIn_Down, 
   BTN_Inject_FadeOut_Up, BTN_Inject_FadeOut_Down

   var activeCh : Integer
   if val > 0.5 then
      activeCh = GetFirstActiveScope()
      if activeCh > -1 then
         if w == BTN_Inject_FadeIn_Up then UpdateChannelFade(activeCh, 0, 1, -1.0)
         elsif w == BTN_Inject_FadeIn_Down then UpdateChannelFade(activeCh, 0, -1, -1.0)
         elsif w == BTN_Inject_FadeOut_Up then UpdateChannelFade(activeCh, 1, 1, -1.0)
         elsif w == BTN_Inject_FadeOut_Down then UpdateChannelFade(activeCh, 1, -1, -1.0) end
         RefreshAllInjectionDisplays() 
      end
      SetWidgetValue(w, 0.0)
   end
End


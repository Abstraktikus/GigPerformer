// ---------------------------------------------------------
// ARRANGER KNOBS AND SLIDER INFO DISPLAY (FOR MORPHFADER)
// ---------------------------------------------------------

Function GetHardwareLabel(idx : Integer) Returns String
    if idx >= 0 and idx < MAX_MACROS then
        result = "Macro " + (idx + 1)
    else
        result = "?"
    end
End

// ---------------------------------------------------------
// CONTROLLER INFO DISPLAY (CLEAN, SMART & STATUS AWARE)
// ---------------------------------------------------------

Function GetAssignedHWString(mIdx : Integer) Returns String
   // Hardware assignments are now embedded in ControllerMaps.txt (Source= lines)
   result = ""
End

Function GetLinkNameHelper(idx : Integer) Returns String
   var pName : String = ""
   if Link_IsCC[idx] then
       if Length(Link_ExpectedName[idx]) > 0 then pName = Link_ExpectedName[idx] + " (CC" + Link_TargetParam[idx] + ")"
       else pName = "MIDI CC " + Link_TargetParam[idx] end
   else
       if Link_Type[idx] == 0 then pName = GetParameterName(BLK_VST[Link_BlockIdx[idx]], Link_TargetParam[idx])
       elsif Link_Type[idx] == 1 then pName = GetParameterName(BLK_NoteProcessor[Link_BlockIdx[idx]], Link_TargetParam[idx])
       elsif Link_Type[idx] == 2 then pName = GetParameterName(AudioMixer, Link_TargetParam[idx])
       end
   end
   result = pName
End

/// ---------------------------------------------------------
// SCROLL TO CURRENT CONTROLLER SCOPE
// ---------------------------------------------------------
Function ScrollToCurrentCtrlScope()
    var i, l : Integer
    var targetLine : Integer = 0
    var searchStr, searchStrAlt : String = ""
    var isGrouped : Boolean = false
    var foundLine : Boolean = false // ---> NEW: Clean exit flag <---
    
    var totalLines : Integer = Size(CtrlInfo_Lines)
    var displayLines : Integer = 17 
    var maxStart : Integer = totalLines - displayLines
    var scrollVal : Double = 0.0

    // If EditScope is -1 (Global), targetLine stays 0 -> scrolls to the top!
    if CurrentEditScope != -1 then
        
        // 1. Check categories (is it a group macro?)
        // ---> FIRST SAFE WHILE-LOOP <---
        l = 0
        While l < 16 and not isGrouped Do
            if CurrentEditScope == SOLO_SMART_MacroIdx[l] then searchStr = "Smart Solo"; isGrouped = true
            elsif CurrentEditScope == SOLO_STRICT_MacroIdx[l] then searchStr = "Strict Solo"; isGrouped = true
            elsif CurrentEditScope == USER_MUTE_MacroIdx[l] then searchStr = "User Mute"; isGrouped = true
            elsif CurrentEditScope == LOOPER_CH_MacroIdx[l] then searchStr = "Looper Triggers"; isGrouped = true
            end
            l = l + 1
        End
        
        // 2. Individual functions or standard macros
        if not isGrouped then
            searchStr = GetHardwareLabel(CurrentEditScope) // yields e.g. "Macro 1"
            searchStrAlt = searchStr + " [" // "Macro 1 ["
            searchStr = searchStr + ":"     // "Macro 1:"
        end
        
        // 3. Find the matching line
        // ---> SECOND SAFE WHILE-LOOP <---
        i = 0
        While i < totalLines and not foundLine Do
            if isGrouped then
                // For groups: does the keyword appear anywhere in the line?
                if IndexOfSubstring(CtrlInfo_Lines[i], searchStr, true) > -1 then
                    targetLine = i
                    foundLine = true
                end
            else
                // For individual macros: the line must start exactly with "Macro X:" or "Macro X ["!
                // (Prevents "Macro 1" from falsely matching "Macro 10")
                if IndexOfSubstring(CtrlInfo_Lines[i], searchStr, false) == 0 or 
                   IndexOfSubstring(CtrlInfo_Lines[i], searchStrAlt, false) == 0 then
                    targetLine = i
                    foundLine = true
                end
            end
            i = i + 1
        End
    end

    // 4. Calculate slider value
    if maxStart <= 0 then 
        scrollVal = 1.0 
    else
        if targetLine > maxStart then targetLine = maxStart end
        scrollVal = 1.0 - (IntToFloat(targetLine) / IntToFloat(maxStart))
    end

    // 5. Set value and render display
    SetWidgetValue(SLD_ControllerInfo, scrollVal)
    RefreshCtrlInfoDisplay()
End

// ---------------------------------------------------------
// UNIVERSAL MACRO FEEDBACK ENGINE (The HUD)
// ---------------------------------------------------------
Function TriggerMacroFeedback(sourceIdx : Integer, isCC : Boolean, val : Double)
    var i : Integer
    var msg, pName, paramName : String
    var mappedVal : Double = 0.0
    var linkFound : Boolean = false
    var isJitter : Boolean = false
    
    // ========================================================
    // CPU SAVER (Jitter Gate)
    // ========================================================
    // Check if the same controller/pedal is firing again
    if sourceIdx == Last_HUD_Source and isCC == Last_HUD_IsCC then
        // If value changes by less than 0.5%, it is jitter
        if Abs(val - Last_HUD_Val) < 0.005 then
           isJitter = true
        end
    end
    
    // Only proceed if this was a real movement
    if not isJitter then
        // Store new valid value for this controller
        Last_HUD_Source = sourceIdx
        Last_HUD_IsCC = isCC
        Last_HUD_Val = val

        msg = ""

        // ========================================================
        // 1. CHECK SPECIAL FUNCTIONS
        // ========================================================
        if (not isCC and sourceIdx == CF_MacroIdx) or (isCC and sourceIdx == CF_CCIdx) then
            msg = "Global Audio Balance: " + Round(val * 100.0) + "%"
            linkFound = true
            
        else
            // 2. SEARCH NORMAL PARAMETER LINKS
            For i = 0; i < Link_Count; i = i + 1 Do
                // Grab the FIRST active link belonging to this controller
                if not linkFound and Link_Active[i] and Link_SourceIdx[i] == sourceIdx and Link_SourceIsCC[i] == isCC then
                    
                    // A) Read actual plugin name
                    if Link_Type[i] == 0 then pName = GetPluginInfo(BLK_VST[Link_BlockIdx[i]], 0)
                    elsif Link_Type[i] == 1 then pName = "NoteProc (Ch " + (Link_BlockIdx[i]+1) + ")"
                    elsif Link_Type[i] == 2 then pName = "AudioMixer"
                    else pName = Link_BlockName[i] end

                    // B) Get parameter name
                    paramName = Link_ExpectedName[i]
                    if paramName == "" then paramName = "Param " + Link_TargetParam[i] end

                    // C) Calculate the actual current value
                    mappedVal = Link_MinVal[i] + (val * (Link_MaxVal[i] - Link_MinVal[i]))
                    
                    // D) Assemble the string
                    msg = pName + " | " + paramName + " : " + Round(mappedVal * 100.0) + "%"
                    linkFound = true 
                end
            End
        end // Closes the "else" of step 1
        
        // 3. SEND TO DISPLAY & START TIMER
        // (Only makes sense if it was not jitter)
        if linkFound then
            // ---> MAP-CHANGE LOCK <---
            if TimeSinceStartup() > MacroFeedbackLockTimer then
                Trace("HUD PUSH: Sending '" + msg + "' to display!") 
                OSC_SendStringSpecific("/UI/SetMacroFeedback", msg, Local_IP, Local_PORT)
                MacroFeedbackTimer = TimeSinceStartup() + 1500.0
            else
                // While lock is active, silently discard fader movements
                Trace("HUD PUSH BLOCKED: Map-change lock timer still active.")
            end
        end
        
    end // Closes the "if not isJitter" block
End

// ---------------------------------------------------------
// CONTROLLER INFO DISPLAY (CLEAN, SMART & STATUS AWARE)
// ---------------------------------------------------------

// Hierarchical Controller Info Display
Function UpdateControllerInfoDisplay()
   var m, l, b, fi, v, p, devIdx, lay0Count, layBindCount, vstV, devIdx2, s2 : Integer
   var devName, srcDesc, targetDesc, statusStr, overlayDesc, hwDesc : String
   var hasAny : Boolean = false

   CtrlInfo_Lines = []

   // Header
   CtrlInfo_Lines <-- "--- MAPPING: " + CurrentCtrlMapName + " ---"

   // VST validation status
   For v = 1; v < MAX_VST_DECL; v = v + 1 Do
      if MapVST_Valid[v] > 0 then
         if MapVST_Valid[v] == 1 then
            statusStr = "[OK]"
         elsif MapVST_Valid[v] == 2 then
            statusStr = "[MISMATCH]"
         elsif MapVST_Valid[v] == 3 then
            statusStr = "[NOT LOADED]"
         else
            statusStr = ""
         end
         CtrlInfo_Lines <-- "VST" + IntToString(v) + ": " + MapVST_Name[v] + "  " + statusStr
      end
   End
   CtrlInfo_Lines <-- ""

   // User Macros (1-50) with hierarchy
   For m = 1; m <= 50; m = m + 1 Do
      hasAny = false
      For l = 0; l < MAX_LAYERS; l = l + 1 Do
         if Mac_Layer_BindCount[MacLayerIdx(m, l)] > 0 then
            hasAny = true
         end
      End
      if hasAny or Mac_SourceCount[m] > 0 then
         // Source description
         if Mac_SourceCount[m] > 0 then
            devIdx = Mac_SourceDev[MacSourceIdx(m, 0)]
            if devIdx >= 0 and devIdx < MAX_DEVICES then
               devName = DEV_Name[devIdx]
            else
               devName = "DEV" + IntToString(devIdx)
            end
            srcDesc = devName + ":" + Mac_SourceType[MacSourceIdx(m, 0)] + IntToString(Mac_SourceCtrl[MacSourceIdx(m, 0)])
         else
            srcDesc = "?"
         end
         CtrlInfo_Lines <-- "Macro " + IntToString(m) + " [" + srcDesc + "]:"

         // LAY0: show as "(N Targets)" with sub-lines
         lay0Count = Mac_Layer_BindCount[MacLayerIdx(m, 0)]
         if lay0Count > 0 then
            if lay0Count == 1 then
               CtrlInfo_Lines <-- "  LAY0: (1 Target)"
            else
               CtrlInfo_Lines <-- "  LAY0: (" + IntToString(lay0Count) + " Targets)"
            end
            For b = 0; b < lay0Count; b = b + 1 Do
               fi = MacLayerBindIdx(m, 0, b)
               targetDesc = Mac_Layer_Target[fi]
               if Length(Mac_Layer_ParamLabel[fi]) > 0 then
                  targetDesc = targetDesc + " " + Mac_Layer_ParamLabel[fi]
               end
               if Mac_Layer_RangeMin[fi] <> 0.0 or Mac_Layer_RangeMax[fi] <> 1.0 then
                  targetDesc = targetDesc + " {" + DoubleToString(Mac_Layer_RangeMin[fi], 1) + "," + DoubleToString(Mac_Layer_RangeMax[fi], 1) + "}"
               end
               // Check VST validity
               if Mac_Layer_TargetType[fi] == "VST" then
                  vstV = Mac_Layer_VSTIdx[fi]
                  if vstV >= 1 and vstV < MAX_VST_DECL then
                     if MapVST_Valid[vstV] > 1 then
                        targetDesc = targetDesc + "  [BLOCKED: VST" + IntToString(vstV) + " invalid]"
                     end
                  end
               end
               CtrlInfo_Lines <-- "    -> " + targetDesc
            End
         end

         // LAY1-N: single line each
         For l = 1; l < MAX_LAYERS; l = l + 1 Do
            layBindCount = Mac_Layer_BindCount[MacLayerIdx(m, l)]
            if layBindCount > 0 then
               fi = MacLayerBindIdx(m, l, 0)
               overlayDesc = Mac_Layer_Target[fi]
               if Mac_Layer_TargetType[fi] == "OVERLAY" then
                  overlayDesc = overlayDesc + ":CH" + IntToString(Mac_Layer_Channel[fi])
               end
               if Mac_Layer_RangeMin[fi] <> 0.0 or Mac_Layer_RangeMax[fi] <> 1.0 then
                  overlayDesc = overlayDesc + " {" + DoubleToString(Mac_Layer_RangeMin[fi], 1) + "," + DoubleToString(Mac_Layer_RangeMax[fi], 1) + "}"
               end
               CtrlInfo_Lines <-- "  LAY" + IntToString(l) + ": " + overlayDesc
            end
         End
      end
   End

   // CC Bindings (Permanent)
   CtrlInfo_Lines <-- ""
   CtrlInfo_Lines <-- "--- CC BINDINGS (Permanent) ---"
   For p = 0; p < Permanent_Count; p = p + 1 Do
      CtrlInfo_Lines <-- "CC" + IntToString(Permanent_SourceCC[p]) + ": " + Permanent_Function[p]
   End

   // System Macro Groups
   CtrlInfo_Lines <-- ""
   CtrlInfo_Lines <-- "--- SYSTEM MACRO GROUPS ---"
   CtrlInfo_Lines <-- ">> Macro 51-66: Looper (Ch 1-16) <<"
   CtrlInfo_Lines <-- ">> Macro 67-82: Smart Solo (Ch 1-16) <<"
   CtrlInfo_Lines <-- ">> Macro 83-98: Strict Solo (Ch 1-16) <<"
   CtrlInfo_Lines <-- ">> Macro 99-114: User Mute (Ch 1-16) <<"
   CtrlInfo_Lines <-- ">> Macro 115-130: Velocity Range (Ch 1-16) <<"
   CtrlInfo_Lines <-- ">> Macro 131-146: Root/Chord (Ch 1-16) <<"
   CtrlInfo_Lines <-- ">> Macro 147-162: Octaver (Ch 1-16) <<"
   CtrlInfo_Lines <-- ">> Macro 163-178: Humanizer (Ch 1-16) <<"
   CtrlInfo_Lines <-- ">> Macro 179-194: Scale Quantizer (Ch 1-16) <<"
   CtrlInfo_Lines <-- ">> Macro 195-210: Auto Sustain (Ch 1-16) <<"

   // Hardware Assignments
   CtrlInfo_Lines <-- ""
   CtrlInfo_Lines <-- "--- HARDWARE ASSIGNMENTS ---"
   For m = 1; m <= MAX_MACROS; m = m + 1 Do
      if Mac_SourceCount[m] > 0 then
         devIdx2 = Mac_SourceDev[MacSourceIdx(m, 0)]
         if devIdx2 >= 0 and devIdx2 < MAX_DEVICES then
            hwDesc = DEV_Name[devIdx2]
         else
            hwDesc = "DEV" + IntToString(devIdx2)
         end
         hwDesc = hwDesc + ":" + Mac_SourceType[MacSourceIdx(m, 0)] + IntToString(Mac_SourceCtrl[MacSourceIdx(m, 0)])
         if Mac_SourceCount[m] > 1 then
            For s2 = 1; s2 < Mac_SourceCount[m]; s2 = s2 + 1 Do
               devIdx2 = Mac_SourceDev[MacSourceIdx(m, s2)]
               if devIdx2 >= 0 and devIdx2 < MAX_DEVICES then
                  hwDesc = hwDesc + " & " + DEV_Name[devIdx2]
               else
                  hwDesc = hwDesc + " & DEV" + IntToString(devIdx2)
               end
               hwDesc = hwDesc + ":" + Mac_SourceType[MacSourceIdx(m, s2)] + IntToString(Mac_SourceCtrl[MacSourceIdx(m, s2)])
            End
         end
         CtrlInfo_Lines <-- "Macro " + IntToString(m) + " = " + hwDesc
      end
   End

   ScrollToCurrentCtrlScope()
End

// ---------------------------------------------------------
// CONTROLLER MAP SCOPE: SMART RANGE EDITOR (SNAPSHOT STYLE)
// ---------------------------------------------------------

Function UpdateEditScopeDisplay()
   var txt : String
   
   // Priority for empty state
   if CurrentCtrlMapName == "-" or CurrentCtrlMapName == "None" or CurrentCtrlMapName == "" then
       txt = "Scope: -"
       
   // Normal operation
   elsif CurrentEditScope == -1 then
       txt = "Scope: [GLOBAL] (All User Macros)"
   else
       txt = "Scope: [" + GetHardwareLabel(CurrentEditScope) + "]"
   end
   
   SetWidgetLabel(LBL_Edit_Scope, txt)
End

// ---------------------------------------------------------
// CONTROLLER MAP SCOPE: SMART RANGE EDITOR (SNAPSHOT STYLE)
// ---------------------------------------------------------
Function CycleEditScope(dir : Integer)
   var i, nextScope, loopGuard : Integer
   var isValid : Boolean

   nextScope = CurrentEditScope
   isValid = false
   loopGuard = 0

   // If no map is loaded, only "Global" exists
   if CurrentCtrlMapName == "-" or CurrentCtrlMapName == "None" or CurrentCtrlMapName == "" then
       nextScope = -1
       isValid = true
   else
       // Search for the next occupied scope
       While not isValid and loopGuard <= MAX_MACROS + 2 Do
           loopGuard = loopGuard + 1
           nextScope = nextScope + dir

           // Wrap around (-1 to MAX_MACROS-1)
           if nextScope < -1 then nextScope = MAX_MACROS - 1
           elsif nextScope >= MAX_MACROS then nextScope = -1
           end

           // 1. Is it the Global Scope? (always valid)
           if nextScope == -1 then
               isValid = true
                     
           // 2. Is it one of our special functions?
           elsif nextScope == CF_MacroIdx or 
                 nextScope == SCRUB_MacroIdx or
                 nextScope == VST_PREV_MacroIdx or
                 nextScope == VST_NEXT_MacroIdx or
                 nextScope == VST_SCOPE_PREV_MacroIdx or
                 nextScope == VST_SCOPE_NEXT_MacroIdx or
                 nextScope == VST_SCOPE_MacroIdx or
                 nextScope == VST_BROWSE_MacroIdx or
                 nextScope == REC_SONGPART_MacroIdx or
                 nextScope == SYSTEM_TOGGLE_MacroIdx then
               isValid = true
           
           else
               // 3. Is it a Looper or Channel-Toggle Macro?
               i = 0
               While i < 16 and not isValid Do
                   if nextScope == LOOPER_CH_MacroIdx[i] or 
                      nextScope == SOLO_STRICT_MacroIdx[i] or 
                      nextScope == SOLO_SMART_MacroIdx[i] or 
                      nextScope == USER_MUTE_MacroIdx[i] then 
                       isValid = true
                   end
                   i = i + 1
               End
               
               // 4. Are there active links for this controller?
               if not isValid then
                   i = 0
                   While i < Link_Count and not isValid Do
                       if Link_Active[i] and Link_SourceIdx[i] == nextScope then
                           isValid = true
                       end
                       i = i + 1
                   End
               end
           end
       End
   end

   // If a valid scope was found, apply it
   if isValid then
       CurrentEditScope = nextScope
       
       // Send hardware slider position to morph widget (arranger faders 1-16 only)
       if CurrentEditScope > -1 and CurrentEditScope <= 15 then
           SetWidgetValue(SLD_Morph, GetParameter(ExternalArranger, CurrentEditScope))
           if DebugMode then Trace("METER: SLD_Morph <- " + GetParameter(ExternalArranger, CurrentEditScope) + " (CycleEditScope, slot=" + CurrentEditScope + ")") end
       else
           SetWidgetValue(SLD_Morph, 0.0)
           if DebugMode then Trace("METER: SLD_Morph <- 0.0 (CycleEditScope, scope=" + CurrentEditScope + ")") end
       end

       // LOCK: Cancel learn mode when switching to "Global"
       if CurrentEditScope == -1 then
           IsHardwareLearning = false
           SetWidgetValue(BTN_MacroLearn, 0.0)
       end

       // Update labels & auto-scroll
       UpdateEditScopeDisplay()
       ScrollToCurrentCtrlScope()

       // v2: defer LFO inspector refresh to the next TimerTick.
       // RefreshLFOInspector lives far below this function in file order
       // and cannot be called directly without a forward-declaration
       // failure. On TimerTick consumes this flag and repaints.
       LFOInspectorNeedsRefresh = true
   end
End

Function AppendLinkEncoded(name : String, paramId : Integer, sliderIdx : Integer, minV : Double, maxV : Double, expName : String, isCC : Boolean, srcIsCC : Boolean)
   var idx, typeFound, idxFound, countRoutings, r, k : Integer
   var parts : String Array
   var isSleep : Boolean
   var numPart, char : String = ""
   
   // Parse-stop flag (must be at top)
   var stopParse : Boolean = false 
   
   typeFound = -1; idxFound = 0

   // 1. VSTs (Type 0)
   if IndexOfSubstring(name, "VST", false) == 0 then
       k = 3
       // ---> SAFE WHILE-LOOP <---
       While k < Length(name) and not stopParse Do
           char = CopySubstring(name, k, 1)
           if char >= "0" and char <= "9" then 
               numPart = numPart + char 
           else 
               stopParse = true 
           end
           k = k + 1
       End
       
       idx = StringToInt(numPart) - 1
       if idx >= 0 and idx < MAX_VSTS then typeFound = 0; idxFound = idx end
       
   // 2. Channels (NoteProcessor & Direct CC)
   elsif IndexOfSubstring(name, "Ch", false) == 0 then
       parts = SplitString(name, "_")
       if Size(parts) >= 2 then
            idx = StringToInt(ReplaceString(parts[0], "Ch", "", false)) - 1
            if idx >= 0 and idx < 16 then
                if parts[1] == "NP" then typeFound = 1; idxFound = idx end
            end
       else
            idx = StringToInt(ReplaceString(name, "Ch", "", false))
            if idx >= 1 and idx <= 16 then typeFound = 3; idxFound = idx end
       end

   // 3. Mixer (Type 2)
   elsif name == "AudioMixer" then typeFound = 2; idxFound = 0 end
   
   if typeFound > -1 then
       isSleep = false
       if typeFound == 0 then 
           countRoutings = 0
           for r = 0; r < 16; r = r + 1 do
               if RoutingMatrix[(idxFound * 16) + r] == true then countRoutings = countRoutings + 1 end
           end
           if countRoutings == 1 then
               if IndexOfSubstring(expName, "Volume", true) > -1 or IndexOfSubstring(expName, "Level", true) > -1 then isSleep = true end
           end
       end
       
       Link_Active         <-- true
       Link_SourceIdx      <-- sliderIdx
       Link_Type           <-- typeFound
       Link_BlockIdx       <-- idxFound
       Link_TargetParam    <-- paramId
       Link_BlockName      <-- name
       Link_MinVal         <-- minV
       Link_MaxVal         <-- maxV
       Link_ExpectedName   <-- expName 
       Link_IsCC           <-- isCC
       Link_IsSleepSwitch  <-- isSleep
       Link_SourceIsCC     <-- srcIsCC
       Link_Count = Link_Count + 1
   else
       Trace("Link Warning: Could not resolve '" + name + "'")
   end
End

// ---------------------------------------------------------
// STATE DISPLAY FOR RECH CONFIG CHANGES
// ---------------------------------------------------------

Function CaptureRechBaseline()
   var i : Integer
   // Snapshots the current, clean state of the matrix after loading
   For i = 0; i < 256; i = i + 1 Do
      Loaded_RECH_State[i] = GetParameter(RECH, i)
   End
End

Function RefreshCtrlMapList()
   var content, initialContent, tempContent, mapName : String
   var pos, closePos : Integer
   
   Trace("RefreshList: Scanning " + ControllerMapFilePath)

   // 1. AUTO-CREATE (Generic Header)
   if not FileExists(ControllerMapFilePath) then
       Trace("RefreshList: File missing. Creating new database...")
       initialContent = "; CONTROLLER DATABASE" + NEW_LINE + 
                        "; Format: [Map:Name]" + NEW_LINE + 
                        "; Source = BlockAlias : ParameterIndex" + NEW_LINE + 
                        NEW_LINE + 
                        "[Map:Standard]" + NEW_LINE +
                        "; Default Layout for multiple VSTs" + NEW_LINE +
                        NEW_LINE +
                        "[Map:Standard_VST1]" + NEW_LINE +
                        "[Map:Standard_VST2]" + NEW_LINE +
                        "[Map:Standard_VST3]" + NEW_LINE +
                        "[Map:Standard_VST4]" + NEW_LINE +
                        "[Map:Standard_VST5]" + NEW_LINE
                        
       if SaveStringToTextFile(ControllerMapFilePath, initialContent) then
           Trace("RefreshList: File created successfully.")
       else
           Trace("RefreshList: CRITICAL ERROR - Could not create file!")
       end
   end

   // 2. Clear list
   CtrlMapList = []
   CtrlMapList <-- "-" 
   
   // 3. Scan file in high-speed mode (without SplitString!)
   if FileExists(ControllerMapFilePath) then
       content = LoadStringFromTextFile(ControllerMapFilePath)
       tempContent = content
       
       pos = IndexOfSubstring(tempContent, "[Map:", false)
       While pos > -1 Do
           // Cut everything before the map tag
           tempContent = CopySubstring(tempContent, pos, Length(tempContent) - pos)
           
           // Find the closing bracket
           closePos = IndexOfSubstring(tempContent, "]", false)
           if closePos > -1 then
               mapName = CopySubstring(tempContent, 5, closePos - 5)
               CtrlMapList <-- mapName
               Trace("RefreshList: Found Map -> " + mapName)
               
               // Cut the processed portion
               tempContent = CopySubstring(tempContent, closePos, Length(tempContent) - closePos)
           else
               tempContent = "" // Fallback emergency exit
           end
           
           // Find the next map
           pos = IndexOfSubstring(tempContent, "[Map:", false)
       End
   end
   
   Trace("RefreshList: Total Maps = " + Size(CtrlMapList))
End

// ---------------------------------------------------------------------
// CONTROLLER MAP LOADER & BROWSER --> HARDWARE SYNC (WITH BYPASS LOGIC)
// ---------------------------------------------------------------------

Function SyncArrangerToCurrentMap()
   var i, hwIdx : Integer
   var currentVal : Double = 0.0; var range : Double = 0.0; var faderVal : Double = 0.0
   
   if DebugMode then Trace("=== START HARD-TRACE: SYNC ARRANGER TO MAP (" + CurrentCtrlMapName + ") ===") end
   
   For i = 0; i < Link_Count; i = i + 1 Do
       if Link_Active[i] then
           hwIdx = Link_SourceIdx[i]
           
           if DebugMode then Trace("  -> Analyzing Link " + i + " | SourceIdx (Macro/CC): " + hwIdx) end
           
           // ========================================================
           // ---> 50% RULE FOR ONE-WAY CONTROLS (MIDI CC)
           // ========================================================
           if Link_IsCC[i] then
               faderVal = 0.5 
               if DebugMode then Trace("     [IS CC] One-way control detected! Setting faderVal to 0.5 (50%)") end
           else
               // IF IT IS A VST PARAMETER: Ask the host for the actual value!
               if Link_Type[i] == 0 then 
                   currentVal = GetParameter(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i])
                   if DebugMode then Trace("     [IS VST] Type 0 (Plugin " + (Link_BlockIdx[i]+1) + " | Param " + Link_TargetParam[i] + "). Read value: " + currentVal) end
               elsif Link_Type[i] == 1 then 
                   currentVal = GetParameter(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i])
                   if DebugMode then Trace("     [IS NP] Type 1. Read value: " + currentVal) end
               elsif Link_Type[i] == 2 then
                   currentVal = GetParameter(AudioMixer, Link_TargetParam[i])
                   if DebugMode then Trace("     [IS MIXER] Type 2. Read value: " + currentVal) end
               end
               
               range = Link_MaxVal[i] - Link_MinVal[i]
               if Abs(range) > 0.0001 then 
                   faderVal = (currentVal - Link_MinVal[i]) / range 
                   if DebugMode then Trace("     [MATH] Scale: (" + currentVal + " - " + Link_MinVal[i] + ") / " + range + " = " + faderVal) end
               else 
                   faderVal = 0.0 
                   if DebugMode then Trace("     [MATH] WARNING: Range is 0! Setting faderVal to 0.0") end
               end
           end
           
           // Safety clamping
           if faderVal < 0.0 then faderVal = 0.0 elsif faderVal > 1.0 then faderVal = 1.0 end
           
           // Send to hardware (only if the source is an arranger macro)
           if not Link_SourceIsCC[i] then
               // ---> GUARD <---
               if hwIdx >= 0 and hwIdx <= 15 then
                   ScriptWrite_ExpectedPrev[hwIdx] = ScriptWrite_Expected[hwIdx]
                   ScriptWrite_Expected[hwIdx] = faderVal
                   SetParameter(ExternalArranger, hwIdx, faderVal)
                   Mem_Fader_Buffer[hwIdx] = faderVal
                   if DebugMode then Trace("     [HARDWARE] Guard PASSED! Arranger motorfader " + (hwIdx+1) + " moving to " + faderVal) end
               else
                   if DebugMode then Trace("     [HARDWARE] Guard BLOCKED! Index " + hwIdx + " is not a physical arranger fader (0-15).") end
               end
           else
               if DebugMode then Trace("     [HARDWARE] Ignored. Source is a CC, not a physical arranger fader.") end
           end
       end
   End
   if DebugMode then Trace("=== END HARD-TRACE ===") end
End

// ---------------------------------------------------------
// MORPH SEND // Sends slider value to ALL linked parameters
// ---------------------------------------------------------

Function MorphSend(sliderIdx : Integer, val : Double)
    var i : Integer
    For i = 0; i < Link_Count; i = i + 1 Do
        if Link_SourceIdx[i] == sliderIdx then 
            if Link_Type[i] == 0 then SetParameter(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i], val)
            elsif Link_Type[i] == 1 then SetParameter(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i], val)
            elsif Link_Type[i] == 2 then SetParameter(AudioMixer, Link_TargetParam[i], val)
            end
        end
    End
End

// Read values directly from the plugin
Function CaptureSmartRanges(isMin : Boolean)
   var i, sIdx, count : Integer = 0
   var currentVal, diff : Double = 0.0
   
   For i = 0; i < Link_Count; i = i + 1 Do
       if Link_Active[i] then
           sIdx = Link_SourceIdx[i]
           if CurrentEditScope == -1 or CurrentEditScope == sIdx then
               
               // ---> BUGFIX: Skip pure MIDI CCs entirely! <---
               if not Link_IsCC[i] then
                   
                   currentVal = 0.0 // Clean reset for each iteration
                   
                   if Link_Type[i] == 0 then currentVal = GetParameter(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i])
                   elsif Link_Type[i] == 1 then currentVal = GetParameter(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i])
                   elsif Link_Type[i] == 2 then currentVal = GetParameter(AudioMixer, Link_TargetParam[i])
                   end
                   
                   if isMin then 
                       diff = Abs(currentVal - Link_MaxVal[i])
                       if diff > 0.001 then Link_MinVal[i] = currentVal; count = count + 1 end
                   else 
                       diff = Abs(currentVal - Link_MinVal[i])
                       if diff > 0.001 then Link_MaxVal[i] = currentVal; count = count + 1 end
                   end
                   
               end
               
           end
       end
   End
   if isMin then Trace("Editor: Captured MIN (A) values for " + count + " links.") else Trace("Editor: Captured MAX (B) values for " + count + " links.") end
   SyncArrangerToCurrentMap()
   UpdateControllerInfoDisplay()
End

// --------------------------------------------------------------------
// EXPORT SMART CONFIG // Overwrites the map directly in the file
// --------------------------------------------------------------------

Function ExportSmartConfig()
   var s, lnk, typeLoop, pID : Integer
   var line, newBlock, realName, valStr, finalContent, currentLine, lfoPrefix : String
   var linkFound, isCC, inTargetSection, replaced : Boolean
   var lines : String Array

   if CurrentCtrlMapName == "-" or CurrentCtrlMapName == "" then
       Trace("EXPORT ERROR: No Map loaded!")
   else
       // 1. NEUEN BLOCK BAUEN (RAM)
       newBlock = "[Map:" + CurrentCtrlMapName + "]" + NEW_LINE

       // Scan everything: Macros (0) and CCs (1)
       For typeLoop = 0; typeLoop <= 1; typeLoop = typeLoop + 1 Do
           isCC = (typeLoop == 1)
           
           For s = 0; s < 256; s = s + 1 Do // Scan up to new MAX_MACROS
               line = ""
               linkFound = false
               
               if isCC then line = "CC" + s
               else line = "Macro" + (s + 1) end

               // --- SPECIAL FUNCTIONS (SINGLE MACROS) ---
               if (not isCC and s == CF_MacroIdx) or (isCC and s == CF_CCIdx) then
                   newBlock = newBlock + line + " = CROSSFADER" + NEW_LINE
               elsif (not isCC and s == SCRUB_MacroIdx) or (isCC and s == SCRUB_CCIdx) then
                   newBlock = newBlock + line + " = SCRUBBER" + NEW_LINE
               elsif (not isCC and s == VST_PREV_MacroIdx) or (isCC and s == VST_PREV_CCIdx) then
                   newBlock = newBlock + line + " = VST_PREV" + NEW_LINE
               elsif (not isCC and s == VST_NEXT_MacroIdx) or (isCC and s == VST_NEXT_CCIdx) then
                   newBlock = newBlock + line + " = VST_NEXT" + NEW_LINE
               elsif (not isCC and s == VST_BROWSE_MacroIdx) or (isCC and s == VST_BROWSE_CCIdx) then
                   newBlock = newBlock + line + " = VST_BROWSE" + NEW_LINE
               elsif (not isCC and s == VST_SCOPE_MacroIdx) or (isCC and s == VST_SCOPE_CCIdx) then
                   newBlock = newBlock + line + " = VST_SCOPE" + NEW_LINE
               elsif (not isCC and s == VST_SCOPE_PREV_MacroIdx) or (isCC and s == VST_SCOPE_PREV_CCIdx) then
                   newBlock = newBlock + line + " = VST_SCOPE_PREV" + NEW_LINE
               elsif (not isCC and s == VST_SCOPE_NEXT_MacroIdx) or (isCC and s == VST_SCOPE_NEXT_CCIdx) then
                   newBlock = newBlock + line + " = VST_SCOPE_NEXT" + NEW_LINE
               elsif (not isCC and s == REC_SONGPART_MacroIdx) or (isCC and s == REC_SONGPART_CCIdx) then
                   newBlock = newBlock + line + " = REC_SONGPART" + NEW_LINE
               elsif (not isCC and s == SYSTEM_TOGGLE_MacroIdx) or (isCC and s == SYSTEM_TOGGLE_CCIdx) then
                   newBlock = newBlock + line + " = SYSTEM_TOGGLE" + NEW_LINE
               
               else
                   // --- CHECK NORMAL PARAMETER LINKS ---
                   lfoPrefix = ""
                   if not isCC and LFO_ByMacro[s] >= 0 then
                       lfoPrefix = "LFO:" + LFO_Names[LFO_ByMacro[s]] + " | "
                   end
                   line = line + " = " + lfoPrefix
                   For lnk = 0; lnk < Link_Count; lnk = lnk + 1 Do
                       if Link_Active[lnk] and Link_SourceIdx[lnk] == s and Link_SourceIsCC[lnk] == isCC then
                           if linkFound then line = line + " | " end

                           pID = Link_TargetParam[lnk]
                           realName = ""

                           // Determine name
                           if Link_IsCC[lnk] then
                               if Length(Link_ExpectedName[lnk]) > 0 then realName = Link_ExpectedName[lnk] else realName = "CC " + pID end
                           else
                               if Link_Type[lnk] == 0 then realName = GetParameterName(BLK_VST[Link_BlockIdx[lnk]], pID)
                               elsif Link_Type[lnk] == 1 then realName = GetParameterName(BLK_NoteProcessor[Link_BlockIdx[lnk]], pID)
                               elsif Link_Type[lnk] == 2 then realName = GetParameterName(AudioMixer, pID)
                               end
                           end

                           // Assemble line (incl. Min/Max)
                           line = line + Link_BlockName[lnk] + ":"
                           if Link_IsCC[lnk] then line = line + "CC" end
                           line = line + pID
                           if realName != "" then line = line + ":" + realName else line = line + ":" end

                           valStr = " {" + Round(Link_MinVal[lnk]*1000)/1000.0 + ", " + Round(Link_MaxVal[lnk]*1000)/1000.0 + "}"
                           line = line + valStr

                           Link_ExpectedName[lnk] = realName
                           linkFound = true
                       end
                   End
                   if linkFound then newBlock = newBlock + line + NEW_LINE end
               end
           End
       End

       // 2. READ FILE AND REPLACE OLD BLOCK
       finalContent = ""
       inTargetSection = false
       replaced = false
       
       if FileExists(ControllerMapFilePath) then
           lines = SplitString(LoadStringFromTextFile(ControllerMapFilePath), NEW_LINE)
           
           For s = 0; s < Size(lines); s = s + 1 Do
               currentLine = TrimString(lines[s])
               
               // Check if we arrive at a [Map:...] section
               if IndexOfSubstring(currentLine, "[Map:", false) == 0 then
                   if currentLine == "[Map:" + CurrentCtrlMapName + "]" then
                       inTargetSection = true
                       finalContent = finalContent + newBlock // Insert new block
                       replaced = true
                   else
                       inTargetSection = false
                       finalContent = finalContent + lines[s] + NEW_LINE
                   end
               else
                   // Copy lines, EXCEPT when inside the old section of our map
                   if not inTargetSection then
                       finalContent = finalContent + lines[s] + NEW_LINE
                   end
               end
           End
       end
       
       // If the map is completely new and never existed in the file:
       if not replaced then
           finalContent = finalContent + NEW_LINE + newBlock
       end
       
       // 3. WRITE BACK TO FILE!
       if SaveStringToTextFile(ControllerMapFilePath, finalContent) then
           Trace("EXPORT: Successfully saved map '" + CurrentCtrlMapName + "' to file.")
       else
           Trace("EXPORT ERROR: Could not save to " + ControllerMapFilePath)
       end
       
       MapMismatch = false
       UpdateControllerInfoDisplay()
   end
End

// ---------------------------------------------------------
// PREVIEW ACTIVE CONTROLLER MAPS (JOYSTICK SYS MODE)
// Cycles through the base map and all active VST maps
// ---------------------------------------------------------
Function PreviewActiveControllerMaps(direction : Integer)
    var i, j, currIdx : Integer
    var validMaps, uniqueMaps : String Array
    var isDup : Boolean
    var startMap : String
    
    validMaps = []; uniqueMaps = []
    
    // 1. Determine starting point (running map or pre-selected one)
    if PendingMapName != "" then startMap = PendingMapName else startMap = CurrentCtrlMapName end
    
    // 2. Build list of available maps (base + active VSTs)
    if ExpectedMapName != "" and ExpectedMapName != "-" then validMaps <-- ExpectedMapName else validMaps <-- "Standard" end
    For i = 0; i < MAX_VSTS; i = i + 1 Do
        if not IsPluginBypassed(BLK_VST[i]) and GetPluginInfo(BLK_VST[i], 0) != "Element" then
            validMaps <-- "Standard_VST" + (i + 1)
        end
    End
    
    // 3. Filter duplicates
   For i = 0; i < Size(validMaps); i = i + 1 Do
       isDup = false
       j = 0
       While j < Size(uniqueMaps) and not isDup Do
           if uniqueMaps[j] == validMaps[i] then isDup = true end
           j = j + 1
       End
       if not isDup then uniqueMaps <-- validMaps[i] end
   End
   
   // 4. Find index and cycle
   currIdx = -1
   i = 0
   While i < Size(uniqueMaps) and currIdx == -1 Do
       if uniqueMaps[i] == startMap then currIdx = i end
       i = i + 1
   End
   if currIdx == -1 then currIdx = 0 end
    
    currIdx = currIdx + direction
    if currIdx >= Size(uniqueMaps) then currIdx = 0
    elsif currIdx < 0 then currIdx = Size(uniqueMaps) - 1 end
    
    // 5. PREVIEW ONLY: Just store the name!
    PendingMapName = uniqueMaps[currIdx]
    
    // Immediate visual feedback
    OSC_SendStringSpecific("/UI/SetMacroFeedback", ">> SELECT: " + PendingMapName + " <<", Local_IP, Local_PORT)
    MacroFeedbackTimer = TimeSinceStartup() + 3000.0 // Show longer while cycling
End


// ============================================================================
// SECTION 18: LOOPER ENGINE
// ============================================================================

Function GetLoopActionName(val : Integer) Returns String
   if val == 0 then result = "PLAY"
   elsif val == 1 then result = "OVERDUB"
   elsif val == 2 then result = "MUTE"
   else result = "-" end
End

Function GetLoopLengthName(val : Integer) Returns String
   if val == 0 then result = "MANUAL"
   elsif val == 1 then result = "1 BAR"
   else result = IntToString(val) + " BARS" end
End

Function GetLoopOutName(val : Integer) Returns String
   if val == 0 then result = "CHANNEL"
   elsif val == 1 then result = "GLOBAL"
   else result = "-" end
End

Function GetLoopStopName(val : Integer) Returns String
   if val == 0 then result = "INSTANT"
   elsif val == 1 then result = "END OF BAR"
   elsif val == 2 then result = "END OF LOOP"
   else result = "-" end
End

Function RefreshLooperInfoDisplay()
   var visibleCount : Integer = 10 // How many lines fit in the label? (adjust to 9 or 11 if needed)
   var totalLines : Integer = Size(LooperInfo_Lines)
   var maxScroll, startIdx, i : Integer
   var dispTxt : String = "--- LOOPER CONFIGURATION ---" + NEW_LINE

   if totalLines <= visibleCount then
       startIdx = 0
   else
       maxScroll = totalLines - visibleCount
       // Slider 1.0 (top) = Index 0 | Slider 0.0 (bottom) = Max Scroll
       startIdx = Round((1.0 - GetWidgetValue(SLD_LooperConfiguration)) * IntToFloat(maxScroll))
       if startIdx < 0 then startIdx = 0 end
       if startIdx > maxScroll then startIdx = maxScroll end
   end

   For i = 0; i < visibleCount; i = i + 1 Do
       if (startIdx + i) < totalLines then
           dispTxt = dispTxt + LooperInfo_Lines[startIdx + i] + NEW_LINE
       end
   End

   SetWidgetLabel(LBL_LooperConfiguration, dispTxt)
End

// =========================================================
// THE X-RAY SCANNER: LOOPER DIAGNOSTICS
// =========================================================
Function TraceLooperDiagnostic(chIdx : Integer, actionName : String)
    var actStr, lenStr, tgtStr, stopStr, syncStr, countInStr, stateStr, timeStr, blinkStr : String

    if chIdx == -1 then
        Trace("DIAGNOSTIC [" + actionName + "]: Failed - No active Looper Channel in Scope!")
    else
        // 1. Read settings
        actStr = GetLoopActionName(Mem_Loop_Action[chIdx])
        lenStr = GetLoopLengthName(Mem_Loop_Length[chIdx])
        if Mem_Loop_Target[chIdx] == -1 then tgtStr = "STAY" else tgtStr = "CH " + IntToString(Mem_Loop_Target[chIdx] + 1) end
        stopStr = GetLoopStopName(Mem_Loop_StopMode[chIdx])

        // 2. Read global switches
        if GetWidgetValue(BTN_Loop_HostSync) > 0.5 then syncStr = "ON" else syncStr = "OFF" end
        if GetWidgetValue(BTN_Loop_CountIn) > 0.5 then countInStr = "ON" else countInStr = "OFF" end

        // 3. Current state
        stateStr = IntToString(Mem_Loop_State[chIdx])

        // 4. Bar Counters & Sync Mode
        timeStr = "GP: " + Global_CurrentBar + "." + Global_CurrentBeat + "." + Global_CurrentTick +
                  " | SONG: " + CurrentBar + "." + CurrentBeat +
                  " | SYNC-MODE: " + SyncModeNames[CurrentSyncMode]

        // 5. LED Blink Status (variable value vs. actual widget states)
        blinkStr = "Var=" + Global_BlinkState + 
                   " (LED1=" + GetWidgetValue(LBL_Subbar_1) +
                   ", LED2=" + GetWidgetValue(LBL_Subbar_2) +
                   ", LED3=" + GetWidgetValue(LBL_Subbar_3) +
                   ", LED4=" + GetWidgetValue(LBL_Subbar_4) + ")"

        // --- OUTPUT ---
        Trace("=== X-RAY DIAGNOSTIC: " + actionName + " (CH " + (chIdx+1) + ") ===")
        Trace("  SETTINGS : Length=[" + lenStr + "] Action=[" + actStr + "] Target=[" + tgtStr + "] Stop=[" + stopStr + "]")
        Trace("  SWITCHES : HostSync=[" + syncStr + "] CountIn=[" + countInStr + "]")
        Trace("  STATE    : CurrentState=[" + stateStr + "]")
        Trace("  TIMING   : " + timeStr)
        Trace("  BLINK    : " + blinkStr)
        Trace("======================================================")
    end
End

// ---------------------------------------------------------
// LOOPER: DISPLAY RENDERER (builds the UI)
// ---------------------------------------------------------

Function RefreshLooperConfigDisplay()
   var scrollVal : Double = GetWidgetValue(SLD_LooperConfiguration)
   var totalLines : Integer = Size(LooperConfig_Lines)
   var displayLines : Integer = 12 // Adjust to your GUI
   var maxStart : Integer = totalLines - displayLines
   var startIdx, i : Integer
   var finalText : String = "--- LOOPER CONFIGURATION ---" + NEW_LINE // + NEW_LINE

   if maxStart < 0 then maxStart = 0 end
   startIdx = Round((1.0 - scrollVal) * IntToFloat(maxStart))

   For i = 0; i < displayLines; i = i + 1 Do
      if (startIdx + i) < totalLines then
         finalText = finalText + LooperConfig_Lines[startIdx + i] + NEW_LINE
      end
   End
   SetWidgetLabel(LBL_LooperConfiguration, finalText)
End

// ---------------------------------------------------------
// LOOPER: ARRAY CLEANER & PROGRESS CALCULATOR
// ---------------------------------------------------------
Function ClearLooperArrays(chIdx : Integer)
   Select 
      chIdx == 0  Do LoopTime_Ch1 = [];  LoopMsg_Ch1 = []
      chIdx == 1  Do LoopTime_Ch2 = [];  LoopMsg_Ch2 = []
      chIdx == 2  Do LoopTime_Ch3 = [];  LoopMsg_Ch3 = []
      chIdx == 3  Do LoopTime_Ch4 = [];  LoopMsg_Ch4 = []
      chIdx == 4  Do LoopTime_Ch5 = [];  LoopMsg_Ch5 = []
      chIdx == 5  Do LoopTime_Ch6 = [];  LoopMsg_Ch6 = []
      chIdx == 6  Do LoopTime_Ch7 = [];  LoopMsg_Ch7 = []
      chIdx == 7  Do LoopTime_Ch8 = [];  LoopMsg_Ch8 = []
      chIdx == 8  Do LoopTime_Ch9 = [];  LoopMsg_Ch9 = []
      chIdx == 9  Do LoopTime_Ch10 = []; LoopMsg_Ch10 = []
      chIdx == 10 Do LoopTime_Ch11 = []; LoopMsg_Ch11 = []
      chIdx == 11 Do LoopTime_Ch12 = []; LoopMsg_Ch12 = []
      chIdx == 12 Do LoopTime_Ch13 = []; LoopMsg_Ch13 = []
      chIdx == 13 Do LoopTime_Ch14 = []; LoopMsg_Ch14 = []
      chIdx == 14 Do LoopTime_Ch15 = []; LoopMsg_Ch15 = []
      chIdx == 15 Do LoopTime_Ch16 = []; LoopMsg_Ch16 = []
   End
   LoopStartTime[chIdx] = 0.0
   LoopLengthMS[chIdx] = 0.0
   LoopNextEventIdx[chIdx] = 0
   LoopPlayheadMS[chIdx] = -1.0 
End

Function GetLoopProgressString(ch : Integer) Returns String
    var currentTotalTicks, anchorTotalTicks, diffTicks, loopLengthTicks : Integer
    var relBar, relBeat, totalBars, sigNum, ticksPerBeat : Integer
    var waitBeats, remBeats, remBars : Integer
    var beatString, finalResult : String
    var msLeft, msPerBeat : Double = 0.0
    var currentBPM_Prog : Double = GetBPM()
    
    if currentBPM_Prog < 1.0 then currentBPM_Prog = 120.0 end
    msPerBeat = 60000.0 / currentBPM_Prog
    
    sigNum = GetTimeSigNumerator()
    if sigNum <= 0 then sigNum = 4 end 
    
    if Mem_Loop_State[ch] == 0 or Mem_Loop_State[ch] == 4 then
        finalResult = ""
        
    elsif Mem_Loop_State[ch] == 8 then
        // --- STATE 8: FREE COUNTDOWN IN BEATS ---
        msLeft = LoopFreeArmTimer[ch] - TimeSinceStartup()
        if msLeft < 0.0 then msLeft = 0.0 end
        
        remBeats = Round(msLeft / msPerBeat)
        if remBeats < 1 then remBeats = 1 end
        
        finalResult = " | Wait: -" + IntToString(remBeats)
        
        if DebugMode then 
            Trace("LOOP-MATH [Ch" + (ch+1) + " | State 8]: msLeft=" + msLeft + " -> remBeats=" + remBeats) 
        end
        
    elsif Mem_Loop_State[ch] == 5 or Mem_Loop_State[ch] == 6 then
        // --- STATE 5/6: PROFI COUNTDOWN (ARM REC / ARM PLAY) ---
        waitBeats = (sigNum - CurrentBeat) + 1
        finalResult = " | Wait: -" + IntToString(waitBeats)
        
        if DebugMode then 
            Trace("LOOP-MATH [Ch" + (ch+1) + " | State " + Mem_Loop_State[ch] + "]: waitBeats=" + waitBeats) 
        end
        
    else
        // --- STATE 1, 2, 3: THE RELATIVE STOPWATCH ---
        totalBars = Mem_Loop_Length[ch]
        ticksPerBeat = 960 // GP Standard

        // The absolute ticks since song start
        currentTotalTicks = (((CurrentBar - 1) * sigNum) + (CurrentBeat - 1)) * ticksPerBeat + Global_CurrentTick
        
        // The absolute ticks of the set anchor
        anchorTotalTicks = (((LoopAnchorBar[ch] - 1) * sigNum) + (LoopAnchorBeat[ch] - 1)) * ticksPerBeat + LoopAnchorTick[ch]
        
        diffTicks = currentTotalTicks - anchorTotalTicks
        if diffTicks < 0 then diffTicks = 0 end 

        if (Mem_Loop_State[ch] == 2 or Mem_Loop_State[ch] == 3) and totalBars > 0 then
            loopLengthTicks = totalBars * sigNum * ticksPerBeat
            diffTicks = diffTicks % loopLengthTicks 
        end

        relBar = (diffTicks / (sigNum * ticksPerBeat)) + 1
        relBeat = ((diffTicks / ticksPerBeat) % sigNum) + 1
        
        beatString = IntToString(relBar) + "." + IntToString(relBeat)
        
        if totalBars > 0 then
            finalResult = " | " + beatString + "/" + IntToString(totalBars)
        else
            finalResult = " | " + beatString
        end
        
        // THE CRITICAL TRACE FOR LEVEL 3:
        if DebugMode then 
            Trace("LOOP-MATH [Ch" + (ch+1) + "]: GP_Tick=" + currentTotalTicks + " | Anchor=" + anchorTotalTicks + " | Diff=" + diffTicks + " -> Display: " + beatString) 
        end
    end
    
    result = finalResult
End

Function BuildLooperConfigLines()
   var i, focusCh, focusLineIdx, totalLines, visibleCount : Integer
   var lenStr, actStr, targetStr, stateStr, outStr, stopStr : String
   var scrollPos : Double = 0.0
   
   LooperInfo_Lines = [] // Clear array!
   focusCh = GetFirstActiveScope()
   
   focusLineIdx = 0
   visibleCount = 10 // Must match the number in RefreshLooperInfoDisplay!
   
   For i = 0; i < 16; i = i + 1 Do
      // Remember at which array index our active channel starts
      if i == focusCh then focusLineIdx = Size(LooperInfo_Lines) end
      
      if not IsChannelActiveForLooper(i) then
         LooperInfo_Lines <-- "CH " + (i+1) + ": [Bypassed]"
      else
         lenStr = GetLoopLengthName(Mem_Loop_Length[i])
         actStr = GetLoopActionName(Mem_Loop_Action[i])
         if Mem_Loop_Target[i] == -1 then targetStr = "STAY" else targetStr = "CH " + IntToString(Mem_Loop_Target[i] + 1) end
         outStr = GetLoopOutName(Mem_Loop_OutMode[i])
         stopStr = GetLoopStopName(Mem_Loop_StopMode[i])
         
         if Mem_Loop_State[i] == 0 then stateStr = "(Empty)"
         elsif Mem_Loop_State[i] == 1 then stateStr = "(REC" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 2 then stateStr = "(PLAY" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 3 then stateStr = "(DUB" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 4 then stateStr = "(STOP)"
         elsif Mem_Loop_State[i] == 5 then stateStr = "(ARM REC" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 6 then stateStr = "(ARM PLAY" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 7 then stateStr = "(WAIT STOP" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 8 then stateStr = "(COUNT IN" + GetLoopProgressString(i) + ")"
         end
         
         LooperInfo_Lines <-- "CH " + (i+1) + ": " + stateStr
         LooperInfo_Lines <-- "  |- After: [" + actStr + "] | Out: [" + outStr + "]"
         LooperInfo_Lines <-- "  L- Modes: [" + lenStr + "] | Next: [" + targetStr + "] | Stop: [" + stopStr + "]"
      end
   End
   
   // --- AUTO-SCROLL CALCULATION ---
   totalLines = Size(LooperInfo_Lines)
   if totalLines > visibleCount then
       scrollPos = 1.0 - (IntToFloat(focusLineIdx) / IntToFloat(totalLines - visibleCount))
       if scrollPos > 1.0 then scrollPos = 1.0 end
       if scrollPos < 0.0 then scrollPos = 0.0 end
       
       SetWidgetValue(SLD_LooperConfiguration, scrollPos) 
   else
       SetWidgetValue(SLD_LooperConfiguration, 1.0) 
   end
   
   // Redraw!
   RefreshLooperInfoDisplay()
End



On WidgetValueChanged(val : Double) from BTN_Loop_CountIn
    var i : Integer
    if CurrentSyncMode != 1 and CurrentSyncMode != 4 then
        if val > 0.5 then
            For i = 0; i < 16; i = i + 1 Do
                if Mem_Loop_State[i] == 5 then
                    Mem_Loop_State[i] = 8
                    LoopFreeArmTimer[i] = TimeSinceStartup() + GetCountInDurationMS()
                    BuildLooperConfigLines(); UpdateInjectionLooperTransportUI()
                end
            End
        end
    else
        if val > 0.5 then SetWidgetValue(BTN_Loop_CountIn, 0.0) end
    end
End

On WidgetValueChanged(val : Double) from SLD_LooperConfiguration
   RefreshLooperInfoDisplay()
End

On WidgetValueChanged(val : Double) from BTN_Loop_Rec
   var focusCh : Integer = -1 
   if TimeSinceStartup() > LooperButtonSafetyTimer then 
      LooperButtonSafetyTimer = TimeSinceStartup() + 300.0 
      focusCh = GetFirstActiveScope()
      if DebugMode and focusCh > -1 then TraceLooperDiagnostic(focusCh, "BTN_Loop_Rec CLICKED") end
      
      if TimeSinceStartup() > IgnoreUIFeedbackTimer then TriggerFocusLooperTransport(true) 
      end
   end
End

On WidgetValueChanged(val : Double) from BTN_Loop_Play
   var focusCh : Integer = -1 
   if TimeSinceStartup() > LooperButtonSafetyTimer then 
      LooperButtonSafetyTimer = TimeSinceStartup() + 300.0 
      focusCh = GetFirstActiveScope()
      if DebugMode and focusCh > -1 then TraceLooperDiagnostic(focusCh, "BTN_Loop_Play CLICKED") end
      
      if TimeSinceStartup() > IgnoreUIFeedbackTimer then TriggerFocusLooperTransport(false) 
      end
   end
End

On WidgetValueChanged(val : Double) from BTN_Loop_HostSync
   if DebugMode and val > 0.5 then Trace("LOOPER: Host Sync ON") 
   elsif DebugMode then Trace("LOOPER: Host Sync OFF") end
End

On WidgetValueChanged(val : Double) from BTN_Loop_Clear
   var focusCh : Integer = -1 
   var isValid : Boolean = false
   if val > 0.5 then 
      focusCh = GetFirstActiveScope()
      if focusCh != -1 then
         if IsChannelActiveForLooper(focusCh) then isValid = true end
      end

      if isValid then
         if Mem_Loop_State[focusCh] != 0 then
            Select 
               focusCh == 0  Do LoopTime_Ch1 = [];  LoopMsg_Ch1 = []
               focusCh == 1  Do LoopTime_Ch2 = [];  LoopMsg_Ch2 = []
               focusCh == 2  Do LoopTime_Ch3 = [];  LoopMsg_Ch3 = []
               focusCh == 3  Do LoopTime_Ch4 = [];  LoopMsg_Ch4 = []
               focusCh == 4  Do LoopTime_Ch5 = [];  LoopMsg_Ch5 = []
               focusCh == 5  Do LoopTime_Ch6 = [];  LoopMsg_Ch6 = []
               focusCh == 6  Do LoopTime_Ch7 = [];  LoopMsg_Ch7 = []
               focusCh == 7  Do LoopTime_Ch8 = [];  LoopMsg_Ch8 = []
               focusCh == 8  Do LoopTime_Ch9 = [];  LoopMsg_Ch9 = []
               focusCh == 9  Do LoopTime_Ch10 = []; LoopMsg_Ch10 = []
               focusCh == 10 Do LoopTime_Ch11 = []; LoopMsg_Ch11 = []
               focusCh == 11 Do LoopTime_Ch12 = []; LoopMsg_Ch12 = []
               focusCh == 12 Do LoopTime_Ch13 = []; LoopMsg_Ch13 = []
               focusCh == 13 Do LoopTime_Ch14 = []; LoopMsg_Ch14 = []
               focusCh == 14 Do LoopTime_Ch15 = []; LoopMsg_Ch15 = []
               focusCh == 15 Do LoopTime_Ch16 = []; LoopMsg_Ch16 = []
            End
            
            LoopStartTime[focusCh] = 0.0
            LoopLengthMS[focusCh] = 0.0
            Mem_Loop_State[focusCh] = 0
            Trigger_NotesOff(focusCh + 1)
            BuildLooperConfigLines(); UpdateInjectionLooperTransportUI()
         end
      end
      SetWidgetValue(BTN_Loop_Clear, 0.0)
   end
End


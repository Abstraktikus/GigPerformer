On WidgetValueChanged(val : Double) from BTN_LFO_Cycles_Next
   var c : Integer
   var lfoIdx : Integer
   if val > 0.5 then
       if LFO_Draft_Active then
           c = LFO_Draft_Cycles
           if c == -1 then c = 0
           elsif c == 0 then c = 1
           else c = c + 1 end
           LFO_Draft_Cycles = c
       elsif CurrentEditScope >= 0 and CurrentEditScope < 50 then
           lfoIdx = LFO_ByMacro[CurrentEditScope]
           if lfoIdx >= 0 then
               c = LFO_Cycles[lfoIdx]
               if c == -1 then c = 0
               elsif c == 0 then c = 1
               else c = c + 1 end
               LFO_Cycles[lfoIdx] = c
           end
       end
       RefreshLFOInspector()
       SetWidgetValue(BTN_LFO_Cycles_Next, 0.0)
   end
End

On WidgetValueChanged(val : Double) from BTN_LFO_Cycles_Prev
   var c : Integer
   var lfoIdx : Integer
   if val > 0.5 then
       if LFO_Draft_Active then
           c = LFO_Draft_Cycles
           if c == 0 then c = -1
           elsif c == -1 then c = 16
           elsif c == 1 then c = 0
           else c = c - 1 end
           LFO_Draft_Cycles = c
       elsif CurrentEditScope >= 0 and CurrentEditScope < 50 then
           lfoIdx = LFO_ByMacro[CurrentEditScope]
           if lfoIdx >= 0 then
               c = LFO_Cycles[lfoIdx]
               if c == 0 then c = -1
               elsif c == -1 then c = 16
               elsif c == 1 then c = 0
               else c = c - 1 end
               LFO_Cycles[lfoIdx] = c
           end
       end
       RefreshLFOInspector()
       SetWidgetValue(BTN_LFO_Cycles_Prev, 0.0)
   end
End

On WidgetValueChanged(val : Double) from BTN_LFO_Run
   var scopeSlot, lfoIdx : Integer

   // BOOT SAFETY — silent-ignore during the 5-second boot window.
   // Init resets this widget to 0.0 as part of stale-state cleanup;
   // that SetWidgetValue fires this callback and must NOT cascade
   // into LFO_Active[scopeSlot] array reads (arrays may not be
   // populated yet at that point in Init) or StopLFO chains.
   if TimeSinceStartup() < FaderSafetyTimer then
       // Silent-ignore. No further processing.
   else

   scopeSlot = CurrentEditScope

   if scopeSlot < 0 or scopeSlot >= 50 then
       // LOCKED — ignore
       SetWidgetValue(BTN_LFO_Run, 0.0)
   else
       if val > 0.5 then
           if LFO_Draft_Active then
               // DRAFT state — start the preview LFO
               LFO_Draft_Slot      = scopeSlot
               LFO_Draft_StartTime = TimeSinceStartup()
               LFO_Draft_PreValue  = GetParameter(ExternalArranger, scopeSlot)
               LFO_Draft_Running   = true
               if DebugMode then Trace("LFO v2: draft preview started on slot " + (scopeSlot + 1)) end
           else
               lfoIdx = LFO_ByMacro[scopeSlot]
               if lfoIdx >= 0 then
                   StartLFO(scopeSlot)
                   if DebugMode then Trace("LFO v2: manual Run on EDIT slot " + (scopeSlot + 1)) end
               end
           end
       else
           // Button released — stop whichever is running
           if LFO_Draft_Running then
               LFO_Draft_Running = false
               ScriptWrite_ExpectedPrev[LFO_Draft_Slot] = ScriptWrite_Expected[LFO_Draft_Slot]
               ScriptWrite_Expected[LFO_Draft_Slot] = LFO_Draft_PreValue
               SetParameter(ExternalArranger, LFO_Draft_Slot, LFO_Draft_PreValue)
               SetWidgetValue(METER_LFO_H, 0.0)
               SetWidgetValue(METER_LFO_V, 0.0)
               LFO_Draft_Slot = -1
               if DebugMode then
                   Trace("METER: METER_LFO_H <- 0.0 (draft preview stopped)")
                   Trace("METER: METER_LFO_V <- 0.0 (draft preview stopped)")
                   Trace("LFO v2: draft preview stopped, snapped back")
               end
           elsif scopeSlot >= 0 and scopeSlot < 50 then
               lfoIdx = LFO_ByMacro[scopeSlot]
               if lfoIdx >= 0 and LFO_Active[scopeSlot] then
                   StopLFO(scopeSlot)
               end
           end
       end
   end
   end // close boot-safety FaderSafetyTimer else branch
End

On WidgetValueChanged(val : Double) from BTN_LFO_Save
   // v2 unified Save — handles three states:
   //   LOCKED (scope < 0 or >= 50) → flash help message, no-op
   //   DRAFT (scope has no LFO)    → create-or-update registry entry +
   //                                  add LFO:<name> | prefix to the
   //                                  current scope's macro line
   //                                  (overwrites any orphan prefix but
   //                                   never displaces a legitimate one —
   //                                   legitimate prefixes put the scope
   //                                   in EDIT state, not DRAFT)
   //   EDIT  (scope has an LFO)    → persist registry shape only, do not
   //                                  touch ControllerMaps.txt (binding
   //                                  is already there)
   var scopeSlot, lfoIdx, registryIdx, i : Integer
   var mapName, lfoName, content, section, newLine, oldLine : String
   var mapSectionStart, mapSectionEnd, lineStart, lineEnd, nlPos : Integer
   var searchKey, newValue : String
   var saved : Boolean = false

   if val > 0.5 then
       // Setlist View is mandatory for any file mutation — GetCurrentSongName()
       // is only safe inside Setlist View, and writing an LFO without a clean
       // song name would corrupt LFOConfig.txt. Mirror of the BTN_Record_Overdub
       // guard pattern at line ~13608.
       if not InSetlistMode() then
           LFOFlashMsg = "ERROR: NEED SETLIST VIEW!"
           LFOFlashTimer = TimeSinceStartup() + 1500.0
           RefreshLFOInspector()
           if DebugMode then Trace("LFO v2: BTN_LFO_Save blocked - not in Setlist View") end
           SetWidgetValue(BTN_LFO_Save, 0.0)
       else

       scopeSlot = CurrentEditScope
       mapName = CurrentCtrlMapName

       // LOCKED state → user help flash, nothing else
       if scopeSlot < 0 or scopeSlot >= 50 then
           LFOFlashMsg = "Select a User Macro first (Scope Prev/Next)"
           LFOFlashTimer = TimeSinceStartup() + 1500.0
           RefreshLFOInspector()
           if DebugMode then Trace("LFO v2: BTN_LFO_Save rejected, scope " + scopeSlot + " outside user zone") end
       else
           if not LFO_Draft_Active then
               // EDIT state — persist registry shape, do not touch ControllerMaps.txt
               lfoIdx = LFO_ByMacro[scopeSlot]
               if lfoIdx < 0 then
                   if DebugMode then Trace("LFO v2: BTN_LFO_Save ignored (EDIT flag mismatched LFO_ByMacro)") end
               else
                   SaveLFOConfig()
                   if DebugMode then Trace("LFO v2: EDIT save, persisted registry entry '" + LFO_Names[lfoIdx] + "'") end

                   // User feedback — flash that the shape save landed
                   LFOFlashMsg = "Shape saved: " + LFO_Names[lfoIdx] + " (updates all bindings)"
                   LFOFlashTimer = TimeSinceStartup() + 1500.0
                   RefreshLFOInspector()
               end
           else
               // DRAFT state — materialise the draft: create-or-update
               // registry entry + add LFO:<name> | prefix to the scope's
               // macro line in the active map.
               lfoName = LFO_Draft_Name

               // 1. Create-or-update registry entry
               registryIdx = -1
               For i = 0; i < Size(LFO_Names); i = i + 1 Do
                  if LFO_Names[i] == lfoName then registryIdx = i end
               End

               if registryIdx < 0 then
                   LFO_Names  <-- lfoName
                   LFO_Types  <-- LFO_Draft_Type
                   LFO_Rates  <-- LFO_Draft_Rate
                   LFO_Cycles <-- LFO_Draft_Cycles
                   if DebugMode then Trace("LFO v2: DRAFT save, created registry entry '" + lfoName + "'") end
               else
                   LFO_Types[registryIdx]  = LFO_Draft_Type
                   LFO_Rates[registryIdx]  = LFO_Draft_Rate
                   LFO_Cycles[registryIdx] = LFO_Draft_Cycles
                   if DebugMode then Trace("LFO v2: DRAFT save, updated existing registry entry '" + lfoName + "' (shape change propagates to all existing bindings)") end
               end

               // 2. Persist registry to disk
               SaveLFOConfig()

               // 3. Add LFO:<name> | prefix to the current scope's macro line in ControllerMaps.txt
               if FileExists(ControllerMapFilePath) then
                   content = LoadStringFromTextFile(ControllerMapFilePath)

                   searchKey = "[Map:" + mapName + "]"
                   mapSectionStart = IndexOfSubstring(content, searchKey, false)
                   if mapSectionStart < 0 then
                       if DebugMode then Trace("LFO v2: BTN_LFO_Save: map section '" + mapName + "' not found in ControllerMaps.txt") end
                   else
                       mapSectionEnd = IndexOfSubstring(CopySubstring(content, mapSectionStart + Length(searchKey), Length(content) - (mapSectionStart + Length(searchKey))), "[Map:", false)
                       if mapSectionEnd < 0 then mapSectionEnd = Length(content) - (mapSectionStart + Length(searchKey)) end

                       section = CopySubstring(content, mapSectionStart + Length(searchKey), mapSectionEnd)
                       searchKey = "Macro" + (scopeSlot + 1) + " ="
                       lineStart = IndexOfSubstring(section, searchKey, false)

                       if lineStart >= 0 then
                           nlPos = IndexOfSubstring(CopySubstring(section, lineStart, Length(section) - lineStart), NEW_LINE, false)
                           if nlPos >= 0 then
                               oldLine = CopySubstring(section, lineStart, nlPos)
                           else
                               oldLine = CopySubstring(section, lineStart, Length(section) - lineStart)
                           end

                           lineEnd = IndexOfSubstring(oldLine, "=", false)
                           if lineEnd >= 0 then
                               newValue = TrimString(CopySubstring(oldLine, lineEnd + 1, Length(oldLine) - (lineEnd + 1)))
                               // Strip any leading LFO:<other> | prefix. In DRAFT state
                               // a legitimate prefix cannot be present — if it were, the
                               // scope would be in EDIT state. Any prefix we see here is
                               // orphan (name not in registry), so stripping it is safe.
                               if IndexOfSubstring(newValue, "LFO:", false) == 0 then
                                   i = IndexOfSubstring(newValue, "|", false)
                                   if i >= 0 then
                                       newValue = TrimString(CopySubstring(newValue, i + 1, Length(newValue) - (i + 1)))
                                   else
                                       newValue = ""
                                   end
                                   if DebugMode then Trace("LFO v2: DRAFT save, stripped orphan LFO: prefix before adding new binding") end
                               end
                               if Length(newValue) > 0 then
                                   newLine = searchKey + " LFO:" + lfoName + " | " + newValue
                               else
                                   newLine = searchKey + " LFO:" + lfoName
                               end

                               section = ReplaceString(section, oldLine, newLine, false)
                               content = CopySubstring(content, 0, mapSectionStart + Length("[Map:" + mapName + "]")) + section + CopySubstring(content, mapSectionStart + Length("[Map:" + mapName + "]") + mapSectionEnd, Length(content) - (mapSectionStart + Length("[Map:" + mapName + "]") + mapSectionEnd))

                               saved = SaveStringToTextFile(ControllerMapFilePath, content)
                               if DebugMode then Trace("LFO v2: DRAFT save, wrote LFO:" + lfoName + " prefix to [" + mapName + "] Macro" + (scopeSlot + 1) + " (saved=" + saved + ")") end
                           end
                       else
                           if DebugMode then Trace("LFO v2: BTN_LFO_Save: Macro" + (scopeSlot + 1) + " not found in section [" + mapName + "]") end
                       end
                   end
               end

               // 4. User feedback — flash that the bind succeeded, prepended to
               //    the bindings list by RefreshLFOBoundMacroDisplay.
               LFOFlashMsg = "Saved: " + lfoName + " -> Macro " + (scopeSlot + 1)
               LFOFlashTimer = TimeSinceStartup() + 1500.0

               // 5. Rebuild runtime state. LoadControllerMap resets CurrentEditScope
               //    to -1 as a side effect (line ~6805); we capture and restore it so
               //    RefreshLFOInspector below sees the same scope we were working on
               //    and transitions DRAFT → EDIT cleanly instead of collapsing to
               //    LOCKED. mapName is always the map active when Save was clicked
               //    (captured at the top from CurrentCtrlMapName) so the reload is
               //    the same-map guarantee.
               LoadControllerMap(mapName)
               CurrentEditScope = scopeSlot
               UpdateEditScopeDisplay()
               BuildLFOUsageIndex()
               RefreshLFOInspector()
           end
       end
       SetWidgetValue(BTN_LFO_Save, 0.0)
       end   // closes the `else` of the InSetlistMode guard at the top of this callback
   end
End

On WidgetValueChanged(val : Double) from BTN_LFO_Delete
   var scopeSlot, lfoIdx, i, unbindCount : Integer
   var lfoName : String
   var newNames : String Array
   var newTypes, newRates, newCycles : Integer Array
   var content, searchPrefix : String
   var saved : Boolean = false

   if val > 0.5 then
       // Setlist View is mandatory for file mutation — same guard as BTN_LFO_Save.
       if not InSetlistMode() then
           LFOFlashMsg = "ERROR: NEED SETLIST VIEW!"
           LFOFlashTimer = TimeSinceStartup() + 1500.0
           RefreshLFOInspector()
           if DebugMode then Trace("LFO v2: BTN_LFO_Delete blocked - not in Setlist View") end
           SetWidgetValue(BTN_LFO_Delete, 0.0)
       else

       scopeSlot = CurrentEditScope

       // EDIT state only
       if scopeSlot < 0 or scopeSlot >= 50 or LFO_Draft_Active then
           if DebugMode then Trace("LFO v2: BTN_LFO_Delete ignored (not in EDIT state)") end
       else
           lfoIdx = LFO_ByMacro[scopeSlot]
           if lfoIdx < 0 then
               if DebugMode then Trace("LFO v2: BTN_LFO_Delete ignored (scope has no LFO)") end
           else
               lfoName = LFO_Names[lfoIdx]

               // 1. Stop any running instances of this LFO across all slots
               For i = 0; i < MAX_MACROS; i = i + 1 Do
                  if LFO_Active[i] and LFO_ByMacro[i] == lfoIdx then
                      StopLFO(i)
                  end
               End

               // 2. Strip LFO:<name> | prefix from every matching line in ControllerMaps.txt
               unbindCount = 0
               if FileExists(ControllerMapFilePath) then
                   content = LoadStringFromTextFile(ControllerMapFilePath)

                   // Strip "LFO:<name> | " (with trailing separator)
                   searchPrefix = "LFO:" + lfoName + " | "
                   While IndexOfSubstring(content, searchPrefix, false) >= 0 Do
                       content = ReplaceString(content, searchPrefix, "", false)
                       unbindCount = unbindCount + 1
                   End

                   // Also strip bare "LFO:<name>" (no trailing targets — rare edge case)
                   searchPrefix = "LFO:" + lfoName
                   While IndexOfSubstring(content, "= " + searchPrefix + NEW_LINE, false) >= 0 Do
                       content = ReplaceString(content, "= " + searchPrefix + NEW_LINE, "= " + NEW_LINE, false)
                       unbindCount = unbindCount + 1
                   End

                   saved = SaveStringToTextFile(ControllerMapFilePath, content)
                   if DebugMode then Trace("LFO v2: stripped " + unbindCount + " bindings of '" + lfoName + "' from ControllerMaps.txt (saved=" + saved + ")") end
               end

               // 3. Remove from registry — rebuild arrays without this index
               newNames  = []
               newTypes  = []
               newRates  = []
               newCycles = []
               For i = 0; i < Size(LFO_Names); i = i + 1 Do
                  if i != lfoIdx then
                      newNames  <-- LFO_Names[i]
                      newTypes  <-- LFO_Types[i]
                      newRates  <-- LFO_Rates[i]
                      newCycles <-- LFO_Cycles[i]
                  end
               End
               LFO_Names  = newNames
               LFO_Types  = newTypes
               LFO_Rates  = newRates
               LFO_Cycles = newCycles

               SaveLFOConfig()
               if DebugMode then Trace("LFO v2: removed '" + lfoName + "' from registry, " + Size(LFO_Names) + " entries remain") end

               // 4. User feedback — flash that the delete landed
               LFOFlashMsg = "Deleted: " + lfoName + " (" + unbindCount + " bindings removed)"
               LFOFlashTimer = TimeSinceStartup() + 1500.0

               // 5. Rebuild state — LoadControllerMap resets CurrentEditScope to -1
               //    as a side effect; we capture and restore it so the scope stays
               //    on the macro the user was viewing (which will now be in DRAFT
               //    because the LFO binding is gone).
               LoadControllerMap(CurrentCtrlMapName)
               CurrentEditScope = scopeSlot
               UpdateEditScopeDisplay()
               BuildLFOUsageIndex()
               RefreshLFOInspector()
           end
       end
       SetWidgetValue(BTN_LFO_Delete, 0.0)
       end   // closes the `else` of the InSetlistMode guard at the top
   end
End

// ---------------------------------------------------------
// EVENT HANDLERS
// ---------------------------------------------------------

// ----------------------------------------------------
// HARDWARE FEEDBACK & CONTROLLER ROUTER
// ----------------------------------------------------

On ParameterValueChanged(paramIdx : Integer, newVal : Double) from ExternalArranger
   var i, targetChannel : Integer
   var scaledVal : Double = 0.0
   var midiVal : Integer
   var m : MidiMessage
   var isEcho : Boolean = false

   // EMERGENCY BRAKE — if the Trace() watchdog tripped the kill switch,
   // reject all arranger callbacks. Combined with TickLFOs' kill-switch
   // guard, this cuts the primary flood source (LFO sample writes) and
   // the secondary flood source (handler side-effects per callback).
   if EmergencyKillSwitch then
       // Do nothing. Callback silently consumed.
   else

   // 1. GHOST-ZERO LOCK (hard guard)
   // CRITICAL: The echo-dedup block below MUST stay inside this Else
   // branch. It reads ScriptWrite_Expected[paramIdx], and those arrays
   // are populated by the Init function LATE in the boot sequence.
   // GP fires ghost-zero parameter callbacks DURING boot, before Init
   // has run — reading the arrays then is an out-of-bounds access that
   // hard-crashes GP. FaderSafetyTimer covers exactly this window.
   If TimeSinceStartup() < FaderSafetyTimer Then
       // Completely ignored! Protects against plugin load times
       // and physical motorfader bounce-back.
   Else

       // 0. ECHO DEDUP — is this callback our own script write coming back?
       // Match against BOTH current and previous sentinel (see comment at
       // ScriptWrite_Expected declaration for why we need two). Tolerance
       // 0.005 covers float round-trip + MIDI 1/127 quantization.
       // Defensive Size() check: even inside the safety window, make sure
       // the arrays are actually populated before indexing into them.
       if paramIdx >= 0 and paramIdx < MAX_MACROS and Size(ScriptWrite_Expected) > paramIdx and Size(ScriptWrite_ExpectedPrev) > paramIdx then
           if ScriptWrite_Expected[paramIdx] >= 0.0 and Abs(newVal - ScriptWrite_Expected[paramIdx]) < 0.005 then
               isEcho = true
           elsif ScriptWrite_ExpectedPrev[paramIdx] >= 0.0 and Abs(newVal - ScriptWrite_ExpectedPrev[paramIdx]) < 0.005 then
               isEcho = true
           end
       end
       if paramIdx >= 0 and paramIdx <= 15 then

           // ==========================================================
           // ---> LOG-EINTRAG & HUD FEEDBACK (Ausnahme: Scrubber)
           // Echo-dedup guard: when this callback is our own script
           // write coming back (isEcho), skip trace + HUD entirely.
           // ==========================================================
           if paramIdx != SCRUB_MacroIdx and not isEcho then
               if DebugMode then Trace("MACRO-IN: Arranger Slider/Knob " + (paramIdx + 1) + " -> " + Round(newVal * 127.0)) end

               // Send the value to the HUD (false = Macro, not a direct CC)
               TriggerMacroFeedback(paramIdx, false, newVal)
           end
           // ==========================================================
           
           Mem_Fader_Buffer[paramIdx] = newVal
               
           // 2. CROSSFADER CHECK
           if paramIdx == CF_MacroIdx then
               // Same reasoning as SLD_Morph below: only update the widget
               // on hardware moves. Script writes must not echo through a
               // potential widget binding back to the parameter.
               if not isEcho then
                   SetWidgetValue(SLD_Crossfader, newVal)
               end

           // ---> NEU: SCRUBBER CHECK <---
           elsif paramIdx == SCRUB_MacroIdx then
               if TimeSinceStartup() > ScrubberTaubTimer then
                   ExecuteScrub(newVal, false)
               end
                 
           // 3. STANDARD MAPPING
           else
                if paramIdx == CurrentEditScope and not isEcho then
                    // Only reflect HARDWARE moves on SLD_Morph. Script-own
                    // writes (LFO samples, StopLFO snap-back, ApplyEditorTest,
                    // etc.) are isEcho=True and MUST NOT touch SLD_Morph here.
                    // SLD_Morph has a widget-level binding back to an
                    // ExternalArranger parameter (rackspace-layer, invisible
                    // to the script). If we SetWidgetValue on an echo, that
                    // binding writes a fresh SetParameter — without updating
                    // our sentinels — which re-fires the callback and feeds
                    // an infinite loop. Observed 2026-04-11 at 19:08:37 where
                    // the last LFO sample (0.0025244) and the StopLFO snap-
                    // back (0.5) alternated hundreds of times in one second
                    // until the emergency kill switch tripped.
                    IgnoreMorphEcho = true
                    SetWidgetValue(SLD_Morph, newVal)
                    IgnoreMorphEcho = false
                    if DebugMode then Trace("METER: SLD_Morph <- " + newVal + " (hardware write from slot=" + paramIdx + ")") end
                end

                For i = 0; i < Link_Count; i = i + 1 Do
                    if Link_Active[i] == true and Link_SourceIdx[i] == paramIdx then
                        
                        // --- SLEEP SWITCH LOGIC (Pull-To-Sleep) ---
                        if Link_IsSleepSwitch[i] then
                            if newVal < 0.005 then // Fader is (nearly) 0
                                if not IsPluginBypassed(BLK_VST[Link_BlockIdx[i]]) then
                                    SetPluginBypassed(BLK_VST[Link_BlockIdx[i]], true)
                                    targetChannel = GetChannelForVST(Link_BlockIdx[i])
                                    Trigger_NotesOff(targetChannel)
                                    if DebugMode then Trace("SLEEP SWITCH: VST" + (Link_BlockIdx[i]+1) + " bypassed (Fader 0).") end
                                end
                            else // Fader is being pulled up
                                if IsPluginBypassed(BLK_VST[Link_BlockIdx[i]]) then
                                    SetPluginBypassed(BLK_VST[Link_BlockIdx[i]], false)
                                    if DebugMode then Trace("SLEEP SWITCH: VST" + (Link_BlockIdx[i]+1) + " awoken (Fader > 0).") end
                                end
                            end
                        end
                        // ------------------------------------------

                        // Scaling
                        scaledVal = Link_MinVal[i] + (newVal * (Link_MaxVal[i] - Link_MinVal[i]))
                        
                        // --- OUTPUT: CC OR PARAMETER? ---
                        if Link_IsCC[i] == true then
                            midiVal = Round(scaledVal * 127.0)
                            if midiVal < 0 then midiVal = 0 elsif midiVal > 127 then midiVal = 127 end
                            
                            // Type 0 = VST Routing, Type 3 = Direct Channel Routing
                            if Link_Type[i] == 0 then 
                                m = MakeControlChangeMessageEx(Link_TargetParam[i], midiVal, GetChannelForVST(Link_BlockIdx[i]))
                                SendNow(BLK_VSTControl, m)
                            elsif Link_Type[i] == 3 then
                                m = MakeControlChangeMessageEx(Link_TargetParam[i], midiVal, Link_BlockIdx[i])
                                SendNow(BLK_VSTControl, m)
                            end
                        else
                            // Type 0 = VST, Type 1 = NoteProcessor, Type 2 = AudioMixer
                            if Link_Type[i] == 0 then SetParameter(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i], scaledVal)
                            elsif Link_Type[i] == 1 then SetParameter(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i], scaledVal)
                            elsif Link_Type[i] == 2 then SetParameter(AudioMixer, Link_TargetParam[i], scaledVal)
                            end
                        end
                    end
                End
           end
       end 
       
       // SYSTEM ACTION DISPATCH (hardware-macro path)
       // Reverse-lookup is O(1); Isolation Rule guarantees exclusivity.
       // Skip echoes — our own script writes aren't SysAction triggers.
       if not isEcho then
           if newVal > 0.5 and paramIdx >= 0 and paramIdx < MAX_MACROS then
               if SysAction_ByMacro[paramIdx] > -1 then
                   FireSystemAction(SysAction_ByMacro[paramIdx])
               end
           end
       end

       // TIMELINE RECORDING FOR MACROS (SWITCHES ONLY)
       // System-action macros are excluded by design — their behavior should not
       // be recorded/replayed through the Timeline (see Isolation Rule).
       // Skip echoes — script writes shouldn't feed back into the recording.
       // Skip when Timeline is replaying — prevents replay->record feedback loop.
       if not isEcho and not Timeline_IsReplaying then
           if (RecordMode > 0 or TimelineRecActive) and IsPerformanceActive then
               if newVal == 1.0 and not IsSystemActionMacro(paramIdx) then
                   RecordTimelineEvent("Macro", paramIdx)
               end
           end
       end

       // LFO auto-start: ONLY Timeline replay can start a bound LFO from
       // the macro-write path. Hardware fader jitter must NOT auto-start
       // an LFO (physical noise on a bound slot would continuously retrigger
       // it). BTN_LFO_Run is the other, explicit entry point.
       //
       // Echo-check prevents the LFO's own sample writes from re-triggering
       // StartLFO via the async callback path.
       if Timeline_IsReplaying and not isEcho then
           if paramIdx >= 0 and paramIdx < MAX_MACROS and LFO_ByMacro[paramIdx] >= 0 then
               StartLFO(paramIdx)
               if DebugMode then Trace("LFO: StartLFO triggered by timeline replay on slot " + paramIdx) end
           end
       end
   end
   end // end of "if EmergencyKillSwitch then ... else ..."
End

// ---------------------------------------------------------
// HARDWARE RECEIVER (from scriptlet)
// ---------------------------------------------------------

On ParameterValueChanged(paramIdx : Integer, newVal : Double) from BLK_ArrangerSync

    if CurrentSyncMode == 1 or CurrentSyncMode == 4 or CurrentSyncMode == 5 then
        // P_STYLE_HW_START = 29 (Hardware Start Flag vom Scriptlet)
        if paramIdx == 29 and newVal > 0.5 then
            LastHardwarePulseTime = TimeSinceStartup()
            if DebugMode then Trace(">>> ARRANGER_STYLE (1&4): Arranger hardware start via scriptlet flag 29 detected! <<<") end

            // ---------------------------------------------------
            // BUGFIX: GP LEADS - THE GUARD
            // ---------------------------------------------------
            // When GP LEADS (2) is active and the GP transport is STOPPED,
            // but the arranger starts independently, fire an immediate STOP echo!
            if CurrentSyncMode == 2 and IsPlayheadEnabled() == false then
                Trace("   [X] ARRANGER_STYLE (2): Arranger started in isolation! Sending abort echo...")
                SetParameter(BLK_ArrangerSync, P_STYLE_START_STOP, 1.0)
                StyleTriggerResetTimer = TimeSinceStartup() + 60.0
            end
        end
    End
    
    if CurrentSyncMode == 2 or CurrentSyncMode == 3 then
        // Index 44 is our Flag_HW_Start from the Scriptlet
        if paramIdx == 44 and newVal > 0.5 then
            Trace(">>> ARRANGER_STYLE (2&3): HARDWARE START/STOP BUTTON ON ARRANGER PRESSED!")
        
            // We toggle GP. Since the playhead switches, the SystemEvent (above) fires
            // and sends a safety echo to the arranger. Since the button
            // was just pressed anyway, so this is harmless!
            IsCorrectingPlayhead = false // We want the SystemEvent to trigger!
            EnablePlayhead(not PendingPlayheadState)
        end
    End
    
    // TIMELINE RECORDING FOR PART CHANGES (STYLE)
    // ========================================================
    // Record when REC is on AND it's a key press (> 0.5)
    if (RecordMode > 0 or TimelineRecActive) and newVal > 0.5 then

        // Filter out system pings (Start/Stop, HW flags)
        // P_STYLE_START_STOP = 1, P_STYLE_HW_START = 29, Arranger HW button = 44
        if paramIdx != 1 and paramIdx != 29 and paramIdx != 44 then
            RecordTimelineEvent("Style", paramIdx)
        end
    end
End


// ----------------------------------------------------
// MIDI EVENTS
// ----------------------------------------------------

On PitchBendEvent(m : PitchBendMessage) from DeviceIn_0
    var pbVal : Integer = GetPitchBendValue(m)
    if SystemModeActive then
        // TODO(HAL): Read joystick thresholds from control registry
        if pbVal > 12000 and Joy_PB_Fired != 1 then
            Joy_PB_Fired = 1; ProcessSystemNavigation(0, "X_AXIS", 1)
        elsif pbVal < 4000 and Joy_PB_Fired != -1 then
            Joy_PB_Fired = -1; ProcessSystemNavigation(0, "X_AXIS", -1)
        elsif pbVal >= 4000 and pbVal <= 12000 then
            Joy_PB_Fired = 0
        end
    else
        SendNow(DeviceIn_0, m)
    end
End

On ControlChangeEvent(m : ControlChangeMessage) from DeviceIn_0
    var cc : Integer = GetCCNumber(m)
    var val : Integer = GetCCValue(m)

    // Device 0 joystick (only active while sustain pedal is held = SystemModeActive):
    //   CC1 (up)   = Y_AXIS +1 (navigate within current SYS-MODE)
    //   CC16 (down) = cycle SYS-MODE (120ms decision window: dominant axis wins over cross-talk)
    if SystemModeActive and (cc == 1 or cc == 16) then
        if cc == 1 then
            if val > 100 and not Joy_CC1_Fired then
                Joy_CC1_Fired = true; ProcessSystemNavigation(0, "Y_AXIS", 1)
            elsif val < 20 then Joy_CC1_Fired = false end
        end
        if cc == 16 then
            if val > 100 and Joy_CC16_ArmTime == 0.0 then
                Joy_CC16_ArmTime = TimeSinceStartup()  // Arm: start 120ms decision window
            end
            if val < 20 then
                Joy_CC16_ArmTime = 0.0  // Oscillation: CC16 returned to center → cancel
                Joy_CC16_Fired = false
            end
        end
    else
        ProcessHardwareCC(m); FeedLooper_CC(m); SendNow(DeviceIn_0, m)
    end
End

On ControlChangeEvent(m : ControlChangeMessage) from DeviceIn_1
    var cc : Integer = GetCCNumber(m)
    var val : Integer = GetCCValue(m)
    var ch : Integer = GetChannel(m)
    var dir : Integer = 0
    // TODO(HAL): Use FindControl/GetControlType from control registry
    var ctrlIdx : Integer = FindControl(1, cc)

    // ====================================================
    // ---> HARD GATE TRACE <---
    // ====================================================
    if DebugMode then
        Trace("MINILAB IN: CC " + cc + " | Val: " + val + " | Ch: " + ch)
    end

    // 1. MINILAB BUTTON (Press)
    // We listen for both constants to be safe!
    if ctrlIdx >= 0 and GetControlType(ctrlIdx) == CTYPE_BUTTON and val > 0 then
        Trace("MINILAB: Button erkannt! Sende an Router...")
        ProcessSystemNavigation(1, "BUTTON", 1)

    // 2. MINILAB ENCODER DREHUNG
    elsif ctrlIdx >= 0 and GetControlType(ctrlIdx) == CTYPE_ENCODER then
        if val >= 65 then dir = 1 elsif val <= 63 then dir = -1 end
        if dir != 0 then 
            Trace("MINILAB: Encoder detected! Direction: " + dir)
            ProcessSystemNavigation(1, "ENCODER", dir) 
        end
    
    // 3. NORMALE VERARBEITUNG (Pads, Fader, etc.)
    else
        ProcessHardwareCC(m); FeedLooper_CC(m); SendNow(DeviceIn_1, m) 
    end
End

// ====================================================
// DEVICE 0 CALLBACKS
// ====================================================
On NoteEvent(m : NoteMessage) from DeviceIn_0
    var chan : Integer = GetChannel(m)
    
    // 1. Call central HAL logic for macros
    ProcessHardwareNote(m)
    
    // Transport sync: only if this device has the capability
    if DeviceHasCap(0, CAP_TRANSPORT_SYNC) and IsNoteOn(m) and chan >= 9 and chan <= 16 then
        if CurrentSyncMode == 0 and IsPlayheadEnabled() then
             Trace(">>> ON NOTE: [ISOLATED] ArrangerStyle started (Ch " + chan + ") Stoppe GP")
             EnablePlayhead(false)
        elsif CurrentSyncMode == 1 or CurrentSyncMode == 2 or CurrentSyncMode == 3 then
             if StartWatchdogTimer > 0.0 then
                 Trace(">>> ON NOTE: Arranger already running (Ch " + chan + "). Aborting command.")
                 StartWatchdogTimer = 0.0 
             end
             if StopWatchdogTimer > 0.0 and not IsPlayheadEnabled() then
                 Trace(">>> ON NOTE: Arranger still playing (Ch " + chan + ")! Sending stop.")
                 FireDirectArrangerTransport()
                 StopWatchdogTimer = 0.0 
             else
                 LastHardwarePulseTime = TimeSinceStartup()
             end
        end
    end
    
    // Timeline NoteOn-detection playback start
    if IsNoteOn(m) then
        if not TimelinePlaybackActive and not TimelineRecActive and Size(Snap_TL_TimeMS) > 0 then
            if GetWidgetValue(BTN_TL_HostSync) > 0.5 and not IsPlayheadEnabled() then
                StartTimelinePlayback()
            end
        end
    end

    // 3. Keyboard split learning (if active)
    ProcessMidiLearn(m)

    // 4. Looper
    FeedLooper_Note(m)
    
    // 5. Pass note to the block
    SendNow(DeviceIn_0, m)
End

// ====================================================
// DEVICE 1 CALLBACKS
// ====================================================
On NoteEvent(m : NoteMessage) from DeviceIn_1
    // 1. Call central HAL logic for macros
    ProcessHardwareNote(m)
    
    // 2. Keyboard split learning (if you want to control it from the MiniLab)
    ProcessMidiLearn(m)
    
    // 3. Looper
    FeedLooper_Note(m)
    
    // 4. Pass note to the block
    SendNow(DeviceIn_1, m)
End

// ====================================================
// DEVICE 2 CALLBACKS (future expansion)
// ====================================================
On ControlChangeEvent(m : ControlChangeMessage) from DeviceIn_2
    ProcessHardwareCC(m); FeedLooper_CC(m); SendNow(DeviceIn_2, m)
End

On NoteEvent(m : NoteMessage) from DeviceIn_2
    ProcessHardwareNote(m); ProcessMidiLearn(m); FeedLooper_Note(m); SendNow(DeviceIn_2, m)
End

// ====================================================
// DEVICE 3 CALLBACKS (future expansion)
// ====================================================
On ControlChangeEvent(m : ControlChangeMessage) from DeviceIn_3
    ProcessHardwareCC(m); FeedLooper_CC(m); SendNow(DeviceIn_3, m)
End

On NoteEvent(m : NoteMessage) from DeviceIn_3
    ProcessHardwareNote(m); ProcessMidiLearn(m); FeedLooper_Note(m); SendNow(DeviceIn_3, m)
End

// ----------------------------------------------------
// TRANSPORT FEEDBACK
// ----------------------------------------------------

On Song(oldSongIndex : Integer, newSongIndex : Integer)
   var s : String
   var i : Integer
   var SysEx_RegButton1 : String = "F0 43 73 01 52 25 11 00 02 00 00 F7"
   var currentGPName : String
   var k : Integer
   var foundMap : Boolean // ---> THIS MUST BE DECLARED UP HERE! <---

   // 0. HARD-STOP ANY RUNNING LFO. A song switch invalidates the
   //    current LFO_ByMacro[] bindings and is about to trigger a
   //    HardwareSync write storm — if TickLFOs keeps emitting
   //    samples through this, they collide on the same slot and
   //    flood the macro callback path.
   HardStopAllLFOs("song switch")

   // 1. LOCK SYSTEM
   CurrentState = 9 // LOADING
   IsSaving = false
   IsLoadingSnapshot = true // Important: Set lock immediately!
   
   // ========================================================
   // NEW: Kill Write Mode & Record Modes on song change!
   // ========================================================
   SetWidgetValue(BTN_Record_Overdub, 0.0)
   SetWidgetValue(BTN_Record_Replace, 0.0)
   RecordMode = 0
   StripLiveDirty = false
   AnchorCurrentPartIdx = 0
   AnchorRootCursor = 0
   AnchorMatchCount = 0
   AnchorLastRoot = -1
   AnchorLowerChIdx = -1
   AnchorUpperChIdx = -1
   AnchorDetectedRootIdx = -1
   AnchorHasNotesIdx = -1

   ShowVSTOverlay("LOADING SONG...", 3000.0)
   
   Trace("Song Switch Initiated: " + oldSongIndex + " -> " + newSongIndex)
   
   // 2. NOTES OFF (Safety)
   For k = 0; k < 16; k = k + 1 Do
      AllNotesOff(BLK_MidiIn[k])
   End
   
   // 3. ARRANGER SYSEX LOGIC (stays here, send-only)
   if IgnoreNextSongSwitch == true Then 
      IgnoreNextSongSwitch = false
   Else
      currentGPName = GetCurrentSongName()
  
      // Only ONE loop now!
      foundMap = false // Set to false before the loop
      i = Size(Mapping_GPSong) - 1
      
      While i >= 0 and not foundMap Do
          if Mapping_GPSong[i] == currentGPName then
              s = Mapping_SysEx[i]
              if arrangerDevIdx >= 0 and IsDeviceConnected(arrangerDevIdx) then
                  SendSysexNowToMidiOutDevice(GetDeviceMidiOut(arrangerDevIdx), s)
                  Wait(50.0)
                  SendSysexNowToMidiOutDevice(GetDeviceMidiOut(arrangerDevIdx), SysEx_RegButton1)

                  // CROSSFADER SLIDER KALIBRIERUNG ---
                  Wait(150.0)
                  // Send CC7 (Volume) with value 127 on channel 7 (0-based = 6)
                  SendNowToMidiOutDevice(GetDeviceMidiOut(arrangerDevIdx), MakeControlChangeMessageEx(7, 127, 7))
              end
              // --------------------------------------

              Trace("ARRANGER: Setup Sent & Ch7 Calibrated for " + currentGPName)
              LastSysExSentTime = TimeSinceStartup()
              foundMap = true 
          end
          i = i - 1
      End
      
      // 4. SET LAZY LOAD TRIGGER
      // Instead of calling 'LoadSongSnapshot' immediately here (which causes the crash),
      // store the song and load it later in TimerTick after 200ms.
      
      If InSetlistMode() Then 
         PendingSongName = currentGPName
         DelayedLoadTimer = TimeSinceStartup() + 200.0 // 200ms delay
         Trace("LAZY LOAD: Scheduled loading for '" + PendingSongName + "' in 200ms")
      End
      
   End
   
   StateResetTime = TimeSinceStartup() + 3000.0
End


On SystemEvent(newValue : Double) Matching PlayheadStateChanged
    var playing : Boolean = (newValue > 0.5)
    var timeSinceHW : Double = 0.0
    var isHW : Boolean = (timeSinceHW < 800.0) or CurrentTriggerSource == "ARRANGER"
    var isArrangerPush : Boolean 
    
    if IsCorrectingPlayhead then
        IsCorrectingPlayhead = false 
        if DebugMode then Trace(">>> SYSTEM EVENT: Ignoriere eigenes Echo (Korrektur).") end
        UpdateSyncLabel()
    else
        if InSetlistMode() then
            UpdateSyncLabel()
            
            // =========================================================
            // MODE 0: ISOLATED
            // =========================================================
            if CurrentSyncMode == 0 then
                PendingPlayheadState = playing
                if playing then PlayheadEvalTimer = TimeSinceStartup() + 150.0 else PlayheadEvalTimer = TimeSinceStartup() + 300.0 end
                Trace(">>> SYS EVENT [ISOLATED]: Playhead=" + playing + ". Starte Analyse-Timer...")
            end

            // =========================================================
            // MODE 1: ARRANGER LEADS (Timer)
            // =========================================================          
            if CurrentSyncMode == 1 then
                PendingPlayheadState = playing
                IsPerformanceActive = playing
                if playing then   
                  // Keine Aktion
                else
                     // --- STOP LOGIC ---
                     timeSinceHW = TimeSinceStartup() - LastHardwarePulseTime
                     isArrangerPush = (timeSinceHW < 250.0 and timeSinceHW >= 0.0)
                     Trace(">>> [ARRANGER LEADS]: TRANSPORT: GP STOP (Arranger). Suppressing.")
                     StopWatchdogTimer = 0.0
                end
                PlayheadEvalTimer = TimeSinceStartup() + 80.0 
            end
            
            // =========================================================
            // MODE 2: GP LEADS
            // =========================================================
            if CurrentSyncMode == 2 then
                PendingPlayheadState = playing
                if playing then PlayheadEvalTimer = TimeSinceStartup() + 150.0 else PlayheadEvalTimer = TimeSinceStartup() + 300.0 end
                Trace(">>> SYS EVENT [GP LEADS]: Playhead=" + playing + ". Starte Analyse-Timer...")
            end

            // =========================================================
            // MODE 3: FULL SYNC (1:1 mirror)
            // =========================================================
            if CurrentSyncMode == 3 then
                PendingPlayheadState = playing
                
                // ---> THE TIMER WAS MISSING HERE! Without it the UI never gets updated! <---
                if playing then PlayheadEvalTimer = TimeSinceStartup() + 150.0 else PlayheadEvalTimer = TimeSinceStartup() + 300.0 end
                
                if playing then
                    // --- START LOGIC ---
                    StartWatchdogTimer = TimeSinceStartup() + 200.0
                    Trace(">>> TRANSPORT: GP START. Waiting for arranger confirmation (notes)...")
                else
                    // --- STOP LOGIC ---
                    timeSinceHW = TimeSinceStartup() - LastHardwarePulseTime
                    isArrangerPush = (timeSinceHW < 250.0 and timeSinceHW >= 0.0)

                    if not isArrangerPush then
                        Trace(">>> [FULL SYNC]: TRANSPORT: GP STOP (GUI). Sending command to arranger...")
                        FireDirectArrangerTransport()
                    else
                        Trace(">>> [FULL SYNC]: TRANSPORT: GP STOP (Arranger). No command to arranger...")
                    end
                    
                    StopWatchdogTimer = TimeSinceStartup() + 2500.0 
                    IsPerformanceActive = false
                    UpdateSyncLabel()
                end
            end
                
            // =========================================================
            // MODE 4: INITIAL LATCH
            // =========================================================
            if CurrentSyncMode == 4 then
                PendingPlayheadState = playing
                if playing then PlayheadEvalTimer = TimeSinceStartup() + 150.0 else PlayheadEvalTimer = TimeSinceStartup() + 300.0 end
                Trace(">>> SYS EVENT [INITIAL LATCH]: Playhead=" + playing + ". Starte Analyse-Timer...")
            end
            
            CurrentTriggerSource = "NONE"
        end
    end
End

// ---------------------------------------------------------
// LATCH AUTO-RELEASE (4-beat timeout + ms fallback)
// Called once per beat from On BeatChanged. Fires p_LatchRelease on every
// channel currently in Chord+Latch mode when no hardware note-on has been
// seen for LatchTimeoutBeats at the current BPM. Disarms itself after
// firing so subsequent beats are no-ops until the next note-on.
// ---------------------------------------------------------
Function CheckLatchTimeout()
   var currentBpm, msPerBeat, timeoutMs, idleMs : Double = 0.0
   var i, idx : Integer

   if Latch_LastNoteOnTime <= 0.0 then
       // Disarmed — nothing to check until next note-on
   else
       currentBpm = GetBPM()
       if currentBpm > 1.0 then
           msPerBeat = 60000.0 / currentBpm
           timeoutMs = msPerBeat * LatchTimeoutBeats
       else
           timeoutMs = LatchTimeoutFallbackMs
       end

       idleMs = TimeSinceStartup() - Latch_LastNoteOnTime
       if idleMs >= timeoutMs then
           For i = 0; i < 16; i = i + 1 Do
               if Mem_NP_ChordMode[i] == 1 and Mem_NP_LatchMode[i] == 1 then
                   idx = GetParamIdxByName(BLK_NoteProcessor[i], "p_LatchRelease")
                   if idx > -1 then SetParameter(BLK_NoteProcessor[i], idx, 1.0) end
               end
           End
           Latch_LastNoteOnTime = 0.0   // Disarm until next note-on
           if DebugMode then Trace("LATCH: auto-release fired after " + Round(idleMs) + "ms idle") end
       end
   end
End

On BeatChanged(bar : Integer, beat : Integer, subbeat : Integer)
   var e, ch, beatsPerBar : Integer
   var syncFired : Boolean = false
   var targetEndBar, tAct, nSt, jTgt, i : Integer
   
   // THE TRUTH FROM THE LOG: GP IS PERFECT!
   LastSystemBar = bar
   RealTransportBar = bar 
   CurrentBeat = beat 
   
   // ---> IMPORTANT: Global memory for the looper <---
   Global_CurrentBar = bar
   Global_CurrentBeat = beat
   Global_CurrentTick = subbeat
   
   if not IsLoading and not IsLoadingSnapshot then 
       CurrentBar = LastSystemBar + GlobalBarOffset
   end
   
   // --- THE STOPWATCH ---
   if beat == 1 then
       LastBarStartTime = TimeSinceStartup()
   end

   // ==================================================================
   // 1. LOOPER AUTO-TRANSITION (This saves you from MIDI-Clock jitter!)
   // ==================================================================
   if beat == 1 then
      For ch = 0; ch < 16; ch = ch + 1 Do
         // If recording AND a fixed length is set
         if Mem_Loop_State[ch] == 1 and Mem_Loop_Length[ch] > 0 then
             targetEndBar = LoopAnchorBar[ch] + Mem_Loop_Length[ch]
             
             // When we hit the finish line exactly!
             if CurrentBar >= targetEndBar then
                 LoopLengthMS[ch] = TimeSinceStartup() - LoopStartTime[ch]
                 CloseLooperBuffer(ch)
                 
                 tAct = Mem_Loop_Action[ch]
                 if tAct == 0 then nSt = 2 elsif tAct == 1 then nSt = 3 elsif tAct == 2 then nSt = 4 end
                 Mem_Loop_State[ch] = nSt
                 
                 LoopStartTime[ch] = TimeSinceStartup()
                 LoopNextEventIdx[ch] = GetLooperEventCount(ch)
                 LoopPlayheadMS[ch] = -1.0
                 
                 LoopAnchorBar[ch] = CurrentBar
                 LoopAnchorBeat[ch] = CurrentBeat
                 LoopAnchorTick[ch] = Global_CurrentTick
                 
                 // --- AUTO JUMP LOGIC ---
                 jTgt = Mem_Loop_Target[ch]
                 if jTgt != -1 then 
                     if DebugMode then Trace("LOOPER: Auto-Pilot Jump from Ch" + (ch+1) + " to Ch" + (jTgt+1)) end
                     
                     // 1. Switch UI focus
                     For i = 0; i < 16; i = i + 1 Do OutputScope[i] = false End
                     OutputScope[jTgt] = true
                     UpdateMetaColors(); SyncInputFeedback(); UpdateUsageLabelDisplay()
                     RefreshAllInjectionDisplays(); ScrollToCurrentChannel()
                     
                     // 2. ---> NEW: START TARGET CHANNEL IMMEDIATELY! <---
                     if Mem_Loop_State[jTgt] == 0 then // If target is empty -> Record!
                         Mem_Loop_State[jTgt] = 1
                         ClearLooperArrays(jTgt)
                         LoopStartTime[jTgt] = TimeSinceStartup()
                         LoopAnchorBar[jTgt] = CurrentBar
                         LoopAnchorBeat[jTgt] = CurrentBeat
                         LoopAnchorTick[jTgt] = Global_CurrentTick
                         
                         // Read length from the target channel
                         if Mem_Loop_Length[jTgt] > 0 then
                            beatsPerBar = GetTimeSigNumerator(); if beatsPerBar <= 0 then beatsPerBar = 4 end
                            LoopLengthMS[jTgt] = (60000.0 / GetBPM()) * IntToFloat(beatsPerBar) * IntToFloat(Mem_Loop_Length[jTgt])
                         end
                         if DebugMode then Trace("LOOPER: Target channel " + (jTgt+1) + " immediately switched to REC!") end
                         
                     elsif Mem_Loop_State[jTgt] == 4 then // If target is stopped -> Play!
                         Mem_Loop_State[jTgt] = 2
                         LoopStartTime[jTgt] = TimeSinceStartup(); LoopNextEventIdx[jTgt] = 0 
                         LoopAnchorBar[jTgt] = CurrentBar
                         LoopAnchorBeat[jTgt] = CurrentBeat
                         LoopAnchorTick[jTgt] = Global_CurrentTick
                         if DebugMode then Trace("LOOPER: Target channel " + (jTgt+1) + " immediately switched to PLAY!") end
                     end
                     
                     // FIRE DIAGNOSTIC SCANNER FOR TARGET CHANNEL!
                     if DebugMode then TraceLooperDiagnostic(jTgt, "AUTO-JUMP TRANSITION") end
                 end
                 
                 syncFired = true
                 if DebugMode then Trace("LOOPER: Auto-Transition Ch" + (ch+1) + " completed. Length: " + LoopLengthMS[ch] + "ms") end
                 
                 IgnoreUIFeedbackTimer = TimeSinceStartup() + 1500.0
             end
         end
      End
   end

   // ==================================================================
   // 2. LOOPER PUNCH-IN & PLAY/STOP STEUERUNG
   // ==================================================================
   if beat == 1 then
      For ch = 0; ch < 16; ch = ch + 1 Do
         if Mem_Loop_State[ch] == 5 then // ARM REC -> GO!
            Mem_Loop_State[ch] = 1
            ClearLooperArrays(ch)
            LoopStartTime[ch] = TimeSinceStartup()
            
            // Lock the anchor rigidly to beat "1"
            LoopAnchorBar[ch] = CurrentBar
            LoopAnchorBeat[ch] = CurrentBeat
            LoopAnchorTick[ch] = Global_CurrentTick
            
            // Fallback length calculation (will be overwritten at punch-out)
            if Mem_Loop_Length[ch] > 0 then
               beatsPerBar = GetTimeSigNumerator(); if beatsPerBar <= 0 then beatsPerBar = 4 end
               LoopLengthMS[ch] = (60000.0 / GetBPM()) * IntToFloat(beatsPerBar) * IntToFloat(Mem_Loop_Length[ch])
            end
            syncFired = true
            
            // ---> LOCK THE GATE <---
            IgnoreUIFeedbackTimer = TimeSinceStartup() + 1500.0
            
         elsif Mem_Loop_State[ch] == 6 then // ARM PLAY -> GO!
            Mem_Loop_State[ch] = 2
            
            LoopStartTime[ch] = TimeSinceStartup()
            LoopNextEventIdx[ch] = GetLooperEventCount(ch)
            LoopPlayheadMS[ch] = -1.0
            
            LoopAnchorBar[ch] = CurrentBar
            LoopAnchorBeat[ch] = CurrentBeat
            LoopAnchorTick[ch] = Global_CurrentTick
            
            syncFired = true
            
            // ---> LOCK THE GATE <---
            IgnoreUIFeedbackTimer = TimeSinceStartup() + 1500.0
            
         elsif Mem_Loop_State[ch] == 7 and Mem_Loop_StopMode[ch] == 1 then 
            // PENDING STOP -> END OF BAR!
            Mem_Loop_State[ch] = 4
            Trigger_NotesOff(ch + 1)
            syncFired = true
            
            // ---> LOCK THE GATE <---
            IgnoreUIFeedbackTimer = TimeSinceStartup() + 1500.0
         end
      End
   end
   
   // Update bar text (Bar 1.4 / 4 etc.)
   BuildLooperConfigLines() 
   
   if syncFired then 
       UpdateSoloMuteState()
       // Silently update the UI (bounce-back is blocked by the 1500ms timer)
       UpdateInjectionLooperTransportUI() 
   end
   
   // --- UI PROMPTER UPDATE ---
   if not IsLoading and not IsLoadingSnapshot then 
       if RecordMode > 0 or TimelineRecActive then
           UpdatePrompter(false)
       else
           UpdatePrompter(true)
       end
   end
   
   // --- TIMELINE TRIGGER RESET (removed: ms-based playback resets Snap_TL_Fired at start) ---

   // ---> TIME DOMAIN TRACE <---
   if beat == 1 and subbeat == 0 then
       if DebugMode then TraceTimeDomains() end
   end
End

On SysexEvent(m : SysexMessage) From DeviceIn_0
   var byte1, byte2, byte3, byte5, msgSize : Integer; val4, val5, val6, val7 : Integer
   var regButtonIndex, i, microSecs : Integer
   var newBPM : Double = 0.0; var incomingHex : String; var switchOk : Boolean 
   var regNameDecoded, regNameSlug, gpSongSlug, gpArtistSlug : String
   var foundMatch : Boolean = false; var currentSongName : String
   var regNumber, byteIdx, swIdx : Integer
   var incomingHexFull : String = ""

   msgSize = SM_Length(m)
   If msgSize >= 6 Then
      byte1 = SM_GetValue(m, 1); byte2 = SM_GetValue(m, 2); byte3 = SM_GetValue(m, 3)
      
      // ---> NEW: THE SYSEX HEARTBEAT <---
      // 0x43 is the manufacturer ID of Yamaha. Every message from the arranger carries this stamp!
      if byte1 == 0x43 then
          LastHardwarePulseTime = TimeSinceStartup()
      end

      // ---> LAYER SWITCH MATCHING <---
      // Build full hex string from incoming SysEx for comparison
      incomingHexFull = ""
      For byteIdx = 0; byteIdx < msgSize; byteIdx = byteIdx + 1 Do
         if byteIdx > 0 then
            incomingHexFull = incomingHexFull + " "
         end
         incomingHexFull = incomingHexFull + IntToHexString(SM_GetValue(m, byteIdx))
      End
      incomingHexFull = MyToUpper(incomingHexFull)

      For swIdx = 0; swIdx < LayerSwitch_Count; swIdx = swIdx + 1 Do
         if LayerSwitch_DevIdx[swIdx] == 0 and LayerSwitch_Type[swIdx] == "SYSEX" then
            if incomingHexFull == MyToUpper(LayerSwitch_OnData[swIdx]) then
               LayerSwitch_State[swIdx] = 1
               UpdateActiveLayer()
               if DebugMode then
                  Trace("LAYERSWITCH " + IntToString(swIdx) + " (" + LayerSwitch_Label[swIdx] + "): ON")
               end
            elsif incomingHexFull == MyToUpper(LayerSwitch_OffData[swIdx]) then
               LayerSwitch_State[swIdx] = 0
               UpdateActiveLayer()
               if DebugMode then
                  Trace("LAYERSWITCH " + IntToString(swIdx) + " (" + LayerSwitch_Label[swIdx] + "): OFF")
               end
            end
         end
      End

      // 1. BPM SYNC
      if byte1 == 0x43 and byte2 == 0x7E and byte3 == 0x01 Then
          IncomingFromArranger = true; LoopSafetyTimer = TimeSinceStartup()
         if msgSize >= 9 Then
            val4 = SM_GetValue(m, 4); val5 = SM_GetValue(m, 5); val6 = SM_GetValue(m, 6); val7 = SM_GetValue(m, 7)
            microSecs = (val4 * 2097152) + (val5 * 16384) + (val6 * 128) + val7
            if microSecs > 0 Then newBPM = 60000000.0 / microSecs; if Abs(GetBPM() - newBPM) > 0.5 Then LastReceivedBPM = newBPM; SetBPM(newBPM) End End
         End
         
      // 2. ARRANGER COMMANDS (SONG SELECT & REG MEMORY)
      Elsif byte1 == 0x43 and byte2 == 0x73 and byte3 == 0x01 and SM_GetValue(m, 4) == 0x52 Then
         byte5 = SM_GetValue(m, 5)
         
         // --- SONG SELECT ---
         if byte5 == 0x26 Then 
             if (TimeSinceStartup() - LastSysExSentTime) > 2000.0 Then
                if not InSetlistMode() Then SwitchToSetlistView(); Wait(200.0) End
                if msgSize >= 23 Then
                   incomingHex = GetSysexString(m)
                   i = 0
                   
                   // ---> DIE ERSTE SICHERE WHILE-SCHLEIFE <---
                   While i < Size(Mapping_SysEx) and not foundMatch Do
                      if incomingHex == Mapping_SysEx[i] Then
                         Trace("ARRANGER: Known SysEx -> " + Mapping_GPSong[i])
                         if GetCurrentSongName() != Mapping_GPSong[i] Then
                            IgnoreNextSongSwitch = true; switchOk = SwitchToSongByName_Safe(Mapping_GPSong[i]); Wait(100.0) 
                            currentSongName = GetCurrentSongName(); LoadSongSnapshot(currentSongName, false);
                         End
                         foundMatch = true 
                      End
                      i = i + 1
                   End
                   
                   if not foundMatch Then
                       Trace("ARRANGER: Unknown SysEx. Trying auto-match...")
                       regNameDecoded = DecodeDeviceSysExName(incomingHex); regNameSlug = SanitizeAndSlugify(regNameDecoded) 
                       
                       // ---> DIE ZWEITE SICHERE WHILE-SCHLEIFE <---
                       i = 0
                       While i < GetSongCount() and not foundMatch Do
                           gpSongSlug = SanitizeAndSlugify(GetSongName(i)); gpArtistSlug = SanitizeAndSlugify(GetSongArtistName(i))
                           if Length(gpSongSlug) > 0 then
                               if gpSongSlug == regNameSlug then foundMatch = true
                               elsif Length(gpArtistSlug) > 0 and IndexOfSubstring(regNameSlug, gpSongSlug, true) > -1 and IndexOfSubstring(regNameSlug, gpArtistSlug, true) > -1 then foundMatch = true
                               elsif Length(gpSongSlug) > 2 and IndexOfSubstring(regNameSlug, gpSongSlug, true) > -1 then foundMatch = true end
                               
                               if foundMatch then
                                   Trace("ARRANGER: MATCH! " + regNameDecoded + " -> " + GetSongName(i))
                                   AddNewMapping(incomingHex, GetSongName(i), regNameDecoded)
                                   IgnoreNextSongSwitch = true; switchOk = SwitchToSongByIndex(i, 0); Wait(100.0) 
                                   currentSongName = GetCurrentSongName(); LoadSongSnapshot(currentSongName, false)
                               end
                           end
                           i = i + 1
                       End
                   end
                   if not foundMatch Then Trace("ARRANGER: Unknown file '" + regNameDecoded + "'. Ignoring."); LastUnknownSysEx_Trigger = "" end
                End
             End
             
         // --- REGISTRATION MEMORY SWITCH ---
         Elsif byte5 == 0x25 Then 
            if msgSize >= 12 Then
               // FIX: The value is at index 10 (not 11). 11 is F7.
               regButtonIndex = SM_GetValue(m, 10) 
               regNumber = regButtonIndex + 1 // So we have logical numbers from 1 to 10
               
               Trace("PROMPTER: Arranger sends RegMem " + regNumber)
               
               if not InSetlistMode() Then SwitchToSetlistView(); Wait(200.0) End

               // =========================================================
               // NEW: HARDWARE RE-SYNC (Hardware state sync)
               // =========================================================
               // 1. LOCK THE GATE! Block all fader inputs immediately,
               // so arranger motors don't overwrite our GP setup!
               FaderSafetyTimer = TimeSinceStartup() + 800.0 
               
               // 2. Set timer to force our values back after 300ms
               HardwareSyncTimer = TimeSinceStartup() + 300.0
               
               // === 1. RECORDING (Ignored when REC is off) ===
               RecordTimelineEvent("RegMem", regNumber)
               
               // === 2. TIME-MACHINE LOGIC (only execute when NOT recording) ===
               if RecordMode == 0 then
                   if IsPerformanceActive == false then
                       // Mode: PAUSE -> Find the bar of this RegMem and jump there
                       JumpToRegMemAnchor(regNumber)
                   else
                       // Mode: PLAY -> Autopilot monitors the jump
                       CheckRegMemAutopilot(regNumber)
                   end
               end
               
            End
         End
      End
   End
End

// ---------------------------------------------------------
// OSC RECEIVER (VOM LOKALEN RACKSPACE)
// ---------------------------------------------------------

On OSCMessageReceived(m : OSCMessage) Matching "/Command/Scrub"
    ExecuteScrub(OSC_GetArgAsDouble(m, 0), true) // true = from GUI, do NOT send back
End

// --- ADDED BLOCK ---
On OSCMessageReceived(m : OSCMessage) Matching "/Command/RequestUIUpdate"
    // Fires when the local rackspace is activated.
    // Forces the global engine to immediately send the current text to the fresh displays.
    Trace("OSC: Local Rackspace requested UI Update.")
    UpdatePrompter(true)
End

On OSCMessageReceived(m : OSCMessage) Matching "/GP/ViewReady"
    Trace("<<< OSC-IN: Message '/GP/ViewReady' RECEIVED from Python! <<<")
    
    if OSC_IsWaitingForViewSwitch then
        Trace("<<< OSC-IN: Status was 'Waiting'. Starting 3s stabilization timer... <<<")
        
        // End waiting for view switch
        OSC_IsWaitingForViewSwitch = false
        OSC_ViewSwitchTimeout = 0.0
        
        // Only set the timestamp. The rest is handled by On TimerTick (section A.1)
        // This provides the 3-second observation pause without freezing GP.
        PostViewSwitchDelayTimer = TimeSinceStartup() + 3000.0 
    else
        Trace("<<< OSC-IN: Ignored (script was not waiting for view switch).")
    end
End

// ---------------------------------------------------------
// ANCHORPLAYBACK: FORWARD-ONLY ROOT TRACKER
// ---------------------------------------------------------

Function ExecuteAnchorPartChange(newPartIdx : Integer)
   var i, markerEventIdx : Integer
   var sectionName : String = ""

   if newPartIdx < Size(Arr_SectionNames) then sectionName = Arr_SectionNames[newPartIdx] end

   // 1. ALWAYS: Update prompter display
   PreviewPartIdx = newPartIdx
   UpdatePrompter(false)

   // 2. ALWAYS: HUD feedback
   if sectionName != "" then
       OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> ANCHOR: " + sectionName + " <<<", Local_IP, Local_PORT)
       MacroFeedbackTimer = TimeSinceStartup() + 2000.0
   end

   // 3. TIMEJUMP: Correct timeline position if enabled
   if GetWidgetValue(BTN_TimeJump) > 0.5 and TimelinePlaybackActive then
       // Find the Marker event for this part in the timeline
       markerEventIdx = -1
       i = 0
       While i < Size(Snap_TL_Type) and markerEventIdx == -1 Do
           if Snap_TL_Type[i] == "Marker" and Snap_TL_Val[i] == newPartIdx then
               markerEventIdx = i
           end
           i = i + 1
       End

       if markerEventIdx >= 0 then
           // Adjust PlaybackStartTimeMS so msSinceSongStart aligns with the marker's ms
           PlaybackStartTimeMS = TimeSinceStartup() - Snap_TL_TimeMS[markerEventIdx]
           Trace("ANCHOR: TimeJump -> Corrected timeline to " + Round(Snap_TL_TimeMS[markerEventIdx]) + "ms (Part: " + sectionName + ")")
       end
   end

   Trace("ANCHOR: Part change -> " + sectionName + " (idx=" + newPartIdx + ")")
End

Function ProcessAnchorPlayback()
   var currentRoot, nextPartIdx, expectedRoot, nextExpectedRoot, matchThreshold : Integer
   var srcChIdx : Integer = -1

   // 1. GATE: Feature active? Channels configured? Root data available?
   if GetWidgetValue(BTN_MIDIAnchorPlayback) < 0.5 then // Feature off
   elsif Size(Arr_PartRootSeq) == 0 then // No chord data
   elsif AnchorDetectedRootIdx == -1 then // Parameters not cached
   else
       // 2. READ ROOT from Lower (fallback: Upper)
       if AnchorLowerChIdx >= 0 then
           if GetParameter(BLK_NoteProcessor[AnchorLowerChIdx], AnchorHasNotesIdx) > 0.5 then
               srcChIdx = AnchorLowerChIdx
           end
       end
       if srcChIdx == -1 and AnchorUpperChIdx >= 0 then
           if GetParameter(BLK_NoteProcessor[AnchorUpperChIdx], AnchorHasNotesIdx) > 0.5 then
               srcChIdx = AnchorUpperChIdx
           end
       end

       if srcChIdx >= 0 then
           currentRoot = Round(GetParameter(BLK_NoteProcessor[srcChIdx], AnchorDetectedRootIdx) * 11.0)

           // 3. DEDUPLICATE — same root as last time, no new info
           if currentRoot != AnchorLastRoot then
               AnchorLastRoot = currentRoot

               // 4. TRACK against current part
               if AnchorCurrentPartIdx < Size(Arr_PartRootStart) then
                   if AnchorRootCursor < Arr_PartRootLen[AnchorCurrentPartIdx] then
                       expectedRoot = Arr_PartRootSeq[Arr_PartRootStart[AnchorCurrentPartIdx] + AnchorRootCursor]
                       if currentRoot == expectedRoot then
                           AnchorRootCursor = AnchorRootCursor + 1
                           if AnchorRootCursor >= Arr_PartRootLen[AnchorCurrentPartIdx] then
                               AnchorRootCursor = 0  // Wrap — part is repeating
                           end
                       end
                   end
               end

               // 5. CHECK against next part
               nextPartIdx = AnchorCurrentPartIdx + 1
               if nextPartIdx < Size(Arr_PartRootStart) then
                   if AnchorMatchCount < Arr_PartRootLen[nextPartIdx] then
                       nextExpectedRoot = Arr_PartRootSeq[Arr_PartRootStart[nextPartIdx] + AnchorMatchCount]
                       if currentRoot == nextExpectedRoot then
                           AnchorMatchCount = AnchorMatchCount + 1
                       else
                           AnchorMatchCount = 0  // Reset
                       end
                   end

                   // 6. TRIGGER part change at dynamic threshold (min 1 for single-chord parts)
                   matchThreshold = Arr_PartRootLen[nextPartIdx]
                   if matchThreshold > 2 then matchThreshold = 2 end
                   if matchThreshold > 0 and AnchorMatchCount >= matchThreshold then
                       AnchorCurrentPartIdx = nextPartIdx
                       AnchorRootCursor = 0  // Restart tracking in new part
                       AnchorMatchCount = 0
                       ExecuteAnchorPartChange(AnchorCurrentPartIdx)
                   end
               end
           end
       end
   end
End

// ---------------------------------------------------------
// TIMER EVENTS
// ---------------------------------------------------------

On TimerTick(ms : Double)
   var
     currentIsSetlist : Boolean = InSetlistMode()
     isGUI, isStillBypassed, needsBlink, anyLooperActive : Boolean
     tr : Integer = GetGlobalTranspose()
     k, a_idx, tl_idx, k_blink, k_loop, beatsPerBar, beatsPerBar_tick : Integer
     maxCountInBeats, remB, ledIndex : Integer
     lfoSlotStop : Integer
     msLeft_blink : Double = 0.0; timeSinceHW : Double = 0.0; t_progress : Double = 0.0;
     a_val : Double = 0.0; msSinceBarStart : Double = 0.0; currentBPM_Tick : Double = 0.0; msPerBeat : Double = 0.0
     msSinceSongStart : Double = 0.0
     countdownBars : Double = 0.0; nowDb : Double = 0.0
     countdownText : String = ""
     dbIdx : Integer

   // ========================================================================
   // --- INITIALIZATION FOR THIS TICK ---
   // ========================================================================
   currentBPM_Tick = GetBPM()
   if currentBPM_Tick < 1.0 then currentBPM_Tick = 120.0 end
   msPerBeat = 60000.0 / currentBPM_Tick
   anyLooperActive = false

   // ========================================================================
   // OVERLAY DEBOUNCE TIMER CHECK
   // ========================================================================
   nowDb = TimeSinceStartup()
   For dbIdx = 0; dbIdx < MAX_OVERLAY_BINDINGS; dbIdx = dbIdx + 1 Do
      if Debounce_Active[dbIdx] then
         if nowDb - Debounce_Timer[dbIdx] > DEBOUNCE_TIMEOUT then
            Debounce_Active[dbIdx] = false
         end
      end
   End

   // ========================================================================
   // EMERGENCY KILL SWITCH AUTO-RECOVERY
   // ========================================================================
   // The Trace() watchdog at line ~845 flips EmergencyKillSwitch when it
   // detects a flood (>250 traces within 100ms). TickLFOs and the macro
   // handler then freeze themselves, which stops the flood. After 3s of
   // calm (no new traces), we auto-clear the kill switch so the system
   // resumes normal operation. TraceLastTime is updated on every Trace()
   // call, so its age is a reliable "how long since the last script
   // activity" measure.
   if EmergencyKillSwitch and (TimeSinceStartup() - TraceLastTime) > 3000.0 then
       EmergencyKillSwitch = false
       Trace("EMERGENCY: Kill switch auto-recovered after 3s of calm")
   end

   // Deferred UpdateSoloMuteState from Timeline overlay replay
   if SoloMuteStateDirty then
      SoloMuteStateDirty = false
      UpdateSoloMuteState()
   end

   // ========================================================================
   // A. SYSTEM LOGIC (PRIORITY: ALWAYS RUNS, EVEN WITH ACTIVE KILLSWITCH)
   // ========================================================================

   // 0b. LFO ENGINE + 0a. LATCH AUTO-RELEASE
   // Both touch plugin parameters (SetParameter on macros / NoteProcessor scriptlets)
   // and MUST be guarded against the initial boot window and against any active
   // snapshot load. Without this guard, a TimerTick firing during PHASE 6 of
   // Initialization (LoadSongSnapshot closing/replacing plugins) can crash GP
   // when CheckLatchTimeout or TickLFOs write to a transient plugin state.
   // FaderSafetyTimer covers the 5-second cold-boot window; IsLoadingSnapshot
   // covers every subsequent song switch.
   if not IsLoadingSnapshot and TimeSinceStartup() > FaderSafetyTimer then
       TickLFOs()
       CheckLatchTimeout()
   end

   // 0c. LFO flash auto-clear — when the 1.5s flash window expires,
   // transition the LBL_LFO_BoundMacro display from the flash message
   // (phase 1) to the bindings list (phase 2). Cheap no-op when
   // LFOFlashTimer is 0 (inactive).
   if LFOFlashTimer > 0.0 and TimeSinceStartup() >= LFOFlashTimer then
       LFOFlashTimer = 0.0
       LFOFlashMsg = ""
       RefreshLFOBoundMacroDisplay()
   end

   // 0d. Deferred LFO inspector refresh — consumed flag set by
   // CycleEditScope / CycleScopeSection (SECTION 17, forward-decl
   // trap). We pick it up here because RefreshLFOInspector is in
   // file-order above us.
   if LFOInspectorNeedsRefresh then
       LFOInspectorNeedsRefresh = false
       RefreshLFOInspector()
   end

   // 0. JOYSTICK CROSS-TALK GUARD (CC16 vs PitchBend: dominant axis wins after 120ms)
   if Joy_CC16_ArmTime > 0.0 and not Joy_CC16_Fired then
       if TimeSinceStartup() - Joy_CC16_ArmTime >= 120.0 then
           if Joy_PB_Fired == 0 then
               // CC16 dominant (PB quiet after 120ms) → intentional down press
               if DebugMode then Trace(">>> SYSMODE-DIAG [D] CYCLE via CC16 timer (120ms, PB quiet) in TimerTick") end
               Joy_CC16_Fired = true
               CycleGlobalSystemMode()
           else
               if DebugMode then Trace(">>> SYSMODE-DIAG [D-BLOCKED] CC16 suppressed (PB_Fired=" + Joy_PB_Fired + ") cross-talk") end
           end
           Joy_CC16_ArmTime = 0.0  // Decision made, clear window
       end
   end

   // 1. STABILIZATION TIMER (Replaces the 3s wait after view switch)
   if PostViewSwitchDelayTimer > 0.0 then
       if TimeSinceStartup() > PostViewSwitchDelayTimer then
           PostViewSwitchDelayTimer = 0.0 
           Trace("TIMER: 3s stabilization finished. Starting activation sequence...")
           ContinueActualReplace(true, PendingReplaceSlotIdx, PendingReplacePath, PendingReplaceIsManual)
       end
   end

   // 2. ACTIVATION POLLING
   if IsWaitingForWakeUp then
       if TimeSinceStartup() > WakeUpCheckTimer then
           isStillBypassed = IsPluginBypassed(BLK_VST[PendingReplaceSlotIdx])
           
           if not isStillBypassed then
               // PLUGIN IS READY -> NOW THE LIVE SHOT
               IsWaitingForWakeUp = false 
               Trace("HARD-FIRE: SUCCESS! Plugin is active. Executing ReplacePlugin now.")
               
               Select
                   PendingReplaceSlotIdx == 0 Do ReplacePlugin(VST1_GRS, PendingReplacePath, "")
                   PendingReplaceSlotIdx == 1 Do ReplacePlugin(VST2_GRS, PendingReplacePath, "")
                   PendingReplaceSlotIdx == 2 Do ReplacePlugin(VST3_GRS, PendingReplacePath, "")
                   PendingReplaceSlotIdx == 3 Do ReplacePlugin(VST4_GRS, PendingReplacePath, "")
                   PendingReplaceSlotIdx == 4 Do ReplacePlugin(VST5_GRS, PendingReplacePath, "")
                   PendingReplaceSlotIdx == 5 Do ReplacePlugin(VST6_GRS, PendingReplacePath, "")
                   PendingReplaceSlotIdx == 6 Do ReplacePlugin(VST7_GRS, PendingReplacePath, "")
                   PendingReplaceSlotIdx == 7 Do ReplacePlugin(VST8_GRS, PendingReplacePath, "")
                   PendingReplaceSlotIdx == 8 Do ReplacePlugin(VST9_GRS, PendingReplacePath, "")
                   PendingReplaceSlotIdx == 9 Do ReplacePlugin(VST10_GRS, PendingReplacePath, "")
               End
               
               Trace("HARD-FIRE: Command sent to GP.")
               Trace(">>> SHADOW MODE: Would now replace VST " + (PendingReplaceSlotIdx + 1) + " with [" + PendingReplacePath + "]! <<<")
               
               SwitchToSetlistView()
               
           elsif WakeUpRetryCount < 20 then
               WakeUpRetryCount = WakeUpRetryCount + 1
               WakeUpCheckTimer = TimeSinceStartup() + 200.0
               Trace("HARD-FIRE: Engine is still activating... (Retry " + WakeUpRetryCount + ")")
           else
               Trace("HARD-FIRE: CRITICAL ERROR - Plugin failed to activate.")
               IsWaitingForWakeUp = false
               SwitchToSetlistView()
               EmergencyKillSwitch = false 
           end
       end
   end

   // ========================================================================
   // --- AUTO-SHOW GUI ENGINE (Das Karussell) ---
   // ========================================================================
   if AutoShowGUITimer > 0.0 and TimeSinceStartup() > AutoShowGUITimer then
       AutoShowGUITimer = 0.0 
       
       IsUpdatingGUI = true // <--- SCHUTZSCHILD AN
       
       if Active_VST_GUI > -1 and Active_VST_GUI != Pending_VST_GUI then
           ClosePlugin(BLK_VST[Active_VST_GUI])
           SetWidgetValue(W_OpenCloseVST[Active_VST_GUI], 0.0)
       end
           
       if Pending_VST_GUI > -1 then
           OpenPlugin(BLK_VST[Pending_VST_GUI])
           SetWidgetValue(W_OpenCloseVST[Pending_VST_GUI], 1.0)
           SetWidgetValue(VST_Open, 1.0)
           Active_VST_GUI = Pending_VST_GUI
           if DebugMode then Trace("AUTO-SHOW: VST " + (Active_VST_GUI+1) + " GUI opened.") end
       end
           
       IsUpdatingGUI = false // <--- SCHUTZSCHILD AUS
       Pending_VST_GUI = -1 
   end
   
   // 3. SMART POLLING INSPECTOR
   if ReplaceTargetIdx != -1 then
       if not ReplacePollingActive and TimeSinceStartup() > ReplaceTimeoutTimer then
           ReplacePollingActive = true
           ReplaceTimeoutTimer = TimeSinceStartup() + 3000.0 
       end
       
       if ReplacePollingActive then
           RefreshVstArray(ReplaceTargetIdx)
           if GetPluginInfo(BLK_VST[ReplaceTargetIdx], 0) == ReplaceTargetName then
               Trace("INSPECTOR: Success detected! Forwarding to Queue Processor...")
               ProcessTopQueueJobResult(false) 
               ReplaceTargetIdx = -1 
               ReplacePollingActive = false
               ReplaceTimeoutTimer = TimeSinceStartup() + 1000.0
           elsif TimeSinceStartup() > ReplaceTimeoutTimer then
               Trace("INSPECTOR: Timeout! Replace failed.")
               ProcessTopQueueJobResult(false) 
               ReplaceTargetIdx = -1 
               ReplacePollingActive = false
               ReplaceTimeoutTimer = TimeSinceStartup() + 1000.0
           end
       end
    end

    // ========================================================================
    // --- GP TRANSPORT ECHO SENDER ---
    // ========================================================================
    if GPTransportEvaluationTimer > 0.0 and TimeSinceStartup() > GPTransportEvaluationTimer then
        GPTransportEvaluationTimer = 0.0
            
        if TimeSinceStartup() < SyncLockTimer then
            Trace(">>> ECHO SENDER: Bounce blocked (800ms protection active).")
        else
            SyncLockTimer = TimeSinceStartup() + 800.0
            Trace(">>> ECHO SENDER: Sending START/STOP to arranger.")
            SetParameter(BLK_ArrangerSync, P_STYLE_START_STOP, 1.0)
            StyleTriggerResetTimer = TimeSinceStartup() + 60.0
        end
     end

   // ========================================================================
   // B. FROZEN SECTION (BLOCKED BY THE KILLSWITCH)
   // ========================================================================
   if EmergencyKillSwitch == false then 
       
       // --- GLOBAL BLINK ENGINE (The smart metronome & countdown) ---
       maxCountInBeats = 0
       
       for k_blink = 0; k_blink < 16; k_blink = k_blink + 1 do
           if Mem_Loop_State[k_blink] != 0 and Mem_Loop_State[k_blink] != 4 then anyLooperActive = true end
           
           // Find out if a looper is currently in count-in (State 8)
           if Mem_Loop_State[k_blink] == 8 then
               msLeft_blink = LoopFreeArmTimer[k_blink] - TimeSinceStartup()
               if msLeft_blink < 0.0 then msLeft_blink = 0.0 end
               
               remB = Round((msLeft_blink + (msPerBeat / 2.0)) / msPerBeat)
               if remB < 1 then remB = 1 end
               if remB > maxCountInBeats then maxCountInBeats = remB end
           end
       end

       // Timeline count-in contributes to the same LED display
       if TimelineCountInTimer > 0.0 and not TimelineRecActive then
           msLeft_blink = TimelineCountInTimer - TimeSinceStartup()
           if msLeft_blink > 0.0 then
               remB = Round((msLeft_blink + (msPerBeat / 2.0)) / msPerBeat)
               if remB > maxCountInBeats then maxCountInBeats = remB end
               anyLooperActive = true  // Ensure LED display updates during Timeline count-in
           end
       end

       if anyLooperActive or RecordMode > 0 or IsPerformanceActive then

           // CASE A: COUNT-IN RUNNING (transport still stopped)
           if maxCountInBeats > 0 then
               ledIndex = 4 - ((maxCountInBeats - 1) % 4)
               
               SetWidgetValue(LBL_Subbar_1, if ledIndex == 1 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_Subbar_2, if ledIndex == 2 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_Subbar_3, if ledIndex == 3 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_Subbar_4, if ledIndex == 4 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_TL_Subbar_1, if ledIndex == 1 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_TL_Subbar_2, if ledIndex == 2 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_TL_Subbar_3, if ledIndex == 3 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_TL_Subbar_4, if ledIndex == 4 then 1.0 else 0.0 end)
               
               if TimeSinceStartup() > Global_BlinkTimer then
                   Global_BlinkTimer = TimeSinceStartup() + msPerBeat
                   BuildLooperConfigLines() // Text-Countdown im Display updaten
               end

           // CASE B: TRANSPORT RUNNING -> Normal beat indicator (1, 2, 3, 4)
           elsif IsPerformanceActive then
               Global_BlinkState = IntToFloat(CurrentBeat)
               
               SetWidgetValue(LBL_Subbar_1, if Global_BlinkState == 1.0 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_Subbar_2, if Global_BlinkState == 2.0 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_Subbar_3, if Global_BlinkState == 3.0 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_Subbar_4, if Global_BlinkState >= 4.0 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_TL_Subbar_1, if Global_BlinkState == 1.0 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_TL_Subbar_2, if Global_BlinkState == 2.0 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_TL_Subbar_3, if Global_BlinkState == 3.0 then 1.0 else 0.0 end)
               SetWidgetValue(LBL_TL_Subbar_4, if Global_BlinkState >= 4.0 then 1.0 else 0.0 end)
               
           // CASE C: SONG IS STOPPED, WAITING FOR SYNC -> Only LED 1 blinks (Armed status)
           else
               if TimeSinceStartup() > Global_BlinkTimer then
                   Global_BlinkTimer = TimeSinceStartup() + msPerBeat
                   if Global_BlinkState == 1.0 then Global_BlinkState = 0.0 else Global_BlinkState = 1.0 end
                   BuildLooperConfigLines() 
               end
               
               SetWidgetValue(LBL_Subbar_1, Global_BlinkState)
               SetWidgetValue(LBL_Subbar_2, 0.0)
               SetWidgetValue(LBL_Subbar_3, 0.0)
               SetWidgetValue(LBL_Subbar_4, 0.0)
               SetWidgetValue(LBL_TL_Subbar_1, Global_BlinkState)
               SetWidgetValue(LBL_TL_Subbar_2, 0.0)
               SetWidgetValue(LBL_TL_Subbar_3, 0.0)
               SetWidgetValue(LBL_TL_Subbar_4, 0.0)
           end
       else
           // Looper inaktiv -> Alle LEDs aus
           SetWidgetValue(LBL_Subbar_1, 0.0); SetWidgetValue(LBL_Subbar_2, 0.0); SetWidgetValue(LBL_Subbar_3, 0.0); SetWidgetValue(LBL_Subbar_4, 0.0)
           SetWidgetValue(LBL_TL_Subbar_1, 0.0); SetWidgetValue(LBL_TL_Subbar_2, 0.0); SetWidgetValue(LBL_TL_Subbar_3, 0.0); SetWidgetValue(LBL_TL_Subbar_4, 0.0)
       end

       // --- MONITOR FREE ARM COUNTDOWN (Status 8) ---
       For k_loop = 0; k_loop < 16; k_loop = k_loop + 1 Do
           if Mem_Loop_State[k_loop] == 8 then
               if TimeSinceStartup() >= LoopFreeArmTimer[k_loop] then
                   
                   // ---> THE CRITICAL SWITCH FOR COUNT-IN! <---
                   if GetWidgetValue(BTN_Loop_HostSync) > 0.5 then
                       // HOST SYNC [ON]: Fire master transport!
                       if not IsPlayheadEnabled() then
                           if CurrentSyncMode == 2 or CurrentSyncMode == 3 then
                               FireDirectArrangerTransport()
                               LastHardwarePulseTime = TimeSinceStartup() + 1000.0 // Echo protection
                           else
                               IsPerformanceActive = true
                               UpdateSyncLabel()
                               EnablePlayhead(true) 
                           end
                       end
                       
                       Mem_Loop_State[k_loop] = 5 // ARM REC
                       if DebugMode then Trace("COUNT-IN FINISHED: Arranger/GP started. Looper waiting for sync (State 5).") end
                       
                   else
                       // HOST SYNC [OFF]: Start isolated!
                       Mem_Loop_State[k_loop] = 1 // REC
                       ClearLooperArrays(k_loop)
                       
                       LoopStartTime[k_loop] = TimeSinceStartup()
                       LoopNextEventIdx[k_loop] = 0
                       LoopPlayheadMS[k_loop] = -1.0
                       
                       LoopAnchorBar[k_loop] = CurrentBar
                       LoopAnchorBeat[k_loop] = CurrentBeat
                       LoopAnchorTick[k_loop] = Global_CurrentTick
                       
                       if Mem_Loop_Length[k_loop] > 0 then
                           beatsPerBar_tick = GetTimeSigNumerator(); if beatsPerBar_tick <= 0 then beatsPerBar_tick = 4 end
                           LoopLengthMS[k_loop] = (60000.0 / GetBPM()) * IntToFloat(beatsPerBar_tick) * IntToFloat(Mem_Loop_Length[k_loop])
                       end
                       
                       BuildLooperConfigLines()
                       IgnoreUIFeedbackTimer = TimeSinceStartup() + 1500.0
                       UpdateInjectionLooperTransportUI()
                       
                       if DebugMode then Trace("COUNT-IN FINISHED: HostSync OFF. Looper starts isolated (State 1).") end
                   end

               end
           end
       End

       // --- TIMELINE COUNT-IN MONITOR ---
       if TimelineCountInTimer > 0.0 and not TimelineRecActive then
           if TimeSinceStartup() >= TimelineCountInTimer then
               TimelineCountInTimer = 0.0
               TimelineRecActive = true
               RecordStartTimeMS = TimeSinceStartup()

               Trace("TIMELINE: Count-in expired. Recording started at " + Round(RecordStartTimeMS) + "ms")
               OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> TIMELINE: REC <<<", Local_IP, Local_PORT)
               MacroFeedbackTimer = TimeSinceStartup() + 2000.0
           end
       end

       ProcessLooperPlayback()
       
       // --- ISOLATED AUTO-TRANSITION (WHEN HOST SYNC IS OFF) ---
       For k_loop = 0; k_loop < 16; k_loop = k_loop + 1 Do
           if Mem_Loop_State[k_loop] == 1 and Mem_Loop_Length[k_loop] > 0 then
               if GetWidgetValue(BTN_Loop_HostSync) < 0.5 then
                   if (TimeSinceStartup() - LoopStartTime[k_loop]) >= LoopLengthMS[k_loop] then
                       
                       CloseLooperBuffer(k_loop)
                       
                       // Same logic as in grid mode
                       if Mem_Loop_Action[k_loop] == 0 then Mem_Loop_State[k_loop] = 2 
                       elsif Mem_Loop_Action[k_loop] == 1 then Mem_Loop_State[k_loop] = 3 
                       elsif Mem_Loop_Action[k_loop] == 2 then Mem_Loop_State[k_loop] = 4 end
                       
                       LoopStartTime[k_loop] = LoopStartTime[k_loop] + LoopLengthMS[k_loop]
                       LoopNextEventIdx[k_loop] = GetLooperEventCount(k_loop)
                       LoopPlayheadMS[k_loop] = -1.0
                       
                       // Auto Jump
                       if Mem_Loop_Target[k_loop] != -1 then 
                           For a_idx = 0; a_idx < 16; a_idx = a_idx + 1 Do OutputScope[a_idx] = false End
                           OutputScope[Mem_Loop_Target[k_loop]] = true
                           
                           if Mem_Loop_State[Mem_Loop_Target[k_loop]] == 0 then 
                               Mem_Loop_State[Mem_Loop_Target[k_loop]] = 1
                               ClearLooperArrays(Mem_Loop_Target[k_loop])
                               LoopStartTime[Mem_Loop_Target[k_loop]] = TimeSinceStartup()
                               if Mem_Loop_Length[Mem_Loop_Target[k_loop]] > 0 then
                                  beatsPerBar_tick = GetTimeSigNumerator(); if beatsPerBar_tick <= 0 then beatsPerBar_tick = 4 end
                                  LoopLengthMS[Mem_Loop_Target[k_loop]] = (60000.0 / GetBPM()) * IntToFloat(beatsPerBar_tick) * IntToFloat(Mem_Loop_Length[Mem_Loop_Target[k_loop]])
                               end
                           end
                           
                           UpdateMetaColors(); SyncInputFeedback(); UpdateUsageLabelDisplay()
                           RefreshAllInjectionDisplays(); ScrollToCurrentChannel()
                       end
                       
                       IgnoreUIFeedbackTimer = TimeSinceStartup() + 1500.0
                       BuildLooperConfigLines()
                       UpdateInjectionLooperTransportUI()
                       if DebugMode then Trace("LOOPER: Isolated auto-transition (HostSync OFF) on Ch " + (k_loop+1)) end
                   end
               end
           end
       End
       
       UpdateScopeVelocityMeter()
               
        if VST_OverlayTimer > 0.0 and TimeSinceStartup() > VST_OverlayTimer then
            VST_OverlayTimer = 0.0
            RefreshVstInfoDisplay() 
        end
    
        // CLEAR MACRO / CTRL FEEDBACK
        if Ctrl_OverlayTimer > 0.0 and TimeSinceStartup() > Ctrl_OverlayTimer then
           Ctrl_OverlayTimer = 0.0
           RefreshCtrlInfoDisplay() 
        end
        
        // MACRO FEEDBACK SENDEN 
        if Rec_OverlayTimer > 0.0 and TimeSinceStartup() > Rec_OverlayTimer then
            Rec_OverlayTimer = 0.0
            RefreshRecDisplay(GetWidgetValue(SLD_CurrentState)) 
        end
        
        // CLEAR MACRO FEEDBACK
        if MacroFeedbackTimer > 0.0 and TimeSinceStartup() > MacroFeedbackTimer then
            MacroFeedbackTimer = 0.0
            OSC_SendStringSpecific("/UI/SetMacroFeedback", "", Local_IP, Local_PORT)
        end
        
        // --- MACRO ANIMATION ENGINE ---
        For a_idx = 0; a_idx < 16; a_idx = a_idx + 1 Do
            if Anim_Active[a_idx] then
                if Anim_Duration[a_idx] <= 0.0 then t_progress = 1.0
                else t_progress = (TimeSinceStartup() - Anim_StartTime[a_idx]) / Anim_Duration[a_idx] end
                
                if t_progress >= 1.0 then
                    t_progress = 1.0; Anim_Active[a_idx] = false
                    if DebugMode then Trace("ANIMATION: Macro " + (a_idx+1) + " finished.") end
                end
                
                a_val = Anim_Start[a_idx] + ((Anim_Target[a_idx] - Anim_Start[a_idx]) * t_progress)
                ScriptWrite_ExpectedPrev[a_idx] = ScriptWrite_Expected[a_idx]
                ScriptWrite_Expected[a_idx] = a_val
                SetParameter(ExternalArranger, a_idx, a_val)
                Mem_Fader_Buffer[a_idx] = a_val
            end
        End

        // --- INITIAL SYNC ---
        if FactoryLearnDone and not FirstRunDone then
          if TimeSinceStartup() > 300.0 then 
              UpdateMetaColors(); FirstRunDone = true
              if DebugMode then Trace("INIT: Matrix Visuals Synced.") end
          end
        end

        // --- LAZY LOADER & REMAINING LOGIC ---
        if DelayedLoadTimer > 0.0 then
          if TimeSinceStartup() > DelayedLoadTimer then
              Trace("LAZY LOAD: Executing LoadSongSnapshot now...")
              LoadSongSnapshot(PendingSongName, false)        
              VST_OverlayTimer = 0.0; RefreshVstInfoDisplay(); DelayedLoadTimer = 0.0 
          end
        end

        // --- Release the electronic key on the scriptlet ---
        if StyleTriggerResetTimer > 0.0 and TimeSinceStartup() > StyleTriggerResetTimer then
            SetParameter(BLK_ArrangerSync, P_STYLE_START_STOP, 0.0)
            StyleTriggerResetTimer = 0.0
        end  
        
        if StateResetTime > 0.0 and TimeSinceStartup() > StateResetTime then
          CurrentState = 0; StateResetTime = 0.0 
        end
        
        if HardwareSyncTimer > 0.0 and TimeSinceStartup() > HardwareSyncTimer then
            Trace("TIMER: Executing Delayed Hardware Sync now.")
            SyncArrangerToCurrentMap(); HardwareSyncTimer = 0.0
            TraceHardwarePrediction()
            HardwareSyncTimer = 0.0
        end    
        
        If IsUpdatingMatrix and TimeSinceStartup() > MatrixSafetyTimer Then
          IsUpdatingMatrix = false
          For k = 1; k <= 16; k = k + 1 Do Trigger_NotesOff(k) End
          UpdateMetaColors(); Trace("Matrix Update Complete - Safe & Cleaned up.") 
        End
        
        if currentIsSetlist and not LastViewWasSetlist Then 
            Trace("VIEW SWITCH: Back to Setlist View. Restoring song state...")
            TriggerSongTextLoad(GetCurrentSongName()) 
            LoadSongSnapshot(GetCurrentSongName(), DeferredManualReboot)
            DeferredBootRecovery = false
            DeferredManualReboot = false
        End
        LastViewWasSetlist = currentIsSetlist

        if tr != LastGlobalTranspose Then 
          LastGlobalTranspose = tr; RecalculateTextDisplay() 
        End

        if IncomingFromArranger and (TimeSinceStartup() - LoopSafetyTimer > 1500.0) then IncomingFromArranger = false end    
        
        if DelayedSongSwitchTimer > 0.0 then
           if TimeSinceStartup() > DelayedSongSwitchTimer then
               LoadSongText(PendingSongName); DelayedSongSwitchTimer = 0.0 
           end
        end
        
        if LastBarStartTime > 0.0 then msSinceBarStart = TimeSinceStartup() - LastBarStartTime end
        
        // --- TIMELINE PLAYBACK (ms-based) ---
        if TimelinePlaybackActive and not TimelineRecActive then
            msSinceSongStart = TimeSinceStartup() - PlaybackStartTimeMS
            for tl_idx = 0; tl_idx < Size(Snap_TL_TimeMS); tl_idx = tl_idx + 1 do
                if Snap_TL_TimeMS[tl_idx] <= msSinceSongStart and Snap_TL_Fired[tl_idx] == false then
                    FireTimelineEvent(Snap_TL_Type[tl_idx], Snap_TL_Val[tl_idx])
                    Snap_TL_Fired[tl_idx] = true
                end
            end

            // Stop playback after last event + 1 second buffer
            if Size(Snap_TL_TimeMS) > 0 then
                if msSinceSongStart > Snap_TL_TimeMS[Size(Snap_TL_TimeMS) - 1] + 1000.0 then
                    TimelinePlaybackActive = false
                    Trace("TIMELINE: Playback finished.")
                    // Stop all active LFOs on transport stop
                    For lfoSlotStop = 0; lfoSlotStop < MAX_MACROS; lfoSlotStop = lfoSlotStop + 1 Do
                        if LFO_Active[lfoSlotStop] then StopLFO(lfoSlotStop) end
                    End
                    // Restore configured state if STRIP made live changes
                    if StripLiveDirty then
                        LoadControllerMap(CurrentCtrlMapName)
                        StripLiveDirty = false
                        Trace("STRIP: Live changes restored via controller map reload.")
                        OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> STRIP RESTORED <<<", Local_IP, Local_PORT)
                        MacroFeedbackTimer = TimeSinceStartup() + 2000.0
                    end
                end
            end

            // OSC-UI: next upcoming loop show action
            if TimelinePlaybackActive then
                ComputeNextLoopShowAction(msSinceSongStart)
                if nextLoopShow_CountdownMS >= 0.0 then
                    countdownBars = nextLoopShow_CountdownMS / ((60000.0 / RecordedBPM) * IntToFloat(GetTimeSigNumerator()))
                    countdownText = "-> " + LoopMasterActionName(nextLoopShow_ActionCode) + " Ch" + (nextLoopShow_ChIdx + 1) + " in " + IntToString(Round(countdownBars)) + "b (" + IntToString(Round(nextLoopShow_CountdownMS / 1000.0)) + "s)"
                    OSC_SendStringSpecific("/UI/LoopNext", countdownText, Local_IP, Local_PORT)
                    if DebugMode then Trace("LOOPER-TL: /UI/LoopNext = " + countdownText) end
                else
                    OSC_SendStringSpecific("/UI/LoopNext", "", Local_IP, Local_PORT)
                end
            end
        end

        // --- ANCHORPLAYBACK (chord-based part tracking) ---
        ProcessAnchorPlayback()

        if SnapshotPostLoadTimer > 0.0 then
          if TimeSinceStartup() > SnapshotPostLoadTimer then
              ScanGlobalInstruments()
              UpdateUsageLabelDisplay()
              IsLoadingSnapshot = false
              SnapshotPostLoadTimer = 0.0

              // ========================================================
              // ---> NEW: INITIAL AUTO-SHOW AFTER SONG LOADING <---
              // ========================================================
              if GetWidgetValue(BTN_AutoShow_GUI) > 0.5 then
                  // The system already knows from loading which VST has focus.
                  // Set timer to 1 second so GP can briefly recover after loading.
                  Pending_VST_GUI = Active_VST_Scope
                  AutoShowGUITimer = TimeSinceStartup() + 1000.0 
                  if DebugMode then Trace("AUTO-SHOW: Initial GUI open scheduled for VST " + (Active_VST_Scope + 1)) end
              end
          end
        end
    
        // --- START WATCHDOG EXECUTOR ---
        if CurrentSyncMode == 2 or CurrentSyncMode == 3 then
            if StartWatchdogTimer > 0.0 and TimeSinceStartup() > StartWatchdogTimer then
                StartWatchdogTimer = 0.0
                Trace(">>> TRANSPORT: Arranger is silent. Sending start command (Note 14)!")
                FireDirectArrangerTransport()
                SetParameter(BLK_ArrangerSync, 1, 1.0)
            end
        end
        
        // =========================================================
        // DIE AUSGELAGERTE TRANSPORT SYNC EVALUATION
        // =========================================================
        if PlayheadEvalTimer > 0.0 and TimeSinceStartup() > PlayheadEvalTimer then
            PlayheadEvalTimer = 0.0
            
            // 1. GUI block check (only relevant for ISOLATED mode 0)
            if CurrentSyncMode == 0 then
                timeSinceHW = TimeSinceStartup() - LastHardwarePulseTime
                isGUI = (timeSinceHW > 150.0 or timeSinceHW < 0.0)
                if isGUI then
                     Trace("   [X] BLOCKED: GUI must not control GP. Reverting click!")
                     IsCorrectingPlayhead = true
                     EnablePlayhead(not PendingPlayheadState)
                end
            end
            
            EvaluateTransportSync() 
        end

        // WATCHDOG FOR VIEW SWITCH (Python callback)
        if OSC_IsWaitingForViewSwitch and TimeSinceStartup() > OSC_ViewSwitchTimeout then
             Trace("!!! WATCHDOG: TIMEOUT !!! No response from Python. Forcing activation sequence...")
             OSC_IsWaitingForViewSwitch = false; OSC_ViewSwitchTimeout = 0.0
             ContinueActualReplace(false, PendingReplaceSlotIdx, PendingReplacePath, PendingReplaceIsManual)
        end
    
   end // Ende KillSwitch Block
End
// ---------------------------------------------------------
// INPUT FEEDBACK (TRISTATE LOGIK)
// ---------------------------------------------------------

Function SyncInputFeedback()
   var inIdx, outIdx : Integer
   var activeCount : Integer
   var scopeCount : Integer
   
   // Visualisiert den Zustand der Input-Buttons basierend auf dem Output-Scope
   // 0.0 = Keiner verbunden
   // 1.0 = Alle verbunden
   // 0.5 = Gemischt (Manche verbunden, manche nicht)
   
   // --- LOOP KILLER: Wir ignorieren das UI-Echo der Widgets für 150ms ---
   InputSyncTimer = TimeSinceStartup() + 150.0

   scopeCount = 0
   For outIdx = 0; outIdx < 16; outIdx = outIdx + 1 Do
      if OutputScope[outIdx] then scopeCount = scopeCount + 1 end
   End
   
   if scopeCount == 0 then
      For inIdx = 0; inIdx < 16; inIdx = inIdx + 1 Do
         SetWidgetValue(W_Btn_Input[inIdx], 0.0)
      End
   else
      For inIdx = 0; inIdx < 16; inIdx = inIdx + 1 Do
         activeCount = 0
         
         For outIdx = 0; outIdx < 16; outIdx = outIdx + 1 Do
            if OutputScope[outIdx] then
               if GetParameter(RECH, (inIdx * 16) + outIdx) > 0.5 then
                  activeCount = activeCount + 1
               end
            end
         End
         
         if activeCount == scopeCount then
             SetWidgetValue(W_Btn_Input[inIdx], 1.0)
         elsif activeCount == 0 then
             SetWidgetValue(W_Btn_Input[inIdx], 0.0)
         else
             SetWidgetValue(W_Btn_Input[inIdx], 0.5) 
         end
      End
   end
End

Function UpdateMidiConfigLabel()
   var i : Integer = 0
   var isDirty : Boolean = false
   
   // Vergleicht aktuelle Matrix mit unserem Foto (Sichere While-Schleife!)
   While i < 256 and not isDirty Do
      if Abs(GetParameter(RECH, i) - Loaded_RECH_State[i]) > 0.5 then
         isDirty = true
      end
      i = i + 1
   End
   
   // Label entsprechend setzen
   if isDirty then
      SetWidgetLabel(LBL_MidiConfig, "Custom (Unsaved)")
   else
      SetWidgetLabel(LBL_MidiConfig, BaseConfigName)
   end
End

// ---------------------------------------------------------
// MASTER LABELS UPDATE (Füllt leere Displays mit Songnamen)
// ---------------------------------------------------------
Function UpdateMasterLabels(sName : String)
   var prefix, cleanName : String
   
   cleanName = ReplaceString(sName, ".ini", "", false)
   if cleanName == "" then prefix = "Global Rackspace" else prefix = "" + cleanName end
   
   BaseConfigName = prefix
   
   if CurrentCtrlMapName == "-" or CurrentCtrlMapName == "" then
       SetWidgetLabel(LBL_CtrlConfig, prefix)
   end
   
   UpdateMidiConfigLabel()
End

// ---------------------------------------------------------
// TRANSPORT SYNC CYCLE LOGIC
// ---------------------------------------------------------
Function UpdateSyncLabel()
   var baseName : String = SyncModeNames[CurrentSyncMode]
   if CurrentSyncMode == 4 then
       if IsPerformanceActive then 
           SetWidgetLabel(LBL_SyncMode, baseName + " (Active)")
       else
           SetWidgetLabel(LBL_SyncMode, baseName + " (Ready)")
       end
   else
       SetWidgetLabel(LBL_SyncMode, baseName)
   end
End

// CROSSFADER LOGIC 
Function UpdateCFConfigLabel()
    var vstPart, arrangerPart : String
    var activeCount : Integer
    var i : Integer
    
    // 1. VST NAMEN GENERIEREN
    activeCount = 0
    For i = 0; i < 5; i = i + 1 Do
        if GetWidgetValue(W_CF_Audio[i]) > 0.5 then activeCount = activeCount + 1 end
    End
    
    if activeCount == 5 then vstPart = "VST_All"
    elsif activeCount == 0 then vstPart = "VST_None"
    else
        vstPart = "VST_"
        for i = 0; i < 5; i = i + 1 do
            if GetWidgetValue(W_CF_Audio[i]) > 0.5 then 
                vstPart = vstPart + ((i*2)+1) + "-" + ((i*2)+2) + ","
            end
        end
        if Length(vstPart) > 4 then vstPart = CopySubstring(vstPart, 0, Length(vstPart)-1) end
    end
    
    // 2. GENOS NAMEN GENERIEREN
    activeCount = 0
    For i = 0; i < 16; i = i + 1 Do
        if GetWidgetValue(W_CF_Arranger[i]) > 0.5 then activeCount = activeCount + 1 end
    End
    
    if activeCount == 16 then arrangerPart = "Arranger_All"
    elsif activeCount == 0 then arrangerPart = "Arranger_None"
    else
        arrangerPart = "Arranger_"
        for i = 0; i < 16; i = i + 1 do
            if GetWidgetValue(W_CF_Arranger[i]) > 0.5 then 
                arrangerPart = arrangerPart + (i+1) + ","
            end
        end
        if Length(arrangerPart) > 6 then arrangerPart = CopySubstring(arrangerPart, 0, Length(arrangerPart)-1) end
    end
    
    // 3. UPDATE LABEL
    LBL_CrossFaderConfig.SetWidgetLabel(vstPart + " | " + arrangerPart)
End


// ============================================================================
// SECTION 17: CONTROLLER MAP ENGINE
// ============================================================================

Function RefreshCtrlInfoDisplay()
    var scrollVal : Double = GetWidgetValue(SLD_ControllerInfo)
    var totalLines : Integer = Size(CtrlInfo_Lines)
    var displayLines : Integer = 17 
    var maxStart : Integer = totalLines - displayLines
    var startIdx, i : Integer
    var finalText : String = ""

    // ---> 1. OVERLAY CHECK (Fehlermeldungen für X Sekunden zeigen) <---
    if Ctrl_OverlayTimer > 0.0 and TimeSinceStartup() < Ctrl_OverlayTimer then
        finalText = "=== [ LOOPER WARNING ] ===" + NEW_LINE
        finalText = finalText + "---------------------------------" + NEW_LINE + NEW_LINE + NEW_LINE
        finalText = finalText + "   >>> " + Ctrl_OverlayMsg + " <<<" + NEW_LINE + NEW_LINE
        finalText = finalText + "   Multi-Scope Configuration" + NEW_LINE
        finalText = finalText + "   blocked to prevent MIDI Chaos."
        SetWidgetLabel(LBL_ControllerInfo, finalText)
    else
        // --- 2. STATISCHER HEADER (Scrollt nicht mit) ---
        if CurrentCtrlMapName == "-" or CurrentCtrlMapName == "" then
            finalText = "--- NO MAPPING LOADED ---" + NEW_LINE 
        else
            finalText = "--- MAPPING: " + CurrentCtrlMapName + " ---" + NEW_LINE 
        end
        
        // Warnung ggf. anheften
        if MapMismatch then
            finalText = finalText + "!!! WARNING: MAP MISMATCH !!!" + NEW_LINE
            finalText = finalText + "Song expected: '" + ExpectedMapName + "'" + NEW_LINE + NEW_LINE
        end

        // --- 3. SCROLLBEREICH ---
        if maxStart < 0 then maxStart = 0 end
        
        // Slider oben = 1.0 (startIdx 0), Slider unten = 0.0 (startIdx max)
        startIdx = Round((1.0 - scrollVal) * maxStart)

        For i = 0; i < displayLines; i = i + 1 Do
            if (startIdx + i) < totalLines then
                finalText = finalText + CtrlInfo_Lines[startIdx + i] + NEW_LINE
            end
        End

        SetWidgetLabel(LBL_ControllerInfo, finalText)
    end
End

// ---------------------------------------------------------
// GENOS KNOBS UND SLIDER INFO DISPLAY (FOR MORPHFADER)
// ---------------------------------------------------------

Function GetHardwareLabel(idx : Integer) Returns String
    if idx >= 0 and idx < MAX_MACROS then
        result = "Macro " + (idx + 1)
    else
        result = "?"
    end
End

// ---------------------------------------------------------
// CONTROLLER INFO DISPLAY (CLEAN, SMART & STATUS AWARE)
// ---------------------------------------------------------

Function GetAssignedHWString(mIdx : Integer) Returns String
   var i : Integer
   var res : String = ""

   // 1. Gelernte Fremd-Controller (MiniLab, Pedale, etc.) suchen
   For i = 0; i < HW_Count; i = i + 1 Do
       if HW_MacroIdx[i] == mIdx then
           if res != "" then res = res + " | " end
           
           // ---> NEU: Unterscheidung Note vs CC <---
           if HW_IsNote[i] then
               res = res + "Ch" + HW_Channel[i] + ":Note" + HW_CC[i]
           else
               res = res + "Ch" + HW_Channel[i] + ":CC" + HW_CC[i]
           end
       end
   End
   
   if res != "" then result = " [" + res + "]" else result = "" end
End

Function GetLinkNameHelper(idx : Integer) Returns String
   var pName : String = ""
   if Link_IsCC[idx] then
       if Length(Link_ExpectedName[idx]) > 0 then pName = Link_ExpectedName[idx] + " (CC" + Link_TargetParam[idx] + ")"
       else pName = "MIDI CC " + Link_TargetParam[idx] end
   else
       if Link_Type[idx] == 0 then pName = GetParameterName(BLK_VST[Link_BlockIdx[idx]], Link_TargetParam[idx])
       elsif Link_Type[idx] == 1 then pName = GetParameterName(BLK_NoteProcessor[Link_BlockIdx[idx]], Link_TargetParam[idx])
       elsif Link_Type[idx] == 2 then pName = GetParameterName(AudioMixer, Link_TargetParam[idx])
       end
   end
   result = pName
End

/// ---------------------------------------------------------
// SCROLL TO CURRENT CONTROLLER SCOPE
// ---------------------------------------------------------
Function ScrollToCurrentCtrlScope()
    var i, l : Integer
    var targetLine : Integer = 0
    var searchStr, searchStrAlt : String = ""
    var isGrouped : Boolean = false
    var foundLine : Boolean = false // ---> NEU: Das saubere Abbruch-Flag <---
    
    var totalLines : Integer = Size(CtrlInfo_Lines)
    var displayLines : Integer = 17 
    var maxStart : Integer = totalLines - displayLines
    var scrollVal : Double = 0.0

    // Wenn EditScope -1 ist (Global), bleibt targetLine = 0 -> Er scrollt ganz nach oben!
    if CurrentEditScope != -1 then
        
        // 1. Kategorien checken (Ist es ein Gruppen-Macro?)
        // ---> DIE ERSTE SICHERE WHILE-SCHLEIFE <---
        l = 0
        While l < 16 and not isGrouped Do
            if CurrentEditScope == SOLO_SMART_MacroIdx[l] then searchStr = "Smart Solo"; isGrouped = true
            elsif CurrentEditScope == SOLO_STRICT_MacroIdx[l] then searchStr = "Strict Solo"; isGrouped = true
            elsif CurrentEditScope == USER_MUTE_MacroIdx[l] then searchStr = "User Mute"; isGrouped = true
            elsif CurrentEditScope == LOOPER_CH_MacroIdx[l] then searchStr = "Looper Triggers"; isGrouped = true
            end
            l = l + 1
        End
        
        // 2. Einzelfunktionen oder Standard-Macros
        if not isGrouped then
            searchStr = GetHardwareLabel(CurrentEditScope) // ergibt z.B. "Macro 1"
            searchStrAlt = searchStr + " [" // "Macro 1 ["
            searchStr = searchStr + ":"     // "Macro 1:"
        end
        
        // 3. Finde die passende Zeile
        // ---> DIE ZWEITE SICHERE WHILE-SCHLEIFE <---
        i = 0
        While i < totalLines and not foundLine Do
            if isGrouped then
                // Bei Gruppen: Taucht das Keyword irgendwo in der Zeile auf?
                if IndexOfSubstring(CtrlInfo_Lines[i], searchStr, true) > -1 then
                    targetLine = i
                    foundLine = true
                end
            else
                // Bei Einzel-Macros: Die Zeile muss exakt mit "Macro X:" oder "Macro X [" beginnen!
                // (Verhindert, dass "Macro 1" fälschlicherweise bei "Macro 10" hängenbleibt)
                if IndexOfSubstring(CtrlInfo_Lines[i], searchStr, false) == 0 or 
                   IndexOfSubstring(CtrlInfo_Lines[i], searchStrAlt, false) == 0 then
                    targetLine = i
                    foundLine = true
                end
            end
            i = i + 1
        End
    end

    // 4. Slider-Wert berechnen
    if maxStart <= 0 then 
        scrollVal = 1.0 
    else
        if targetLine > maxStart then targetLine = maxStart end
        scrollVal = 1.0 - (IntToFloat(targetLine) / IntToFloat(maxStart))
    end

    // 5. Wert setzen und Display rendern
    SetWidgetValue(SLD_ControllerInfo, scrollVal)
    RefreshCtrlInfoDisplay()
End

Function ExecuteLink(i : Integer, val : Double)
   var scaledVal : Double = Link_MinVal[i] + (val * (Link_MaxVal[i] - Link_MinVal[i]))
   var midiVal : Integer
   var m : MidiMessage

   if Link_IsCC[i] == true then
       midiVal = Round(scaledVal * 127.0)
       if midiVal < 0 then midiVal = 0 elsif midiVal > 127 then midiVal = 127 end
       
       if Link_Type[i] == 0 then 
           m = MakeControlChangeMessageEx(Link_TargetParam[i], midiVal, GetChannelForVST(Link_BlockIdx[i]))
           SendNow(BLK_VSTControl, m)
       elsif Link_Type[i] == 3 then
           m = MakeControlChangeMessageEx(Link_TargetParam[i], midiVal, Link_BlockIdx[i])
           SendNow(BLK_VSTControl, m)
       end
   else
       if Link_Type[i] == 0 then SetParameter(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i], scaledVal)
       elsif Link_Type[i] == 1 then SetParameter(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i], scaledVal)
       elsif Link_Type[i] == 2 then SetParameter(AudioMixer, Link_TargetParam[i], scaledVal)
       end
   end
End

// ---------------------------------------------------------
// UNIVERSAL MACRO FEEDBACK ENGINE (The HUD)
// ---------------------------------------------------------
Function TriggerMacroFeedback(sourceIdx : Integer, isCC : Boolean, val : Double)
    var i : Integer
    var msg, pName, paramName : String
    var mappedVal : Double = 0.0
    var linkFound : Boolean = false
    var isJitter : Boolean = false
    
    // ========================================================
    // DER CPU-RETTUNGS-ANKER (Jitter Gate)
    // ========================================================
    // Prüfen, ob derselbe Regler/Pedal nochmal feuert
    if sourceIdx == Last_HUD_Source and isCC == Last_HUD_IsCC then
        // Wenn sich der Wert um weniger als 0.5% ändert, ist es Zittern!
        if Abs(val - Last_HUD_Val) < 0.005 then
           isJitter = true
        end
    end
    
    // Nur weitermachen, wenn es eine ECHTE Bewegung war
    if not isJitter then
        // Neuen validen Wert für diesen Regler merken
        Last_HUD_Source = sourceIdx
        Last_HUD_IsCC = isCC
        Last_HUD_Val = val

        msg = ""

        // ========================================================
        // 1. SONDERFUNKTIONEN PRÜFEN
        // ========================================================
        if (not isCC and sourceIdx == CF_MacroIdx) or (isCC and sourceIdx == CF_CCIdx) then
            msg = "Global Audio Balance: " + Round(val * 100.0) + "%"
            linkFound = true
            
        else
            // 2. NORMALE PARAMETER LINKS SUCHEN
            For i = 0; i < Link_Count; i = i + 1 Do
                // Wir schnappen uns den ERSTEN aktiven Link, der zu diesem Regler gehört
                if not linkFound and Link_Active[i] and Link_SourceIdx[i] == sourceIdx and Link_SourceIsCC[i] == isCC then
                    
                    // A) Echten Plugin-Namen auslesen
                    if Link_Type[i] == 0 then pName = GetPluginInfo(BLK_VST[Link_BlockIdx[i]], 0)
                    elsif Link_Type[i] == 1 then pName = "NoteProc (Ch " + (Link_BlockIdx[i]+1) + ")"
                    elsif Link_Type[i] == 2 then pName = "AudioMixer"
                    else pName = Link_BlockName[i] end

                    // B) Parameter-Namen nehmen
                    paramName = Link_ExpectedName[i]
                    if paramName == "" then paramName = "Param " + Link_TargetParam[i] end

                    // C) Den ECHTEN aktuellen Wert berechnen
                    mappedVal = Link_MinVal[i] + (val * (Link_MaxVal[i] - Link_MinVal[i]))
                    
                    // D) String zusammenbauen
                    msg = pName + " | " + paramName + " : " + Round(mappedVal * 100.0) + "%"
                    linkFound = true 
                end
            End
        end // <--- FIX: DIESES END HAT GEFEHLT! (Schließt das "else" von Schritt 1)
        
        // 3. AN DISPLAY SENDEN & TIMER STARTEN
        // (Das machen wir sinnvollerweise nur, wenn es kein Jitter war)
        if linkFound then
            // ---> DIE NEUE SPERRE FÜR DEN MAP-WECHSEL <---
            if TimeSinceStartup() > MacroFeedbackLockTimer then
                Trace("HUD PUSH: Sende '" + msg + "' an Display!") 
                OSC_SendStringSpecific("/UI/SetMacroFeedback", msg, Local_IP, Local_PORT)
                MacroFeedbackTimer = TimeSinceStartup() + 1500.0
            else
                // Wenn die Sperre aktiv ist, verschweigen wir die Fader-Bewegungen einfach!
                Trace("HUD PUSH BLOCKED: Map-Change LockTimer ist noch aktiv.")
            end
        end
        
    end // <--- FIX: Schließt den "if not isJitter" Block!
End

// ---------------------------------------------------------
// CONTROLLER INFO DISPLAY (CLEAN, SMART & STATUS AWARE)
// ---------------------------------------------------------

Function UpdateControllerInfoDisplay()
   var s, l, idx, count, vMin, vMax : Integer
   var valStr, hwStr, mainLine, realName : String
   var linksForThisSource : Integer Array
   var isCC, isLooperDisp, isGroupedDisp : Boolean
   var typeLoop : Integer
   var hasLooperMacros, hasVelRange, hasRoot, hasOctaver, hasQuantize, hasSustain, hasHumanize : Boolean = false
   
   var Grp_Count : Integer = Size(MacroGroup_Names)
   var Grp_Has : Boolean Array
   var Grp_Min : Integer Array
   var Grp_Max : Integer Array
   var g, grpIdx : Integer
   
   // Pointer, um die Position anhand des Ankers zu finden.
   var idxLooper, idxSmart, idxStrict, idxMute, idxVel, idxRoot, idxOct, idxHum, idxQuant, idxSus : Integer = -1
   
   // 1. Arrays initialisieren
   For g = 0; g < Grp_Count; g = g + 1 Do
       Grp_Has <-- false; Grp_Min <-- 999; Grp_Max <-- -1
   End
   
   // 2. Wo liegen die Gruppen in der aktuellen Sortierung?
   For g = 0; g < Grp_Count; g = g + 1 Do
       if MacroGroup_Anchors[g] == 82  then idxLooper = g end
       if MacroGroup_Anchors[g] == 34  then idxSmart = g end
       if MacroGroup_Anchors[g] == 50  then idxStrict = g end
       if MacroGroup_Anchors[g] == 66  then idxMute = g end
       if MacroGroup_Anchors[g] == 98  then idxVel = g end
       if MacroGroup_Anchors[g] == 114 then idxRoot = g end
       if MacroGroup_Anchors[g] == 130 then idxOct = g end
       if MacroGroup_Anchors[g] == 146 then idxHum = g end
       if MacroGroup_Anchors[g] == 162 then idxQuant = g end
       if MacroGroup_Anchors[g] == 178 then idxSus = g end
   End
   
   CtrlInfo_Lines = [] 

   // WIR GEHEN BEIDE TYPEN DURCH: Erst Macro (0=False), dann CC (1=True)
   For typeLoop = 0; typeLoop <= 1; typeLoop = typeLoop + 1 Do
       isCC = (typeLoop == 1)
       
       // Durchsuche Index 0 bis 127 (Deckt Macros und CCs ab)
       For s = 0; s < 128; s = s + 1 Do
           
           // Hardware-Name vorab bauen (z.B. "Macro 16" oder "CC 4")
           if isCC then hwStr = GetStandardCCName(s) + " [CC" + s + "]"
           else hwStr = "Macro " + (s+1) + GetAssignedHWString(s) end

           // --- GRUPPEN FILTER (Sammelt die Werte in die dynamischen Arrays) ---
           isGroupedDisp = false
           l = 0
           While l < 16 and not isGroupedDisp Do
               // Looper
               if (not isCC and s == LOOPER_CH_MacroIdx[l]) or (isCC and s == LOOPER_CH_CCIdx[l]) then
                   isGroupedDisp = true; if idxLooper > -1 then Grp_Has[idxLooper] = true; if not isCC then if s < Grp_Min[idxLooper] then Grp_Min[idxLooper] = s end; if s > Grp_Max[idxLooper] then Grp_Max[idxLooper] = s end end end
               end
               // Smart Solo
               if (not isCC and s == SOLO_SMART_MacroIdx[l]) or (isCC and s == SOLO_SMART_CCIdx[l]) then
                   isGroupedDisp = true; if idxSmart > -1 then Grp_Has[idxSmart] = true; if not isCC then if s < Grp_Min[idxSmart] then Grp_Min[idxSmart] = s end; if s > Grp_Max[idxSmart] then Grp_Max[idxSmart] = s end end end
               end
               // Strict Solo
               if (not isCC and s == SOLO_STRICT_MacroIdx[l]) or (isCC and s == SOLO_STRICT_CCIdx[l]) then
                   isGroupedDisp = true; if idxStrict > -1 then Grp_Has[idxStrict] = true; if not isCC then if s < Grp_Min[idxStrict] then Grp_Min[idxStrict] = s end; if s > Grp_Max[idxStrict] then Grp_Max[idxStrict] = s end end end
               end
               // User Mute
               if (not isCC and s == USER_MUTE_MacroIdx[l]) or (isCC and s == USER_MUTE_CCIdx[l]) then
                   isGroupedDisp = true; if idxMute > -1 then Grp_Has[idxMute] = true; if not isCC then if s < Grp_Min[idxMute] then Grp_Min[idxMute] = s end; if s > Grp_Max[idxMute] then Grp_Max[idxMute] = s end end end
               end
               // V7.4 Features
               if (not isCC and s == VELRANGE_MacroIdx[l]) or (isCC and s == VELRANGE_CCIdx[l]) then
                   isGroupedDisp = true; if idxVel > -1 then Grp_Has[idxVel] = true; if not isCC then if s < Grp_Min[idxVel] then Grp_Min[idxVel] = s end; if s > Grp_Max[idxVel] then Grp_Max[idxVel] = s end end end
               end
               if (not isCC and s == ROOT_MacroIdx[l]) or (isCC and s == ROOT_CCIdx[l]) then
                   isGroupedDisp = true; if idxRoot > -1 then Grp_Has[idxRoot] = true; if not isCC then if s < Grp_Min[idxRoot] then Grp_Min[idxRoot] = s end; if s > Grp_Max[idxRoot] then Grp_Max[idxRoot] = s end end end
               end
               if (not isCC and s == OCTAVER_MacroIdx[l]) or (isCC and s == OCTAVER_CCIdx[l]) then
                   isGroupedDisp = true; if idxOct > -1 then Grp_Has[idxOct] = true; if not isCC then if s < Grp_Min[idxOct] then Grp_Min[idxOct] = s end; if s > Grp_Max[idxOct] then Grp_Max[idxOct] = s end end end
               end
               if (not isCC and s == HUMANIZE_MacroIdx[l]) or (isCC and s == HUMANIZE_CCIdx[l]) then
                   isGroupedDisp = true; if idxHum > -1 then Grp_Has[idxHum] = true; if not isCC then if s < Grp_Min[idxHum] then Grp_Min[idxHum] = s end; if s > Grp_Max[idxHum] then Grp_Max[idxHum] = s end end end
               end
               if (not isCC and s == QUANTIZE_MacroIdx[l]) or (isCC and s == QUANTIZE_CCIdx[l]) then
                   isGroupedDisp = true; if idxQuant > -1 then Grp_Has[idxQuant] = true; if not isCC then if s < Grp_Min[idxQuant] then Grp_Min[idxQuant] = s end; if s > Grp_Max[idxQuant] then Grp_Max[idxQuant] = s end end end
               end
               if (not isCC and s == SUSTAIN_MacroIdx[l]) or (isCC and s == SUSTAIN_CCIdx[l]) then
                   isGroupedDisp = true; if idxSus > -1 then Grp_Has[idxSus] = true; if not isCC then if s < Grp_Min[idxSus] then Grp_Min[idxSus] = s end; if s > Grp_Max[idxSus] then Grp_Max[idxSus] = s end end end
               end
               
               l = l + 1
           End

           if isGroupedDisp then
               // Absichtlich leer lassen! Wir machen unten den dynamischen Sammel-Eintrag.
               
           // --- CROSSFADER ---
           elsif (not isCC and s == CF_MacroIdx) or (isCC and s == CF_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> Global Audio/Expr Balance"
               
           // ---  SCRUBBER ---
           elsif (not isCC and s == SCRUB_MacroIdx) or (isCC and s == SCRUB_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> Timeline Scrubber & Panic Transport Stop" 

           // ---  REC SONGPART (MARKER) ANZEIGEN ---
           elsif (not isCC and s == REC_SONGPART_MacroIdx) or (isCC and s == REC_SONGPART_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> Record: Next Songpart (Marker)"
               
           // --- SYSTEM TOGGLE ---
           elsif (not isCC and s == SYSTEM_TOGGLE_MacroIdx) or (isCC and s == SYSTEM_TOGGLE_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> HOLD: System Mode (Joystick Hijack)"
               
           // --- VST SCOPE & BROWSE ANZEIGEN ---
           elsif (not isCC and s == VST_SCOPE_MacroIdx) or (isCC and s == VST_SCOPE_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> VST Scope Select (Encoder)"
               
           elsif (not isCC and s == VST_BROWSE_MacroIdx) or (isCC and s == VST_BROWSE_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> VST Preset Browse (Encoder)"
               
           elsif (not isCC and s == VST_SCOPE_PREV_MacroIdx) or (isCC and s == VST_SCOPE_PREV_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> VST Scope [Previous]"
               
           elsif (not isCC and s == VST_SCOPE_NEXT_MacroIdx) or (isCC and s == VST_SCOPE_NEXT_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> VST Scope [Next]"
               
           elsif (not isCC and s == VST_PREV_MacroIdx) or (isCC and s == VST_PREV_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> VST Preset [Previous]"
               
           elsif (not isCC and s == VST_NEXT_MacroIdx) or (isCC and s == VST_NEXT_CCIdx) then
               CtrlInfo_Lines <-- hwStr + ": >> VST Preset [Next]"
           
           else
               // --- STANDARD LINKS CHECK ---
               count = 0
               linksForThisSource = []
               For l = 0; l < Link_Count; l = l + 1 Do
                   if Link_Active[l] and Link_SourceIdx[l] == s and Link_SourceIsCC[l] == isCC then
                       linksForThisSource <-- l
                       count = count + 1
                   end
               End

               if count > 0 then
                   // Header der Zeile bauen
                   if isCC then mainLine = GetStandardCCName(s) + " [CC" + s + "]: "
                   else mainLine = "Macro " + (s+1) + GetAssignedHWString(s) + ": " end

                   if count > 1 then mainLine = mainLine + "[" + count + " Targets] " end

                   // Links formatieren
                   For l = 0; l < count; l = l + 1 Do
                       idx = linksForThisSource[l]
                       vMin = Round(Link_MinVal[idx] * 100.0); vMax = Round(Link_MaxVal[idx] * 100.0)
                       if vMin != 0 or vMax != 100 then valStr = " {" + vMin + "%-" + vMax + "%}" else valStr = "" end
                       
                       realName = Link_ExpectedName[idx]
                       if realName == "" then realName = "Param " + Link_TargetParam[idx] end
                       
                       // Gewünschtes Format: VST1_GRS:1 Global Filt Cut
                       if l == 0 then
                           CtrlInfo_Lines <-- mainLine + Link_BlockName[idx] + ":" + realName + valStr
                       else
                           CtrlInfo_Lines <-- "  -> " + Link_BlockName[idx] + ":" + realName + valStr
                       end
                   End
               end
           end
       End
   End

   // --- DYNAMISCHE SAMMEL-EINTRÄGE FÜR DIE LISTE ---
   // Die Schleife durchläuft exakt die Sortierung, die du in MacroGroup_Names festgelegt hast!
   For g = 0; g < Grp_Count; g = g + 1 Do
       if Grp_Has[g] then
           CtrlInfo_Lines <-- ""
           if Grp_Min[g] <= Grp_Max[g] then 
               CtrlInfo_Lines <-- ">> Macro " + (Grp_Min[g] + 1) + "-" + (Grp_Max[g] + 1) + ": " + MacroGroup_Names[g] + " (Ch 1-16) <<"
           else 
               CtrlInfo_Lines <-- ">> Buttons 1-16: " + MacroGroup_Names[g] + " (Ch 1-16) <<" 
           end
       end
   End
   
   // Slider nachziehen und rendern
   ScrollToCurrentCtrlScope()
End

// ---------------------------------------------------------
// CONTROLLER MAP SCOPE: SMART RANGE EDITOR (SNAPSHOT STYLE)
// ---------------------------------------------------------

Function UpdateEditScopeDisplay()
   var txt : String
   
   // Vorrang für den "Leeren Zustand"
   if CurrentCtrlMapName == "-" or CurrentCtrlMapName == "None" or CurrentCtrlMapName == "" then
       txt = "Scope: -"
       
   // Normaler Betrieb
   elsif CurrentEditScope == -1 then
       txt = "Scope: [GLOBAL] (All Sliders)"
   else
       txt = "Scope: [" + GetHardwareLabel(CurrentEditScope) + "]"
   end
   
   SetWidgetLabel(LBL_Edit_Scope, txt)
End

// ---------------------------------------------------------
// CONTROLLER MAP SCOPE: SMART RANGE EDITOR (SNAPSHOT STYLE)
// ---------------------------------------------------------
Function CycleEditScope(dir : Integer)
   var i, nextScope, loopGuard : Integer
   var isValid : Boolean

   nextScope = CurrentEditScope
   isValid = false
   loopGuard = 0

   // Wenn gar keine Map geladen ist, gibt es nur "Global"
   if CurrentCtrlMapName == "-" or CurrentCtrlMapName == "None" or CurrentCtrlMapName == "" then
       nextScope = -1
       isValid = true
   else
       // Wir suchen den nächsten belegten Scope. 
       While not isValid and loopGuard <= MAX_MACROS + 2 Do
           loopGuard = loopGuard + 1
           nextScope = nextScope + dir

           // Wrap around (-1 bis MAX_MACROS-1)
           if nextScope < -1 then nextScope = MAX_MACROS - 1
           elsif nextScope >= MAX_MACROS then nextScope = -1
           end

           // 1. Ist es der Global Scope? (Immer gültig)
           if nextScope == -1 then
               isValid = true
                     
           // 2. Sind es unsere Spezial-Funktionen? 
           elsif nextScope == CF_MacroIdx or 
                 nextScope == SCRUB_MacroIdx or
                 nextScope == VST_PREV_MacroIdx or
                 nextScope == VST_NEXT_MacroIdx or
                 nextScope == VST_SCOPE_PREV_MacroIdx or
                 nextScope == VST_SCOPE_NEXT_MacroIdx or
                 nextScope == VST_SCOPE_MacroIdx or
                 nextScope == VST_BROWSE_MacroIdx or
                 nextScope == REC_SONGPART_MacroIdx or
                 nextScope == SYSTEM_TOGGLE_MacroIdx then
               isValid = true
           
           else
               // 3. NEU: Ist es ein Looper oder Channel-Toggle Macro?
               i = 0
               While i < 16 and not isValid Do
                   if nextScope == LOOPER_CH_MacroIdx[i] or 
                      nextScope == SOLO_STRICT_MacroIdx[i] or 
                      nextScope == SOLO_SMART_MacroIdx[i] or 
                      nextScope == USER_MUTE_MacroIdx[i] then 
                       isValid = true
                   end
                   i = i + 1
               End
               
               // 4. Gibt es aktive Links für diesen Regler?
               if not isValid then
                   i = 0
                   While i < Link_Count and not isValid Do
                       if Link_Active[i] and Link_SourceIdx[i] == nextScope then
                           isValid = true
                       end
                       i = i + 1
                   End
               end
           end
       End
   end

   // Wenn ein gültiger Scope gefunden wurde, anwenden!
   if isValid then
       CurrentEditScope = nextScope
       
       // Hardware-Slider Position ans Morph-Widget senden (nur für Genos Fader 1-16)
       if CurrentEditScope > -1 and CurrentEditScope <= 15 then
           SetWidgetValue(SLD_Morph, GetParameter(ExternalArranger, CurrentEditScope))
       else
           SetWidgetValue(SLD_Morph, 0.0)
       end

       // SPERRE: Learn-Modus abbrechen, wenn wir auf "Global" wechseln
       if CurrentEditScope == -1 then
           IsHardwareLearning = false
           SetWidgetValue(BTN_MacroLearn, 0.0)
       end

       // Labels aktualisieren & Auto-Scroll
       UpdateEditScopeDisplay()
       ScrollToCurrentCtrlScope()
   end
End

Function AppendLinkEncoded(name : String, paramId : Integer, sliderIdx : Integer, minV : Double, maxV : Double, expName : String, isCC : Boolean, srcIsCC : Boolean)
   var idx, typeFound, idxFound, countRoutings, r, k : Integer
   var parts : String Array
   var isSleep : Boolean
   var numPart, char : String = ""
   
   // ---> HIER GEHÖRT DAS FLAG HIN (Ganz nach oben!) <---
   var stopParse : Boolean = false 
   
   typeFound = -1; idxFound = 0

   // 1. VSTs (Type 0)
   if IndexOfSubstring(name, "VST", false) == 0 then
       k = 3
       // ---> DIE SICHERE WHILE-SCHLEIFE <---
       While k < Length(name) and not stopParse Do
           char = CopySubstring(name, k, 1)
           if char >= "0" and char <= "9" then 
               numPart = numPart + char 
           else 
               stopParse = true 
           end
           k = k + 1
       End
       
       idx = StringToInt(numPart) - 1
       if idx >= 0 and idx < MAX_VSTS then typeFound = 0; idxFound = idx end
       
   // 2. Channels (NoteProcessor & Direct CC)
   elsif IndexOfSubstring(name, "Ch", false) == 0 then
       parts = SplitString(name, "_")
       if Size(parts) >= 2 then
            idx = StringToInt(ReplaceString(parts[0], "Ch", "", false)) - 1
            if idx >= 0 and idx < 16 then
                if parts[1] == "NP" then typeFound = 1; idxFound = idx end
            end
       else
            idx = StringToInt(ReplaceString(name, "Ch", "", false))
            if idx >= 1 and idx <= 16 then typeFound = 3; idxFound = idx end
       end

   // 3. Mixer (Type 2)
   elsif name == "AudioMixer" then typeFound = 2; idxFound = 0 end
   
   if typeFound > -1 then
       isSleep = false
       if typeFound == 0 then 
           countRoutings = 0
           for r = 0; r < 16; r = r + 1 do
               if RoutingMatrix[(idxFound * 16) + r] == true then countRoutings = countRoutings + 1 end
           end
           if countRoutings == 1 then
               if IndexOfSubstring(expName, "Volume", true) > -1 or IndexOfSubstring(expName, "Level", true) > -1 then isSleep = true end
           end
       end
       
       Link_Active         <-- true
       Link_SourceIdx      <-- sliderIdx
       Link_Type           <-- typeFound
       Link_BlockIdx       <-- idxFound
       Link_TargetParam    <-- paramId
       Link_BlockName      <-- name
       Link_MinVal         <-- minV
       Link_MaxVal         <-- maxV
       Link_ExpectedName   <-- expName 
       Link_IsCC           <-- isCC
       Link_IsSleepSwitch  <-- isSleep
       Link_SourceIsCC     <-- srcIsCC
       Link_Count = Link_Count + 1
   else
       Trace("Link Warning: Could not resolve '" + name + "'")
   end
End

// ---------------------------------------------------------
// STATE DISPLAY FOR RECH CONFIG CHANGES
// ---------------------------------------------------------

Function CaptureRechBaseline()
   var i : Integer
   // Fotografiert den aktuellen, "sauberen" Zustand der Matrix nach dem Laden
   For i = 0; i < 256; i = i + 1 Do
      Loaded_RECH_State[i] = GetParameter(RECH, i)
   End
End

// ---------------------------------------------------------
// HARDWARE MAP MANAGER
// ---------------------------------------------------------
Function SaveHardwareMap()
    var content : String = "[Assignment:Standard]" + NEW_LINE + "; Controller Bindings (Auto-Generated)" + NEW_LINE
    var mIdx, aIdx : Integer
    var line : String
    var hasLinks : Boolean
    var saved : Boolean // <--- HIER IST DER FIX

    // Wir schreiben exakt das Format: Macro1 = Ch1:CC74 | Ch3:CC14
    For mIdx = 0; mIdx < MAX_MACROS; mIdx = mIdx + 1 Do
        line = "Macro" + (mIdx + 1) + " = "
        hasLinks = false
        
        For aIdx = 0; aIdx < HW_Count; aIdx = aIdx + 1 Do
            if HW_MacroIdx[aIdx] == mIdx then
                if hasLinks then line = line + " | " end
                if HW_IsNote[aIdx] then
                    line = line + "Ch" + HW_Channel[aIdx] + ":Note" + HW_CC[aIdx]
                else
                    line = line + "Ch" + HW_Channel[aIdx] + ":CC" + HW_CC[aIdx]
                end
                hasLinks = true
            end
        End
        
        if hasLinks then content = content + line + NEW_LINE end
    End

    // WERT ABFANGEN:
    saved = SaveStringToTextFile(HardwareMapFilePath, content)
    
    if saved then
        Trace("HAL: Hardware Map saved to file.")
    else
        Trace("HAL: ERROR - Could not save Hardware Map!")
    end
End

Function LoadHardwareMap()
    var content, line, key, valPart, entry : String
    var lines, parts, entries, subParts : String Array
    var i, j, mIdx, ch, cc : Integer

    HW_Count = 0; HW_MacroIdx = []; HW_Channel = []; HW_CC = []

    if FileExists(HardwareMapFilePath) then
        content = LoadStringFromTextFile(HardwareMapFilePath)
        lines = SplitString(content, NEW_LINE)
        
        For i = 0; i < Size(lines); i = i + 1 Do
            line = TrimString(lines[i])
            if IndexOfSubstring(line, "Macro", false) == 0 then
                parts = SplitString(line, "=")
                if Size(parts) == 2 then
                    key = TrimString(parts[0]); valPart = TrimString(parts[1])
                    mIdx = StringToInt(ReplaceString(key, "Macro", "", false)) - 1
                    
                    if mIdx >= 0 and mIdx < MAX_MACROS then
                        entries = SplitString(valPart, "|")
                        For j = 0; j < Size(entries); j = j + 1 Do
                            entry = TrimString(entries[j])
                            subParts = SplitString(entry, ":")
                            if Size(subParts) == 2 then
                                ch = StringToInt(ReplaceString(TrimString(subParts[0]), "Ch", "", false))
                                cc = StringToInt(ReplaceString(TrimString(subParts[1]), "CC", "", false))
                                
                                // --- CC ODER NOTE ERKENNEN ---
                                if IndexOfSubstring(TrimString(subParts[1]), "Note", true) == 0 then
                                    cc = StringToInt(ReplaceString(TrimString(subParts[1]), "Note", "", true))
                                    HW_IsNote <-- true
                                else
                                    cc = StringToInt(ReplaceString(TrimString(subParts[1]), "CC", "", true))
                                    HW_IsNote <-- false
                                end
                                
                                HW_MacroIdx <-- mIdx; HW_Channel <-- ch; HW_CC <-- cc
                                HW_Count = HW_Count + 1
                            end
                        End
                    end
                end
            end
        End
        Trace("HAL: Loaded " + HW_Count + " Hardware Assignments.")
    else
        Trace("HAL: No HardwareMap.txt found. Starting blank.")
    end
End

// ---------------------------------------------------------
// GELERNTE HARDWARE AN MACRO FÜR CONTROLLER MAP ZUWEISEN
// ---------------------------------------------------------

Function AssignHardware(mIdx : Integer, ch : Integer, id : Integer, isNote : Boolean)
    var i : Integer
    var found : Boolean = false
    
    For i = 0; i < HW_Count; i = i + 1 Do
        // Überschreiben, wenn Kanal, ID UND Typ (Note/CC) identisch sind!
        if HW_Channel[i] == ch and HW_CC[i] == id and HW_IsNote[i] == isNote then
            HW_MacroIdx[i] = mIdx 
            found = true
        end
    End
    
    if not found then
        HW_MacroIdx <-- mIdx; HW_Channel <-- ch; HW_CC <-- id; HW_IsNote <-- isNote
        HW_Count = HW_Count + 1
    end
    SaveHardwareMap()
End

// ---------------------------------------------------------
// UNLEARN MACRO FÜR CONTROLLER 
// ---------------------------------------------------------

Function UnlearnHardware(mIdx : Integer)
   var i : Integer
   var newCount : Integer = 0
   var tempMacro : Integer Array
   var tempCh : Integer Array
   var tempCC : Integer Array
   var tempIsNote : Boolean Array // <--- NEU

   // Wir kopieren alle Einträge in ein neues Array, AUSSER die, die zum aktuellen Macro gehören
   For i = 0; i < HW_Count; i = i + 1 Do
       if HW_MacroIdx[i] != mIdx then
           tempMacro <-- HW_MacroIdx[i]
           tempCh <-- HW_Channel[i]
           tempCC <-- HW_CC[i]
           tempIsNote <-- HW_IsNote[i] // <--- NEU
           newCount = newCount + 1
       end
   End

   HW_MacroIdx = tempMacro
   HW_Channel = tempCh
   HW_CC = tempCC
   HW_IsNote = tempIsNote // <--- NEU
   HW_Count = newCount

   SaveHardwareMap()
   UpdateControllerInfoDisplay() // Display sofort updaten
   Trace("HAL: Unlearned all external controllers for Macro " + (mIdx + 1))
End

// ---------------------------------------------------------------------
// APPLY EDITOR-TEST // Führt die Logik des "Test-Faders" im Editor aus
// ---------------------------------------------------------------------

Function ApplyEditorTest(val : Double)
    var i, midiVal : Integer
    var scaledVal : Double = 0.0
    var m : MidiMessage 
    
    if CurrentEditScope == -1 then
        For i = 0; i < Link_Count; i = i + 1 Do
            if Link_Active[i] then ExecuteLink(i, val) end
        End
    else
        // ---> DER TÜRSTEHER <---
        if CurrentEditScope >= 0 and CurrentEditScope <= 15 then
            SetParameter(ExternalArranger, CurrentEditScope, val)
        end
        
        For i = 0; i < Link_Count; i = i + 1 Do
            if Link_Active[i] and Link_SourceIdx[i] == CurrentEditScope then ExecuteLink(i, val) end
        End
    end
End

// ---------------------------------------------------------
// THE MAGIC EAR (MIDI LEARN LISTENER)
// ---------------------------------------------------------

// 1. Die Intelligenz: Hier passiert die eigentliche Arbeit
Function ProcessMidiLearn(m : NoteMessage)
   var noteNum, pIdx, vel, i : Integer
   var paramVal : Double = 0.0
   
   // Wir reagieren NUR, wenn wir lernen und die Taste GEDRÜCKT wird
   if (IsLearningMin or IsLearningMax) and IsNoteOn(m) then
       
       noteNum = GetNoteNumber(m)
       paramVal = noteNum / 127.0 // Umrechnen auf 0.0 - 1.0 für das Plugin
       
       // INJECTION: Wir schießen den Wert in alle selektierten Kanäle
       For i = 0; i < 16; i = i + 1 Do
          if OutputScope[i] then
             
             if IsLearningMin then
                // Parameter 0 ist p_SplitMin in Deinem V7.1 NoteProcessor!
                SetParameter(BLK_NoteProcessor[i], 0, paramVal)
             else
                // Parameter 1 ist p_SplitMax in Deinem V7.1 NoteProcessor!
                SetParameter(BLK_NoteProcessor[i], 1, paramVal)
             end
             
             // Gedächtnis und Plugin synchronisieren
             UpdateChannelFade(i, 4, 0, 0.0) 
             
             // NEU: Notenhänger beim Transponieren verhindern!
             if not IsUpdatingMatrix then Trigger_NotesOff(i + 1) end
          end
       End
       
       // Auto-Off: Learn Modus beenden und Buttons ausschalten
       IsLearningMin = false
       IsLearningMax = false
       SetWidgetValue(BTN_LearnMin, 0.0)
       SetWidgetValue(BTN_LearnMax, 0.0)
       
       
       // UI aktualisieren
       UpdateInjectionSplitDisplay()
       UpdateMetaColors() // Da sich der Split geändert hat, könnte der Kanal nun [CUST] sein!
       
       Trace("LEARN SUCCESS: Injected Note " + noteNum + " to Scope.")
   end
   
   if (IsLearningVelMin or IsLearningVelMax) and IsNoteOn(m) then
           vel = GetVelocity(m)
           paramVal = IntToFloat(vel) / 127.0
           
           For i = 0; i < 16; i = i + 1 Do
              if OutputScope[i] then
                 if IsLearningVelMin then
                    Mem_NP_MinVel[i] = vel
                    pIdx = GetParamIdxByName(BLK_NoteProcessor[i], "p_MinVel")
                 else
                    Mem_NP_MaxVel[i] = vel
                    pIdx = GetParamIdxByName(BLK_NoteProcessor[i], "p_MaxVel")
                 end
                 
                 // Ins Plugin injizieren
                 if pIdx > -1 then SetParameter(BLK_NoteProcessor[i], pIdx, paramVal) end
              end
           End
           
           // Auto-Off: Learn Modus beenden
           IsLearningVelMin = false
           IsLearningVelMax = false
           SetWidgetValue(BTN_Inject_NP_VelMinLearn, 0.0)
           SetWidgetValue(BTN_Inject_NP_VelMaxLearn, 0.0)
           
           UpdateInjectionNPDisplay()
           UpdateMetaColors() 
           Trace("LEARN SUCCESS: Injected Velocity " + vel + " to Scope.")
       end   
End

Function LoadControllerMap(mapName : String)
   var content, line, key, valuePart, header : String
   var lines, parts, groupParts, blockParts, paramParts : String Array
   var i, j, k, sliderIdx : Integer
   var targetBlkName, pStr : String
   var sectionFound : Boolean = false
   
   // Parsing Vars
   var entryStr, scaleStr : String
   var minV, maxV : Double = 0.0
   var braceOpen, braceClose : Integer
   var scaleParts : String Array
   var expectedParamName : String 
   var validMap : Boolean
   var startPos, endPos : Integer
   var remainingContent, sectionContent : String
   var chNum : Integer
   
   // Temp Vars für CC Logik
   var isCC : Boolean
   var finalID : Integer
   var isSrcCC : Boolean

   Trace("LoadMap: Requesting '" + mapName + "'")

   // ---------------------------------------------------------
   // 1. ENGINE RESET (Alle Arrays leeren)
   // ---------------------------------------------------------
   Link_Count = 0
   Link_Active = []; Link_SourceIdx = []; Link_Type = []; Link_BlockIdx = []; 
   Link_TargetParam = []; Link_BlockName = []; Link_MinVal = []; Link_MaxVal = []
   Link_ExpectedName = []; Link_IsCC = []; Link_IsSleepSwitch = []; Link_SourceIsCC = []
   
   CF_MacroIdx = -1; CF_CCIdx = -1
   SCRUB_MacroIdx = -1; SCRUB_CCIdx = -1
   VST_BROWSE_MacroIdx = -1; VST_BROWSE_CCIdx = -1
   Last_VST_Browse_Val = -1.0
   SYSTEM_TOGGLE_MacroIdx = -1; SYSTEM_TOGGLE_CCIdx = -1
   
   // ---> BUGFIX: ALLE FEHLENDEN SYSTEM-MACROS RESETTEN! <---
   VST_SCOPE_MacroIdx = -1; VST_SCOPE_CCIdx = -1
   VST_SCOPE_PREV_MacroIdx = -1; VST_SCOPE_PREV_CCIdx = -1
   VST_SCOPE_NEXT_MacroIdx = -1; VST_SCOPE_NEXT_CCIdx = -1
   VST_PREV_MacroIdx = -1; VST_PREV_CCIdx = -1
   VST_NEXT_MacroIdx = -1; VST_NEXT_CCIdx = -1
   REC_SONGPART_MacroIdx = -1; REC_SONGPART_CCIdx = -1
   
   For k = 0; k < 16; k = k + 1 Do 
       LOOPER_CH_MacroIdx[k] = DEF_LOOPER_CH_MacroIdx[k]; LOOPER_CH_CCIdx[k] = -1 
       SOLO_STRICT_MacroIdx[k] = DEF_SOLO_STRICT_MacroIdx[k]; SOLO_STRICT_CCIdx[k] = -1
       SOLO_SMART_MacroIdx[k] = DEF_SOLO_SMART_MacroIdx[k]; SOLO_SMART_CCIdx[k] = -1
       USER_MUTE_MacroIdx[k] = DEF_USER_MUTE_MacroIdx[k]; USER_MUTE_CCIdx[k] = -1
       VELRANGE_MacroIdx[k] = DEF_VELRANGE_MacroIdx[k]; VELRANGE_CCIdx[k] = -1
       ROOT_MacroIdx[k]     = DEF_ROOT_MacroIdx[k];     ROOT_CCIdx[k] = -1
       OCTAVER_MacroIdx[k]  = DEF_OCTAVER_MacroIdx[k];  OCTAVER_CCIdx[k] = -1
       HUMANIZE_MacroIdx[k] = DEF_HUMANIZE_MacroIdx[k]; HUMANIZE_CCIdx[k] = -1
       QUANTIZE_MacroIdx[k] = DEF_QUANTIZE_MacroIdx[k]; QUANTIZE_CCIdx[k] = -1
       SUSTAIN_MacroIdx[k]  = DEF_SUSTAIN_MacroIdx[k];  SUSTAIN_CCIdx[k] = -1
   End
   
   CurrentCtrlMapName = mapName
   LBL_CtrlConfig.SetWidgetLabel(mapName)
   CurrentEditScope = -1

   // ---------------------------------------------------------
   // 2. LOGIC SPLIT (Leer vs. Laden)
   // ---------------------------------------------------------
   if mapName == "-" or mapName == "None" or mapName == "" then
       UpdateEditScopeDisplay()
       SetWidgetLabel(LBL_ControllerInfo, "") 
       Trace("LoadMap: Mappings cleared.")
       
   else
       UpdateEditScopeDisplay()
   
       if FileExists(ControllerMapFilePath) then
           content = LoadStringFromTextFile(ControllerMapFilePath)
           header = "[Map:" + mapName + "]"
           
           // HIGH-SPEED SCAN: Wir suchen nur den Header!
           startPos = IndexOfSubstring(content, header, false)
           
           if startPos > -1 then
               sectionFound = true
               Trace("LoadMap: --- FOUND SECTION: " + header + " ---")
               
               // 1. Schneide alles VOR und INKLUSIVE dem Header ab
               remainingContent = CopySubstring(content, startPos + Length(header), Length(content) - (startPos + Length(header)))
               
               // 2. Suche den Start der NÄCHSTEN Map
               endPos = IndexOfSubstring(remainingContent, "[Map:", false)
               
               if endPos > -1 then
                   // Schneide genau unseren Block heraus
                   sectionContent = CopySubstring(remainingContent, 0, endPos)
               else
                   // Es war die letzte Map im File
                   sectionContent = remainingContent
               end
               
               // JETZT ERST SPLITTEN! (Geht blitzschnell, da nur ~40 Zeilen)
               lines = SplitString(sectionContent, NEW_LINE)
               
               // SCHNELLE SCHLEIFE ÜBER KURZEN BLOCK
               For i = 0; i < Size(lines); i = i + 1 Do
                   line = TrimString(lines[i])
                   
                   // ZEILE PARSEN
                   if Length(line) > 0 and IndexOfSubstring(line, ";", false) != 0 and IndexOfSubstring(line, "=", false) > -1 then
                       parts = SplitString(line, "=")
                       
                       if Size(parts) == 2 then
                           key = TrimString(parts[0]) 
                           valuePart = TrimString(parts[1])
                           
                           isSrcCC = false
                           sliderIdx = -1
                           
                           if IndexOfSubstring(key, "Macro", false) == 0 then 
                               sliderIdx = StringToInt(ReplaceString(key, "Macro", "", false)) - 1
                           elsif IndexOfSubstring(key, "CC", false) == 0 then 
                               sliderIdx = StringToInt(ReplaceString(key, "CC", "", false))
                               isSrcCC = true
                           end
                           
                           if sliderIdx >= 0 and sliderIdx <= 127 then
                               // --- SONDERFUNKTIONEN ---
                               if valuePart == "CROSSFADER" then
                                   if isSrcCC then CF_CCIdx = sliderIdx else CF_MacroIdx = sliderIdx end
                               elsif valuePart == "VST_PREV" then
                                   if isSrcCC then VST_PREV_CCIdx = sliderIdx else VST_PREV_MacroIdx = sliderIdx end
                               elsif valuePart == "VST_NEXT" then
                                   if isSrcCC then VST_NEXT_CCIdx = sliderIdx else VST_NEXT_MacroIdx = sliderIdx end
                               elsif valuePart == "VST_BROWSE" then
                                   if isSrcCC then VST_BROWSE_CCIdx = sliderIdx else VST_BROWSE_MacroIdx = sliderIdx end
                               elsif valuePart == "VST_SCOPE" then
                                   if isSrcCC then VST_SCOPE_CCIdx = sliderIdx else VST_SCOPE_MacroIdx = sliderIdx end
                               elsif valuePart == "VST_SCOPE_PREV" then
                                   if isSrcCC then VST_SCOPE_PREV_CCIdx = sliderIdx else VST_SCOPE_PREV_MacroIdx = sliderIdx end
                               elsif valuePart == "VST_SCOPE_NEXT" then
                                   if isSrcCC then VST_SCOPE_NEXT_CCIdx = sliderIdx else VST_SCOPE_NEXT_MacroIdx = sliderIdx end
                               elsif valuePart == "REC_SONGPART" then
                                   if isSrcCC then REC_SONGPART_CCIdx = sliderIdx else REC_SONGPART_MacroIdx = sliderIdx end
                               elsif valuePart == "SYSTEM_TOGGLE" then
                                   if isSrcCC then SYSTEM_TOGGLE_CCIdx = sliderIdx else SYSTEM_TOGGLE_MacroIdx = sliderIdx end
                               elsif valuePart == "SCRUBBER" then
                                   if isSrcCC then SCRUB_CCIdx = sliderIdx else SCRUB_MacroIdx = sliderIdx end
                                   
                               // --- GRUPPEN MAKROS ---
                                elsif IndexOfSubstring(valuePart, "LOOPER_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "LOOPER_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then LOOPER_CH_CCIdx[chNum] = sliderIdx else LOOPER_CH_MacroIdx[chNum] = sliderIdx end
                                    end
                                elsif IndexOfSubstring(valuePart, "SOLO_STRICT_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "SOLO_STRICT_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then SOLO_STRICT_CCIdx[chNum] = sliderIdx else SOLO_STRICT_MacroIdx[chNum] = sliderIdx end
                                    end
                                elsif IndexOfSubstring(valuePart, "SOLO_SMART_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "SOLO_SMART_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then SOLO_SMART_CCIdx[chNum] = sliderIdx else SOLO_SMART_MacroIdx[chNum] = sliderIdx end
                                    end
                                elsif IndexOfSubstring(valuePart, "USER_MUTE_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "USER_MUTE_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then USER_MUTE_CCIdx[chNum] = sliderIdx else USER_MUTE_MacroIdx[chNum] = sliderIdx end
                                    end

                                elsif IndexOfSubstring(valuePart, "VELRANGE_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "VELRANGE_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then VELRANGE_CCIdx[chNum] = sliderIdx else VELRANGE_MacroIdx[chNum] = sliderIdx end
                                    end
                                elsif IndexOfSubstring(valuePart, "ROOT_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "ROOT_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then ROOT_CCIdx[chNum] = sliderIdx else ROOT_MacroIdx[chNum] = sliderIdx end
                                    end
                                elsif IndexOfSubstring(valuePart, "OCTAVER_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "OCTAVER_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then OCTAVER_CCIdx[chNum] = sliderIdx else OCTAVER_MacroIdx[chNum] = sliderIdx end
                                    end
                                elsif IndexOfSubstring(valuePart, "HUMANIZE_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "HUMANIZE_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then HUMANIZE_CCIdx[chNum] = sliderIdx else HUMANIZE_MacroIdx[chNum] = sliderIdx end
                                    end
                                elsif IndexOfSubstring(valuePart, "QUANTIZE_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "QUANTIZE_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then QUANTIZE_CCIdx[chNum] = sliderIdx else QUANTIZE_MacroIdx[chNum] = sliderIdx end
                                    end
                                elsif IndexOfSubstring(valuePart, "SUSTAIN_CH", false) == 0 then
                                    chNum = StringToInt(ReplaceString(valuePart, "SUSTAIN_CH", "", false)) - 1
                                    if chNum >= 0 and chNum < 16 then
                                        if isSrcCC then SUSTAIN_CCIdx[chNum] = sliderIdx else SUSTAIN_MacroIdx[chNum] = sliderIdx end
                                    end
                               
                               // --- NORMALE LINKS ---
                               else
                                   groupParts = SplitString(valuePart, "|")
                                   For j = 0; j < Size(groupParts); j = j + 1 Do
                                       entryStr = TrimString(groupParts[j])
                                       minV = 0.0; maxV = 1.0
                                       
                                       braceOpen = IndexOfSubstring(entryStr, "{", false)
                                       braceClose = IndexOfSubstring(entryStr, "}", false)
                                       if braceOpen > -1 and braceClose > braceOpen then
                                           scaleStr = CopySubstring(entryStr, braceOpen + 1, braceClose - braceOpen - 1)
                                           entryStr = TrimString(CopySubstring(entryStr, 0, braceOpen))
                                           scaleParts = SplitString(scaleStr, ",")
                                           if Size(scaleParts) == 2 then
                                               minV = StringToDouble(TrimString(scaleParts[0]))
                                               maxV = StringToDouble(TrimString(scaleParts[1]))
                                           end
                                       end
                                       
                                       blockParts = SplitString(entryStr, ":")
                                       if Size(blockParts) >= 2 then
                                           targetBlkName = TrimString(blockParts[0])
                                           paramParts = SplitString(blockParts[1], ",")
                                           expectedParamName = ""
                                           if Size(blockParts) >= 3 then expectedParamName = TrimString(blockParts[2]) end
                                           
                                           For k = 0; k < Size(paramParts); k = k + 1 Do
                                               if Link_Count < MAX_LINKS then
                                                   pStr = TrimString(paramParts[k])
                                                   isCC = false
                                                   if IndexOfSubstring(pStr, "CC", false) == 0 then
                                                       isCC = true
                                                       finalID = StringToInt(ReplaceString(pStr, "CC", "", false))
                                                   else
                                                       finalID = StringToInt(pStr)
                                                   end
                                                   AppendLinkEncoded(targetBlkName, finalID, sliderIdx, minV, maxV, expectedParamName, isCC, isSrcCC)
                                               end
                                           End
                                       end
                                   End
                               end
                           end
                       end
                   end
               End
           else
               Trace("LoadMap ERROR: Section '" + header + "' not found!") 
           end
           
           // --- 3. POST PROCESSING ---
           if sectionFound then 
               if not IsLoadingSnapshot then
                   HardwareSyncTimer = TimeSinceStartup() + 100.0 
                   validMap = ValidateMapping()
                   if not validMap then MapMismatch = true else MapMismatch = false end
               else
                   MapMismatch = false
               end
               
               if VST_SCOPE_MacroIdx >= 0 and VST_SCOPE_MacroIdx <= 15 then SetParameter(ExternalArranger, VST_SCOPE_MacroIdx, 0.5) end
               if VST_BROWSE_MacroIdx >= 0 and VST_BROWSE_MacroIdx <= 15 then SetParameter(ExternalArranger, VST_BROWSE_MacroIdx, 0.5) end
               if REC_SONGPART_MacroIdx >= 0 and REC_SONGPART_MacroIdx <= 15 then SetParameter(ExternalArranger, REC_SONGPART_MacroIdx, 0.5) end
               
               UpdateControllerInfoDisplay()
           end
       end
   end 
   
   // Index Update
   For i = 0; i < Size(CtrlMapList); i = i + 1 Do 
       if CtrlMapList[i] == mapName then CurrentCtrlMapIndex = i end 
   End
End

// ---------------------------------------------------------
// SMART ADAPT: AUTO-MAP ON ISOLATION (UNIVERSAL)
// ---------------------------------------------------------
Function EvaluateSmartAdapt()
    var i, activeVSTs, targetVstIdx : Integer
    var targetMap : String = ""

    // 1. TÜRSTEHER: Ist das Feature überhaupt aktiviert?
    if GetWidgetValue(BTN_SmartAdapt) > 0.5 then
        
        // 2. WIE VIELE VSTS SIND GERADE WACH? (Die universelle Wahrheit)
        activeVSTs = 0
        targetVstIdx = -1
        
        For i = 0; i < MAX_VSTS; i = i + 1 Do
            // IsPluginBypassed == false bedeutet das VST ist AKTIV/WACH
            if not IsPluginBypassed(BLK_VST[i]) and GetPluginInfo(BLK_VST[i], 0) != "Element" then
                activeVSTs = activeVSTs + 1
                targetVstIdx = i
            end
        End

        // 3. ISOLATION AKTIV: Exakt EIN VST ist wach! (Egal durch welchen Modus)
        if activeVSTs == 1 then
            targetMap = "Standard_VST" + IntToString(targetVstIdx + 1)
            
            // Nur wechseln, wenn wir nicht sowieso schon auf dieser Map sind
            if CurrentCtrlMapName != targetMap then
                
                // Aktuelle Map sichern (aber nur, wenn wir gerade erst ins Solo gehen!)
                if not IsAutoSoloMapActive then
                    PreSoloMapName = CurrentCtrlMapName
                    IsAutoSoloMapActive = true
                end
                
                Trace("SMART ADAPT: VST " + (targetVstIdx + 1) + " spielt alleine. Lade " + targetMap)
                LoadControllerMap(targetMap)
                
                // Hardware Sync minimal verzögern (Debounce 400ms)
                HardwareSyncTimer = TimeSinceStartup() + 400.0 
                
                OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> AUTO-MAP: " + targetMap + " <<<", Local_IP, Local_PORT)
                MacroFeedbackTimer = TimeSinceStartup() + 2000.0
            end
            
        // 4. ISOLATION INAKTIV (>1 VST wach oder alle stumm): Zurück zur alten Map!
        else
            if IsAutoSoloMapActive then
                if PreSoloMapName != "" and PreSoloMapName != CurrentCtrlMapName then
                    Trace("SMART ADAPT: Isolation beendet (" + activeVSTs + " VSTs aktiv). Kehre zurück zu -> " + PreSoloMapName)
                    LoadControllerMap(PreSoloMapName)
                    
                    HardwareSyncTimer = TimeSinceStartup() + 400.0
                    OSC_SendStringSpecific("/UI/SetMacroFeedback", ">>> MAP RESTORED <<<", Local_IP, Local_PORT)
                    MacroFeedbackTimer = TimeSinceStartup() + 2000.0
                end
                IsAutoSoloMapActive = false
                PreSoloMapName = ""
            end
        end
        
    // 5. FEATURE AUSGESCHALTET: Eventuellen Geister-Status aufräumen!
    else
        if IsAutoSoloMapActive then
            if PreSoloMapName != "" and PreSoloMapName != CurrentCtrlMapName then
                Trace("SMART ADAPT: Feature deaktiviert. Kehre zurück zu -> " + PreSoloMapName)
                LoadControllerMap(PreSoloMapName)
                HardwareSyncTimer = TimeSinceStartup() + 400.0
            end
            IsAutoSoloMapActive = false
            PreSoloMapName = ""
        end
    end
End

Function RefreshCtrlMapList()
   var content, initialContent, tempContent, mapName : String
   var pos, closePos : Integer
   
   Trace("RefreshList: Scanning " + ControllerMapFilePath)

   // 1. AUTO-CREATE (Generic Header)
   if not FileExists(ControllerMapFilePath) then
       Trace("RefreshList: File missing. Creating new database...")
       initialContent = "; CONTROLLER DATABASE" + NEW_LINE + 
                        "; Format: [Map:Name]" + NEW_LINE + 
                        "; Source = BlockAlias : ParameterIndex" + NEW_LINE + 
                        NEW_LINE + 
                        "[Map:Standard]" + NEW_LINE +
                        "; Default Layout for multiple VSTs" + NEW_LINE +
                        NEW_LINE +
                        "[Map:Standard_VST1]" + NEW_LINE +
                        "[Map:Standard_VST2]" + NEW_LINE +
                        "[Map:Standard_VST3]" + NEW_LINE +
                        "[Map:Standard_VST4]" + NEW_LINE +
                        "[Map:Standard_VST5]" + NEW_LINE
                        
       if SaveStringToTextFile(ControllerMapFilePath, initialContent) then
           Trace("RefreshList: File created successfully.")
       else
           Trace("RefreshList: CRITICAL ERROR - Could not create file!")
       end
   end

   // 2. Liste leeren
   CtrlMapList = []
   CtrlMapList <-- "-" 
   
   // 3. Datei im High-Speed Modus scannen (Ohne SplitString!)
   if FileExists(ControllerMapFilePath) then
       content = LoadStringFromTextFile(ControllerMapFilePath)
       tempContent = content
       
       pos = IndexOfSubstring(tempContent, "[Map:", false)
       While pos > -1 Do
           // Schneide alles vor dem Map-Tag ab
           tempContent = CopySubstring(tempContent, pos, Length(tempContent) - pos)
           
           // Suche das schließende Bracket
           closePos = IndexOfSubstring(tempContent, "]", false)
           if closePos > -1 then
               mapName = CopySubstring(tempContent, 5, closePos - 5)
               CtrlMapList <-- mapName
               Trace("RefreshList: Found Map -> " + mapName)
               
               // Schneide den verarbeiteten Teil ab
               tempContent = CopySubstring(tempContent, closePos, Length(tempContent) - closePos)
           else
               tempContent = "" // Fallback Notausgang
           end
           
           // Suche die nächste Map
           pos = IndexOfSubstring(tempContent, "[Map:", false)
       End
   end
   
   Trace("RefreshList: Total Maps = " + Size(CtrlMapList))
End

Function CycleCtrlMap(direction : Integer)
    var newIdx : Integer
    
    // Liste leer? Scan!
    if Size(CtrlMapList) <= 1 then 
        Trace("Cycle: List empty/default. Refreshing...")
        RefreshCtrlMapList() 
    end
    
    if Size(CtrlMapList) > 0 then
        newIdx = CurrentCtrlMapIndex + direction
        
        // Wrap Around
        if newIdx < 0 then newIdx = Size(CtrlMapList) - 1
        elsif newIdx >= Size(CtrlMapList) then newIdx = 0
        end
        
        Trace("Cycle: Index " + CurrentCtrlMapIndex + " -> " + newIdx + " (" + CtrlMapList[newIdx] + ")")
        
        LoadControllerMap(CtrlMapList[newIdx])
        RecordTimelineEvent("Map", newIdx)        
        CurrentCtrlMapIndex = newIdx
    else
        Trace("Cycle: ERROR - List is still empty!")
        LBL_CtrlConfig.SetWidgetLabel("No Maps!")
    end
End

// ---------------------------------------------------------------------
// CONTROLLER MAP LOADER & BROWSER --> HARDWARE SYNC (WITH BYPASS LOGIC)
// ---------------------------------------------------------------------

Function SyncArrangerToCurrentMap()
   var i, hwIdx : Integer
   var currentVal : Double = 0.0; var range : Double = 0.0; var faderVal : Double = 0.0
   
   if DebugMode then Trace("=== START HARD-TRACE: SYNC GENOS TO MAP (" + CurrentCtrlMapName + ") ===") end
   
   For i = 0; i < Link_Count; i = i + 1 Do
       if Link_Active[i] then
           hwIdx = Link_SourceIdx[i]
           
           if DebugMode then Trace("  -> Analyzing Link " + i + " | SourceIdx (Macro/CC): " + hwIdx) end
           
           // ========================================================
           // ---> DIE 50% REGEL FÜR EINBAHNSTRASSEN (MIDI CC) 
           // ========================================================
           if Link_IsCC[i] then
               faderVal = 0.5 
               if DebugMode then Trace("     [IS CC] Einbahnstraße erkannt! Setze faderVal hart auf 0.5 (50%)") end
           else
               // WENN ES EIN VST-PARAMETER IST: Frage den Host nach dem echten Wert!
               if Link_Type[i] == 0 then 
                   currentVal = GetParameter(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i])
                   if DebugMode then Trace("     [IS VST] Type 0 (Plugin " + (Link_BlockIdx[i]+1) + " | Param " + Link_TargetParam[i] + "). Gelesener Wert: " + currentVal) end
               elsif Link_Type[i] == 1 then 
                   currentVal = GetParameter(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i])
                   if DebugMode then Trace("     [IS NP] Type 1. Gelesener Wert: " + currentVal) end
               elsif Link_Type[i] == 2 then 
                   currentVal = GetParameter(AudioMixer, Link_TargetParam[i])
                   if DebugMode then Trace("     [IS MIXER] Type 2. Gelesener Wert: " + currentVal) end
               end
               
               range = Link_MaxVal[i] - Link_MinVal[i]
               if Abs(range) > 0.0001 then 
                   faderVal = (currentVal - Link_MinVal[i]) / range 
                   if DebugMode then Trace("     [MATH] Skaliere: (" + currentVal + " - " + Link_MinVal[i] + ") / " + range + " = " + faderVal) end
               else 
                   faderVal = 0.0 
                   if DebugMode then Trace("     [MATH] WARNUNG: Range ist 0! Setze faderVal auf 0.0") end
               end
           end
           
           // Sicherheits-Begrenzung
           if faderVal < 0.0 then faderVal = 0.0 elsif faderVal > 1.0 then faderVal = 1.0 end
           
           // An die Hardware senden (Nur wenn der Sender ein Genos-Macro ist)
           if not Link_SourceIsCC[i] then
               // ---> DER TÜRSTEHER <---
               if hwIdx >= 0 and hwIdx <= 15 then
                   SetParameter(ExternalArranger, hwIdx, faderVal)
                   Mem_Fader_Buffer[hwIdx] = faderVal
                   if DebugMode then Trace("     [HARDWARE] Türsteher PASSIERT! Genos Motorfader " + (hwIdx+1) + " fährt auf " + faderVal) end
               else
                   if DebugMode then Trace("     [HARDWARE] Türsteher BLOCKIERT! Index " + hwIdx + " ist kein physikalischer Genos-Fader (0-15).") end
               end
           else
               if DebugMode then Trace("     [HARDWARE] Ignoriert. Quelle ist selbst ein CC, kein physikalischer Genos-Fader.") end
           end
       end
   End
   if DebugMode then Trace("=== END HARD-TRACE ===") end
End

// ---------------------------------------------------------
// AUTO SWITCH MAP ON BYPASS
// ---------------------------------------------------------

// Diese Funktion prüft, ob wir uns im "Standard-Modus" befinden 
// und passt die Map sofort an den neuen VST-Status an.
Function AutoSwitchMapOnBypass()
    // Wir schalten nur automatisch um, wenn die aktuelle Map 
    // entweder "Standard" ist oder bereits eine der dynamischen VST-Maps.
    // So verhindern wir, dass eine speziell geladene Song-Map überschrieben wird.
    if CurrentCtrlMapName == "Standard" or IndexOfSubstring(CurrentCtrlMapName, "Standard_VST", false) == 0 then
        LoadControllerMap(GetDynamicStandardMap())
    end
    
    // Danach immer die Hardware syncen
    SyncArrangerToCurrentMap()
End

// ---------------------------------------------------------
// MORPH SEND // Sendet Slider-Wert an ALLE verknüpften Parameter
// ---------------------------------------------------------

Function MorphSend(sliderIdx : Integer, val : Double)
    var i : Integer
    For i = 0; i < Link_Count; i = i + 1 Do
        if Link_SourceIdx[i] == sliderIdx then 
            if Link_Type[i] == 0 then SetParameter(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i], val)
            elsif Link_Type[i] == 1 then SetParameter(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i], val)
            elsif Link_Type[i] == 2 then SetParameter(AudioMixer, Link_TargetParam[i], val)
            end
        end
    End
End

// Werte direkt aus dem Plugin holen
Function CaptureSmartRanges(isMin : Boolean)
   var i, sIdx, count : Integer = 0
   var currentVal, diff : Double = 0.0
   
   For i = 0; i < Link_Count; i = i + 1 Do
       if Link_Active[i] then
           sIdx = Link_SourceIdx[i]
           if CurrentEditScope == -1 or CurrentEditScope == sIdx then
               
               // ---> BUGFIX: Reine MIDI CCs überspringen wir komplett! <---
               if not Link_IsCC[i] then
                   
                   currentVal = 0.0 // Sauberer Reset für jeden Durchlauf
                   
                   if Link_Type[i] == 0 then currentVal = GetParameter(BLK_VST[Link_BlockIdx[i]], Link_TargetParam[i])
                   elsif Link_Type[i] == 1 then currentVal = GetParameter(BLK_NoteProcessor[Link_BlockIdx[i]], Link_TargetParam[i])
                   elsif Link_Type[i] == 2 then currentVal = GetParameter(AudioMixer, Link_TargetParam[i])
                   end
                   
                   if isMin then 
                       diff = Abs(currentVal - Link_MaxVal[i])
                       if diff > 0.001 then Link_MinVal[i] = currentVal; count = count + 1 end
                   else 
                       diff = Abs(currentVal - Link_MinVal[i])
                       if diff > 0.001 then Link_MaxVal[i] = currentVal; count = count + 1 end
                   end
                   
               end
               
           end
       end
   End
   if isMin then Trace("Editor: Captured MIN (A) values for " + count + " links.") else Trace("Editor: Captured MAX (B) values for " + count + " links.") end
   SyncArrangerToCurrentMap()
   UpdateControllerInfoDisplay()
End

// --------------------------------------------------------------------
// EXPORT SMART CONFIG // Überschreibt die Map direkt in der Datei!
// --------------------------------------------------------------------

Function ExportSmartConfig()
   var s, lnk, chIdx, typeLoop, pID : Integer
   var looperChFound, strictSoloChFound, smartSoloChFound, userMuteChFound : Integer
   var velRangeChFound, rootChFound, octChFound, humChFound, quantChFound, susChFound : Integer
   var line, newBlock, realName, valStr, finalContent, currentLine : String
   var linkFound, isCC, inTargetSection, replaced : Boolean
   var lines : String Array

   if CurrentCtrlMapName == "-" or CurrentCtrlMapName == "" then
       Trace("EXPORT ERROR: No Map loaded!")
   else
       // 1. NEUEN BLOCK BAUEN (RAM)
       newBlock = "[Map:" + CurrentCtrlMapName + "]" + NEW_LINE

       // Wir scannen alles: Macros (0) und CCs (1)
       For typeLoop = 0; typeLoop <= 1; typeLoop = typeLoop + 1 Do
           isCC = (typeLoop == 1)
           
           For s = 0; s < 256; s = s + 1 Do // Scanne bis zum neuen MAX_MACROS
               line = ""
               linkFound = false
               
               if isCC then line = "CC" + s
               else line = "Macro" + (s + 1) end

               // --- SONDERFUNKTIONEN (SINGLE MACROS) ---
               if (not isCC and s == CF_MacroIdx) or (isCC and s == CF_CCIdx) then
                   newBlock = newBlock + line + " = CROSSFADER" + NEW_LINE
               elsif (not isCC and s == SCRUB_MacroIdx) or (isCC and s == SCRUB_CCIdx) then
                   newBlock = newBlock + line + " = SCRUBBER" + NEW_LINE
               elsif (not isCC and s == VST_PREV_MacroIdx) or (isCC and s == VST_PREV_CCIdx) then
                   newBlock = newBlock + line + " = VST_PREV" + NEW_LINE
               elsif (not isCC and s == VST_NEXT_MacroIdx) or (isCC and s == VST_NEXT_CCIdx) then
                   newBlock = newBlock + line + " = VST_NEXT" + NEW_LINE
               elsif (not isCC and s == VST_BROWSE_MacroIdx) or (isCC and s == VST_BROWSE_CCIdx) then
                   newBlock = newBlock + line + " = VST_BROWSE" + NEW_LINE
               elsif (not isCC and s == VST_SCOPE_MacroIdx) or (isCC and s == VST_SCOPE_CCIdx) then
                   newBlock = newBlock + line + " = VST_SCOPE" + NEW_LINE
               elsif (not isCC and s == VST_SCOPE_PREV_MacroIdx) or (isCC and s == VST_SCOPE_PREV_CCIdx) then
                   newBlock = newBlock + line + " = VST_SCOPE_PREV" + NEW_LINE
               elsif (not isCC and s == VST_SCOPE_NEXT_MacroIdx) or (isCC and s == VST_SCOPE_NEXT_CCIdx) then
                   newBlock = newBlock + line + " = VST_SCOPE_NEXT" + NEW_LINE
               elsif (not isCC and s == REC_SONGPART_MacroIdx) or (isCC and s == REC_SONGPART_CCIdx) then
                   newBlock = newBlock + line + " = REC_SONGPART" + NEW_LINE
               elsif (not isCC and s == SYSTEM_TOGGLE_MacroIdx) or (isCC and s == SYSTEM_TOGGLE_CCIdx) then
                   newBlock = newBlock + line + " = SYSTEM_TOGGLE" + NEW_LINE
               
               else
                   // --- GRUPPEN-MACROS (CHANNEL BASED) ---
                   looperChFound = -1; strictSoloChFound = -1; smartSoloChFound = -1; userMuteChFound = -1
                   velRangeChFound = -1; rootChFound = -1; octChFound = -1; humChFound = -1; quantChFound = -1; susChFound = -1
                   
                   For chIdx = 0; chIdx < 16; chIdx = chIdx + 1 Do
                       if (not isCC and s == LOOPER_CH_MacroIdx[chIdx]) or (isCC and s == LOOPER_CH_CCIdx[chIdx]) then looperChFound = chIdx end
                       if (not isCC and s == SOLO_STRICT_MacroIdx[chIdx]) or (isCC and s == SOLO_STRICT_CCIdx[chIdx]) then strictSoloChFound = chIdx end
                       if (not isCC and s == SOLO_SMART_MacroIdx[chIdx]) or (isCC and s == SOLO_SMART_CCIdx[chIdx]) then smartSoloChFound = chIdx end
                       if (not isCC and s == USER_MUTE_MacroIdx[chIdx]) or (isCC and s == USER_MUTE_CCIdx[chIdx]) then userMuteChFound = chIdx end
                       
                       // V7.4 Features
                       if (not isCC and s == VELRANGE_MacroIdx[chIdx]) or (isCC and s == VELRANGE_CCIdx[chIdx]) then velRangeChFound = chIdx end
                       if (not isCC and s == ROOT_MacroIdx[chIdx]) or (isCC and s == ROOT_CCIdx[chIdx]) then rootChFound = chIdx end
                       if (not isCC and s == OCTAVER_MacroIdx[chIdx]) or (isCC and s == OCTAVER_CCIdx[chIdx]) then octChFound = chIdx end
                       if (not isCC and s == HUMANIZE_MacroIdx[chIdx]) or (isCC and s == HUMANIZE_CCIdx[chIdx]) then humChFound = chIdx end
                       if (not isCC and s == QUANTIZE_MacroIdx[chIdx]) or (isCC and s == QUANTIZE_CCIdx[chIdx]) then quantChFound = chIdx end
                       if (not isCC and s == SUSTAIN_MacroIdx[chIdx]) or (isCC and s == SUSTAIN_CCIdx[chIdx]) then susChFound = chIdx end
                   End
                   
                   // Treffer auswerten (Nur speichern, wenn es KEIN Standard-Macro ist, oder wenn es ein CC ist)
                   if looperChFound > -1 then
                       if isCC or s != DEF_LOOPER_CH_MacroIdx[looperChFound] then newBlock = newBlock + line + " = LOOPER_CH" + (looperChFound + 1) + NEW_LINE end
                   elsif strictSoloChFound > -1 then
                       if isCC or s != DEF_SOLO_STRICT_MacroIdx[strictSoloChFound] then newBlock = newBlock + line + " = SOLO_STRICT_CH" + (strictSoloChFound + 1) + NEW_LINE end
                   elsif smartSoloChFound > -1 then
                       if isCC or s != DEF_SOLO_SMART_MacroIdx[smartSoloChFound] then newBlock = newBlock + line + " = SOLO_SMART_CH" + (smartSoloChFound + 1) + NEW_LINE end
                   elsif userMuteChFound > -1 then
                       if isCC or s != DEF_USER_MUTE_MacroIdx[userMuteChFound] then newBlock = newBlock + line + " = USER_MUTE_CH" + (userMuteChFound + 1) + NEW_LINE end
                   
                   // V7.4 Features auswerten
                   elsif velRangeChFound > -1 then
                       if isCC or s != DEF_VELRANGE_MacroIdx[velRangeChFound] then newBlock = newBlock + line + " = VELRANGE_CH" + (velRangeChFound + 1) + NEW_LINE end
                   elsif rootChFound > -1 then
                       if isCC or s != DEF_ROOT_MacroIdx[rootChFound] then newBlock = newBlock + line + " = ROOT_CH" + (rootChFound + 1) + NEW_LINE end
                   elsif octChFound > -1 then
                       if isCC or s != DEF_OCTAVER_MacroIdx[octChFound] then newBlock = newBlock + line + " = OCTAVER_CH" + (octChFound + 1) + NEW_LINE end
                   elsif humChFound > -1 then
                       if isCC or s != DEF_HUMANIZE_MacroIdx[humChFound] then newBlock = newBlock + line + " = HUMANIZE_CH" + (humChFound + 1) + NEW_LINE end
                   elsif quantChFound > -1 then
                       if isCC or s != DEF_QUANTIZE_MacroIdx[quantChFound] then newBlock = newBlock + line + " = QUANTIZE_CH" + (quantChFound + 1) + NEW_LINE end
                   elsif susChFound > -1 then
                       if isCC or s != DEF_SUSTAIN_MacroIdx[susChFound] then newBlock = newBlock + line + " = SUSTAIN_CH" + (susChFound + 1) + NEW_LINE end

                   else
                       // --- NORMALE PARAMETER LINKS PRÜFEN ---
                       line = line + " = "
                       For lnk = 0; lnk < Link_Count; lnk = lnk + 1 Do
                           if Link_Active[lnk] and Link_SourceIdx[lnk] == s and Link_SourceIsCC[lnk] == isCC then
                               if linkFound then line = line + " | " end 
                               
                               pID = Link_TargetParam[lnk]
                               realName = ""
                               
                               // Name ermitteln
                               if Link_IsCC[lnk] then 
                                   if Length(Link_ExpectedName[lnk]) > 0 then realName = Link_ExpectedName[lnk] else realName = "CC " + pID end
                               else
                                   if Link_Type[lnk] == 0 then realName = GetParameterName(BLK_VST[Link_BlockIdx[lnk]], pID)
                                   elsif Link_Type[lnk] == 1 then realName = GetParameterName(BLK_NoteProcessor[Link_BlockIdx[lnk]], pID)
                                   elsif Link_Type[lnk] == 2 then realName = GetParameterName(AudioMixer, pID)
                                   end
                               end
                               
                               // Zeile zusammenbauen (inkl. Min/Max)
                               line = line + Link_BlockName[lnk] + ":" 
                               if Link_IsCC[lnk] then line = line + "CC" end 
                               line = line + pID
                               if realName != "" then line = line + ":" + realName else line = line + ":" end
                               
                               valStr = " {" + Round(Link_MinVal[lnk]*1000)/1000.0 + ", " + Round(Link_MaxVal[lnk]*1000)/1000.0 + "}"
                               line = line + valStr
                               
                               Link_ExpectedName[lnk] = realName 
                               linkFound = true
                           end
                       End
                       if linkFound then newBlock = newBlock + line + NEW_LINE end
                   end
               end
           End
       End

       // 2. DATEI EINLESEN UND ALTEN BLOCK ERSETZEN
       finalContent = ""
       inTargetSection = false
       replaced = false
       
       if FileExists(ControllerMapFilePath) then
           lines = SplitString(LoadStringFromTextFile(ControllerMapFilePath), NEW_LINE)
           
           For s = 0; s < Size(lines); s = s + 1 Do
               currentLine = TrimString(lines[s])
               
               // Schauen ob wir bei einer [Map:...] Sektion ankommen
               if IndexOfSubstring(currentLine, "[Map:", false) == 0 then
                   if currentLine == "[Map:" + CurrentCtrlMapName + "]" then
                       inTargetSection = true
                       finalContent = finalContent + newBlock // Neuen Block einfügen
                       replaced = true
                   else
                       inTargetSection = false
                       finalContent = finalContent + lines[s] + NEW_LINE
                   end
               else
                   // Zeilen kopieren, AUSSER wir befinden uns im alten Bereich unserer Map
                   if not inTargetSection then
                       finalContent = finalContent + lines[s] + NEW_LINE
                   end
               end
           End
       end
       
       // Falls die Map ganz neu ist und noch nie in der Datei stand:
       if not replaced then
           finalContent = finalContent + NEW_LINE + newBlock
       end
       
       // 3. ZURÜCK IN DIE DATEI SCHREIBEN!
       if SaveStringToTextFile(ControllerMapFilePath, finalContent) then
           Trace("EXPORT: Successfully saved map '" + CurrentCtrlMapName + "' to file.")
       else
           Trace("EXPORT ERROR: Could not save to " + ControllerMapFilePath)
       end
       
       MapMismatch = false
       UpdateControllerInfoDisplay()
   end
End

// ---------------------------------------------------------
// PREVIEW ACTIVE CONTROLLER MAPS (JOYSTICK SYS MODE)
// Blättert durch die Base-Map und alle aktiven VST-Maps
// ---------------------------------------------------------
Function PreviewActiveControllerMaps(direction : Integer)
    var i, j, currIdx : Integer
    var validMaps, uniqueMaps : String Array
    var isDup : Boolean
    var startMap : String
    
    validMaps = []; uniqueMaps = []
    
    // 1. Ausgangspunkt bestimmen (Entweder die laufende Map oder die schon vorgewählte)
    if PendingMapName != "" then startMap = PendingMapName else startMap = CurrentCtrlMapName end
    
    // 2. Liste der verfügbaren Maps bauen (Base + Aktive VSTs)
    if ExpectedMapName != "" and ExpectedMapName != "-" then validMaps <-- ExpectedMapName else validMaps <-- "Standard" end
    For i = 0; i < MAX_VSTS; i = i + 1 Do
        if not IsPluginBypassed(BLK_VST[i]) and GetPluginInfo(BLK_VST[i], 0) != "Element" then
            validMaps <-- "Standard_VST" + (i + 1)
        end
    End
    
    // 3. Duplikate filtern
   For i = 0; i < Size(validMaps); i = i + 1 Do
       isDup = false
       j = 0
       While j < Size(uniqueMaps) and not isDup Do
           if uniqueMaps[j] == validMaps[i] then isDup = true end
           j = j + 1
       End
       if not isDup then uniqueMaps <-- validMaps[i] end
   End
   
   // 4. Index finden und blättern
   currIdx = -1
   i = 0
   While i < Size(uniqueMaps) and currIdx == -1 Do
       if uniqueMaps[i] == startMap then currIdx = i end
       i = i + 1
   End
   if currIdx == -1 then currIdx = 0 end
    
    currIdx = currIdx + direction
    if currIdx >= Size(uniqueMaps) then currIdx = 0
    elsif currIdx < 0 then currIdx = Size(uniqueMaps) - 1 end
    
    // 5. NUR VORSCHAU: Wir speichern nur den Namen!
    PendingMapName = uniqueMaps[currIdx]
    
    // Sofortiges visuelles Feedback
    OSC_SendStringSpecific("/UI/SetMacroFeedback", ">> SELECT: " + PendingMapName + " <<", Local_IP, Local_PORT)
    MacroFeedbackTimer = TimeSinceStartup() + 3000.0 // Länger anzeigen während des Blätterns
End


// ============================================================================
// SECTION 18: LOOPER ENGINE
// ============================================================================

Function GetLoopActionName(val : Integer) Returns String
   if val == 0 then result = "PLAY"
   elsif val == 1 then result = "OVERDUB"
   elsif val == 2 then result = "MUTE"
   else result = "-" end
End

Function GetLoopLengthName(val : Integer) Returns String
   if val == 0 then result = "MANUAL"
   elsif val == 1 then result = "1 BAR"
   else result = IntToString(val) + " BARS" end
End

Function GetLoopOutName(val : Integer) Returns String
   if val == 0 then result = "CHANNEL"
   elsif val == 1 then result = "GLOBAL"
   else result = "-" end
End

Function GetLoopStopName(val : Integer) Returns String
   if val == 0 then result = "INSTANT"
   elsif val == 1 then result = "END OF BAR"
   elsif val == 2 then result = "END OF LOOP"
   else result = "-" end
End

Function RefreshLooperInfoDisplay()
   var visibleCount : Integer = 10 // WIE VIELE ZEILEN PASSEN IN DEIN LABEL? (Ggf. anpassen auf 9 oder 11)
   var totalLines : Integer = Size(LooperInfo_Lines)
   var maxScroll, startIdx, i : Integer
   var dispTxt : String = "--- LOOPER CONFIGURATION ---" + NEW_LINE

   if totalLines <= visibleCount then
       startIdx = 0
   else
       maxScroll = totalLines - visibleCount
       // Slider 1.0 (oben) = Index 0 | Slider 0.0 (unten) = Max Scroll
       startIdx = Round((1.0 - GetWidgetValue(SLD_LooperConfiguration)) * IntToFloat(maxScroll))
       if startIdx < 0 then startIdx = 0 end
       if startIdx > maxScroll then startIdx = maxScroll end
   end

   For i = 0; i < visibleCount; i = i + 1 Do
       if (startIdx + i) < totalLines then
           dispTxt = dispTxt + LooperInfo_Lines[startIdx + i] + NEW_LINE
       end
   End

   SetWidgetLabel(LBL_LooperConfiguration, dispTxt)
End

// =========================================================
// THE X-RAY SCANNER: LOOPER DIAGNOSTICS
// =========================================================
Function TraceLooperDiagnostic(chIdx : Integer, actionName : String)
    var actStr, lenStr, tgtStr, stopStr, syncStr, countInStr, stateStr, timeStr, blinkStr : String

    if chIdx == -1 then
        Trace("DIAGNOSTIC [" + actionName + "]: Failed - No active Looper Channel in Scope!")
    else
        // 1. Settings auslesen
        actStr = GetLoopActionName(Mem_Loop_Action[chIdx])
        lenStr = GetLoopLengthName(Mem_Loop_Length[chIdx])
        if Mem_Loop_Target[chIdx] == -1 then tgtStr = "STAY" else tgtStr = "CH " + IntToString(Mem_Loop_Target[chIdx] + 1) end
        stopStr = GetLoopStopName(Mem_Loop_StopMode[chIdx])

        // 2. Globale Schalter auslesen
        if GetWidgetValue(BTN_Loop_HostSync) > 0.5 then syncStr = "ON" else syncStr = "OFF" end
        if GetWidgetValue(BTN_Loop_CountIn) > 0.5 then countInStr = "ON" else countInStr = "OFF" end

        // 3. Aktueller Status
        stateStr = IntToString(Mem_Loop_State[chIdx])

        // 4. Bar Counters & Sync Mode
        timeStr = "GP: " + Global_CurrentBar + "." + Global_CurrentBeat + "." + Global_CurrentTick +
                  " | SONG: " + CurrentBar + "." + CurrentBeat +
                  " | SYNC-MODE: " + SyncModeNames[CurrentSyncMode]

        // 5. LED Blink Status (Was sagt die Variable und was machen die echten Widgets?)
        blinkStr = "Var=" + Global_BlinkState + 
                   " (LED1=" + GetWidgetValue(LBL_Subbar_1) +
                   ", LED2=" + GetWidgetValue(LBL_Subbar_2) +
                   ", LED3=" + GetWidgetValue(LBL_Subbar_3) +
                   ", LED4=" + GetWidgetValue(LBL_Subbar_4) + ")"

        // --- AUSGABE ---
        Trace("=== X-RAY DIAGNOSTIC: " + actionName + " (CH " + (chIdx+1) + ") ===")
        Trace("  SETTINGS : Length=[" + lenStr + "] Action=[" + actStr + "] Target=[" + tgtStr + "] Stop=[" + stopStr + "]")
        Trace("  SWITCHES : HostSync=[" + syncStr + "] CountIn=[" + countInStr + "]")
        Trace("  STATE    : CurrentState=[" + stateStr + "]")
        Trace("  TIMING   : " + timeStr)
        Trace("  BLINK    : " + blinkStr)
        Trace("======================================================")
    end
End

// ---------------------------------------------------------
// LOOPER: DISPLAY RENDERER (Bauen die UI auf)
// ---------------------------------------------------------

Function RefreshLooperConfigDisplay()
   var scrollVal : Double = GetWidgetValue(SLD_LooperConfiguration)
   var totalLines : Integer = Size(LooperConfig_Lines)
   var displayLines : Integer = 12 // Anpassen an dein GUI
   var maxStart : Integer = totalLines - displayLines
   var startIdx, i : Integer
   var finalText : String = "--- LOOPER CONFIGURATION ---" + NEW_LINE // + NEW_LINE

   if maxStart < 0 then maxStart = 0 end
   startIdx = Round((1.0 - scrollVal) * IntToFloat(maxStart))

   For i = 0; i < displayLines; i = i + 1 Do
      if (startIdx + i) < totalLines then
         finalText = finalText + LooperConfig_Lines[startIdx + i] + NEW_LINE
      end
   End
   SetWidgetLabel(LBL_LooperConfiguration, finalText)
End

// ---------------------------------------------------------
// LOOPER: ARRAY CLEANER & PROGRESS CALCULATOR
// ---------------------------------------------------------
Function ClearLooperArrays(chIdx : Integer)
   Select 
      chIdx == 0  Do LoopTime_Ch1 = [];  LoopMsg_Ch1 = []
      chIdx == 1  Do LoopTime_Ch2 = [];  LoopMsg_Ch2 = []
      chIdx == 2  Do LoopTime_Ch3 = [];  LoopMsg_Ch3 = []
      chIdx == 3  Do LoopTime_Ch4 = [];  LoopMsg_Ch4 = []
      chIdx == 4  Do LoopTime_Ch5 = [];  LoopMsg_Ch5 = []
      chIdx == 5  Do LoopTime_Ch6 = [];  LoopMsg_Ch6 = []
      chIdx == 6  Do LoopTime_Ch7 = [];  LoopMsg_Ch7 = []
      chIdx == 7  Do LoopTime_Ch8 = [];  LoopMsg_Ch8 = []
      chIdx == 8  Do LoopTime_Ch9 = [];  LoopMsg_Ch9 = []
      chIdx == 9  Do LoopTime_Ch10 = []; LoopMsg_Ch10 = []
      chIdx == 10 Do LoopTime_Ch11 = []; LoopMsg_Ch11 = []
      chIdx == 11 Do LoopTime_Ch12 = []; LoopMsg_Ch12 = []
      chIdx == 12 Do LoopTime_Ch13 = []; LoopMsg_Ch13 = []
      chIdx == 13 Do LoopTime_Ch14 = []; LoopMsg_Ch14 = []
      chIdx == 14 Do LoopTime_Ch15 = []; LoopMsg_Ch15 = []
      chIdx == 15 Do LoopTime_Ch16 = []; LoopMsg_Ch16 = []
   End
   LoopStartTime[chIdx] = 0.0
   LoopLengthMS[chIdx] = 0.0
   LoopNextEventIdx[chIdx] = 0
   LoopPlayheadMS[chIdx] = -1.0 
End

Function GetLoopProgressString(ch : Integer) Returns String
    var currentTotalTicks, anchorTotalTicks, diffTicks, loopLengthTicks : Integer
    var relBar, relBeat, totalBars, sigNum, ticksPerBeat : Integer
    var waitBeats, remBeats, remBars : Integer
    var beatString, finalResult : String
    var msLeft, msPerBeat : Double = 0.0
    var currentBPM_Prog : Double = GetBPM()
    
    if currentBPM_Prog < 1.0 then currentBPM_Prog = 120.0 end
    msPerBeat = 60000.0 / currentBPM_Prog
    
    sigNum = GetTimeSigNumerator()
    if sigNum <= 0 then sigNum = 4 end 
    
    if Mem_Loop_State[ch] == 0 or Mem_Loop_State[ch] == 4 then
        finalResult = ""
        
    elsif Mem_Loop_State[ch] == 8 then
        // --- STATE 8: FREE COUNTDOWN IN BEATS ---
        msLeft = LoopFreeArmTimer[ch] - TimeSinceStartup()
        if msLeft < 0.0 then msLeft = 0.0 end
        
        remBeats = Round(msLeft / msPerBeat)
        if remBeats < 1 then remBeats = 1 end
        
        finalResult = " | Wait: -" + IntToString(remBeats)
        
        if DebugMode then 
            Trace("LOOP-MATH [Ch" + (ch+1) + " | State 8]: msLeft=" + msLeft + " -> remBeats=" + remBeats) 
        end
        
    elsif Mem_Loop_State[ch] == 5 or Mem_Loop_State[ch] == 6 then
        // --- STATE 5/6: PROFI COUNTDOWN (ARM REC / ARM PLAY) ---
        waitBeats = (sigNum - CurrentBeat) + 1
        finalResult = " | Wait: -" + IntToString(waitBeats)
        
        if DebugMode then 
            Trace("LOOP-MATH [Ch" + (ch+1) + " | State " + Mem_Loop_State[ch] + "]: waitBeats=" + waitBeats) 
        end
        
    else
        // --- STATE 1, 2, 3: DIE RELATIVE STOPPUHR ---
        totalBars = Mem_Loop_Length[ch]
        ticksPerBeat = 960 // GP Standard

        // Die absoluten Ticks seit Songstart
        currentTotalTicks = (((CurrentBar - 1) * sigNum) + (CurrentBeat - 1)) * ticksPerBeat + Global_CurrentTick
        
        // Die absoluten Ticks des gesetzten Ankers
        anchorTotalTicks = (((LoopAnchorBar[ch] - 1) * sigNum) + (LoopAnchorBeat[ch] - 1)) * ticksPerBeat + LoopAnchorTick[ch]
        
        diffTicks = currentTotalTicks - anchorTotalTicks
        if diffTicks < 0 then diffTicks = 0 end 

        if (Mem_Loop_State[ch] == 2 or Mem_Loop_State[ch] == 3) and totalBars > 0 then
            loopLengthTicks = totalBars * sigNum * ticksPerBeat
            diffTicks = diffTicks % loopLengthTicks 
        end

        relBar = (diffTicks / (sigNum * ticksPerBeat)) + 1
        relBeat = ((diffTicks / ticksPerBeat) % sigNum) + 1
        
        beatString = IntToString(relBar) + "." + IntToString(relBeat)
        
        if totalBars > 0 then
            finalResult = " | " + beatString + "/" + IntToString(totalBars)
        else
            finalResult = " | " + beatString
        end
        
        // DER ENTSCHEIDENDE TRACE FÜR EBENE 3:
        if DebugMode then 
            Trace("LOOP-MATH [Ch" + (ch+1) + "]: GP_Tick=" + currentTotalTicks + " | Anker=" + anchorTotalTicks + " | Diff=" + diffTicks + " -> Display: " + beatString) 
        end
    end
    
    result = finalResult
End

Function BuildLooperConfigLines()
   var i, focusCh, focusLineIdx, totalLines, visibleCount : Integer
   var lenStr, actStr, targetStr, stateStr, outStr, stopStr : String
   var scrollPos : Double = 0.0
   
   LooperInfo_Lines = [] // Array leeren!
   focusCh = GetFirstActiveScope()
   
   focusLineIdx = 0
   visibleCount = 10 // Muss identisch mit der Zahl in RefreshLooperInfoDisplay sein!
   
   For i = 0; i < 16; i = i + 1 Do
      // Merken, ab welchem Array-Index unser aktiver Kanal beginnt
      if i == focusCh then focusLineIdx = Size(LooperInfo_Lines) end
      
      if not IsChannelActiveForLooper(i) then
         LooperInfo_Lines <-- "CH " + (i+1) + ": [Bypassed]"
      else
         lenStr = GetLoopLengthName(Mem_Loop_Length[i])
         actStr = GetLoopActionName(Mem_Loop_Action[i])
         if Mem_Loop_Target[i] == -1 then targetStr = "STAY" else targetStr = "CH " + IntToString(Mem_Loop_Target[i] + 1) end
         outStr = GetLoopOutName(Mem_Loop_OutMode[i])
         stopStr = GetLoopStopName(Mem_Loop_StopMode[i])
         
         if Mem_Loop_State[i] == 0 then stateStr = "(Empty)"
         elsif Mem_Loop_State[i] == 1 then stateStr = "(REC" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 2 then stateStr = "(PLAY" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 3 then stateStr = "(DUB" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 4 then stateStr = "(STOP)"
         elsif Mem_Loop_State[i] == 5 then stateStr = "(ARM REC" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 6 then stateStr = "(ARM PLAY" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 7 then stateStr = "(WAIT STOP" + GetLoopProgressString(i) + ")"
         elsif Mem_Loop_State[i] == 8 then stateStr = "(COUNT IN" + GetLoopProgressString(i) + ")"
         end
         
         LooperInfo_Lines <-- "CH " + (i+1) + ": " + stateStr
         LooperInfo_Lines <-- "  |- After: [" + actStr + "] | Out: [" + outStr + "]"
         LooperInfo_Lines <-- "  L- Modes: [" + lenStr + "] | Next: [" + targetStr + "] | Stop: [" + stopStr + "]"
      end
   End
   
   // --- AUTO-SCROLL BERECHNUNG ---
   totalLines = Size(LooperInfo_Lines)
   if totalLines > visibleCount then
       scrollPos = 1.0 - (IntToFloat(focusLineIdx) / IntToFloat(totalLines - visibleCount))
       if scrollPos > 1.0 then scrollPos = 1.0 end
       if scrollPos < 0.0 then scrollPos = 0.0 end
       
       SetWidgetValue(SLD_LooperConfiguration, scrollPos) 
   else
       SetWidgetValue(SLD_LooperConfiguration, 1.0) 
   end
   
   // Bild neu zeichnen!
   RefreshLooperInfoDisplay()
End

// ---------------------------------------------------------
// LOOPER: BUFFER SANITIZER (Hanging Note & Sustain Killer)
// ---------------------------------------------------------
Function CloseLooperBuffer(chIdx : Integer)
   var i, sz, note, b0, b1, b2 : Integer
   var m : MidiMessage
   var activeNotes : Boolean Array = []
   var sustainActive : Boolean = false
   var targetTime : Double = LoopLengthMS[chIdx] - 1.0 // 1 ms vor Ende
   
   if targetTime <= 0.0 then targetTime = 0.0 end
   For i = 0; i < 128; i = i + 1 Do activeNotes <-- false End

   Select 
      chIdx == 0 Do
         sz = Size(LoopMsg_Ch1)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch1[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch1 <-- targetTime; LoopMsg_Ch1 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch1 <-- targetTime; LoopMsg_Ch1 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 1 Do
         sz = Size(LoopMsg_Ch2)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch2[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch2 <-- targetTime; LoopMsg_Ch2 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch2 <-- targetTime; LoopMsg_Ch2 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 2 Do
         sz = Size(LoopMsg_Ch3)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch3[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch3 <-- targetTime; LoopMsg_Ch3 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch3 <-- targetTime; LoopMsg_Ch3 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end

      chIdx == 3 Do
         sz = Size(LoopMsg_Ch4)
         For i = 0; i < sz; i = i + 1 Do
            m = LoopMsg_Ch4[i]; b0 = GetByte(m, 0); b1 = GetByte(m, 1); b2 = GetByte(m, 2)
            if b0 == 144 + chIdx then
               if b2 > 0 then activeNotes[b1] = true else activeNotes[b1] = false end
            elsif b0 == 128 + chIdx then activeNotes[b1] = false 
            elsif b0 == 176 + chIdx and b1 == 64 then
               if b2 >= 64 then sustainActive = true else sustainActive = false end
            end
         End
         For note = 0; note < 128; note = note + 1 Do
            if activeNotes[note] then LoopTime_Ch4 <-- targetTime; LoopMsg_Ch4 <-- MakeMidiMessage3(128 + chIdx, note, 0) end
         End
         if sustainActive then LoopTime_Ch4 <-- targetTime; LoopMsg_Ch4 <-- MakeMidiMessage3(176 + chIdx, 64, 0) end


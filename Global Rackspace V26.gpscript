Function UpdateVstInfoDisplay()
   var i, c : Integer
   var chStr, vstName, statusStr, presetStr : String

   VstInfo_Lines = [] 

   For i = 0; i < MAX_VSTS; i = i + 1 Do 
       vstName = GetPluginInfo(BLK_VST[i], 0)
       if IsPluginBypassed(BLK_VST[i]) then statusStr = "[Bypassed]" else statusStr = "[Active]" end
       
       presetStr = LoadedPresets[i]
       if presetStr == "" then presetStr = "-" end

       chStr = ""
       if Size(RoutingMatrix) == 160 then
           For c = 0; c < 16; c = c + 1 Do
               if RoutingMatrix[(i * 16) + c] == true then
                   if chStr != "" then chStr = chStr + ", " end
                   chStr = chStr + IntToString(c + 1)
               end
           End
       end
       if chStr == "" then chStr = "None" end

       // Zurück zu 4 Zeilen (Info-Zeile ist raus!)
       VstInfo_Lines <-- "VST " + (i + 1) + ": [" + vstName + "] " + statusStr
       VstInfo_Lines <-- "   Preset: " + presetStr
       VstInfo_Lines <-- "   Channels: " + chStr
       VstInfo_Lines <-- "" 
   End
   
   For i = 0; i < 10; i = i + 1 Do VstInfo_Lines <-- "" End
   RefreshVstInfoDisplay()
End

Function UpdateUsageLabelDisplay()
   var i, vstIdx, count : Integer
   var targetName, bypassStr, routingText : String
   var assignedVSTs : Integer Array = [-1, -1, -1]
   var firstScopeIdx : Integer = GetFirstActiveScope()
   
   if firstScopeIdx == -1 then
      SetWidgetLabel(LBL_ChannelUsage, "No Scope")
      SetWidgetLabel(LBL_VSTRouting, "-")
      
      // Keine Auswahl -> Buttons verstecken
      For i = 0; i < 3; i = i + 1 Do SetWidgetHideOnPresentation(W_Inject_Bypass[i], true) End
   else
      SetWidgetLabel(LBL_ChannelUsage, ChannelUsage[firstScopeIdx])
      
      // 1. Suche bis zu 3 VSTs, die auf diesem Kanal liegen
      count = 0
      routingText = ""
      if Size(RoutingMatrix) == 160 then
          For vstIdx = 0; vstIdx < MAX_VSTS; vstIdx = vstIdx + 1 Do
              if RoutingMatrix[(vstIdx * 16) + firstScopeIdx] == true then
                  if count < 3 then
                      assignedVSTs[count] = vstIdx
                      
                      // Status-String bauen
                      if Mem_ManualVSTBypass[vstIdx] then 
                          bypassStr = " [MAN OFF]" // Eindeutige Anzeige für den manuellen Override
                      elsif IsPluginBypassed(BLK_VST[vstIdx]) then 
                          bypassStr = " [Bypassed]" 
                      else 
                          bypassStr = " [Active]" 
                      end

                      if count > 0 then routingText = routingText + " | " end
                      routingText = routingText + GetPluginInfo(BLK_VST[vstIdx], 0) + bypassStr
                      
                      count = count + 1
                  end
              end
          End
      end
      
      if count == 0 then routingText = "-" end
      SetWidgetLabel(LBL_VSTRouting, routingText)

      // 2. Buttons aktualisieren (Sichtbarkeit und Wert)
      IsUpdatingBypassUI = true // <--- SCHUTZSCHILD AN

      For i = 0; i < 3; i = i + 1 Do
          if assignedVSTs[i] != -1 then
              SetWidgetHideOnPresentation(W_Inject_Bypass[i], false)

              if Mem_ManualVSTBypass[assignedVSTs[i]] == true then
                  SetWidgetValue(W_Inject_Bypass[i], 1.0) 
              else
                  SetWidgetValue(W_Inject_Bypass[i], 0.0) 
              end
          else
              SetWidgetHideOnPresentation(W_Inject_Bypass[i], true)
       end
   End

   IsUpdatingBypassUI = false // <--- SCHUTZSCHILD AUS
   end
End

// ---------------------------------------------------------
// UPDATE INJECTION DISPLAY VELOCITY METER (HARVESTER)
// ---------------------------------------------------------
Function UpdateScopeVelocityMeter()
   var i : Integer
   var currentVal, maxVal : Double = 0.0
   
   // Wir suchen den lautesten Anschlag innerhalb der selektierten Kanäle
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] then
         // Da deine Scriptlet-Parameter 0 bis 15 genau Ch 1 bis 16 entsprechen:
         currentVal = GetParameter(BLK_VelocityMonitor, i)
         if currentVal > maxVal then 
            maxVal = currentVal 
         end
      end
   End
   
   // Wert an das LED-Meter-Widget senden
   SetWidgetValue(W_VelocityMeter, maxVal)
End


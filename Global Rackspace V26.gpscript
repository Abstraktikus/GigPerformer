Function UpdateInjectionLooperTransportUI()
   var i, focusCh, currentState : Integer
   var isValid : Boolean = false
   focusCh = GetActiveLooperScope()
   
   if focusCh > -1 then 
       isValid = true 
   end
   
   SetWidgetHideOnPresentation(BTN_Loop_Rec, not isValid)
   SetWidgetHideOnPresentation(BTN_Loop_Play, not isValid)

   if isValid then
      currentState = Mem_Loop_State[focusCh]
      
      Select
         currentState == 0 or currentState == 4 Do 
            SetWidgetValue(BTN_Loop_Rec, 0.0); SetWidgetValue(BTN_Loop_Play, 0.0)
         currentState == 1 Do 
            SetWidgetValue(BTN_Loop_Rec, 1.0); SetWidgetValue(BTN_Loop_Play, 0.0)
         currentState == 2 Do 
            SetWidgetValue(BTN_Loop_Rec, 0.0); SetWidgetValue(BTN_Loop_Play, 1.0)
         currentState == 3 Do 
            SetWidgetValue(BTN_Loop_Rec, 1.0); SetWidgetValue(BTN_Loop_Play, 1.0)
         currentState == 5 Do 
            SetWidgetValue(BTN_Loop_Rec, 1.0); SetWidgetValue(BTN_Loop_Play, 0.0)
         currentState == 6 Do 
            SetWidgetValue(BTN_Loop_Rec, 0.0); SetWidgetValue(BTN_Loop_Play, 1.0)
         currentState == 7 Do 
            SetWidgetValue(BTN_Loop_Rec, 0.0); SetWidgetValue(BTN_Loop_Play, 1.0)
         currentState == 8 Do 
            SetWidgetValue(BTN_Loop_Rec, 1.0); SetWidgetValue(BTN_Loop_Play, 0.0)
      End
   end
End

// ---------------------------------------------------------
// UPDATE LOOPER INJECTION DISPLAY
// ---------------------------------------------------------

Function UpdateInjectionLooperDisplay()
   var focusCh : Integer
   var targetTxt : String
   var isValid : Boolean = false
   
   focusCh = GetFirstActiveScope()
   
   if focusCh != -1 then
      if IsChannelActiveForLooper(focusCh) then isValid = true end
   end
   
   if not isValid then
      SetWidgetLabel(LBL_LoopAction, "Bypassed")
      SetWidgetLabel(LBL_LoopTarget, "-")
      SetWidgetLabel(LBL_LoopLength, "-")
      SetWidgetLabel(LBL_LoopOut, "-") 
      SetWidgetLabel(LBL_LoopStop, "-") 
   else
      SetWidgetLabel(LBL_LoopLength, GetLoopLengthName(Mem_Loop_Length[focusCh]))
      SetWidgetLabel(LBL_LoopAction, GetLoopActionName(Mem_Loop_Action[focusCh]))
      
      if Mem_Loop_Target[focusCh] == -1 then targetTxt = "STAY" 
      else targetTxt = "-> CH " + IntToString(Mem_Loop_Target[focusCh] + 1) end
      SetWidgetLabel(LBL_LoopTarget, targetTxt)
      
      SetWidgetLabel(LBL_LoopOut, GetLoopOutName(Mem_Loop_OutMode[focusCh]))
      SetWidgetLabel(LBL_LoopStop, GetLoopStopName(Mem_Loop_StopMode[focusCh]))
   end
   
   BuildLooperConfigLines() 
   UpdateInjectionLooperTransportUI()
End


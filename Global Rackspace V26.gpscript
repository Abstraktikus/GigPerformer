Function UpdateInjectionTransposeDisplay()
   var i, firstScopeIdx : Integer
   var currentTrans : Integer
   
   firstScopeIdx = -1
   firstScopeIdx = GetFirstActiveScope()
   
   if firstScopeIdx == -1 then
      SetWidgetLabel(LBL_InjectMTAmount, "-")
      SetWidgetLabel(LBL_InjectMT_Info, "No Scope")
   else
      currentTrans = Mem_Transpose[firstScopeIdx] 
      
      // --- HIER IST DAS UPDATE ---
      SetWidgetLabel(LBL_InjectMTAmount, IntToString(currentTrans) + " ST")
      SetWidgetLabel(LBL_InjectMT_Info, GetMusicTheoryString(currentTrans))
   end

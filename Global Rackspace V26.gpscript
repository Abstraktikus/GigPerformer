// =========================================================

On WidgetValueChanged(val : Double) from BTN_SmartAdapt
    EvaluateSmartAdapt()
End

On WidgetValueChanged(newValue : double) from BTN_CtrlConfig_Prev
    If newValue > 0.5 Then CycleCtrlMap(-1); BTN_CtrlConfig_Prev.SetWidgetValue(0.0) End
End

On WidgetValueChanged(newValue : double) from BTN_CtrlConfig_Next
    If newValue > 0.5 Then CycleCtrlMap(1); BTN_CtrlConfig_Next.SetWidgetValue(0.0) End
End

On WidgetValueChanged(val : Double) from BTN_ScopeSection_Prev
    if val > 0.5 then CycleScopeSection(-1); SetWidgetValue(BTN_ScopeSection_Prev, 0.0) end
End

On WidgetValueChanged(val : Double) from BTN_ScopeSection_Next
    if val > 0.5 then CycleScopeSection(1); SetWidgetValue(BTN_ScopeSection_Next, 0.0) end
End

On WidgetValueChanged(v : Double) from BTN_Scope_Prev
    if v > 0.5 then CycleEditScope(-1); SetWidgetValue(BTN_Scope_Prev, 0.0) end
End

On WidgetValueChanged(v : Double) from BTN_Scope_Next
    if v > 0.5 then CycleEditScope(1); SetWidgetValue(BTN_Scope_Next, 0.0) end
End

On WidgetValueChanged(v : Double) from BTN_Capture_Min
    if v > 0.5 then CaptureSmartRanges(true); SetWidgetValue(BTN_Capture_Min, 0.0) end
End

On WidgetValueChanged(v : Double) from BTN_Capture_Max
    if v > 0.5 then CaptureSmartRanges(false); SetWidgetValue(BTN_Capture_Max, 0.0) end
End

On WidgetValueChanged(val : Double) from BTN_MacroLearn
    if val > 0.5 then
        if CurrentEditScope == -1 then
            IsHardwareLearning = false; SetWidgetValue(BTN_MacroLearn, 0.0)
        else
            IsHardwareLearning = true
            Trace("HAL Learn: Waiting for CC on Macro " + (CurrentEditScope + 1) + "...")
        end
    else
        IsHardwareLearning = false
    end
End

On WidgetValueChanged(val : Double) from BTN_MacroUnLearn
    if val > 0.5 then
        if CurrentEditScope != -1 then UnlearnHardware(CurrentEditScope) end
        SetWidgetValue(BTN_MacroUnLearn, 0.0) 
    end
End

On WidgetValueChanged(v : Double) from BTN_Export_Log
    if v > 0.5 then 
        ExportSmartConfig()
        SetWidgetValue(BTN_Export_Log, 0.0)
        SetWidgetLabel(LBL_ControllerInfo, NEW_LINE + NEW_LINE + "       >>> SAVED TO FILE! <<<" + NEW_LINE + "       (" + CurrentCtrlMapName + ")")
        Wait(1500.0) 
        UpdateControllerInfoDisplay()
    end
End

On WidgetValueChanged(newVal : Double) from SLD_Morph
   if not IgnoreMorphEcho then ApplyEditorTest(newVal) end
End

On WidgetValueChanged(val : Double) from SLD_ControllerInfo
    RefreshCtrlInfoDisplay()
End


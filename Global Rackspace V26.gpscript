// 5. INJECTION (MATRIX & ROUTING)
// =========================================================

On WidgetValueChanged(w : Widget, inputIdx : Integer, val : Double) from BTN_Ch1_In, BTN_Ch2_In, BTN_Ch3_In, BTN_Ch4_In, BTN_Ch5_In, BTN_Ch6_In, BTN_Ch7_In, BTN_Ch8_In, BTN_Ch9_In, BTN_Ch10_In, BTN_Ch11_In, BTN_Ch12_In, BTN_Ch13_In, BTN_Ch14_In, BTN_Ch15_In, BTN_Ch16_In
   var outIdx, paramIdx : Integer
   if TimeSinceStartup() > InputSyncTimer and not IsLoadingSnapshot then
       if val < 0.1 or val > 0.9 then
           SetWidgetLabel(LBL_MidiConfig, "Custom (Unsaved)")
           For outIdx = 0; outIdx < 16; outIdx = outIdx + 1 Do
              if OutputScope[outIdx] then
                  paramIdx = (inputIdx * 16) + outIdx
                  if val > 0.5 then SetParameter(RECH, paramIdx, 1.0) else SetParameter(RECH, paramIdx, 0.0) end
              end
           End
           UpdateMidiConfigLabel(); UpdateMetaColors(); SyncInputFeedback()
       end
   end
End

On WidgetValueChanged(w : Widget, index : Integer, val : Double) from 
   BTN_Ch1_Out_Bl, BTN_Ch2_Out_Bl, BTN_Ch3_Out_Bl, BTN_Ch4_Out_Bl, BTN_Ch5_Out_Bl, BTN_Ch6_Out_Bl, BTN_Ch7_Out_Bl, BTN_Ch8_Out_Bl, BTN_Ch9_Out_Bl, BTN_Ch10_Out_Bl, BTN_Ch11_Out_Bl, BTN_Ch12_Out_Bl, BTN_Ch13_Out_Bl, BTN_Ch14_Out_Bl, BTN_Ch15_Out_Bl, BTN_Ch16_Out_Bl,
   BTN_Ch1_Out_Or, BTN_Ch2_Out_Or, BTN_Ch3_Out_Or, BTN_Ch4_Out_Or, BTN_Ch5_Out_Or, BTN_Ch6_Out_Or, BTN_Ch7_Out_Or, BTN_Ch8_Out_Or, BTN_Ch9_Out_Or, BTN_Ch10_Out_Or, BTN_Ch11_Out_Or, BTN_Ch12_Out_Or, BTN_Ch13_Out_Or, BTN_Ch14_Out_Or, BTN_Ch15_Out_Or, BTN_Ch16_Out_Or,
   BTN_Ch1_Out_Ye, BTN_Ch2_Out_Ye, BTN_Ch3_Out_Ye, BTN_Ch4_Out_Ye, BTN_Ch5_Out_Ye, BTN_Ch6_Out_Ye, BTN_Ch7_Out_Ye, BTN_Ch8_Out_Ye, BTN_Ch9_Out_Ye, BTN_Ch10_Out_Ye, BTN_Ch11_Out_Ye, BTN_Ch12_Out_Ye, BTN_Ch13_Out_Ye, BTN_Ch14_Out_Ye, BTN_Ch15_Out_Ye, BTN_Ch16_Out_Ye,
   BTN_Ch1_Out_Re, BTN_Ch2_Out_Re, BTN_Ch3_Out_Re, BTN_Ch4_Out_Re, BTN_Ch5_Out_Re, BTN_Ch6_Out_Re, BTN_Ch7_Out_Re, BTN_Ch8_Out_Re, BTN_Ch9_Out_Re, BTN_Ch10_Out_Re, BTN_Ch11_Out_Re, BTN_Ch12_Out_Re, BTN_Ch13_Out_Re, BTN_Ch14_Out_Re, BTN_Ch15_Out_Re, BTN_Ch16_Out_Re,
   BTN_Ch1_Out_Gr, BTN_Ch2_Out_Gr, BTN_Ch3_Out_Gr, BTN_Ch4_Out_Gr, BTN_Ch5_Out_Gr, BTN_Ch6_Out_Gr, BTN_Ch7_Out_Gr, BTN_Ch8_Out_Gr, BTN_Ch9_Out_Gr, BTN_Ch10_Out_Gr, BTN_Ch11_Out_Gr, BTN_Ch12_Out_Gr, BTN_Ch13_Out_Gr, BTN_Ch14_Out_Gr, BTN_Ch15_Out_Gr, BTN_Ch16_Out_Gr
   
   var chIdx : Integer 
   chIdx = index % 16 
   
   if TimeSinceStartup() > OutputSyncTimer then
       if val > 0.5 then OutputScope[chIdx] = true else OutputScope[chIdx] = false end
       UpdateMetaColors(); SyncInputFeedback(); UpdateUsageLabelDisplay()
       RefreshAllInjectionDisplays(); ScrollToCurrentChannel()
   end
End

// =========================================================
// 6. INJECTION (KEYBOARD, FILTER, NOTES & BYPASS)

// --- SMART CONFIG CHECK ---
// ----------------------------------------------------------------------

// Gibt TRUE zurück, wenn der Kanal vom Standard abweicht (Custom ist)
Function IsChannelCustom(chIdx : Integer) Returns Boolean
   // CheckBlock liefert 'false', wenn es eine Abweichung gibt. 'not' dreht es um.
   result = not CheckBlock(BLK_NoteProcessor[chIdx], DEF_NoteProcessor, "IsCust NP")
End

Function IsChannelFactory(chIdx : Integer) Returns Boolean
   // Gibt 'true' zurück, wenn alles exakt dem Factory-Array entspricht
   result = CheckBlock(BLK_NoteProcessor[chIdx], FACT_NoteProcessor, "IsFact NP")
End


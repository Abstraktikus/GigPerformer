// ---------------------------------------------------------
// HELPER: TRACE
// ---------------------------------------------------------


// ============================================================================
// SECTION 13: CORE UTILITIES
// ============================================================================

Function Wait(ms : Double)
   var t_wait : Double = 0.0
   t_wait = TimeSinceStartup();
   While (TimeSinceStartup() - t_wait) < ms Do End
End

Function Trace(msg : String)
   // 1. Normale Text-Ausgabe (nur im DebugMode)
   if DebugMode then
      Print("[" + DoubleToString(TimeSinceStartup(), 1) + "] GLB: " + msg)
   end
   
   // 2. DER WÄCHTER (Immer aktiv, unabhängig vom DebugMode)
   if (TimeSinceStartup() - TraceLastTime) > 100.0 then
      TraceLoopCount = 0
   end
   
   TraceLastTime = TimeSinceStartup()
   TraceLoopCount = TraceLoopCount + 1
   
   // Limit auf 250 erhöht für den schnellen Text-Parser
   if TraceLoopCount > 250 then
      Print("!!! NOTBREMSE: Todes-Schleife erkannt! Letzter Trace: " + msg)
      
      EmergencyKillSwitch = true 
     
      // BLACKBOX: Schreibt den Fehler direkt in deine Zwischenablage!
      SendToClipboard("GP DEATH LOOP TRACE:" + NEW_LINE + msg)
      
      TraceLoopCount = 0 
   end
End

Function DebugCrash(msg : String)
   Trace(msg)
End

Function TraceActiveScope()
    var i : Integer
    var scopeStr : String = ""
    
    For i = 0; i < 16; i = i + 1 Do
        if OutputScope[i] then
            if scopeStr != "" then scopeStr = scopeStr + ", " end
            scopeStr = scopeStr + IntToString(i + 1)
        end
    End
    
    if scopeStr == "" then scopeStr = "None" end
    Trace("SCOPE DEBUG: Currently active Output Scopes -> [" + scopeStr + "]")
End

// ---------------------------------------------------------
// HELPER: SNAPSHOT PATH BUILDER
// ---------------------------------------------------------

Function GetSnapshotPath(fileName : String) Returns String
   var sep : String = "/"
   
   // Separator Erkennung basierend auf deinem Pfad
   if IndexOfSubstring(UserSnapshotPath, "\\", false) > -1 Then 
      sep = "\\" 
   Else 
      sep = "/" 
   End
   
   // Automatisch .ini anhängen, falls vergessen
   if IndexOfSubstring(fileName, ".ini", false) == -1 then 
      fileName = fileName + ".ini" 
   end
   
   result = UserSnapshotPath + sep + fileName
End

// ---------------------------------------------------------
// HELPER: HIGH-SPEED SPACER (Verhindert String-Overhead)
// ---------------------------------------------------------
Function GetSpaces(count : Integer) Returns String
    var res : String = ""
    var chunk : String = "          " // 10 Leerzeichen
    var c : Integer = count
    
    if c > 0 then
        While c >= 10 Do
            res = res + chunk
            c = c - 10
        End
        While c > 0 Do
            res = res + " "
            c = c - 1
        End
    end
    
    result = res
End

// ---------------------------------------------------------
// HELPER: PAD INTEGER WITH ZEROS (z.B. 1 -> "001")
// ---------------------------------------------------------
Function PadInt(val : Integer, length : Integer) Returns String
    var s : String = IntToString(val)
    While Length(s) < length Do
        s = "0" + s
    End
    result = s
End

// ---------------------------------------------------------
// HELPER: SPLIT STRING FÜR CONTROLLER / MORPHING
// ---------------------------------------------------------

Function SplitString(text : String, delimiter : String) Returns String Array
   var resultArr : String Array; var pos, delimLen, loopGuard : Integer; var temp, partStr : String
   temp = text; resultArr = []; delimLen = Length(delimiter); loopGuard = 0
   While Length(temp) > 0 and loopGuard < 20000 Do
      pos = IndexOfSubstring(temp, delimiter, false)
      If pos > -1 Then 
         partStr = CopySubstring(temp, 0, pos);
         resultArr <-- partStr; 
         temp = CopySubstring(temp, pos + delimLen, Length(temp) - (pos + delimLen))
      Else 
         resultArr <-- temp;
         temp = "" 
      End
      loopGuard = loopGuard + 1
   End
   result = resultArr
End

// ----------------------------------------------------------------------
// --- HELPER: Setzt die Farbe und den Selektions-Status eines Kanals ---
// ----------------------------------------------------------------------

Function SetChannelState(chIdx : Integer, colorCode : Integer)
   var isSelected : Double = 0.0
      
   // Prüfen, ob der Kanal gerade im Scope (selektiert) ist
   if OutputScope[chIdx] then isSelected = 1.0 else isSelected = 0.0 end
   
   // 1. Alle Layer verstecken (Reset) - WICHTIG: Auch Orange!
   SetWidgetHideOnPresentation(W_Out_Layer_Bl[chIdx], true) // Blau (Off)
   SetWidgetHideOnPresentation(W_Out_Layer_Ye[chIdx], true) // Gelb (Std)
   SetWidgetHideOnPresentation(W_Out_Layer_Gr[chIdx], true) // Grün (Custom)
   SetWidgetHideOnPresentation(W_Out_Layer_Re[chIdx], true) // Rot (Merge)
   SetWidgetHideOnPresentation(W_Out_Layer_Or[chIdx], true) // Orange (Dirty)
   
   // 2. Den richtigen Layer aufdecken & Wert setzen (fürs Leuchten)
   if colorCode == 0 then       // BLAU (Kein Signal / Off / Clean Mute)
      SetWidgetHideOnPresentation(W_Out_Layer_Bl[chIdx], false)
      SetWidgetValue(W_Out_Layer_Bl[chIdx], isSelected)
      
   elsif colorCode == 1 then    // GELB (Standard Signal / Factory)
      SetWidgetHideOnPresentation(W_Out_Layer_Ye[chIdx], false)
      SetWidgetValue(W_Out_Layer_Ye[chIdx], isSelected)
      
   elsif colorCode == 2 then    // ROT (Merge / Chaos)
      SetWidgetHideOnPresentation(W_Out_Layer_Re[chIdx], false)
      SetWidgetValue(W_Out_Layer_Re[chIdx], isSelected)
      
   elsif colorCode == 3 then    // GRÜN (Custom Signal)
      SetWidgetHideOnPresentation(W_Out_Layer_Gr[chIdx], false)
      SetWidgetValue(W_Out_Layer_Gr[chIdx], isSelected)

   elsif colorCode == 4 then    // ORANGE (Dirty / Volatile - Aus, aber Custom Werte)
      SetWidgetHideOnPresentation(W_Out_Layer_Or[chIdx], false)
      SetWidgetValue(W_Out_Layer_Or[chIdx], isSelected)
   end
End

// ----------------------------------------------------------------------
// --- LOOPER HELPER: TAKTZÄHLER WENN SYNC OFF ---
// ----------------------------------------------------------------------

Function GetCountInDurationMS() Returns Double
    var currentBpm : Double = GetBPM()
    var num : Integer = GetTimeSigNumerator()
    var barsToWait : Integer = 1
    
    if num <= 0 then num = 4 end
    if currentBpm < 1.0 then currentBpm = 120.0 end
    
    // Die Profi-Grenze: Ab 140 BPM geben wir dem Musiker automatisch 2 Takte Vorlaufzeit!
    if currentBpm >= 140.0 then barsToWait = 2 end
    
    result = (60000.0 / currentBpm) * IntToFloat(num * barsToWait)
End

// ---------------------------------------------------------
// HELPER: CREATE SYSTEM STANDARD
// ---------------------------------------------------------
Function ResetState()
   CurrentState = 0
End

// Sucht den ERSTEN aktiven Kanal im Scope
Function GetFirstActiveScope() Returns Integer
    var i : Integer = 0
    result = -1
    While i < 16 and result == -1 Do
        if OutputScope[i] then result = i end
        i = i + 1
    End
End

// ---------------------------------------------------------
// HELPER FÜR INJECTION 
// ---------------------------------------------------------

Function GetNoteName(noteNum : Integer) Returns String
   var notes : String Array = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"]
   var octave : Integer
   var noteIndex : Integer
   
   octave = (noteNum / 12) - 2 // GP Standard: Note 0 = C-2
   noteIndex = noteNum % 12
   
   result = notes[noteIndex] + IntToString(octave)
End

Function GetScaleKeyName(val : Integer) Returns String
   var keys : String Array = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"]
   if val >= 0 and val <= 11 then result = keys[val] else result = "-" end
End

Function GetScaleTypeName(val : Integer) Returns String
   var scales : String Array = ["Major", "Minor", "Maj Penta", "Min Penta", "Blues", "Dorian"]
   if val >= 0 and val <= 5 then result = scales[val] else result = "-" end
End

// ---------------------------------------------------------
// MUSIC THEORY ENGINE (TRANSPOSE)
// ---------------------------------------------------------
Function GetMusicTheoryString(semitones : Integer) Returns String
   var notes : String Array = ["C", "C#", "D", "D#", "E", "F", "F#", "G", "G#", "A", "A#", "B"]
   var intervals : String Array = ["Unison", "Minor 2nd", "Major 2nd", "Minor 3rd", "Major 3rd", "Perfect 4th", "Tritone", "Perfect 5th", "Minor 6th", "Major 6th", "Minor 7th", "Major 7th"]
   
   var absVal, octaves, remainder, noteIndex : Integer
   var targetNote, intervalName, dirStr, finalStr : String
   
   if semitones == 0 then
      finalStr = "C -> C (Original Pitch)"
   else
      // Absolute Werte für die Berechnung
      if semitones < 0 then 
         absVal = -semitones 
      else 
         absVal = semitones 
      end
      octaves = absVal / 12
      remainder = absVal % 12
      
      // Ziel-Note berechnen (Modulo mit Wrap-Around für negative Zahlen)
      noteIndex = semitones % 12
      if noteIndex < 0 then noteIndex = noteIndex + 12 end
      targetNote = notes[noteIndex]
      
      // Intervall-Namen bauen
      intervalName = intervals[remainder]
      if octaves == 1 and remainder == 0 then intervalName = "Octave"
      elsif octaves > 0 and remainder > 0 then intervalName = "" + octaves + " Oct + " + intervalName
      elsif octaves > 1 and remainder == 0 then intervalName = "" + octaves + " Octaves"
      end
      
      // Richtung
      if semitones > 0 then dirStr = "Up" else dirStr = "Down" end
      
      finalStr = "C -> " + targetNote + " (" + intervalName + " " + dirStr + ")"
   end
   
   result = finalStr
End

// ---------------------------------------------------------
// GET LUXUS LABEL
// ---------------------------------------------------------

Function GetLuxusLabel(noteNum : Integer) Returns String
   // Ergebnis: "C-2 (0)" oder "G8 (127)"
   result = GetNoteName(noteNum) + " (" + noteNum + ")"
End

// ---------------------------------------------------------
// CHANNEL USAGE LOGIC
// ---------------------------------------------------------

// Sucht das ERSTE VST (0-9), das diesem Kanal zugewiesen ist
Function GetPrimaryVSTForChannel(chIdx : Integer) Returns Integer
   var v : Integer = 0
   result = -1 // Fallback (Kein VST zugewiesen)
   
   // SICHERHEIT: Nur abfragen, wenn die Matrix schon fertig gebaut ist!
   if Size(RoutingMatrix) == 160 then
       // Sichere Schleife: Läuft nur solange wir unter MAX_VSTS sind UND noch nichts gefunden haben
       While v < MAX_VSTS and result == -1 Do
          if RoutingMatrix[(v * 16) + chIdx] == true then
             result = v
          end
          v = v + 1
       End
   end
End

// ---------------------------------------------------------
// LOOPER: BASE HELPERS (Haben keine Abhängigkeiten)
// ---------------------------------------------------------

Function IsChannelActiveForLooper(chIdx : Integer) Returns Boolean
   if not IsPluginBypassed(BLK_NoteProcessor[chIdx]) then 
      result = true 
   else 
      result = false 
   end
End

// Sucht den ERSTEN aktiven Looper-Kanal im Scope
Function GetActiveLooperScope() Returns Integer
    var i : Integer = 0
    result = -1
    While i < 16 and result == -1 Do
        if OutputScope[i] and IsChannelActiveForLooper(i) then result = i end
        i = i + 1
    End
End

Function ShowCtrlOverlay(msg : String, durationMS : Double)
   Ctrl_OverlayMsg = msg
   Ctrl_OverlayTimer = TimeSinceStartup() + durationMS
   RefreshCtrlInfoDisplay()
End

// ---------------------------------------------------------
// HELPER: GET CURRENT MAP SLOT
// ---------------------------------------------------------
Function GetActiveMapSlot() Returns Integer
   if Size(ReplaceableSlots) > 0 then
       result = ReplaceableSlots[CurrentMapSlotIndex]
   else
       result = 0 // Fallback auf VST 1
   end
End


    Rec_OverlayTimer = TimeSinceStartup() + durationMS
    RefreshRecDisplay(GetWidgetValue(SLD_CurrentState))
End

// ---------------------------------------------------------
// MIDI MAPPING HELPERS
// ---------------------------------------------------------

Function GetStandardCCName(cc : Integer) Returns String
   if cc == 1 then result = "Modulation Wheel"
   elsif cc == 2 then result = "Breath Controller"
   elsif cc == 4 then result = "Foot Pedal"
   elsif cc == 5 then result = "Portamento Time"
   elsif cc == 7 then result = "Volume"
   elsif cc == 10 then result = "Pan"
   elsif cc == 11 then result = "Expression"
   elsif cc == 64 then result = "Sustain"
   elsif cc == 65 then result = "Portamento"
   elsif cc == 66 then result = "Sostenuto"
   elsif cc == 67 then result = "Soft Pedal"
   elsif cc == 71 then result = "Resonance"
   elsif cc == 74 then result = "Frequency Cutoff"
   else result = "CC " + cc
   end
End

// -------------------------------------------------------------
// APPENDER FUNKTIONEN FÜR CONTROLLER MAP (VST/Channels to Scope
// -------------------------------------------------------------

// Validiert den Namen grob vorab
Function IsBlockNameValid(name : String) Returns Boolean
    result = false
    if IndexOfSubstring(name, "VST", false) == 0 then result = true
    elsif IndexOfSubstring(name, "Ch", false) == 0 then result = true
    elsif name == "AudioMixer" then result = true
    end
End

Function ClickWidget(displayWidget : Widget)
   displayWidget.SetWidgetValue(1.0); displayWidget.SetWidgetValue(0.0)
End

Function UpdateTagInLine(line : String, tagName : String, newVal : String) Returns String
    var startPos, endPos : Integer; var pre, post, res : String
    res = line; startPos = IndexOfSubstring(line, tagName, false)
    if startPos > -1 Then
        pre = CopySubstring(line, 0, startPos + Length(tagName)) 
        post = CopySubstring(line, startPos, Length(line) - startPos)
        endPos = IndexOfSubstring(post, "}", false)
        if endPos > -1 Then 
            post = CopySubstring(post, endPos, Length(post) - endPos)
            res = pre + newVal + post 
        End
    Else res = tagName + newVal + "} " + line End
    result = res
End

Function StartMacroAnimation(macroID : Integer, targetVal : Double, durMS : Double)
   // macroID kommt aus dem Text-File (1 bis 16). Unser Array ist 0-basiert.
   var mIdx : Integer = macroID - 1 
   
   if mIdx >= 0 and mIdx <= 15 then
       Anim_Start[mIdx] = GetParameter(ExternalArranger, mIdx)
       Anim_Target[mIdx] = targetVal
       Anim_Duration[mIdx] = durMS
       Anim_StartTime[mIdx] = TimeSinceStartup()
       
       Anim_Active[mIdx] = true // Zündung!
       
       Trace("ANIMATION: Started Macro " + macroID + " -> " + targetVal + " over " + durMS + "ms")
   end
End

// ---------------------------------------------------------
// HELPER FÜR CHORD VIEWER
// ---------------------------------------------------------

Function JoinStringArray(arr : String Array, delimiter : String) Returns String
   var i : Integer; var res : String = ""
   i = 0
   While i < Size(arr) Do
      if i > 0 Then res = res + delimiter End
      res = res + arr[i]; i = i + 1
   End
   result = res
End

Function TrimAndClean(s : String) Returns String
   result = TrimString(s)
End

Function IsDigitsOnly(s : String) Returns Boolean
   var i, len : Integer; var c : String; var isNum : Boolean
   len = Length(s); isNum = true; i = 0
   
   While i < len and isNum Do 
      c = CopySubstring(s, i, 1)
      If c < "0" or c > "9" Then 
         isNum = false // Legal: Bricht die Schleife im nächsten Durchlauf ab!
      End
      i = i + 1 
   End
   
   result = isNum
End

Function ExtractTagValue(line : String, tagName : String) Returns String
   var startPos, endPos, tagLen : Integer; var res, tempSub : String
   res = ""; tagLen = Length(tagName)
   startPos = IndexOfSubstring(line, tagName, false)
   If startPos > -1 Then
      tempSub = CopySubstring(line, startPos, Length(line) - startPos)
      endPos = IndexOfSubstring(tempSub, "}", false)
      If endPos > -1 Then res = CopySubstring(tempSub, tagLen, endPos - tagLen); res = TrimString(res) End
   End
   result = res
End

Function MyToUpper(s : String) Returns String
   var res : String = s
   res = ReplaceString(res, "a", "A", true); res = ReplaceString(res, "b", "B", true)
   res = ReplaceString(res, "c", "C", true); res = ReplaceString(res, "d", "D", true)
   res = ReplaceString(res, "e", "E", true); res = ReplaceString(res, "f", "F", true)
   res = ReplaceString(res, "g", "G", true); res = ReplaceString(res, "h", "H", true)
   res = ReplaceString(res, "i", "I", true); res = ReplaceString(res, "j", "J", true)
   res = ReplaceString(res, "k", "K", true); res = ReplaceString(res, "l", "L", true)
   res = ReplaceString(res, "m", "M", true); res = ReplaceString(res, "n", "N", true)
   res = ReplaceString(res, "o", "O", true); res = ReplaceString(res, "p", "P", true)
   res = ReplaceString(res, "q", "Q", true); res = ReplaceString(res, "r", "R", true)
   res = ReplaceString(res, "s", "S", true); res = ReplaceString(res, "t", "T", true)
   res = ReplaceString(res, "u", "U", true); res = ReplaceString(res, "v", "V", true)
   res = ReplaceString(res, "w", "W", true); res = ReplaceString(res, "x", "X", true)
   res = ReplaceString(res, "y", "Y", true); res = ReplaceString(res, "z", "Z", true)
   result = res
End

// ---------------------------------------------------------
// TRANSPOSE ENGINE FÜR CHORD VIEWER
// ---------------------------------------------------------

Function GetNoteIndex(note : String) Returns Integer
   var i, idx : Integer; var searchNote : String
   i = 0; idx = -1
   searchNote = MyToUpper(note)
   If searchNote == "H" Then searchNote = "B" End
   If Size(NoteNamesSharp) > 0 Then 
      While i < 12 and idx == -1 Do 
         If NoteNamesSharp[i] == searchNote Then idx = i Else i = i + 1 End 
      End 
   End
   If idx == -1 and Size(NoteNamesFlat) > 0 Then 
      i = 0 
      While i < 12 and idx == -1 Do 
         If NoteNamesFlat[i] == searchNote Then idx = i Else i = i + 1 End 
      End 
   End
   result = idx
End

// ---------------------------------------------------------
// NEW GENOS MAPPING HELPERS
// ---------------------------------------------------------

Function HexCharToInt(c : String) Returns Integer
   if c == "0" then result = 0
   elsif c == "1" then result = 1
   elsif c == "2" then result = 2
   elsif c == "3" then result = 3
   elsif c == "4" then result = 4
   elsif c == "5" then result = 5
   elsif c == "6" then result = 6
   elsif c == "7" then result = 7
   elsif c == "8" then result = 8
   elsif c == "9" then result = 9
   elsif c == "a" or c == "A" then result = 10
   elsif c == "b" or c == "B" then result = 11
   elsif c == "c" or c == "C" then result = 12
   elsif c == "d" or c == "D" then result = 13
   elsif c == "e" or c == "E" then result = 14
   elsif c == "f" or c == "F" then result = 15
   else result = 0 end
End

Function IntToChar(asciiVal : Integer) Returns String
   if asciiVal >= 32 and asciiVal <= 126 then
      result = CopySubstring(ASCII_LOOKUP, asciiVal - 32, 1)
   else
      result = "" 
   end
End

// ---------------------------------------------------------
// FILE PARSING
// ---------------------------------------------------------

Function GetBodyFromFile(content : String) Returns String
   var lines : String Array = SplitString(content, NEW_LINE); var body : String = ""; var i : Integer; var line : String; var configStarted : Boolean = false
   For i = 0; i < Size(lines); i = i + 1 Do
      line = TrimString(lines[i])
      If IndexOfSubstring(line, "# Song Configuration", false) == 0 or IndexOfSubstring(line, "# Config", false) == 0 Then configStarted = true End
      If configStarted == false Then body = body + lines[i] + NEW_LINE End
   End
   result = body
End

Function GetConfigFromFile(content : String) Returns String
   var lines : String Array = SplitString(content, NEW_LINE); var conf : String = ""; var i : Integer; var line : String; var startFound : Boolean = false
   For i = 0; i < Size(lines); i = i + 1 Do
      line = TrimString(lines[i])
      If IndexOfSubstring(line, "# Song Configuration", false) == 0 or IndexOfSubstring(line, "# Config", false) == 0 Then startFound = true End
      If startFound Then conf = conf + lines[i] + NEW_LINE End
   End
   If Length(conf) < 5 Then conf = "# Song Configuration" + NEW_LINE End
   result = conf
End

// =========================================================
// 2. DEN ERSTEN JOB DER WARTESCHLANGE STARTEN (Skript-Tod!)
// =========================================================

Function SuperCleanPath(raw : String) Returns String
   var i, len : Integer
   var c, res : String
   res = ""
   len = Length(raw)
   For i = 0; i < len; i = i + 1 Do
       c = CopySubstring(raw, i, 1)
       // MAGIE: Verwirft alle unsichtbaren Steuerzeichen (0-31, inkl. \r und \n).
       // Erlaubt alles ab Leerzeichen (32) aufwärts, inkl. Sonderzeichen und Umlaute!
       if c >= " " and c != "\"" then
           res = res + c
       end
   End
   result = TrimString(res)
End


// ============================================================================
// SECTION 14: HARDWARE ABSTRACTION LAYER — RUNTIME
// ============================================================================

// ----------------------------------------------------------------------------
// 14a: Config File Parser
// ----------------------------------------------------------------------------

Function ParseCapString(capStr : String) Returns Integer
   var parts : String Array
   var i, caps : Integer
   caps = 0
   parts = SplitString(capStr, ",")
   For i = 0; i < Size(parts); i = i + 1 Do
      Select
         TrimString(parts[i]) == "TRANSPORT_SYNC"      Do caps = caps + CAP_TRANSPORT_SYNC
         TrimString(parts[i]) == "SYSEX_TRIGGER"        Do caps = caps + CAP_SYSEX_TRIGGER
         TrimString(parts[i]) == "CROSSFADER_TARGETS"   Do caps = caps + CAP_CROSSFADER_TARGETS
         TrimString(parts[i]) == "SYSEX_PROFILES"       Do caps = caps + CAP_SYSEX_PROFILES
         TrimString(parts[i]) == "JOYSTICK"             Do caps = caps + CAP_JOYSTICK
         TrimString(parts[i]) == "MIDI_OUT"             Do caps = caps + CAP_MIDI_OUT
         TrimString(parts[i]) == "FEEDBACK_CC"          Do caps = caps + CAP_FEEDBACK_CC
         TrimString(parts[i]) == "SYSEX_COMMANDS"       Do caps = caps + CAP_SYSEX_COMMANDS
      End
   End
   result = caps
End

Function ParseControlType(typeStr : String) Returns Integer
   result = CTYPE_FADER
   Select
      typeStr == "FADER"    Do result = CTYPE_FADER
      typeStr == "ENCODER"  Do result = CTYPE_ENCODER
      typeStr == "BUTTON"   Do result = CTYPE_BUTTON
      typeStr == "JOYSTICK" Do result = CTYPE_JOYSTICK
      typeStr == "PAD"      Do result = CTYPE_PAD
   End
End

Function ParseFeedbackType(fbStr : String) Returns Integer
   result = FB_NONE
   Select
      fbStr == "NONE"  Do result = FB_NONE
      fbStr == "CC"    Do result = FB_CC
      fbStr == "SYSEX" Do result = FB_SYSEX
   End
End

// Parses DeviceConfig.txt (INI format) and fills DEV_*, CTRL_*, SYSEX_* registries.
Function ParseDeviceConfig()
   var content, line, key, val, section : String
   var lines : String Array
   var i, eqPos, currentDevIdx, currentCtrlIdx, currentSysExIdx : Integer

   if not FileExists(DeviceConfigFilePath) then
      Trace("HAL: No DeviceConfig.txt found at " + DeviceConfigFilePath + ". Running in fallback mode.")
   else
      content = LoadStringFromTextFile(DeviceConfigFilePath)
      lines = SplitString(content, NEW_LINE)
      section = ""
      currentDevIdx = -1
      currentCtrlIdx = -1
      currentSysExIdx = -1

      CTRL_DevIdx = []; CTRL_Type = []; CTRL_CC = []; CTRL_Channel = []
      CTRL_RangeMin = []; CTRL_RangeMax = []; CTRL_Feedback = []; CTRL_Label = []
      SYSEX_DevIdx = []; SYSEX_Purpose = []; SYSEX_Data = []
      CTRL_Count = 0; SYSEX_Count = 0

      For i = 0; i < Size(lines); i = i + 1 Do
         line = TrimString(lines[i])

         if Length(line) == 0 then
            // skip empty line
         elsif GetCharAtIndex(line, 0) == ";" then
            // skip comment

         elsif IndexOfSubstring(line, "[DEVICE:", false) == 0 then
            section = "DEVICE"
            currentDevIdx = StringToInt(CopySubstring(line, 8, 1))
            if currentDevIdx >= 0 and currentDevIdx < MAX_DEVICES then
               DEV_Active[currentDevIdx] = true
            end

         elsif IndexOfSubstring(line, "[CONTROL:", false) == 0 then
            section = "CONTROL"
            currentCtrlIdx = CTRL_Count
            CTRL_DevIdx <-- 0; CTRL_Type <-- CTYPE_FADER; CTRL_CC <-- -1
            CTRL_Channel <-- -1; CTRL_RangeMin <-- 0; CTRL_RangeMax <-- 127
            CTRL_Feedback <-- FB_NONE; CTRL_Label <-- ""
            CTRL_Count = CTRL_Count + 1

         elsif IndexOfSubstring(line, "[SYSEX:", false) == 0 then
            section = "SYSEX"
            currentSysExIdx = SYSEX_Count
            SYSEX_DevIdx <-- 0; SYSEX_Purpose <-- ""; SYSEX_Data <-- ""
            SYSEX_Count = SYSEX_Count + 1

         else
            eqPos = IndexOfSubstring(line, "=", false)
            if eqPos > 0 then
               key = TrimString(CopySubstring(line, 0, eqPos))
               val = TrimString(CopySubstring(line, eqPos + 1, Length(line) - eqPos - 1))

               if section == "DEVICE" and currentDevIdx >= 0 and currentDevIdx < MAX_DEVICES then
                  Select
                     key == "Name"     Do DEV_Name[currentDevIdx] = val
                     key == "MidiIn"   Do DEV_MidiIn[currentDevIdx] = val
                     key == "MidiOut"  Do DEV_MidiOut[currentDevIdx] = val
                     key == "Channel"  Do DEV_Channel[currentDevIdx] = StringToInt(val)
                     key == "Caps"     Do DEV_Caps[currentDevIdx] = ParseCapString(val)
                  End

               elsif section == "CONTROL" and currentCtrlIdx >= 0 then
                  Select
                     key == "Device"   Do CTRL_DevIdx[currentCtrlIdx] = StringToInt(val)
                     key == "Label"    Do CTRL_Label[currentCtrlIdx] = val
                     key == "Type"     Do CTRL_Type[currentCtrlIdx] = ParseControlType(val)
                     key == "CC"       Do CTRL_CC[currentCtrlIdx] = StringToInt(val)
                     key == "Channel"  Do CTRL_Channel[currentCtrlIdx] = StringToInt(val)
                     key == "RangeMin" Do CTRL_RangeMin[currentCtrlIdx] = StringToInt(val)
                     key == "RangeMax" Do CTRL_RangeMax[currentCtrlIdx] = StringToInt(val)
                     key == "Feedback" Do CTRL_Feedback[currentCtrlIdx] = ParseFeedbackType(val)
                  End

               elsif section == "SYSEX" and currentSysExIdx >= 0 then
                  Select
                     key == "Device"   Do SYSEX_DevIdx[currentSysExIdx] = StringToInt(val)
                     key == "Purpose"  Do SYSEX_Purpose[currentSysExIdx] = val
                     key == "Data"     Do SYSEX_Data[currentSysExIdx] = val
                  End
               end
            end
         end
      End

      Trace("HAL: Loaded " + IntToString(CTRL_Count) + " controls, " + IntToString(SYSEX_Count) + " SysEx commands.")
   end
End

// ----------------------------------------------------------------------------
// 14b: Device Lookup
// ----------------------------------------------------------------------------

Function DeviceHasCap(devIdx : Integer, cap : Integer) Returns Boolean
   if devIdx >= 0 and devIdx < MAX_DEVICES and DEV_Active[devIdx] then
      result = (DEV_Caps[devIdx] And cap) > 0
   end
End

Function GetDeviceIdxByName(name : String) Returns Integer
   var i : Integer
   result = -1
   For i = 0; i < MAX_DEVICES; i = i + 1 Do
      if DEV_Active[i] and DEV_Name[i] == name then result = i end
   End
End

Function GetDeviceMidiOut(devIdx : Integer) Returns String
   result = ""
   if devIdx >= 0 and devIdx < MAX_DEVICES then result = DEV_MidiOut[devIdx] end
End

Function IsDeviceConnected(devIdx : Integer) Returns Boolean
   if devIdx >= 0 and devIdx < MAX_DEVICES and DEV_Active[devIdx] and DEV_MidiOut[devIdx] != "" then
      result = MidiOutDeviceExists(DEV_MidiOut[devIdx])
   end
End

// ----------------------------------------------------------------------------
// 14c: Control Lookup
// ----------------------------------------------------------------------------

Function FindControl(devIdx : Integer, cc : Integer) Returns Integer
   var i : Integer
   result = -1
   For i = 0; i < CTRL_Count; i = i + 1 Do
      if CTRL_DevIdx[i] == devIdx and CTRL_CC[i] == cc then result = i end
   End
End

Function GetControlType(ctrlIdx : Integer) Returns Integer
   result = -1
   if ctrlIdx >= 0 and ctrlIdx < CTRL_Count then result = CTRL_Type[ctrlIdx] end
End

Function GetControlFeedback(ctrlIdx : Integer) Returns Integer
   result = FB_NONE
   if ctrlIdx >= 0 and ctrlIdx < CTRL_Count then result = CTRL_Feedback[ctrlIdx] end
End

// ----------------------------------------------------------------------------
// 14d: SysEx Lookup & Send
// ----------------------------------------------------------------------------

Function GetDeviceSysEx(devIdx : Integer, purpose : String) Returns String
   var i : Integer
   result = ""
   For i = 0; i < SYSEX_Count; i = i + 1 Do
      if SYSEX_DevIdx[i] == devIdx and SYSEX_Purpose[i] == purpose then
         result = SYSEX_Data[i]
      end
   End
End

Function SendDeviceSysEx(devIdx : Integer, purpose : String)
   var data, outDev : String
   if IsDeviceConnected(devIdx) then
      data = GetDeviceSysEx(devIdx, purpose)
      outDev = GetDeviceMidiOut(devIdx)
      if data != "" and outDev != "" then
         SendSysexNowToMidiOutDevice(SM_CreateSysexFromString(data), outDev)
      end
   end
End

// ----------------------------------------------------------------------------
// 14e: Device-to-Block Mapping
// ----------------------------------------------------------------------------

Function MapDevicesToBlocks()
   var i : Integer
   For i = 0; i < MAX_DEVICES; i = i + 1 Do
      DEV_BlockIdx[i] = -1
      if DEV_Active[i] then DEV_BlockIdx[i] = i end
   End
End

Function GetDeviceIdxForBlock(blockIdx : Integer) Returns Integer
   result = -1
   if blockIdx >= 0 and blockIdx < MAX_DEVICES and DEV_Active[blockIdx] then
      result = blockIdx
   end
End


// ============================================================================
// SECTION 15: MIDI & CHANNEL ENGINE
// ============================================================================

// ---------------------------------------------------------
// HELPER: GET PARAMETER INDEX BY NAME
// ---------------------------------------------------------
Function GetParamIdxByName(blk : PluginBlock, targetName : String) Returns Integer
   var p, pCount : Integer
   var found : Boolean = false
   result = -1
   
   pCount = GetParameterCount(blk)
   p = 0
   While p < pCount and not found Do
      if TrimString(GetParameterName(blk, p)) == targetName then
         result = p
         found = true
      end
      p = p + 1
   End
End

// ---------------------------------------------------------
// HELPER: FILTER FÜR CONFIG-PARAMETER
// ---------------------------------------------------------
Function IsNPConfigParam(blk : PluginBlock, pIdx : Integer) Returns Boolean
   var pName : String = GetParameterName(blk, pIdx)
   var isConfig : Boolean = true
   
   if IndexOfSubstring(pName, "SoloMute", true) > -1 then isConfig = false
   elsif IndexOfSubstring(pName, "UserMute", true) > -1 then isConfig = false
   elsif IndexOfSubstring(pName, "Panic", true) > -1 then isConfig = false
   elsif IndexOfSubstring(pName, "StopSustain", true) > -1 then isConfig = false
   end
   
   result = isConfig
End

// ----------------------------------------------------------------------
// --- CHECK BLOCK (Smart Version - 100% Crash Proof) ---
// ----------------------------------------------------------------------
Function CheckBlock(blk : PluginBlock, arr : Double Array, context : String) Returns Boolean
   var p, pCount, arrSize : Integer
   var val, refVal : Double = 0.0
   var isMatch : Boolean = true 
   
   arrSize = Size(arr)
   
   if arrSize == 0 then 
      if DebugMode then Trace("DIFF " + context + ": Reference Array is empty!") end
      result = false
   else
      pCount = GetParameterCount(blk)
      p = 0
      While p < pCount and isMatch Do
         if IsNPConfigParam(blk, p) then
            val = GetParameter(blk, p)
            
            // ---> DIE PANZERUNG <---
            // Greife nur auf das Array zu, wenn der Index auch existiert!
            if p < arrSize then
                refVal = arr[p]
            else
                refVal = 0.0 // Fallback-Sicherheit, falls Plugin > Array
            end
            
            if Abs(val - refVal) > 0.001 then 
               isMatch = false
            end
         end
         p = p + 1
      End
      result = isMatch
   end
End

// ----------------------------------------------------------------------
// --- FACTORY & DEFAULT LEARNING (Dynamic & Object-Oriented) ---
// ----------------------------------------------------------------------
Function CaptureFactoryDefaults()
   var p, pCount, resetIdx : Integer
   var probeIdx : Integer = 15 // Wir nutzen Kanal 16 als Sonde
   var soloMuteIdx, userMuteIdx : Integer
   
   FACT_NoteProcessor = [] 
   DEF_NoteProcessor = []
   
   // 1. Hard-Reset des Probe-Kanals (Zwingt das Scriptlet auf Standard)
   resetIdx = GetParamIdxByName(BLK_NoteProcessor[probeIdx], "p_FactoryReset")
   if resetIdx > -1 then
       SetParameter(BLK_NoteProcessor[probeIdx], resetIdx, 1.0)
       // TIMING LÜCKE SCHLIESSEN: Wir geben dem Scriptlet Zeit, die Parameter intern zu nullen!
       Wait(100.0) 
   end
   
   // 2. JETZT ERST die sauberen Defaults auslesen
   pCount = GetParameterCount(BLK_NoteProcessor[probeIdx])
   For p = 0; p < pCount; p = p + 1 Do 
       FACT_NoteProcessor <-- GetParameter(BLK_NoteProcessor[probeIdx], p) 
       DEF_NoteProcessor  <-- GetParameter(BLK_NoteProcessor[probeIdx], p) 
   End
   
   // Explizit Solo/User Mute nullen im Default Array
   soloMuteIdx = GetParamIdxByName(BLK_NoteProcessor[probeIdx], "p_SoloMute")
   userMuteIdx = GetParamIdxByName(BLK_NoteProcessor[probeIdx], "p_UserMute")
   
   if soloMuteIdx > -1 then FACT_NoteProcessor[soloMuteIdx] = 0.0; DEF_NoteProcessor[soloMuteIdx] = 0.0 end
   if userMuteIdx > -1 then FACT_NoteProcessor[userMuteIdx] = 0.0; DEF_NoteProcessor[userMuteIdx] = 0.0 end
   
   FactoryLearnDone = true
   if DebugMode then Trace("INIT: " + pCount + " Factory Defaults requested and hardened.") end
End

// ---------------------------------------------------------
// SCRIPTLED TRIGGER NOTES OFF
// ---------------------------------------------------------
Function Trigger_NotesOff(ch : Integer)
   var idx : Integer = ch - 1
   var pIdx : Integer
   
   if idx >= 0 and idx < 16 then
      pIdx = GetParamIdxByName(BLK_NoteProcessor[idx], "p_Panic")
      if pIdx > -1 then
          SetParameter(BLK_NoteProcessor[idx], pIdx, 1.0)
          SetParameter(BLK_NoteProcessor[idx], pIdx, 0.0)
          if DebugMode then Trace("NOTES OFF: Triggered Panic on NoteProcessor for Channel " + ch) end
      end
   end
End

// ---------------------------------------------------------
// INJECTION KBSPLIT (Lowest/Highest)
// ---------------------------------------------------------

Function InjectKBSplitToggle(paramName : String, uiVal : Double)
   var i, pIdx : Integer
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] then
         pIdx = GetParamIdxByName(BLK_NoteProcessor[i], paramName)
         if pIdx > -1 then SetParameter(BLK_NoteProcessor[i], pIdx, uiVal) end
         if not IsUpdatingMatrix then Trigger_NotesOff(i + 1) end
      end
   End
   UpdateMetaColors() 
End

// ---------------------------------------------------------
// INJECT FILTER TOGGLE
// ---------------------------------------------------------
Function InjectFilterToggle(paramName : String, uiVal : Double)
   var i, pIdx : Integer
   
   Trace(">>> INJECT: Button '" + paramName + "' gedrückt (Zielwert: " + uiVal + ")")
   
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] then
         pIdx = GetParamIdxByName(BLK_NoteProcessor[i], paramName)
         
         if pIdx > -1 then 
             SetParameter(BLK_NoteProcessor[i], pIdx, uiVal) 
             Trace("    [OK] Kanal " + (i+1) + ": Parameter an Index " + pIdx + " gefunden -> Geschaltet!")
         else
             Trace("    [FEHLER] Kanal " + (i+1) + ": Parameter '" + paramName + "' EXISTIERT HIER NICHT! (Alte Scriptlet-Version?)")
         end
      end
   End
   UpdateMetaColors() 
End

// ---------------------------------------------------------
// INJECT TRANSPOSE 
// ---------------------------------------------------------
Function InjectTranspose(steps : Integer)
   var i, newVal, pIdx : Integer
   var paramVal : Double = 0.0
   
   Trace(">>> INJECT: Transpose gedrückt (Steps: " + steps + ")")
   
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] then
         newVal = Mem_Transpose[i] + steps
         
         if newVal < -48 then newVal = -48
         elsif newVal > 48 then newVal = 48
         end
         
         Mem_Transpose[i] = newVal
         paramVal = (IntToFloat(newVal) + 48.0) / 96.0
         
         pIdx = GetParamIdxByName(BLK_NoteProcessor[i], "p_Transpose")
         if pIdx > -1 then 
             SetParameter(BLK_NoteProcessor[i], pIdx, paramVal) 
             Trace("    [OK] Kanal " + (i+1) + ": Transpose an Index " + pIdx + " gefunden -> Geschaltet!")
         else
             Trace("    [FEHLER] Kanal " + (i+1) + ": Parameter 'p_Transpose' EXISTIERT HIER NICHT!")
         end
         
         if not IsUpdatingMatrix then Trigger_NotesOff(i + 1) end
      end
   End
   
   UpdateInjectionTransposeDisplay()
   UpdateMetaColors() 
End

// ---------------------------------------------------------
// INJECT USER MUTE
// ---------------------------------------------------------

Function InjectUserMuteToggle(uiVal : Double)
   var i, intVal, idx_mute : Integer
   if uiVal > 0.5 then intVal = 1 else intVal = 0 end
   
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] then
         Mem_UserMute[i] = intVal
         
         // Dynamische Suche
         idx_mute = GetParamIdxByName(BLK_NoteProcessor[i], "p_UserMute")
         if idx_mute > -1 then SetParameter(BLK_NoteProcessor[i], idx_mute, uiVal) end
         
         // Falls wir muten, sicherstellen dass keine Noten hängen
         if intVal == 1 and not IsUpdatingMatrix then Trigger_NotesOff(i + 1) end
      end
   End
   UpdateMetaColors() 
End

// ---------------------------------------------------------
// VST MANUAL OVERRIDE BYPASS CALLBACKS
// ---------------------------------------------------------

Function HandleInjectBypassClick(btnIdx : Integer, val : Double)
    var i, count, firstScopeIdx, targetVstIdx : Integer
    
    // Der GPScript-konforme Türsteher:
    if not IsUpdatingBypassUI then
        
        // ---> UNSER SAUBERER SCOPE-HELPER <---
        firstScopeIdx = GetFirstActiveScope()

        if firstScopeIdx > -1 then
            count = 0
            targetVstIdx = -1
            
            // Welches VST gehört zu diesem Button?
            if Size(RoutingMatrix) == 160 then
                i = 0
                // ---> DIE SICHERE WHILE-SCHLEIFE <---
                While i < MAX_VSTS and targetVstIdx == -1 Do
                    if RoutingMatrix[(i * 16) + firstScopeIdx] == true then
                        if count == btnIdx then
                            targetVstIdx = i
                        end
                        count = count + 1
                    end
                    i = i + 1 // Immer artig hochzählen
                End
            end

            // Wert in RAM schreiben und ausführen
            if targetVstIdx > -1 then
                if val > 0.5 then
                    Mem_ManualVSTBypass[targetVstIdx] = true  // Bypass AN (Button leuchtet)
                else
                    Mem_ManualVSTBypass[targetVstIdx] = false // Bypass AUS (Button dunkel)
                end
                
                // Sofortige Neu-Evaluierung erzwingen!
                ExecuteSmartBypass()
            end
        end
        
    end // Ende des Türsteher-Blocks
End

// ---------------------------------------------------------
// RESET HELPER (Muss VOR ResetToDefault stehen!)
// ---------------------------------------------------------

Function ResetChannelToStandard(chIdx : Integer)
    var resetIdx, idx : Integer 
    
    // 1. HARDWARE RESET IM SCRIPTLET AUSLÖSEN (Dynamisch!)
    resetIdx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_FactoryReset")
    if resetIdx > -1 then
        SetParameter(BLK_NoteProcessor[chIdx], resetIdx, 1.0)
        Wait(10.0) // Ein Millisekunden-Atemzug für das Scriptlet
        SetParameter(BLK_NoteProcessor[chIdx], resetIdx, 0.0)
    end
    
    // 2. DYNAMISCHER PLUGIN-RESET (Die absolute Panzerung!)
    // Wir setzen jeden wichtigen Parameter direkt über seinen Namen auf den logischen GP-Standard!
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_SplitMin"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_SplitMax"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 1.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_Transpose"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.5) end // 0.5 = 0 ST Offset!
    
    // DIE NEUEN FILTER (Exakte Namen!)
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_PassSustain"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_PassPitchBend"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_PassModWheel"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_PassVolume"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_PassExpression"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_PassAfterTouch"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 1.0) end // DEFAULT ON!
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_PassPC"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    
    // FADES
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_MinNote"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_MaxNote"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 1.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_FadeIn"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_FadeOut"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    
    // ENGINE
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_MonoLowest"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_MonoHighest"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_ChordMode"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_LatchMode"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_Engine"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_MuteOriginal"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_MinKeys"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end // 0.0 = 1 Key
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_OctaveOffset"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.5) end // 0.5 = 0 Oct
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_AutoSustain"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_SoloMute"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_UserMute"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end    
    
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_Octaver"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_OctaverMuteOrig"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_OctLow"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_OctLowOffset"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_OctHigh"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_OctHighOffset"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_VelRangeActive"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_MinVel"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_MaxVel"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 1.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_HumanizeActive"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_HumVelAmount"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_HumTimeAmount"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_QuantizeActive"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_QuantKey"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    idx = GetParamIdxByName(BLK_NoteProcessor[chIdx], "p_QuantScale"); if idx > -1 then SetParameter(BLK_NoteProcessor[chIdx], idx, 0.0) end
    
    // 3. RAM HART AUF LOGISCHE STANDARDS SETZEN!
    Mem_MinNote[chIdx] = 0.0; Mem_MaxNote[chIdx] = 1.0; Mem_Transpose[chIdx] = 0
    Mem_FadeIn[chIdx] = 0; Mem_FadeOut[chIdx] = 0
    Mem_NP_ChordMode[chIdx] = 0; Mem_NP_LatchMode[chIdx] = 0; Mem_NP_Engine[chIdx] = 0
    Mem_NP_MuteOrig[chIdx] = 0; Mem_NP_MinKeys[chIdx] = 1; Mem_NP_Octave[chIdx] = 0; Mem_NP_AutoSustain[chIdx] = 0
    Mem_SoloStrict[chIdx] = 0; Mem_SoloSmart[chIdx]  = 0; Mem_UserMute[chIdx]   = 0
    Mem_NP_Octaver[chIdx] = 0; Mem_NP_OctaverMuteOrig[chIdx] = 0
    Mem_NP_OctLow[chIdx] = 0; Mem_NP_OctLowOffset[chIdx] = 0
    Mem_NP_OctHigh[chIdx] = 0; Mem_NP_OctHighOffset[chIdx] = 0
    Mem_NP_VelRangeActive[chIdx] = 0; Mem_NP_MinVel[chIdx] = 0; Mem_NP_MaxVel[chIdx] = 127
    Mem_NP_HumanizeActive[chIdx] = 0; Mem_NP_HumVel[chIdx] = 0; Mem_NP_HumTime[chIdx] = 0
    Mem_NP_QuantizeActive[chIdx] = 0; Mem_NP_QuantKey[chIdx] = 0; Mem_NP_QuantScale[chIdx] = 0
End

// ---------------------------------------------------------
// Setzt ALLE Parameter eines Blocks auf 0.0 (Tabula Rasa)
// ---------------------------------------------------------

// Variante 1: Für normale Plugins (Filter, MT, ChordM)
Function ResetPluginParams(mb : PluginBlock)
   var p, count : Integer
   count = GetParameterCount(mb)
   For p = 0; p < count; p = p + 1 Do
      SetParameter(mb, p, 0.0)
   End
End

// Variante 2: Speziell für MidiInBlock (KBSplit)
Function ResetMidiInParams(mb : MidiInBlock)
   var p, count : Integer
   count = GetParameterCount(mb)
   For p = 0; p < count; p = p + 1 Do
      SetParameter(mb, p, 0.0)
   End
End

// Spezieller Reset für MIDI Filter: Setzt alles auf "PassThru" (0.094...)
Function ResetFilterParams(mb : PluginBlock)
   var p, count : Integer
   count = GetParameterCount(mb)
   For p = 0; p < count; p = p + 1 Do
      SetParameter(mb, p, FILTER_DEFAULT_VAL)
   End
End

// ---------------------------------------------------------
// SMART COPY & COMPARE HELPERS
// ---------------------------------------------------------

// Vergleicht zwei Plugins (gibt true zurück, wenn ALLES > 0.001 identisch ist)
Function ArePluginParamsEqual(b1 : PluginBlock, b2 : PluginBlock) Returns Boolean
   var p, count : Integer
   var v1, v2 : Double = 0.0
   var isEqual : Boolean = true
   
   count = GetParameterCount(b1)
   // Sicherheitscheck: Gleiche Plugin-Typen?
   if count != GetParameterCount(b2) then 
      result = false
   else
      p = 0
      While p < count and isEqual Do
         v1 = GetParameter(b1, p)
         v2 = GetParameter(b2, p)
         // Wir tolerieren winzige Abweichungen (Floating Point)
         if Abs(v1 - v2) > 0.001 then 
             isEqual = false
         end
         p = p + 1
      End
      result = isEqual
   end
End

// Dasselbe für MidiInBlock
Function AreMidiParamsEqual(b1 : MidiInBlock, b2 : MidiInBlock) Returns Boolean
   var p, count : Integer
   var v1, v2 : Double = 0.0
   var isEqual : Boolean = true
   
   count = GetParameterCount(b1)
   p = 0
      While p < count and isEqual Do
         v1 = GetParameter(b1, p)
         v2 = GetParameter(b2, p)
         // Wir tolerieren winzige Abweichungen (Floating Point)
         if Abs(v1 - v2) > 0.001 then 
             isEqual = false
         end
         p = p + 1
      End
   result = isEqual
End

// Kopiert Werte von A nach B (Blitzschnell im RAM)
Function CopyPluginParams(src : PluginBlock, dest : PluginBlock)
   var p, count : Integer; count = GetParameterCount(src)
   For p = 0; p < count; p = p + 1 Do SetParameter(dest, p, GetParameter(src, p)) End
End

Function CopyMidiParams(src : MidiInBlock, dest : MidiInBlock)
   var p, count : Integer; count = GetParameterCount(src)
   For p = 0; p < count; p = p + 1 Do SetParameter(dest, p, GetParameter(src, p)) End
End

// ---------------------------------------------------------
// KB-sPLIT WATCHDOG
// ---------------------------------------------------------

Function SyncKBSplitWatchdog()
   var i : Integer; var pMin, pMax : Double = 0.0
   
   // Nur prüfen, wenn NICHT geladen wird
   If not IsLoadingSnapshot Then
      
      For i = 0; i < 16; i = i + 1 Do
         // 1. Echte Werte aus dem Plugin lesen
         pMin = GetParameter(BLK_MidiIn[i], 16)
         pMax = GetParameter(BLK_MidiIn[i], 17)
         
         // 2. MIN prüfen
         if Abs(pMin - Mem_MinNote[i]) > 0.001 then 
            UpdateChannelFade(i, 4, 0, 0.0) 
         end
         
         // 3. MAX prüfen (Muss ZWINGEND in der Schleife stehen!)
         if Abs(pMax - Mem_MaxNote[i]) > 0.001 then 
            UpdateChannelFade(i, 4, 0, 0.0)
         end
      End // <-- Hier endet die Schleife erst!
      
   End
End

// ---------------------------------------------------------
// INJECTION HELPER & CALLBACKS: NOTE PROCESSOR
// ---------------------------------------------------------

Function InjectNPToggle(paramType : Integer, paramName : String, uiVal : Double)
   var i, intVal, pIdx : Integer
   if uiVal > 0.5 then intVal = 1 else intVal = 0 end
   
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] then
         if paramType == 0 then Mem_NP_ChordMode[i] = intVal
         elsif paramType == 1 then Mem_NP_LatchMode[i] = intVal
         elsif paramType == 2 then Mem_NP_Engine[i] = intVal
         elsif paramType == 3 then Mem_NP_MuteOrig[i] = intVal
         elsif paramType == 4 then Mem_NP_AutoSustain[i] = intVal
         elsif paramType == 5 then Mem_NP_Octaver[i] = intVal
         elsif paramType == 6 then Mem_NP_OctaverMuteOrig[i] = intVal
         elsif paramType == 7 then Mem_NP_VelRangeActive[i] = intVal
         elsif paramType == 8 then Mem_NP_HumanizeActive[i] = intVal
         elsif paramType == 9 then Mem_NP_QuantizeActive[i] = intVal
         end
         
         pIdx = GetParamIdxByName(BLK_NoteProcessor[i], paramName)
         if pIdx > -1 then SetParameter(BLK_NoteProcessor[i], pIdx, IntToFloat(intVal)) end
         
         if not IsUpdatingMatrix then Trigger_NotesOff(i + 1) end
      end
   End
   // Das UI-Update lagern wir absichtlich aus, damit es nicht flackert!
   UpdateMetaColors() 
End

Function InjectNPStep(paramType : Integer, paramName : String, direction : Integer)
   var i, newVal, pIdx : Integer
   var pluginVal : Double = 0.0
   
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] then
         if paramType == 0 then // MinKeys (1-5)
            newVal = Mem_NP_MinKeys[i] + direction
            if newVal < 1 then newVal = 1 elsif newVal > 5 then newVal = 5 end
            Mem_NP_MinKeys[i] = newVal; pluginVal = (IntToFloat(newVal) - 1.0) / 4.0 
         elsif paramType == 1 then // OctaveOffset (-3 bis 3)
            newVal = Mem_NP_Octave[i] + direction
            if newVal < -3 then newVal = -3 elsif newVal > 3 then newVal = 3 end
            Mem_NP_Octave[i] = newVal; pluginVal = (IntToFloat(newVal) + 3.0) / 6.0 
         elsif paramType == 2 then // OctLow (0-3)
            newVal = Mem_NP_OctLow[i] + direction
            if newVal < 0 then newVal = 0 elsif newVal > 3 then newVal = 3 end
            Mem_NP_OctLow[i] = newVal; pluginVal = IntToFloat(newVal) / 3.0 
         elsif paramType == 3 then // OctLowOffset (0-3)
            newVal = Mem_NP_OctLowOffset[i] + direction
            if newVal < 0 then newVal = 0 elsif newVal > 3 then newVal = 3 end
            Mem_NP_OctLowOffset[i] = newVal; pluginVal = IntToFloat(newVal) / 3.0 
         elsif paramType == 4 then // OctHigh (0-3)
            newVal = Mem_NP_OctHigh[i] + direction
            if newVal < 0 then newVal = 0 elsif newVal > 3 then newVal = 3 end
            Mem_NP_OctHigh[i] = newVal; pluginVal = IntToFloat(newVal) / 3.0 
         elsif paramType == 5 then // OctHighOffset (0-3)
            newVal = Mem_NP_OctHighOffset[i] + direction
            if newVal < 0 then newVal = 0 elsif newVal > 3 then newVal = 3 end
            Mem_NP_OctHighOffset[i] = newVal; pluginVal = IntToFloat(newVal) / 3.0 

         // --- V7.4 NEUE STEPS ---
         elsif paramType == 6 then // MinVel (0-127)
            newVal = Mem_NP_MinVel[i] + direction
            if newVal < 0 then newVal = 0 elsif newVal > 127 then newVal = 127 end
            // Verhindern, dass Min größer als Max wird
            if newVal > Mem_NP_MaxVel[i] then newVal = Mem_NP_MaxVel[i] end
            Mem_NP_MinVel[i] = newVal; pluginVal = IntToFloat(newVal) / 127.0 
         elsif paramType == 7 then // MaxVel (0-127)
            newVal = Mem_NP_MaxVel[i] + direction
            if newVal < 0 then newVal = 0 elsif newVal > 127 then newVal = 127 end
            // Verhindern, dass Max kleiner als Min wird
            if newVal < Mem_NP_MinVel[i] then newVal = Mem_NP_MinVel[i] end
            Mem_NP_MaxVel[i] = newVal; pluginVal = IntToFloat(newVal) / 127.0 
         elsif paramType == 8 then // HumVel (0-100)
            newVal = Mem_NP_HumVel[i] + direction
            if newVal < 0 then newVal = 0 elsif newVal > 100 then newVal = 100 end
            Mem_NP_HumVel[i] = newVal; pluginVal = IntToFloat(newVal) / 100.0 
         elsif paramType == 9 then // HumTime (0-100)
            newVal = Mem_NP_HumTime[i] + direction
            if newVal < 0 then newVal = 0 elsif newVal > 100 then newVal = 100 end
            Mem_NP_HumTime[i] = newVal; pluginVal = IntToFloat(newVal) / 100.0 
         elsif paramType == 10 then // QuantKey (0-11)
            newVal = Mem_NP_QuantKey[i] + direction
            if newVal < 0 then newVal = 11 elsif newVal > 11 then newVal = 0 end // Endlos blättern!
            Mem_NP_QuantKey[i] = newVal; pluginVal = IntToFloat(newVal) / 11.0 
         elsif paramType == 11 then // QuantScale (0-5)
            newVal = Mem_NP_QuantScale[i] + direction
            if newVal < 0 then newVal = 5 elsif newVal > 5 then newVal = 0 end // Endlos blättern!
            Mem_NP_QuantScale[i] = newVal; pluginVal = IntToFloat(newVal) / 5.0 
         end
         
         pIdx = GetParamIdxByName(BLK_NoteProcessor[i], paramName)
         if pIdx > -1 then SetParameter(BLK_NoteProcessor[i], pIdx, pluginVal) end
         if not IsUpdatingMatrix then Trigger_NotesOff(i + 1) end
      end
   End
   UpdateInjectionNPDisplay()
   UpdateMetaColors()
End


// ============================================================================
// SECTION 16: DISPLAY ENGINE
// ============================================================================

// ---------------------------------------------------------
// RECORDER LED ENGINE
// ---------------------------------------------------------
Function UpdateSubbarLEDs(currentBeat : Integer)
    var i : Integer
    var ledIndex : Integer

    // Modulo-Rechnung: Zwingt jeden Beat stur in einen 0-3 Kreislauf
    ledIndex = (currentBeat - 1) % 4

    // Alle LEDs durchlaufen: Nur die aktuell berechnete LED einschalten
    For i = 0; i < 4; i = i + 1 Do
        if i == ledIndex then
            SetWidgetValue(Arr_Subbar_LEDs[i], 1.0)
        else
            SetWidgetValue(Arr_Subbar_LEDs[i], 0.0)
        end
    End
End

// =========================================================
// FORENSIC X-RAY: Löst das Geheimnis des toten Kanals
// =========================================================
Function TraceForensicChannelDump()
    var i : Integer
    var activeCh : Integer = GetFirstActiveScope()
    
    if activeCh > -1 then
        Trace("=========================================================")
        Trace("🔴 FORENSIC DUMP: CHANNEL " + (activeCh + 1) + " 🔴")
        Trace("---------------------------------------------------------")
        Trace("1. SCRIPTLET PARAMETER (Die absolute Wahrheit):")
        Trace("   -> p_SoloMute (Idx 25) : " + GetParameter(BLK_NoteProcessor[activeCh], 25))
        Trace("   -> p_UserMute (Idx 26) : " + GetParameter(BLK_NoteProcessor[activeCh], 26))
        Trace("   -> p_SplitMin (Idx 0)  : " + GetParameter(BLK_NoteProcessor[activeCh], 0))
        Trace("   -> p_SplitMax (Idx 1)  : " + GetParameter(BLK_NoteProcessor[activeCh], 1))
        Trace("   -> p_Panic    (Idx 24) : " + GetParameter(BLK_NoteProcessor[activeCh], 24))
        Trace("   -> GP Bypass Status    : " + IsPluginBypassed(BLK_NoteProcessor[activeCh]))
        Trace("---------------------------------------------------------")
        Trace("2. RAM GEDÄCHTNIS (Was das Skript glaubt):")
        Trace("   -> OutputScope         : " + OutputScope[activeCh])
        Trace("   -> LooperSoloMute Arr  : " + LooperSoloMute[activeCh])
        Trace("   -> Mem_SoloStrict      : " + Mem_SoloStrict[activeCh])
        Trace("   -> Mem_SoloSmart       : " + Mem_SoloSmart[activeCh])
        Trace("   -> Mem_UserMute        : " + Mem_UserMute[activeCh])
        Trace("=========================================================")
    else
        Trace("FORENSIC: Kein Kanal im Scope!")
    end
End

// ---------------------------------------------------------
// CUSTOM SCROLLBAR DISPLAY
// Zeigt 4 Kanäle basierend auf der Position des Sliders an
// ---------------------------------------------------------
Function RefreshDiagDisplay()
   var scrollVal : Double = GetWidgetValue(SLD_MIDIConfiguration)
   var totalLines : Integer = 48
   var visibleCount : Integer = 4 // Dein Widget fasst exakt 4 Daten-Zeilen
   var maxStart : Integer = totalLines - visibleCount
   var startIdx, i : Integer
   var finalText : String

   if maxStart < 0 then maxStart = 0 end
   startIdx = Round((1.0 - scrollVal) * IntToFloat(maxStart))

   finalText = "--- CHANNEL ANALYSIS ---" + NEW_LINE
   
   For i = 0; i < visibleCount; i = i + 1 Do
       if (startIdx + i) < totalLines then
           finalText = finalText + Diag_Lines[startIdx + i] + NEW_LINE
       end
   End

   SetWidgetLabel(LBL_MIDIConfiguration, finalText)
End

Function ScrollToCurrentChannel()
    var activeIdx : Integer
    var targetLine, maxStart : Integer
    var scrollVal : Double = 0.0

    activeIdx = GetFirstActiveScope()

    // 2. Ziel-Scrollposition berechnen
    if activeIdx > -1 then
        maxStart = 44 // 48 Gesamtzeilen - 4 sichtbare Zeilen
        targetLine = activeIdx * 3 // Jeder Kanal belegt jetzt 3 Zeilen
        
        if targetLine > maxStart then targetLine = maxStart end
        
        scrollVal = 1.0 - (IntToFloat(targetLine) / IntToFloat(maxStart))
        
        SetWidgetValue(SLD_MIDIConfiguration, scrollVal)
        RefreshDiagDisplay()
    end
End

// ---------------------------------------------------------
// VST OVERVIEW DISPLAY & AUTO-SCROLL
// ---------------------------------------------------------

Function RefreshVstInfoDisplay()
   var scrollVal : Double = GetWidgetValue(SLD_VSTConfiguration)
   var totalLines : Integer = Size(VstInfo_Lines)
   var displayLines : Integer = 13 
   var maxStart : Integer = totalLines - displayLines
   var startIdx, i : Integer
   var finalText : String = ""

   // 1. HARD LOCK (Aktion erforderlich!)
   if IsPresetLocked then
       // HIER IST DER FIX: Filtered_VstNames statt Fav_VstNames
       finalText = NEW_LINE + NEW_LINE + "    >>> --- PRESS REPLACE --- <<<" + NEW_LINE + "    To load: " + Filtered_VstNames[CurrentFavIndex]
       SetWidgetLabel(LBL_VSTConfiguration, finalText)
       
   // 2. OVERLAY CHECK (Hält das Display für X Sekunden besetzt, z.B. bei Success)
   elsif VST_OverlayTimer > 0.0 and TimeSinceStartup() < VST_OverlayTimer then
       finalText = NEW_LINE + NEW_LINE + "    >>> " + VST_OverlayMsg + " <<<"
       SetWidgetLabel(LBL_VSTConfiguration, finalText)
       
   // 3. NORMAL VIEW (Alles in Ordnung)
   else
       if InSetlistMode() then
           finalText = "--- SONG: " + GetCurrentSongName() + " ---" + NEW_LINE
       else
           finalText = "--- GLOBAL RACKSPACE ---" + NEW_LINE
       end

       if maxStart < 0 then maxStart = 0 end
       startIdx = Round((1.0 - scrollVal) * maxStart)

       For i = 0; i < displayLines; i = i + 1 Do
           if (startIdx + i) < totalLines then
               finalText = finalText + VstInfo_Lines[startIdx + i] + NEW_LINE
           end
       End
       SetWidgetLabel(LBL_VSTConfiguration, finalText)
   end
End

Function RefreshSafeReplacerUI()
   var realSlotIdx : Integer 
   var loadedPluginName, targetPluginName, targetPubName : String
   
   if Size(ReplaceableSlots) > 0 and Size(Filtered_VstNames) > 0 then
       realSlotIdx = ReplaceableSlots[CurrentMapSlotIndex]
       loadedPluginName = GetPluginInfo(BLK_VST[realSlotIdx], 0)
       
       SetWidgetLabel(LBL_MAP, "VST " + (realSlotIdx + 1))
       
       // --- RESIDENT SCHUTZ-MODUS ---
       if realSlotIdx < 2 then 
           SetWidgetLabel(LBL_Publisher, "--- RESIDENT ---")
           SetWidgetLabel(LBL_VST, loadedPluginName)
           SetWidgetLabel(LBL_VSTPreset, LoadedPresets[realSlotIdx])
           IsPresetLocked = false
           IsBrowsingFavorites = false
           SetWidgetValue(BTN_ReplaceVST, 0.0)
       
       // --- DYNAMISCHER MODUS (VST 3 bis 10) ---
       else
           targetPubName = UniquePublishers[CurrentPubIndex]
           targetPluginName = Filtered_VstNames[CurrentFavIndex]
           SetWidgetLabel(LBL_Publisher, targetPubName)
           if loadedPluginName == targetPluginName then IsBrowsingFavorites = false end
           
           if not IsBrowsingFavorites then
               SetWidgetLabel(LBL_VST, loadedPluginName)
               SetWidgetLabel(LBL_VSTPreset, LoadedPresets[realSlotIdx])
               IsPresetLocked = false
               SetWidgetValue(BTN_ReplaceVST, 0.0) 
           else
               SetWidgetLabel(LBL_VST, targetPluginName)
               SetWidgetLabel(LBL_VSTPreset, "-")
               IsPresetLocked = true
           end
       end
       RefreshVstInfoDisplay()
   end
End

Function TraceHardwarePrediction()
   var s, midiVal : Integer
   var faderVal : Double = 0.0
   var hwLabel, assignment, linkInfo : String
   var l : Integer

   Trace("=== PREDICTION: GENOS 2 MACROS (0-127) ===")
   Trace("Map in RAM: " + CurrentCtrlMapName)

   For s = 0; s < 16; s = s + 1 Do
      // 1. Hardware Label bauen (1-6 Knobs, 7 Leer, 8-16 Sliders)
      if s < 6 then hwLabel = "Knob " + (s+1)
      elsif s == 6 then hwLabel = "Unbelegt"
      else hwLabel = "Slider " + (s-6) end // s=7 -> Slider 1

      // 2. Aktuellen Wert aus dem ExternalArranger Block holen
      faderVal = GetParameter(ExternalArranger, s)
      midiVal = Round(faderVal * 127.0)

      // 3. Herausfinden, was der Regler in dieser Map gerade macht
      assignment = "- Empty -"
      if s == CF_MacroIdx then assignment = "[CROSSFADER]"
      elsif s == SCRUB_MacroIdx then assignment = "[SCRUBBER]"
      elsif s == VST_BROWSE_MacroIdx then assignment = "[VST BROWSE]"
      elsif s == VST_SCOPE_MacroIdx then assignment = "[VST SCOPE]"
      elsif s == REC_SONGPART_MacroIdx then assignment = "[REC MARKER]"
      else
         // In der ControllerMap suchen
         linkInfo = ""
         For l = 0; l < Link_Count; l = l + 1 Do
            if Link_Active[l] and Link_SourceIdx[l] == s and Link_SourceIsCC[l] == false then
               if linkInfo != "" then linkInfo = linkInfo + " & " end
               if Link_ExpectedName[l] != "" then linkInfo = linkInfo + Link_ExpectedName[l] 
               else linkInfo = linkInfo + "Param " + Link_TargetParam[l] end
            end
         End
         if linkInfo != "" then assignment = linkInfo end
      end

      // 4. Ins Log schreiben
      Trace("Macro " + PadInt(s+1, 2) + " [" + hwLabel + "] -> Wert: " + PadInt(midiVal, 3) + " | " + assignment)
   End
   Trace("==========================================")
End

// ---------------------------------------------------------
// UPDATE INJECTION DISPLAY FOR KEYBOARD SPLIT
// ---------------------------------------------------------
Function UpdateInjectionSplitDisplay()
   var i, firstScopeIdx : Integer
   var noteMin, noteMax : Integer
   var txt : String
   
   firstScopeIdx = -1
   firstScopeIdx = GetFirstActiveScope()
   
   if firstScopeIdx == -1 then
      SetWidgetLabel(LBL_Injection_Split, "-")
   else
      // Wir holen die Integer-Werte (0-127) aus unserem Gedächtnis
      noteMin = Round(Mem_MinNote[firstScopeIdx] * 127.0)
      noteMax = Round(Mem_MaxNote[firstScopeIdx] * 127.0)
      
      // Nutzt deine bestehende LuxusLabel Funktion!
      txt = GetLuxusLabel(noteMin) + " - " + GetLuxusLabel(noteMax)
      SetWidgetLabel(LBL_Injection_Split, txt)
   end
End

// ---------------------------------------------------------
// UPDATE INJECTION DISPLAY (VELOCITY FADES)
// ---------------------------------------------------------
Function UpdateInjectionFadeDisplay()
   var i, firstScopeIdx : Integer
   var searchActive : Boolean = true
   
   firstScopeIdx = -1
   
   // We use a While loop to safely find the first active scope
   i = 0
   While i < 16 and searchActive Do
      if OutputScope[i] then 
         firstScopeIdx = i
         searchActive = false // Stop searching! We found one.
      end
      i = i + 1
   End
   
   if firstScopeIdx == -1 then
      SetWidgetLabel(LBL_Inject_FadeIn, "-")
      SetWidgetLabel(LBL_Inject_FadeOut, "-")
   else
      // Wir holen die Werte direkt aus dem Kanal-Gedächtnis
      SetWidgetLabel(LBL_Inject_FadeIn, IntToString(Mem_FadeIn[firstScopeIdx]) + " ST")
      SetWidgetLabel(LBL_Inject_FadeOut, IntToString(Mem_FadeOut[firstScopeIdx]) + " ST")
   end
End

// ---------------------------------------------------------
// UPDATE INJECTION DISPLAY (FILTER TOGGLES MULTI-SCOPE)
// ---------------------------------------------------------
Function UpdateInjectionFilterDisplay()
   var i, idxPB, idxMW, idxVol, idxExpr, idxAT, idxPC : Integer
   var pb : Double = 0.0; var at : Double = 0.0; var mw : Double = 0.0; var pc : Double = 0.0; var vol : Double = 0.0; var expr : Double = 0.0
   var anyActive : Boolean = false
   
   For i = 0; i < 16; i = i + 1 Do
      if OutputScope[i] then
         anyActive = true
         
         // EXAKTE NAMEN AUS DEINEM SCRIPTLET!
         idxPB = GetParamIdxByName(BLK_NoteProcessor[i], "p_PassPitchBend")
         idxMW = GetParamIdxByName(BLK_NoteProcessor[i], "p_PassModWheel")
         idxVol = GetParamIdxByName(BLK_NoteProcessor[i], "p_PassVolume")
         idxExpr = GetParamIdxByName(BLK_NoteProcessor[i], "p_PassExpression")
         idxAT = GetParamIdxByName(BLK_NoteProcessor[i], "p_PassAfterTouch")
         idxPC = GetParamIdxByName(BLK_NoteProcessor[i], "p_PassPC")
         
         if idxPB > -1 and GetParameter(BLK_NoteProcessor[i], idxPB) > 0.5 then pb = 1.0 end
         if idxAT > -1 and GetParameter(BLK_NoteProcessor[i], idxAT) > 0.5 then at = 1.0 end
         if idxMW > -1 and GetParameter(BLK_NoteProcessor[i], idxMW) > 0.5 then mw = 1.0 end
         if idxPC > -1 and GetParameter(BLK_NoteProcessor[i], idxPC) > 0.5 then pc = 1.0 end
         if idxVol > -1 and GetParameter(BLK_NoteProcessor[i], idxVol) > 0.5 then vol = 1.0 end
         if idxExpr > -1 and GetParameter(BLK_NoteProcessor[i], idxExpr) > 0.5 then expr = 1.0 end
      end
   End
   
   IsUpdatingFilters = true
   if anyActive then
      SetWidgetValue(BTN_Inject_Filter_PB, pb)
      SetWidgetValue(BTN_Inject_Filter_AT, at)
      SetWidgetValue(BTN_Inject_Filter_MW, mw)
      SetWidgetValue(BTN_Inject_Filter_PC, pc)
      SetWidgetValue(BTN_Inject_Filter_Vol, vol)
      SetWidgetValue(BTN_Inject_Filter_Expr, expr)
   else
      SetWidgetValue(BTN_Inject_Filter_PB, 0.0); SetWidgetValue(BTN_Inject_Filter_AT, 0.0); SetWidgetValue(BTN_Inject_Filter_MW, 0.0)
      SetWidgetValue(BTN_Inject_Filter_PC, 0.0); SetWidgetValue(BTN_Inject_Filter_Vol, 0.0); SetWidgetValue(BTN_Inject_Filter_Expr, 0.0)
   end
   IsUpdatingFilters = false
End

// ---------------------------------------------------------
// UPDATE INJECTION DISPLAY (NOTE PROCESSOR)
// ---------------------------------------------------------
Function UpdateInjectionNPDisplay()
   var i, firstScopeIdx, idxMonoL, idxMonoH : Integer
   var searchActive : Boolean = true
   var octStr, keyStr : String
   
   firstScopeIdx = -1
   
   i = 0
   While i < 16 and searchActive Do
      if OutputScope[i] then 
         firstScopeIdx = i
         searchActive = false 
      end
      i = i + 1
   End
   
   IsUpdatingNP = true
   
   if firstScopeIdx == -1 then
      SetWidgetValue(BTN_Inject_NP_Root, 0.0)
      SetWidgetValue(BTN_Inject_NP_Hold, 0.0)
      SetWidgetValue(BTN_Inject_NP_HM, 0.0)
      SetWidgetValue(BTN_Inject_NP_RootOnly, 0.0)
      SetWidgetValue(BTN_Inject_NP_AutoSustain, 0.0)
      SetWidgetLabel(LBL_Inject_NP_MinKeys, "-")
      SetWidgetLabel(LBL_Inject_NP_MT, "-")
      SetWidgetValue(BTN_Inject_KBSplit_Lowest, 0.0)
      SetWidgetValue(BTN_Inject_KBSplit_Highest, 0.0)
      SetWidgetValue(BTN_Inject_NP_Octaver, 0.0)
      SetWidgetValue(BTN_Inject_NP_OctaverMuteOrig, 0.0)
      SetWidgetLabel(LBL_Inject_NP_OctLow, "-")
      SetWidgetLabel(LBL_Inject_NP_OctLowOffset, "-")
      SetWidgetLabel(LBL_Inject_NP_OctHigh, "-")
      SetWidgetLabel(LBL_Inject_NP_OctHighOffset, "-")
      
      // --- V7.4 OFFLINE STATES ---
      SetWidgetValue(BTN_Inject_NP_VelRange, 0.0)
      SetWidgetLabel(LBL_Inject_NP_VelMin, "-")
      SetWidgetLabel(LBL_Inject_NP_VelMax, "-")
      
      SetWidgetValue(BTN_Inject_NP_Humanize, 0.0)
      SetWidgetLabel(LBL_Inject_NP_HumVel, "-")
      SetWidgetLabel(LBL_Inject_NP_HumTime, "-")
      
      SetWidgetValue(BTN_Inject_NP_Quantize, 0.0)
      SetWidgetLabel(LBL_Inject_NP_QuantKey, "-")
      SetWidgetLabel(LBL_Inject_NP_QuantScale, "-")
      
   elsif Size(Mem_NP_ChordMode) > firstScopeIdx then
         SetWidgetValue(BTN_Inject_NP_Root, IntToFloat(Mem_NP_ChordMode[firstScopeIdx]))
         SetWidgetValue(BTN_Inject_NP_Hold, IntToFloat(Mem_NP_LatchMode[firstScopeIdx]))
         SetWidgetValue(BTN_Inject_NP_HM, IntToFloat(Mem_NP_Engine[firstScopeIdx]))
         SetWidgetValue(BTN_Inject_NP_RootOnly, IntToFloat(Mem_NP_MuteOrig[firstScopeIdx]))
         SetWidgetValue(BTN_Inject_NP_AutoSustain, IntToFloat(Mem_NP_AutoSustain[firstScopeIdx]))
         SetWidgetValue(BTN_Inject_NP_Octaver, IntToFloat(Mem_NP_Octaver[firstScopeIdx]))
         SetWidgetValue(BTN_Inject_NP_OctaverMuteOrig, IntToFloat(Mem_NP_OctaverMuteOrig[firstScopeIdx]))
         SetWidgetLabel(LBL_Inject_NP_OctLow, IntToString(Mem_NP_OctLow[firstScopeIdx]) + " Sub")
         SetWidgetLabel(LBL_Inject_NP_OctLowOffset, "Gap " + IntToString(Mem_NP_OctLowOffset[firstScopeIdx]))
         SetWidgetLabel(LBL_Inject_NP_OctHigh, IntToString(Mem_NP_OctHigh[firstScopeIdx]) + " Up")
         SetWidgetLabel(LBL_Inject_NP_OctHighOffset, "Gap " + IntToString(Mem_NP_OctHighOffset[firstScopeIdx]))
         
         // ---> DYNAMISCHE SPLIT GRENZEN <---
         idxMonoL = GetParamIdxByName(BLK_NoteProcessor[firstScopeIdx], "p_MonoLowest")
         idxMonoH = GetParamIdxByName(BLK_NoteProcessor[firstScopeIdx], "p_MonoHighest")
         
         if idxMonoL > -1 then SetWidgetValue(BTN_Inject_KBSplit_Lowest, GetParameter(BLK_NoteProcessor[firstScopeIdx], idxMonoL)) end
         if idxMonoH > -1 then SetWidgetValue(BTN_Inject_KBSplit_Highest, GetParameter(BLK_NoteProcessor[firstScopeIdx], idxMonoH)) end

         if Mem_NP_MinKeys[firstScopeIdx] == 1 then keyStr = "1 Key" else keyStr = IntToString(Mem_NP_MinKeys[firstScopeIdx]) + " Keys" end
         SetWidgetLabel(LBL_Inject_NP_MinKeys, keyStr)
      
      if Mem_NP_Octave[firstScopeIdx] == 0 then octStr = "0 Oct"
      elsif Mem_NP_Octave[firstScopeIdx] > 0 then octStr = "+" + IntToString(Mem_NP_Octave[firstScopeIdx]) + " Oct"
      else octStr = IntToString(Mem_NP_Octave[firstScopeIdx]) + " Oct" end
      SetWidgetLabel(LBL_Inject_NP_MT, octStr)
      
      // --- V7.4 ONLINE STATES ---
      SetWidgetValue(BTN_Inject_NP_VelRange, IntToFloat(Mem_NP_VelRangeActive[firstScopeIdx]))
      SetWidgetLabel(LBL_Inject_NP_VelMin, IntToString(Mem_NP_MinVel[firstScopeIdx]))
      SetWidgetLabel(LBL_Inject_NP_VelMax, IntToString(Mem_NP_MaxVel[firstScopeIdx]))
      
      SetWidgetValue(BTN_Inject_NP_Humanize, IntToFloat(Mem_NP_HumanizeActive[firstScopeIdx]))
      SetWidgetLabel(LBL_Inject_NP_HumVel, "+/- " + IntToString(Mem_NP_HumVel[firstScopeIdx]))
      SetWidgetLabel(LBL_Inject_NP_HumTime, IntToString(Mem_NP_HumTime[firstScopeIdx]) + " ms")
      
      SetWidgetValue(BTN_Inject_NP_Quantize, IntToFloat(Mem_NP_QuantizeActive[firstScopeIdx]))
      SetWidgetLabel(LBL_Inject_NP_QuantKey, GetScaleKeyName(Mem_NP_QuantKey[firstScopeIdx]))
      SetWidgetLabel(LBL_Inject_NP_QuantScale, GetScaleTypeName(Mem_NP_QuantScale[firstScopeIdx]))
   end
   
   IsUpdatingNP = false
End

